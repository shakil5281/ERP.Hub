<div class="modal-overlay search-dialog" @onclick="CloseOverlay" @onkeydown="HandleKeydown" @ref="_overlayRef">
    <div class="modal" @onclick:stopPropagation>
        <div class="search-input-wrapper">
            <span class="material-icons search-input-icon">search</span>
            <input @ref="_searchInput"
                   @bind="_query"
                   @bind:event="oninput"
                   @onkeydown="HandleKeydown"
                   placeholder="Search pages, modules, reports..."
                   class="search-input"
                   autofocus />
            @if (!string.IsNullOrEmpty(_query))
            {
                <button class="search-clear-btn" @onclick="ClearSearch">
                    <span class="material-icons" style="font-size:14px;">close</span>
                </button>
            }
            <div class="search-kbd-hint">
                <kbd>ESC</kbd>
            </div>
        </div>

        @if (_selectedIndex >= 0 && _filteredResults.Any())
        {
            <div class="search-active-indicator">
                <span class="text-xs text-muted">@(_selectedIndex + 1) of @_filteredResults.Count results</span>
            </div>
        }

        <div class="search-results-container">
            @if (!string.IsNullOrEmpty(_query) && _query.Length >= 2)
            {
                @if (_filteredResults.Any())
                {
                    <div class="search-results-section">
                        <div class="search-section-label">Results</div>
                        @for (var i = 0; i < _filteredResults.Count; i++)
                        {
                            var idx = i;
                            var result = _filteredResults[idx];
                            <div class="search-result-item @(idx == _selectedIndex ? "selected" : "")"
                                 @onclick="() => NavigateTo(result.Url)"
                                 @onmouseenter="() => _selectedIndex = idx">
                                <div class="search-result-icon">
                                    <span class="material-icons" style="color:#4f46e5;">@result.Icon</span>
                                </div>
                                <div class="search-result-content">
                                    <div class="search-result-title fw-semibold">@result.Title</div>
                                    <div class="text-xs text-muted">@result.Description</div>
                                </div>
                                <div class="search-result-path text-muted">
                                    <span class="text-xs">@result.Url</span>
                                </div>
                                <span class="material-icons search-result-arrow text-muted" style="font-size:16px;">arrow_forward</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="search-empty">
                        <span class="material-icons" style="font-size:36px;color:#9ca3af;">search_off</span>
                        <span class="text-sm text-muted">No results found</span>
                        <span class="text-xs text-muted">Try a different search term</span>
                    </div>
                }
            }
            else
            {
                <div class="search-suggestions">
                    <div class="search-section-label">Quick Links</div>
                    <div class="search-quick-links">
                        @foreach (var link in _quickLinks)
                        {
                            <button class="search-quick-link" @onclick="() => NavigateTo(link.Url)">
                                <span class="material-icons" style="font-size:16px;">@link.Icon</span>
                                <span>@link.Title</span>
                            </button>
                        }
                    </div>
                    <div class="search-section-label mt-3">Recent Pages</div>
                    <div class="search-recent-list">
                        @foreach (var recentPage in _recentPages.Take(5))
                        {
                            <div class="search-recent-item" @onclick="() => NavigateTo(recentPage.Url)">
                                <span class="material-icons text-muted" style="font-size:16px;">@recentPage.Icon</span>
                                <span class="text-sm">@recentPage.Title</span>
                                <span class="text-xs text-muted ms-auto">@recentPage.Url</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private ElementReference _searchInput;
    private ElementReference _overlayRef;
    private string _query = string.Empty;
    private int _selectedIndex = -1;
    private List<SearchResult> _filteredResults = new();

