        new() { Title = "Shift", Description = "Manage work shifts", Url = "/shift", Icon = "schedule" },
        new() { Title = "Address", Description = "Address management", Url = "/address", Icon = "location_on" },
        new() { Title = "Group", Description = "Group management", Url = "/group", Icon = "groups" },
        new() { Title = "Floor", Description = "Floor management", Url = "/floor", Icon = "layers" },
        new() { Title = "Employee", Description = "Manage employees", Url = "/hr/employees", Icon = "people" },
        new() { Title = "Manpower", Description = "Manpower planning", Url = "/hr/manpower", Icon = "groups" },
        new() { Title = "Manpower Requirement", Description = "Staffing requirements", Url = "/hr/manpower-requirement", Icon = "person_add" },
        new() { Title = "Separation", Description = "Employee separation", Url = "/hr/seperation", Icon = "exit_to_app" },
        new() { Title = "Daily Attendance", Description = "Daily attendance records", Url = "/attendance/daily", Icon = "schedule" },
        new() { Title = "Attendance Summary", Description = "Attendance overview", Url = "/attendance/daily-summary", Icon = "assessment" },
        new() { Title = "Job Cards", Description = "Manage employee job cards", Url = "/attendance/job-cards", Icon = "badge" },
        new() { Title = "Missing Entry", Description = "Correct missing punch entry logs", Url = "/attendance/missing-entry", Icon = "hourglass_disabled" },
