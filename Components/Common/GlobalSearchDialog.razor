    };

    private void PerformSearch()
    {
        if (string.IsNullOrEmpty(_query) || _query.Length < 2)
        {
            _filteredResults.Clear();
            _selectedIndex = -1;
            return;
        }

        var lower = _query.ToLowerInvariant();
        _filteredResults = _allPages
            .Where(p => p.Title.ToLowerInvariant().Contains(lower) ||
                       p.Description.ToLowerInvariant().Contains(lower) ||
                       p.Url.ToLowerInvariant().Contains(lower))
            .Take(10)
            .ToList();
        _selectedIndex = _filteredResults.Any() ? 0 : -1;
    }

    private void ClearSearch()
    {
        _query = string.Empty;
        _filteredResults.Clear();
        _selectedIndex = -1;
    }

    private void HandleKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            if (_filteredResults.Any())
                _selectedIndex = Math.Min(_selectedIndex + 1, _filteredResults.Count - 1);
        }
        else if (e.Key == "ArrowUp")
        {
            _selectedIndex = Math.Max(_selectedIndex - 1, 0);
        }
        else if (e.Key == "Enter" && _selectedIndex >= 0 && _selectedIndex < _filteredResults.Count)
        {
            NavigateTo(_filteredResults[_selectedIndex].Url);
        }
        else if (e.Key == "Escape")
        {
            MudDialog.Cancel();
        }

        PerformSearch();
    }

    private void NavigateTo(string url)
    {
        MudDialog.Close();
        NavigationManager.NavigateTo(url);
    }

    private class SearchResult
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Icon { get; set; } = Icons.Material.Filled.Search;
    }

    private class SearchItem
    {
        public string Title { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Icon { get; set; } = Icons.Material.Filled.Link;
    }
}
