        new() { Title = "Holiday Bill", Description = "Holiday billing", Url = "/payroll/holiday-bill", Icon = Icons.Material.Filled.Celebration },
        new() { Title = "Leave Type", Description = "Manage leave types", Url = "/leave/type", Icon = Icons.Material.Filled.Category },
        new() { Title = "Leave Application", Description = "Apply for leave", Url = "/leave/application", Icon = Icons.Material.Filled.CalendarMonth },
        new() { Title = "Leave Details", Description = "Leave records", Url = "/leave/details", Icon = Icons.Material.Filled.ListAlt },
        new() { Title = "Monthly Summary", Description = "Monthly reports", Url = "/reports/monthly", Icon = Icons.Material.Filled.Assessment },
        new() { Title = "Monthly Report", Description = "Payroll reports", Url = "/reports/payroll", Icon = Icons.Material.Filled.Summarize },
        new() { Title = "Punch Log", Description = "Collect punch data", Url = "/datacollect/punch-log", Icon = Icons.Material.Filled.Fingerprint },
        new() { Title = "Daily Attendance Process", Description = "Process daily attendance", Url = "/datacollect/daily-attendance-process", Icon = Icons.Material.Filled.DateRange },
        new() { Title = "Monthly Process", Description = "Monthly data processing", Url = "/datacollect/monthly-process", Icon = Icons.Material.Filled.CalendarMonth },
