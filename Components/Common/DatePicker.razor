<div @ref="_wrapperElement" class="relative w-full">
    <div class="flex items-center justify-between bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 cursor-pointer text-[13.5px] hover:border-zinc-300 transition-colors" @onclick="ToggleCalendar">
        <span class="text-zinc-900 font-medium">@Value.ToString("MMMM dd, yyyy")</span>
        <svg class="w-4 h-4 fill-zinc-400" viewBox="0 0 24 24">
            <path d="M19 4h-2V2h-2v2H9V2H7v2H5c-1.103 0-2 .897-2 2v14c0 1.103.897 2 2 2h14c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm-14 4h14v12H5V8z"/>
        </svg>
    </div>

    @if (_showCalendar)
    {
        <div class="fixed top-0 left-0 w-screen h-screen z-[990]" @onclick="CloseCalendar"></div>
        <div class="absolute @(_openUp ? "bottom-[45px]" : "top-[45px]") left-0 bg-white border border-zinc-200 rounded-lg shadow-xl w-[270px] p-3.5 z-[1000] animate-fade-in" @onclick:stopPropagation>
            <!-- Header -->
            <div class="flex justify-between items-center mb-3">
                <button type="button" class="bg-transparent border border-zinc-200 rounded-md w-7 h-7 flex items-center justify-center cursor-pointer hover:bg-zinc-50 transition-colors text-zinc-600" @onclick="PrevMonth">
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
                </button>
                <span class="font-bold text-zinc-950 text-[13.5px]">@_activeMonth.ToString("MMMM yyyy")</span>
                <button type="button" class="bg-transparent border border-zinc-200 rounded-md w-7 h-7 flex items-center justify-center cursor-pointer hover:bg-zinc-50 transition-colors text-zinc-600" @onclick="NextMonth">
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                </button>
            </div>

            <!-- Grid of Days -->
            <div class="grid grid-cols-7 gap-1 text-center">
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Su</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Mo</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Tu</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">We</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Th</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Fr</span>
                <span class="text-[11px] font-bold text-zinc-400 py-1 select-none">Sa</span>

                <!-- Empty space padding for first week offset -->
                @for (int i = 0; i < _dayOffset; i++)
                {
                    <span class="py-1.5"></span>
                }

                <!-- Days of month -->
                @for (int day = 1; day <= _daysInMonth; day++)
                {
                    var currentDay = day;
                    var dateForCell = new DateTime(_activeMonth.Year, _activeMonth.Month, currentDay);
                    var isSelected = dateForCell.Date == Value.Date;
                    var isToday = dateForCell.Date == DateTime.Today.Date;
                    
                    <span class="text-[12.5px] font-medium py-1.5 rounded-md cursor-pointer text-zinc-800 transition-all select-none
                                 @(isSelected ? "bg-black text-white hover:bg-black font-bold" : 
                                   isToday ? "bg-zinc-100 font-bold hover:bg-zinc-200" : "hover:bg-zinc-100")" 
                          @onclick="() => SelectDate(currentDay)">
                        @currentDay
                    </span>
                }
            </div>
        </div>
    }
</div>
