@page "/datacollect/punch-log"
@inject IErpService ErpService

<PageTitle>ERPHub - Collect Punch Log</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <div class="mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Collect Punch Logs</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Select a date range and sync punch records from the ZK device.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg p-6 mb-4 flex flex-wrap gap-4 items-end">
                <div>
                    <MudDatePicker Date="@_fromDate"
                                   DateChanged="@(d => { if (d.HasValue) _fromDate = d.Value; })"
                                   Label="Start Date"
                                   Editable="true"
                                   Placeholder="Select Date"
                                   DateFormat="yyyy-MM-dd"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense" />
                </div>
                <div>
                    <MudDatePicker Date="@_toDate"
                                   DateChanged="@(d => { if (d.HasValue) _toDate = d.Value; })"
                                   Label="End Date"
                                   Editable="true"
                                   Placeholder="Select Date"
                                   DateFormat="yyyy-MM-dd"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense" />
                </div>
                <div>
                    <button type="button" class="px-5 py-2 bg-black text-white text-xs font-semibold rounded-lg hover:bg-zinc-800 transition-colors flex items-center gap-2" @onclick="SyncFromDevice" disabled="@_isSyncing">
                        @if (_isSyncing)
                        {
                            <svg class="w-3.5 h-3.5 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 40" /></svg>
                        }
                        else
                        {
                            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4v5h5M20 20v-5h-5M20.49 9A9 9 0 0 0 5.64 5.64L4 4m15.36 15.36A9 9 0 0 1 3.51 15" /></svg>
                        }
                        @_syncButtonText
                    </button>
                </div>
            </div>

            @if (_isSyncing)
            {
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4 flex items-center gap-3">
                    <svg class="w-5 h-5 text-blue-500 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 40" /></svg>
                    <span class="text-xs text-blue-700 font-medium">Syncing punch records from device...</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(_syncMessage))
            {
                <div class="@(_syncError ? "bg-red-50 border-red-200 text-red-700" : "bg-green-50 border-green-200 text-green-700") border rounded-lg p-4 mb-4 flex items-center gap-3">
                    @if (_syncError)
                    {
                        <svg class="w-5 h-5 text-red-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-green-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    }
                    <span class="text-xs font-medium">@_syncMessage</span>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private bool _isSyncing;
    private string _syncButtonText = "Sync Device";
    private string? _syncMessage;
    private bool _syncError;

    protected override Task OnInitializedAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _toDate = DateTime.Today;
        return Task.CompletedTask;
    }

    private async Task SyncFromDevice()
    {
        if (!_fromDate.HasValue || !_toDate.HasValue)
        {
            _syncError = true;
            _syncMessage = "Please select both start and end dates.";
            return;
        }

        _isSyncing = true;
        _syncButtonText = "Syncing...";
        _syncMessage = null;
        _syncError = false;
        StateHasChanged();

        try
        {
            var count = await ErpService.SyncPunchRecordsFromZKDeviceAsync(_fromDate, _toDate);
            _syncError = false;
            _syncMessage = $"{count} records synced from ZK device.";
            _syncButtonText = "Synced!";
            await Task.Delay(2000);
            _syncButtonText = "Sync Device";
        }
        catch (Exception ex)
        {
            _syncError = true;
            var details = ex.InnerException?.Message;
            _syncMessage = string.IsNullOrEmpty(details) ? ex.Message : $"{ex.Message} ({details})";
            _syncButtonText = "Sync Failed";
            await Task.Delay(3000);
            _syncButtonText = "Sync Device";
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }
}
