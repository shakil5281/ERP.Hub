@page "/organogram"

<PageTitle>ERPHub - Company Organogram</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Company Organogram</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage departments, sections, designations, and production lines.</p>
                </div>
                <div>
                    <NavLink href="/hr/import-organogram" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md border border-zinc-300 text-zinc-700 bg-white font-semibold hover:bg-zinc-50 transition-colors cursor-pointer">
                        Import Excel
                    </NavLink>
                </div>
            </div>

            <!-- Tabs -->
            <div class="tabs organogram-tabs mb-4">
                <div class="tabs-header">
                    <button class="tab @(_activeTab == "department" ? "active" : "")" @onclick="() => OnTabChanged(0)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
                        Department
                    </button>
                    <button class="tab @(_activeTab == "section" ? "active" : "")" @onclick="() => OnTabChanged(1)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                        Section
                    </button>
                    <button class="tab @(_activeTab == "designation" ? "active" : "")" @onclick="() => OnTabChanged(2)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Designation
                    </button>
                    <button class="tab @(_activeTab == "line" ? "active" : "")" @onclick="() => OnTabChanged(3)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Line
                    </button>
                </div>
            </div>

            <!-- ==================== DEPARTMENT TAB ==================== -->
            @if (_activeTab == "department")
            {
                <div class="animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                        <div class="flex-1 max-w-[320px] max-sm:max-w-none">
                            <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors"
                                   placeholder="Search departments..."
                                   @bind="_deptSearch" @bind:event="oninput" />
                        </div>
                        <div>
                            <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddDept">+ Add Department</button>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                        <div class="table-container">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Sl</th>
                                        <th>Name (EN)</th>
                                        <th>Name (BN)</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in FilteredDepartments)
                                    {
                                        <tr>
                                            <td data-label="Sl">@(FilteredDepartments.ToList().IndexOf(item) + 1)</td>
                                            <td data-label="Name (EN)">@item.NameEn</td>
                                            <td data-label="Name (BN)" class="font-sutonnymj">@item.NameBn</td>
                                            <td data-label="Actions">
                                                <button class="btn-icon btn-icon-sm text-indigo-500" @onclick="() => OpenEditDept(item)" title="Edit">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-icon btn-icon-sm text-red-500" @onclick="() => ConfirmDeleteDept(item.Id)" title="Delete">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                @if (!FilteredDepartments.Any())
                                {
                                    <tbody>
                                        <tr>
                                            <td colspan="4" class="text-center py-8 text-muted">Data Not Available</td>
                                        </tr>
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ==================== SECTION TAB ==================== -->
            @if (_activeTab == "section")
            {
                <div class="animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                        <div class="flex-1 max-w-[320px] max-sm:max-w-none">
                            <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors"
                                   placeholder="Search sections..."
                                   @bind="_sectionSearch" @bind:event="oninput" />
                        </div>
                        <div class="flex gap-4 items-center max-sm:flex-col max-sm:items-stretch">
                            <div class="flex gap-2 items-center max-sm:justify-between">
                                <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Department:</span>
                                <select class="form-control" @bind="_sectionDeptFilter">
                                    <option value="0">All Departments</option>
                                    @foreach (var dept in _departments)
                                    {
                                        <option value="@dept.Id">@dept.NameEn</option>
                                    }
                                </select>
                            </div>
                            <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddSection">+ Add Section</button>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                        <div class="table-container">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Sl</th>
                                        <th>Name (EN)</th>
                                        <th>Name (BN)</th>
                                        <th>Department</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in FilteredSections)
                                    {
                                        <tr>
                                            <td data-label="Sl">@(FilteredSections.ToList().IndexOf(item) + 1)</td>
                                            <td data-label="Name (EN)">@item.NameEn</td>
                                            <td data-label="Name (BN)" class="font-sutonnymj">@item.NameBn</td>
                                            <td data-label="Department">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-700">@item.DepartmentNameEn</span>
                                            </td>
                                            <td data-label="Actions">
                                                <button class="btn-icon btn-icon-sm text-indigo-500" @onclick="() => OpenEditSection(item)" title="Edit">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-icon btn-icon-sm text-red-500" @onclick="() => ConfirmDeleteSection(item.Id)" title="Delete">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                @if (!FilteredSections.Any())
                                {
                                    <tbody>
                                        <tr>
                                            <td colspan="5" class="text-center py-8 text-muted">Data Not Available</td>
                                        </tr>
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ==================== DESIGNATION TAB ==================== -->
            @if (_activeTab == "designation")
            {
                <div class="animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                        <div class="flex-1 max-w-[320px] max-sm:max-w-none">
                            <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors"
                                   placeholder="Search designations..."
                                   @bind="_desigSearch" @bind:event="oninput" />
                        </div>
                        <div class="flex gap-4 items-center max-sm:flex-col max-sm:items-stretch">
                            <div class="flex gap-2 items-center max-sm:justify-between">
                                <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Section:</span>
                                <select class="form-control" @bind="_desigSectionFilter">
                                    <option value="0">All Sections</option>
                                    @foreach (var sec in _sections)
                                    {
                                        <option value="@sec.Id">@sec.NameEn</option>
                                    }
                                </select>
                            </div>
                            <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddDesig">+ Add Designation</button>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                        <div class="table-container">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Sl</th>
                                        <th>Name (EN)</th>
                                        <th>Name (BN)</th>
                                        <th>Section</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in FilteredDesignations)
                                    {
                                        <tr>
                                            <td data-label="Sl">@(FilteredDesignations.ToList().IndexOf(item) + 1)</td>
                                            <td data-label="Name (EN)">@item.NameEn</td>
                                            <td data-label="Name (BN)" class="font-sutonnymj">@item.NameBn</td>
                                            <td data-label="Section">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700">@item.SectionNameEn</span>
                                            </td>
                                            <td data-label="Actions">
                                                <button class="btn-icon btn-icon-sm text-indigo-500" @onclick="() => OpenEditDesig(item)" title="Edit">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-icon btn-icon-sm text-red-500" @onclick="() => ConfirmDeleteDesig(item.Id)" title="Delete">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                @if (!FilteredDesignations.Any())
                                {
                                    <tbody>
                                        <tr>
                                            <td colspan="5" class="text-center py-8 text-muted">Data Not Available</td>
                                        </tr>
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ==================== LINE TAB ==================== -->
            @if (_activeTab == "line")
            {
                <div class="animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                        <div class="flex-1 max-w-[320px] max-sm:max-w-none">
                            <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors"
                                   placeholder="Search lines..."
                                   @bind="_lineSearch" @bind:event="oninput" />
                        </div>
                        <div class="flex gap-4 items-center max-sm:flex-col max-sm:items-stretch">
                            <div class="flex gap-2 items-center max-sm:justify-between">
                                <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Section:</span>
                                <select class="form-control" @bind="_lineSectionFilter">
                                    <option value="0">All Sections</option>
                                    @foreach (var sec in _sections)
                                    {
                                        <option value="@sec.Id">@sec.NameEn</option>
                                    }
                                </select>
                            </div>
                            <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddLine">+ Add Line</button>
                        </div>
                    </div>

                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                        <div class="table-container">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Sl</th>
                                        <th>Name (EN)</th>
                                        <th>Name (BN)</th>
                                        <th>Section</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in FilteredLines)
                                    {
                                        <tr>
                                            <td data-label="Sl">@(FilteredLines.ToList().IndexOf(item) + 1)</td>
                                            <td data-label="Name (EN)">@item.NameEn</td>
                                            <td data-label="Name (BN)" class="font-sutonnymj">@item.NameBn</td>
                                            <td data-label="Section">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700">@item.SectionNameEn</span>
                                            </td>
                                            <td data-label="Actions">
                                                <button class="btn-icon btn-icon-sm text-indigo-500" @onclick="() => OpenEditLine(item)" title="Edit">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-icon btn-icon-sm text-red-500" @onclick="() => ConfirmDeleteLine(item.Id)" title="Delete">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                @if (!FilteredLines.Any())
                                {
                                    <tbody>
                                        <tr>
                                            <td colspan="5" class="text-center py-8 text-muted">Data Not Available</td>
                                        </tr>
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ==================== MODALS ==================== -->

            <!-- Department Modal -->
            @if (_showDeptModal)
            {
                <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
                        <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                            <h3 class="font-bold text-sm text-zinc-950">@(_isEditDept ? "Edit Department" : "New Department")</h3>
                            <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseDeptModal">&times;</button>
                        </div>
                        <div class="p-5 flex flex-col gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (English)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingDept.NameEn" placeholder="e.g. Production" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (Bengali)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingDept.NameBn" placeholder="e.g. উৎপাদন" />
                            </div>
                        </div>
                        <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                            <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseDeptModal">Cancel</button>
                            <button type="button" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="SaveDept">@(_isEditDept ? "Update" : "Save")</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Section Modal -->
            @if (_showSectionModal)
            {
                <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
                        <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                            <h3 class="font-bold text-sm text-zinc-950">@(_isEditSection ? "Edit Section" : "New Section")</h3>
                            <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseSectionModal">&times;</button>
                        </div>
                        <div class="p-5 flex flex-col gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Department</label>
                                <select class="form-control" @bind="_editingSection.DepartmentId">
                                    <option value="0">-- Select Department --</option>
                                    @foreach (var dept in _departments)
                                    {
                                        <option value="@dept.Id">@dept.NameEn</option>
                                    }
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (English)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingSection.NameEn" placeholder="e.g. Sewing" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (Bengali)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingSection.NameBn" placeholder="e.g. সেয়িং" />
                            </div>
                        </div>
                        <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                            <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseSectionModal">Cancel</button>
                            <button type="button" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="SaveSection">@(_isEditSection ? "Update" : "Save")</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Designation Modal -->
            @if (_showDesigModal)
            {
                <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
                        <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                            <h3 class="font-bold text-sm text-zinc-950">@(_isEditDesig ? "Edit Designation" : "New Designation")</h3>
                            <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseDesigModal">&times;</button>
                        </div>
                        <div class="p-5 flex flex-col gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Section</label>
                                <select class="form-control" @bind="_editingDesig.SectionId">
                                    <option value="0">-- Select Section --</option>
                                    @foreach (var sec in _sections)
                                    {
                                        <option value="@sec.Id">@sec.NameEn (@sec.DepartmentNameEn)</option>
                                    }
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (English)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingDesig.NameEn" placeholder="e.g. Operator" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (Bengali)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingDesig.NameBn" placeholder="e.g. অপারেটর" />
                            </div>
                        </div>
                        <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                            <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseDesigModal">Cancel</button>
                            <button type="button" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="SaveDesig">@(_isEditDesig ? "Update" : "Save")</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Line Modal -->
            @if (_showLineModal)
            {
                <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
                    <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
                        <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                            <h3 class="font-bold text-sm text-zinc-950">@(_isEditLine ? "Edit Line" : "New Line")</h3>
                            <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseLineModal">&times;</button>
                        </div>
                        <div class="p-5 flex flex-col gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Section</label>
                                <select class="form-control" @bind="_editingLine.SectionId">
                                    <option value="0">-- Select Section --</option>
                                    @foreach (var sec in _sections)
                                    {
                                        <option value="@sec.Id">@sec.NameEn (@sec.DepartmentNameEn)</option>
                                    }
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (English)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingLine.NameEn" placeholder="e.g. Assembly Line A" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Name (Bengali)</label>
                                <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingLine.NameBn" placeholder="e.g. অ্যাসেম্বলি লাইন এ" />
                            </div>
                        </div>
                        <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                            <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseLineModal">Cancel</button>
                            <button type="button" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="SaveLine">@(_isEditLine ? "Update" : "Save")</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
