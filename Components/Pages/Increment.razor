@page "/payroll/increment"

<PageTitle>ERPHub - Increment Tracker</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Increment Tracker</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage salary appraisal policies, effective dates, and grade level promotions.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_appraisals" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.PreviousPay)">Previous Pay</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.NewPay)">New Pay</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.IncrementAmount)">Increment</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.Percentage)">Percentage</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.EffectiveDate)">Effective Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AppraisalCycle, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Previous Pay">@context.PreviousPay</MudTd>
                        <MudTd DataLabel="New Pay">@context.NewPay</MudTd>
                        <MudTd DataLabel="Increment">@context.IncrementAmount</MudTd>
                        <MudTd DataLabel="Percentage">@context.Percentage</MudTd>
                        <MudTd DataLabel="Effective Date">@context.EffectiveDate</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.BadgeClass">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class AppraisalCycle
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string PreviousPay { get; set; } = string.Empty;
        public string NewPay { get; set; } = string.Empty;
        public string IncrementAmount { get; set; } = string.Empty;
        public string Percentage { get; set; } = string.Empty;
        public string EffectiveDate { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<AppraisalCycle> _appraisals = new()
    {
        new AppraisalCycle { EmployeeName = "John Smith", PreviousPay = "$9,000.00", NewPay = "$10,000.00", IncrementAmount = "+$1,000.00", Percentage = "11.1%", EffectiveDate = "2026-06-01", Status = "Approved", BadgeClass = "bg-green-50 text-green-700" },
        new AppraisalCycle { EmployeeName = "Peter Parker", PreviousPay = "$5,000.00", NewPay = "$5,500.00", IncrementAmount = "+$500.00", Percentage = "10.0%", EffectiveDate = "2026-06-15", Status = "Pending Review", BadgeClass = "bg-amber-50 text-amber-700" }
    };
}
