@page "/"

<PageTitle>ERPHub - Dashboard</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <MudGrid Spacing="6">
            @* Stat Cards *@
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-6 d-flex align-items-center justify-content-between" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold" Style="letter-spacing:0.05em;">Total Revenue</MudText>
                        <MudText Typo="Typo.h5" Class="fw-extrabold">@_totalRevenue.ToString("C")</MudText>
                    </div>
                    <MudPaper Class="d-flex align-items-center justify-content-center flex-shrink-0" Style="width:40px;height:40px;border-radius:8px;background-color:var(--mud-palette-info-hover);" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Info" Size="Size.Medium" />
                    </MudPaper>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-6 d-flex align-items-center justify-content-between" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold" Style="letter-spacing:0.05em;">Inventory In Stock</MudText>
                        <MudText Typo="Typo.h5" Class="fw-extrabold">@_totalStock Items</MudText>
                    </div>
                    <MudPaper Class="d-flex align-items-center justify-content-center flex-shrink-0" Style="width:40px;height:40px;border-radius:8px;background-color:var(--mud-palette-success-hover);" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Success" Size="Size.Medium" />
                    </MudPaper>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-6 d-flex align-items-center justify-content-between" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold" Style="letter-spacing:0.05em;">Pending Tasks</MudText>
                        <MudText Typo="Typo.h5" Class="fw-extrabold">@_pendingTasks Count</MudText>
                    </div>
                    <MudPaper Class="d-flex align-items-center justify-content-center flex-shrink-0" Style="width:40px;height:40px;border-radius:8px;background-color:var(--mud-palette-warning-hover);" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Warning" Size="Size.Medium" />
                    </MudPaper>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-6 d-flex align-items-center justify-content-between" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold" Style="letter-spacing:0.05em;">Paid Invoices</MudText>
                        <MudText Typo="Typo.h5" Class="fw-extrabold">@_paidInvoices Count</MudText>
                    </div>
                    <MudPaper Class="d-flex align-items-center justify-content-center flex-shrink-0" Style="width:40px;height:40px;border-radius:8px;background-color:var(--mud-palette-error-hover);" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Error" Size="Size.Medium" />
                    </MudPaper>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Charts & Details *@
        <MudGrid Spacing="6" Class="mt-4">
            @* Revenue Chart *@
            <MudItem xs="12" lg="8">
                <MudPaper Class="pa-6 d-flex flex-column" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Sales Revenue Analytics</MudText>
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color">Active Invoices Breakdown</MudText>
                    </div>
                    <div class="d-flex align-items-end justify-content-around" style="height:220px; padding-top:10px; padding-bottom:6px; border-bottom:1px solid var(--mud-palette-table-lines);">
                        @if (_invoices != null && _invoices.Any())
                        {
                            decimal maxTotal = _invoices.Max(i => i.GrandTotal);
                            if (maxTotal == 0) maxTotal = 1;

                            @foreach (var invoice in _invoices.OrderBy(i => i.Id))
                            {
                                var percentage = (int)((invoice.GrandTotal / maxTotal) * 100);
                                var barHeight = Math.Max(15, percentage);

                                <div class="d-flex flex-column align-items-center justify-content-end" style="width:12%;height:100%;">
                                    <div class="bg-black" style="min-height:10px; flex-shrink:0; width:100%; height:@(barHeight)%; border-top-left-radius:6px; border-top-right-radius:6px;"
                                         title="Total: @invoice.GrandTotal.ToString("C")"
                                         @onmouseover="() => {}"></div>
                                    <MudText Typo="Typo.caption" Class="text-truncate mud-secondary-text-color" Style="width:100%;" title="@invoice.InvoiceNumber">
                                        @invoice.InvoiceNumber
                                    </MudText>
                                </div>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mud-secondary-text-color align-self-center">No invoice data available to chart.</MudText>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-center mt-3">* Hover over bars to view invoice details.</MudText>
                </MudPaper>
            </MudItem>

            @* Activity Feed *@
            <MudItem xs="12" lg="4">
                <MudPaper Class="pa-6 d-flex flex-column" Elevation="0" Outlined="true" Style="border-radius:8px;">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">System Activity</MudText>
                    <div class="d-flex flex-column" style="gap:14px;">
                        @foreach (var activity in _activities)
                        {
                            <div class="d-flex" style="gap:12px; padding-bottom:14px; border-bottom:1px solid var(--mud-palette-table-lines);">
                                <div style="width:10px; height:10px; border-radius:50%; margin-top:6px; flex-shrink:0; background-color:@activity.Color;"></div>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.body2" Class="fw-semibold">@activity.Title</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@activity.TimeDescription</MudText>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Recent Invoices Table *@
        <MudPaper Class="pa-6 mt-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">Recent Sales Orders</MudText>
            <MudTable Items="@_invoices?.Take(4).ToList()" Hover="true" Elevation="0" Outlined="false" Class="mud-table-no-border">
                <ColGroup>
                    <col />
                    <col />
                    <col />
                    <col />
                    <col />
                    <col style="width:100px;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.InvoiceNumber)">Invoice No</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.ClientName)">Client</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.IssueDate)">Issue Date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.DueDate)">Due Date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.GrandTotal)">Amount</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Invoice, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Invoice No"><MudText Typo="Typo.body2" Class="fw-bold">@context.InvoiceNumber</MudText></MudTd>
                    <MudTd DataLabel="Client">
                        <MudText Typo="Typo.body2" Class="fw-medium">@context.ClientName</MudText>
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@context.ClientEmail</MudText>
                    </MudTd>
                    <MudTd DataLabel="Issue Date"><MudText Typo="Typo.body2" Class="mud-secondary-text-color">@context.IssueDate.ToShortDateString()</MudText></MudTd>
                    <MudTd DataLabel="Due Date"><MudText Typo="Typo.body2" Class="mud-secondary-text-color">@context.DueDate.ToShortDateString()</MudText></MudTd>
                    <MudTd DataLabel="Amount"><MudText Typo="Typo.body2" Class="fw-bold">@context.GrandTotal.ToString("C")</MudText></MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)" Class="fw-bold" T="string">
                            @context.Status.ToString()
                        </MudChip>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">No invoices found.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
