@page "/"

<PageTitle>ERPHub - Dashboard</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Stat Cards *@
        <div class="flex flex-wrap" style="gap:24px;">
            <div class="flex-grow-1" style="flex-basis:0;min-width:200px;">
                <div class="stat-card card">
                    <div class="flex flex-col">
                        <span class="text-muted text-uppercase fw-bold text-xs" style="letter-spacing:0.05em;">Total Revenue</span>
                        <span class="font-extrabold text-xl">@_totalRevenue.ToString("C")</span>
                    </div>
                    <div class="stat-card-icon" style="background-color:var(--mud-palette-info-hover);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                </div>
            </div>

            <div class="flex-grow-1" style="flex-basis:0;min-width:200px;">
                <div class="stat-card card">
                    <div class="flex flex-col">
                        <span class="text-muted text-uppercase fw-bold text-xs" style="letter-spacing:0.05em;">Inventory In Stock</span>
                        <span class="font-extrabold text-xl">@_totalStock Items</span>
                    </div>
                    <div class="stat-card-icon" style="background-color:var(--mud-palette-success-hover);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    </div>
                </div>
            </div>

            <div class="flex-grow-1" style="flex-basis:0;min-width:200px;">
                <div class="stat-card card">
                    <div class="flex flex-col">
                        <span class="text-muted text-uppercase fw-bold text-xs" style="letter-spacing:0.05em;">Pending Tasks</span>
                        <span class="font-extrabold text-xl">@_pendingTasks Count</span>
                    </div>
                    <div class="stat-card-icon" style="background-color:var(--mud-palette-warning-hover);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
                    </div>
                </div>
            </div>

            <div class="flex-grow-1" style="flex-basis:0;min-width:200px;">
                <div class="stat-card card">
                    <div class="flex flex-col">
                        <span class="text-muted text-uppercase fw-bold text-xs" style="letter-spacing:0.05em;">Paid Invoices</span>
                        <span class="font-extrabold text-xl">@_paidInvoices Count</span>
                    </div>
                    <div class="stat-card-icon" style="background-color:var(--mud-palette-error-hover);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                </div>
            </div>
        </div>

        @* Charts & Details *@
        <div class="flex flex-wrap mt-4" style="gap:24px;">
            @* Revenue Chart *@
            <div class="flex-grow-1" style="flex-basis:0;min-width:300px;">
                <div class="card pa-6 flex flex-col" style="border-radius:8px;">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="fw-bold text-base">Sales Revenue Analytics</h6>
                        <span class="text-muted text-xs">Active Invoices Breakdown</span>
                    </div>
                    <div class="flex items-end justify-around" style="height:220px; padding-top:10px; padding-bottom:6px; border-bottom:1px solid var(--mud-palette-table-lines);">
                        @if (_invoices != null && _invoices.Any())
                        {
                            decimal maxTotal = _invoices.Max(i => i.GrandTotal);
                            if (maxTotal == 0) maxTotal = 1;

                            @foreach (var invoice in _invoices.OrderBy(i => i.Id))
                            {
                                var percentage = (int)((invoice.GrandTotal / maxTotal) * 100);
                                var barHeight = Math.Max(15, percentage);

                                <div class="flex flex-col items-center justify-end" style="width:12%;height:100%;">
                                    <div class="bg-black" style="min-height:10px; flex-shrink:0; width:100%; height:@(barHeight)%; border-top-left-radius:6px; border-top-right-radius:6px;"
                                         title="Total: @invoice.GrandTotal.ToString("C")"
                                         @onmouseover="() => {}"></div>
                                    <span class="text-muted text-xs truncate" style="width:100%;" title="@invoice.InvoiceNumber">
                                        @invoice.InvoiceNumber
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted text-sm self-center">No invoice data available to chart.</span>
                        }
                    </div>
                    <span class="text-muted text-xs text-center mt-3">* Hover over bars to view invoice details.</span>
                </div>
            </div>

            @* Activity Feed *@
            <div class="flex-grow-1" style="flex-basis:0;min-width:240px;">
                <div class="card pa-6 flex flex-col" style="border-radius:8px;">
                    <h6 class="fw-bold text-base mb-4">System Activity</h6>
                    <div class="flex flex-col" style="gap:14px;">
                        @foreach (var activity in _activities)
                        {
                            <div class="flex" style="gap:12px; padding-bottom:14px; border-bottom:1px solid var(--mud-palette-table-lines);">
                                <div style="width:10px; height:10px; border-radius:50%; margin-top:6px; flex-shrink:0; background-color:@activity.Color;"></div>
                                <div class="flex-grow-1">
                                    <span class="fw-semibold text-sm">@activity.Title</span>
                                    <span class="text-muted text-xs block">@activity.TimeDescription</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Recent Invoices Table *@
        <div class="card pa-6 mt-4" style="border-radius:8px;">
            <h6 class="fw-bold text-base mb-4">Recent Sales Orders</h6>
            <div class="table-container">
                <table>
                    <colgroup>
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col style="width:100px;" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Invoice No</th>
                            <th>Client</th>
                            <th>Issue Date</th>
                            <th>Due Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _invoices?.Take(4).ToList() ?? new())
                        {
                            <tr>
                                <td data-label="Invoice No"><span class="fw-bold text-sm">@item.InvoiceNumber</span></td>
                                <td data-label="Client">
                                    <span class="fw-medium text-sm">@item.ClientName</span>
                                    <span class="text-muted text-xs block">@item.ClientEmail</span>
                                </td>
                                <td data-label="Issue Date"><span class="text-muted text-sm">@item.IssueDate.ToShortDateString()</span></td>
                                <td data-label="Due Date"><span class="text-muted text-sm">@item.DueDate.ToShortDateString()</span></td>
                                <td data-label="Amount"><span class="fw-bold text-sm">@item.GrandTotal.ToString("C")</span></td>
                                <td data-label="Status">
                                    <span class="chip @GetStatusColor(item.Status)">@item.Status.ToString()</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (_invoices == null || !_invoices.Any())
                    {
                        <tbody>
                            <tr>
                                <td colspan="6" class="text-center py-8 text-muted">No invoices found.</td>
                            </tr>
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
