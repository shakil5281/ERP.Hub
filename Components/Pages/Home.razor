@page "/"

<PageTitle>ERPHub - Dashboard</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
    <!-- Stat Grid -->
    <div class="grid grid-cols-4 gap-6 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Total Revenue</span>
                <span class="text-2xl font-extrabold text-zinc-950">@_totalRevenue.ToString("C")</span>
            </div>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-indigo-50 text-indigo-600 flex-shrink-0">
                <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current">
                    <path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8z"/>
                    <path d="M11 8h2v2h-2zm0 4h2v4h-2z"/>
                </svg>
            </div>
        </div>

        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Inventory In Stock</span>
                <span class="text-2xl font-extrabold text-zinc-950">@_totalStock Items</span>
            </div>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-emerald-50 text-emerald-600 flex-shrink-0">
                <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current">
                    <path d="m21.406 7.357-9-4a1.002 1.002 0 0 0-.812 0l-9 4A1 1 0 0 0 2 8.281v7.438a1 1 0 0 0 .594.91l9 4a.996.996 0 0 0 .812 0l9-4A1 1 0 0 0 22 15.719V8.281a1 1 0 0 0-.594-.924zM12 4.148l6.866 3.052L12 10.252 5.134 7.2 12 4.148zM4 9.394l7 3.111v6.938l-7-3.111V9.394zm9 10.049v-6.938l7-3.111v6.938l-7 3.111z"/>
                </svg>
            </div>
        </div>

        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Pending Tasks</span>
                <span class="text-2xl font-extrabold text-zinc-950">@_pendingTasks Count</span>
            </div>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-amber-50 text-amber-600 flex-shrink-0">
                <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current">
                    <path d="M19 4h-2V2h-2v2H9V2H7v2H5c-1.103 0-2 .897-2 2v14c0 1.103.897 2 2 2h14c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm-14 4h14v12H5V8z"/>
                </svg>
            </div>
        </div>

        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Paid Invoices</span>
                <span class="text-2xl font-extrabold text-zinc-950">@_paidInvoices Count</span>
            </div>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-pink-50 text-pink-600 flex-shrink-0">
                <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current">
                    <path d="M16 2H8C4.691 2 2 4.691 2 8v13a1 1 0 0 0 1 1h15c3.309 0 6-2.691 6-6V8c0-3.309-2.691-6-6-6zM8 4h8c2.206 0 4 1.794 4 4v2H4V8c0-2.206 1.794-4 4-4zM4 20v-8h16v6c0 2.206-1.794 4-4 4H5.414L4 20z"/>
                </svg>
            </div>
        </div>
    </div>

    <!-- Charts & Details -->
    <div class="grid grid-cols-3 gap-6 mb-6 max-xl:grid-cols-1">
        <!-- Revenue Chart Card -->
        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm col-span-2 max-xl:col-span-1 flex flex-col">
            <div class="flex justify-between items-center mb-5">
                <h3 class="text-base font-bold text-zinc-950">Sales Revenue Analytics</h3>
                <span class="text-xs text-zinc-500 font-medium">Active Invoices Breakdown</span>
            </div>
            <div class="h-[220px] flex items-end justify-around pt-2.5 border-b border-zinc-200 pb-1.5">
                @if (_invoices != null && _invoices.Any())
                {
                    decimal maxTotal = _invoices.Max(i => i.GrandTotal);
                    if (maxTotal == 0) maxTotal = 1;

                    @foreach (var invoice in _invoices.OrderBy(i => i.Id))
                    {
                        var percentage = (int)((invoice.GrandTotal / maxTotal) * 100);
                        <!-- Ensure at least 15% height for visual presence -->
                        var barHeight = Math.Max(15, percentage);
                        
                        <div class="flex flex-col items-center w-[12%] h-full justify-end gap-2">
                            <div class="w-full bg-black rounded-t-md hover:bg-zinc-800 transition-colors min-h-[10px] cursor-pointer" style="height: @(barHeight)%;" title="Total: @invoice.GrandTotal.ToString("C")"></div>
                            <span class="text-[11px] text-zinc-400 text-center truncate w-full" title="@invoice.InvoiceNumber">
                                @invoice.InvoiceNumber
                            </span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-zinc-400 text-sm self-center">No invoice data available to chart.</p>
                }
            </div>
            <div class="flex justify-center gap-5 mt-3 text-xs text-zinc-400 select-none">
                <span>* Hover over bars to view invoice details. Height matches proportionate invoice value.</span>
            </div>
        </div>

        <!-- Recent Activity Feed -->
        <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm col-span-1 flex flex-col">
            <h3 class="text-base font-bold text-zinc-950 mb-5">System Activity</h3>
            <div class="flex flex-col gap-3.5">
                @foreach (var activity in _activities)
                {
                    <div class="flex gap-3 pb-3.5 border-b border-zinc-100 last:border-0 last:pb-0">
                        <div class="w-2.5 h-2.5 rounded-full mt-1.5 flex-shrink-0" style="background-color: @activity.Color;"></div>
                        <div class="flex-1">
                            <p class="font-semibold text-zinc-800 text-[13px] leading-snug">@activity.Title</p>
                            <span class="text-[11px] text-zinc-400">@activity.TimeDescription</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Invoices Table -->
    <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm mb-6">
        <h3 class="text-base font-bold text-zinc-950 mb-5">Recent Sales Orders</h3>
        <div class="w-full overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-zinc-200 bg-zinc-50/75">
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Invoice No</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Client</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Issue Date</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Due Date</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Amount</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_invoices != null && _invoices.Any())
                    {
                        @foreach (var invoice in _invoices.Take(4))
                        {
                            <tr class="border-b border-zinc-100 hover:bg-zinc-50/30 transition-colors">
                                <td class="p-2.5 px-4 font-bold text-zinc-900">@invoice.InvoiceNumber</td>
                                <td class="p-2.5 px-4 text-zinc-900">
                                    <div class="font-medium">@invoice.ClientName</div>
                                    <div class="text-[11px] text-zinc-400">@invoice.ClientEmail</div>
                                </td>
                                <td class="p-2.5 px-4 text-zinc-600 text-xs">@invoice.IssueDate.ToShortDateString()</td>
                                <td class="p-2.5 px-4 text-zinc-600 text-xs">@invoice.DueDate.ToShortDateString()</td>
                                <td class="p-2.5 px-4 font-bold text-zinc-900">@invoice.GrandTotal.ToString("C")</td>
                                <td class="p-2.5 px-4">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-bold text-center capitalize
                                                 @(invoice.Status == InvoiceStatus.Paid ? "bg-emerald-50 text-emerald-700" :
                                                   invoice.Status == InvoiceStatus.Sent ? "bg-amber-50 text-amber-700" :
                                                   "bg-zinc-100 text-zinc-600")">
                                        @invoice.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-zinc-400 py-8 text-sm">No invoices found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
