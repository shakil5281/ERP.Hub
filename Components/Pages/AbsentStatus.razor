@page "/attendance/absent-status"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AttendanceService AttendanceService

<PageTitle>ERPHub - Absent Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header with Export Buttons *@
        <div class="d-flex align-center mb-6 w-100" style="flex-wrap:wrap; gap: 16px;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Absent Status Summary</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">Track employee total absent and continuous absent days over a period.</MudText>
            </div>
            <MudSpacer />
            <div class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           Disabled="@(_records.Count == 0 || _isExporting)"
                           OnClick="ExportToExcel"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           Size="Size.Small">
                    Excel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(_records.Count == 0 || _isExporting)"
                           OnClick="ExportToPdf"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Size="Size.Small">
                    PDF
                </MudButton>
            </div>
        </div>

        @* Filters *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4" Style="border-radius:8px;">
            <MudGrid Spacing="3" class="align-items-end">
                <MudItem xs="12" sm="4" md="3">
                    <MudDatePicker Label="From Date"
                                   Date="@_fromDate"
                                   DateChanged="@(d => { if (d.HasValue) _fromDate = d.Value; })"
                                   Editable="true"
                                   Placeholder="Select Date"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudDatePicker Label="To Date"
                                   Date="@_toDate"
                                   DateChanged="@(d => { if (d.HasValue) _toDate = d.Value; })"
                                   Editable="true"
                                   Placeholder="Select Date"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Label="Employee ID"
                                  @bind-Value="_employeeIdFilter"
                                  Variant="Variant.Outlined"
                                  Placeholder="e.g. 1001"
                                  dense="true"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Employee Status"
                               @bind-Value="_employeeStatus"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="0">All</MudSelectItem>
                        <MudSelectItem Value="1">Active</MudSelectItem>
                        <MudSelectItem Value="2">Inactive</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Company"
                               @bind-Value="_companyIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="0">All Companies</MudSelectItem>
                        @foreach (var c in _companies)
                        {
                            <MudSelectItem Value="@c.Id">@c.CompanyNameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Department"
                               @bind-Value="_departmentIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Designation"
                               @bind-Value="_designationIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Designations</MudSelectItem>
                        @foreach (var dg in _designations)
                        {
                            <MudSelectItem Value="@dg.Id">@dg.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="12" md="3" Class="d-flex align-center gap-2" Style="margin-top: 10px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="@_isLoading" @onclick="LoadRecords" Class="flex-grow-1">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               @onclick="ClearFilters" Class="flex-grow-1">
                        Clear
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Data Table *@
        @if (_isLoading)
        {
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Loading records...</MudText>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_records" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0" Filter="new Func<AbsentSummaryDto, bool>(FilterFunc)">
                    <ToolBarContent>
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Absent Summary</MudText>
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@_fromDate.ToString("yyyy-MM-dd") to @_toDate.ToString("yyyy-MM-dd")</MudText>
                        </div>
                        <MudSpacer />
                        <MudTextField @bind-Value="_searchString"
                                      Placeholder="Quick search name or ID..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Class="mt-0"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="text-align: center;">Sl</MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.EmployeeId)">Employee ID</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.Department)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.Designation)">Designation</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.TotalAbsentDays)">Total Absent</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.ContinuousAbsentDays)">Continuous Absent</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align: center;" DataLabel="Sl">@(_records.IndexOf(context) + 1)</MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Employee ID"><MudText Typo="Typo.body2" Class="fw-bold font-mono">@context.EmployeeId</MudText></MudTd>
                        <MudTd DataLabel="Employee Name"><MudText Typo="Typo.body2" Class="fw-medium">@context.EmployeeName</MudText></MudTd>
                        <MudTd DataLabel="Department"><MudText Typo="Typo.body2">@context.Department</MudText></MudTd>
                        <MudTd DataLabel="Designation"><MudText Typo="Typo.body2">@context.Designation</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Total Absent">
                            <MudText Typo="Typo.body2" Class="fw-bold text-error">@context.TotalAbsentDays</MudText>
                        </MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Continuous Absent">
                            <MudText Typo="Typo.body2" Class="fw-bold text-warning">@context.ContinuousAbsentDays</MudText>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                    </NoRecordsContent>
                </MudTable>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _toDate = DateTime.Today;
    
    private string? _employeeIdFilter;
    private int _employeeStatus; // 0=All, 1=Active, 2=Inactive
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _designationIdFilter;
    
    private bool _isLoading;
    private bool _isExporting;
    private string _searchString = "";
    
    private List<AbsentSummaryDto> _records = new();
    private List<AbsentSummaryDto> _allRecords = new();

    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Employee> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadRecords();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var companiesTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(companiesTask, departmentsTask, designationsTask, employeesTask);

            _companies = await companiesTask ?? new();
            _departments = await departmentsTask ?? new();
            _designations = await designationsTask ?? new();
            _employees = await employeesTask ?? new();
        }
        catch
        {
            // Lookup data failed
        }
    }

    private async Task LoadRecords()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            bool? activeParam = _employeeStatus == 1 ? true : (_employeeStatus == 2 ? false : null);
            
            // Generate the raw attendance first so it is populated in the database.
            // Be aware that CalculateAttendanceAsync takes null dates as "Today",
            // and it might be slow for a whole month. But we will let it run.
            await AttendanceService.CalculateAttendanceAsync(_fromDate, _toDate);
            
            _allRecords = await AttendanceService.GetAbsentSummaryAsync(_fromDate, _toDate, _employeeIdFilter, activeParam);
            
            ApplyClientFilters();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading records: {ex.Message}", Severity.Error);
            _allRecords = new();
            _records = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyClientFilters()
    {
        var matchingEmployeeIds = _employees
            .Where(e =>
                (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
                (_designationIdFilter == 0 || e.DesignationId == _designationIdFilter))
            .Select(e => e.EmployeeId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        bool hasOrgFilter = _departmentIdFilter > 0 || _designationIdFilter > 0;

        _records = _allRecords
            .Where(r => !hasOrgFilter || matchingEmployeeIds.Contains(r.EmployeeId))
            .ToList();
    }

    private async Task ClearFilters()
    {
        _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
        _toDate = DateTime.Today;
        _employeeIdFilter = null;
        _employeeStatus = 0;
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _designationIdFilter = 0;
        _searchString = "";
        await LoadRecords();
    }

    private bool FilterFunc(AbsentSummaryDto element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.EmployeeName != null && element.EmployeeName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
            
        if (element.Department != null && element.Department.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private async Task ExportToExcel()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                Snackbar.Add("No records match the current filter.", Severity.Warning);
                return;
            }

            var columns = GetExportColumns(exportRecords);

            var bytes = await ExportService.ExportToExcelAsync(
                exportRecords,
                "Absent Summary",
                $"Absent Summary ({_fromDate:yyyy-MM-dd} to {_toDate:yyyy-MM-dd})",
                columns);
                
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"AbsentSummary_{DateTime.Now:yyyyMMddHHmmss}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            Snackbar.Add("Excel exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                Snackbar.Add("No records match the current filter.", Severity.Warning);
                return;
            }

            var columns = GetExportColumns(exportRecords);

            var bytes = await ExportService.ExportToPdfAsync(
                exportRecords,
                $"Absent Summary ({_fromDate:yyyy-MM-dd} to {_toDate:yyyy-MM-dd})",
                columns);
                
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"AbsentSummary_{DateTime.Now:yyyyMMddHHmmss}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            Snackbar.Add("PDF exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<AbsentSummaryDto, object>> GetExportColumns(List<AbsentSummaryDto> recordsSource) => new()
    {
        ["Sl"] = r => recordsSource.IndexOf(r) + 1,
        ["Employee ID"] = r => r.EmployeeId,
        ["Employee Name"] = r => r.EmployeeName,
        ["Department"] = r => r.Department,
        ["Designation"] = r => r.Designation,
        ["Total Absent"] = r => r.TotalAbsentDays,
        ["Continuous Absent"] = r => r.ContinuousAbsentDays
    };
}
