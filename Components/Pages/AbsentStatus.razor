@page "/attendance/absent-status"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ToastService Toast
@inject AttendanceService AttendanceService

<PageTitle>ERPHub - Absent Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header with Export Buttons *@
        <div class="d-flex align-center mb-6" style="flex-wrap:wrap; gap: 16px;width: 100%;">
            <div>
                <span class="text-2xl fw-extrabold">Absent Status Summary</span>
                <span class="text-xs mud-secondary-text-color mt-1 d-block">Track employee total absent and continuous absent days over a period.</span>
            </div>
            <span class="flex-grow-1"></span>
            <div class="d-flex justify-end gap-2">
                <button class="btn btn-outlined btn-sm"
                        disabled="@(_records.Count == 0 || _isExporting)"
                        @onclick="ExportToExcel">
                    <span class="material-icons">table_chart</span> Excel
                </button>
                <button class="btn btn-primary btn-sm"
                        disabled="@(_records.Count == 0 || _isExporting)"
                        @onclick="ExportToPdf">
                    <span class="material-icons">picture_as_pdf</span> PDF
                </button>
            </div>
        </div>

        @* Filters *@
        <div class="card pa-4 mb-4" style="border-radius:8px;">
            <div class="d-flex flex-wrap gap-3 align-items-end">
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">From Date</label>
                    <input type="date" class="form-control" value="@_fromDate.ToString("yyyy-MM-dd")"
                           @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) _fromDate = d; }" />
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">To Date</label>
                    <input type="date" class="form-control" value="@_toDate.ToString("yyyy-MM-dd")"
                           @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) _toDate = d; }" />
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">Employee ID</label>
                    <input class="form-control" placeholder="e.g. 1001"
                           @bind="_employeeIdFilter"
                           @bind:event="oninput" />
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">Employee Status</label>
                    <select class="form-control" @bind="_employeeStatus">
                        <option value="0">All</option>
                        <option value="1">Active</option>
                        <option value="2">Inactive</option>
                    </select>
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">Company</label>
                    <select class="form-control" @bind="_companyIdFilter">
                        <option value="0">All Companies</option>
                        @foreach (var c in _companies)
                        {
                            <option value="@c.Id">@c.CompanyNameEn</option>
                        }
                    </select>
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">Department</label>
                    <select class="form-control" @bind="_departmentIdFilter">
                        <option value="0">All Departments</option>
                        @foreach (var d in _departments)
                        {
                            <option value="@d.Id">@d.NameEn</option>
                        }
                    </select>
                </div>
                <div style="flex:1 1 220px;min-width:200px;">
                    <label class="form-label">Designation</label>
                    <select class="form-control" @bind="_designationIdFilter">
                        <option value="0">All Designations</option>
                        @foreach (var dg in _designations)
                        {
                            <option value="@dg.Id">@dg.NameEn</option>
                        }
                    </select>
                </div>
                <div class="d-flex align-center gap-2" style="flex:1 1 100%;margin-top:10px;">
                    <button class="btn btn-primary flex-grow-1" disabled="@_isLoading" @onclick="LoadRecords">Apply</button>
                    <button class="btn btn-outlined flex-grow-1" @onclick="ClearFilters">Clear</button>
                </div>
            </div>
        </div>

        @* Data Table *@
        @if (_isLoading)
        {
            <div class="text-center mud-secondary-text-color py-8">Loading records...</div>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-toolbar">
                    <div>
                        <div class="fw-bold font-heading">Absent Summary</div>
                        <div class="text-xs mud-secondary-text-color">@_fromDate.ToString("yyyy-MM-dd") to @_toDate.ToString("yyyy-MM-dd")</div>
                    </div>
                    <span class="flex-grow-1"></span>
                    <div class="d-flex align-center" style="position:relative;">
                        <span class="material-icons" style="position:absolute;left:8px;color:#a1a1aa;font-size:16px;">search</span>
                        <input class="form-control" placeholder="Quick search name or ID..." @bind="_searchString" style="padding-left:28px;width:220px;" />
                    </div>
                </div>
                @if (_records.Any(FilterFunc))
                {
                    <div class="table-body">
                        <table>
                            <thead>
                                <tr>
                                    <th style="text-align: center;">Sl</th>
                                    <th style="text-align: center;">Employee ID</th>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Designation</th>
                                    <th style="text-align: center;">Total Absent</th>
                                    <th style="text-align: center;">Continuous Absent</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var context in _records.Where(FilterFunc))
                                {
                                    <tr>
                                        <td style="text-align: center;">@(_records.IndexOf(context) + 1)</td>
                                        <td style="text-align: center;"><span class="fw-bold font-mono">@context.EmployeeId</span></td>
                                        <td><span class="fw-medium">@context.EmployeeName</span></td>
                                        <td>@context.Department</td>
                                        <td>@context.Designation</td>
                                        <td style="text-align: center;"><span class="fw-bold text-error">@context.TotalAbsentDays</span></td>
                                        <td style="text-align: center;"><span class="fw-bold text-warning">@context.ContinuousAbsentDays</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="table-empty">
                        <span>Data Not Available</span>
                    </div>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _toDate = DateTime.Today;
    
    private string? _employeeIdFilter;
    private int _employeeStatus; // 0=All, 1=Active, 2=Inactive
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _designationIdFilter;
    
    private bool _isLoading;
    private bool _isExporting;
    private string _searchString = "";
    
    private List<AbsentSummaryDto> _records = new();
    private List<AbsentSummaryDto> _allRecords = new();

    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Employee> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadRecords();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var companiesTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(companiesTask, departmentsTask, designationsTask, employeesTask);

            _companies = await companiesTask ?? new();
            _departments = await departmentsTask ?? new();
            _designations = await designationsTask ?? new();
            _employees = await employeesTask ?? new();
        }
        catch
        {
            // Lookup data failed
        }
    }

    private async Task LoadRecords()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            bool? activeParam = _employeeStatus == 1 ? true : (_employeeStatus == 2 ? false : null);
            
            // Generate the raw attendance first so it is populated in the database.
            // Be aware that CalculateAttendanceAsync takes null dates as "Today",
            // and it might be slow for a whole month. But we will let it run.
            await AttendanceService.CalculateAttendanceAsync(_fromDate, _toDate);
            
            _allRecords = await AttendanceService.GetAbsentSummaryAsync(_fromDate, _toDate, _employeeIdFilter, activeParam);
            
            ApplyClientFilters();
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Error loading records: {ex.Message}");
            _allRecords = new();
            _records = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyClientFilters()
    {
        var matchingEmployeeIds = _employees
            .Where(e =>
                (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
                (_designationIdFilter == 0 || e.DesignationId == _designationIdFilter))
            .Select(e => e.EmployeeId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        bool hasOrgFilter = _departmentIdFilter > 0 || _designationIdFilter > 0;

        _records = _allRecords
            .Where(r => !hasOrgFilter || matchingEmployeeIds.Contains(r.EmployeeId))
            .ToList();
    }

    private async Task ClearFilters()
    {
        _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
        _toDate = DateTime.Today;
        _employeeIdFilter = null;
        _employeeStatus = 0;
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _designationIdFilter = 0;
        _searchString = "";
        await LoadRecords();
    }

    private bool FilterFunc(AbsentSummaryDto element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.EmployeeName != null && element.EmployeeName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
            
        if (element.Department != null && element.Department.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private async Task ExportToExcel()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                await Toast.ShowWarningAsync("No records match the current filter.");
                return;
            }

            var columns = GetExportColumns(exportRecords);

            var bytes = await ExportService.ExportToExcelAsync(
                exportRecords,
                "Absent Summary",
                $"Absent Summary ({_fromDate:yyyy-MM-dd} to {_toDate:yyyy-MM-dd})",
                columns);
                
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"AbsentSummary_{DateTime.Now:yyyyMMddHHmmss}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            await Toast.ShowSuccessAsync("Excel exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                await Toast.ShowWarningAsync("No records match the current filter.");
                return;
            }

            var columns = GetExportColumns(exportRecords);

            var bytes = await ExportService.ExportToPdfAsync(
                exportRecords,
                $"Absent Summary ({_fromDate:yyyy-MM-dd} to {_toDate:yyyy-MM-dd})",
                columns);
                
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"AbsentSummary_{DateTime.Now:yyyyMMddHHmmss}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            await Toast.ShowSuccessAsync("PDF exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<AbsentSummaryDto, object>> GetExportColumns(List<AbsentSummaryDto> recordsSource) => new()
    {
        ["Sl"] = r => recordsSource.IndexOf(r) + 1,
        ["Employee ID"] = r => r.EmployeeId,
        ["Employee Name"] = r => r.EmployeeName,
        ["Department"] = r => r.Department,
        ["Designation"] = r => r.Designation,
        ["Total Absent"] = r => r.TotalAbsentDays,
        ["Continuous Absent"] = r => r.ContinuousAbsentDays
    };
}
