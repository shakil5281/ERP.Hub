@page "/payroll/night-bill"

<PageTitle>ERPHub - Night Shift Bills</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Night Shift Billing</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Calculate and process nocturnal shift duty allowances and night premiums.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-responsive-wrapper">
                    <table class="w-full">
                        <thead>
                            <tr>
                                <th>Employee Name <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Night Shifts Logged <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Allowance Rate <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Total Allowance <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Period <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Status <button class="sort-btn" @onclick="() => {}">↕</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_claims.Any())
                            {
                                @foreach (var item in _claims)
                                {
                                    <tr>
                                        <td data-label="Employee Name">@item.EmployeeName</td>
                                        <td data-label="Night Shifts Logged">@item.NightShiftsLogged</td>
                                        <td data-label="Allowance Rate">@item.AllowanceRate</td>
                                        <td data-label="Total Allowance">@item.TotalAllowance</td>
                                        <td data-label="Period">@item.Period</td>
                                        <td data-label="Status">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-8 text-muted">Data Not Available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <div class="flex items-center gap-3">
                        <span class="pagination-info">Rows per page:</span>
                        <select class="page-size-select">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                    </div>
                    <div class="pagination">
                        <button class="pagination-btn" disabled>‹</button>
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn" disabled>›</button>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class NightAllowanceClaim
    {
        public string EmployeeName { get; set; } = string.Empty;
        public int NightShiftsLogged { get; set; }
        public string AllowanceRate { get; set; } = string.Empty;
        public string TotalAllowance { get; set; } = string.Empty;
        public string Period { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<NightAllowanceClaim> _claims = new()
    {
        new NightAllowanceClaim { EmployeeName = "Logan (Wolverine)", NightShiftsLogged = 15, AllowanceRate = "$20.00 / Shift", TotalAllowance = "$300.00", Period = "June 2026", Status = "Approved" }
    };
}
