@page "/payroll/night-bill"

<PageTitle>ERPHub - Night Shift Bills</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Night Shift Billing</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Calculate and process nocturnal shift duty allowances and night premiums.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_claims" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.NightShiftsLogged)">Night Shifts Logged</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.AllowanceRate)">Allowance Rate</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.TotalAllowance)">Total Allowance</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.Period)">Period</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<NightAllowanceClaim, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Night Shifts Logged">@context.NightShiftsLogged</MudTd>
                        <MudTd DataLabel="Allowance Rate">@context.AllowanceRate</MudTd>
                        <MudTd DataLabel="Total Allowance">@context.TotalAllowance</MudTd>
                        <MudTd DataLabel="Period">@context.Period</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class NightAllowanceClaim
    {
        public string EmployeeName { get; set; } = string.Empty;
        public int NightShiftsLogged { get; set; }
        public string AllowanceRate { get; set; } = string.Empty;
        public string TotalAllowance { get; set; } = string.Empty;
        public string Period { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<NightAllowanceClaim> _claims = new()
    {
        new NightAllowanceClaim { EmployeeName = "Logan (Wolverine)", NightShiftsLogged = 15, AllowanceRate = "$20.00 / Shift", TotalAllowance = "$300.00", Period = "June 2026", Status = "Approved" }
    };
}
