@page "/reports/monthly"

<PageTitle>ERPHub - Monthly Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Monthly Summary</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Consolidated high-level performance metrics, work hour statistics, and operational audits.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_metrics" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<KpiMetric, object>(x=>x.MetricName)">Metric Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KpiMetric, object>(x=>x.CurrentValue)">Current Value</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KpiMetric, object>(x=>x.Target)">Target / Limit</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<KpiMetric, object>(x=>x.Growth)">Monthly Growth</MudTableSortLabel></MudTh>
                        <MudTh>Variance Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Metric Name">@context.MetricName</MudTd>
                        <MudTd DataLabel="Current Value">@context.CurrentValue</MudTd>
                        <MudTd DataLabel="Target / Limit">@context.Target</MudTd>
                        <MudTd DataLabel="Monthly Growth">@context.Growth</MudTd>
                        <MudTd DataLabel="Variance Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.BadgeClass">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class KpiMetric
    {
        public string MetricName { get; set; } = string.Empty;
        public string CurrentValue { get; set; } = string.Empty;
        public string Target { get; set; } = string.Empty;
        public string Growth { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<KpiMetric> _metrics = new()
    {
        new KpiMetric { MetricName = "Total Work Hours", CurrentValue = "22,450 hrs", Target = "20,000 hrs Min", Growth = "↑ 4.2%", Status = "Optimal", BadgeClass = "bg-green-50 text-green-700" },
        new KpiMetric { MetricName = "Turnover Rate", CurrentValue = "0.85%", Target = "2.00% Max", Growth = "↓ 0.2%", Status = "Optimal", BadgeClass = "bg-green-50 text-green-700" },
        new KpiMetric { MetricName = "Payroll Budget Variance", CurrentValue = "$4,850.00", Target = "$5,000.00 Allow", Growth = "↑ 0.5%", Status = "Within Bounds", BadgeClass = "bg-green-50 text-green-700" }
    };
}
