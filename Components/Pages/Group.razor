@page "/group"
@inject ERPHub.Services.IErpService ErpService

<PageTitle>ERPHub - Groups</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Groups</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage corporate entities and group listings.</p>
                </div>
                <div>
                    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer animate-fade-in" @onclick="OpenAddModal">+ Add Group</button>
                </div>
            </div>

            <!-- Filters Bar -->
            <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                <div class="flex-1 max-w-[320px] max-sm:max-w-none">
                    <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors" 
                           placeholder="Search by group name..." 
                           @bind="_searchQuery" @bind:event="oninput" />
                </div>
            </div>

            <!-- Data Table -->
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-responsive-wrapper">
                    <table class="w-full">
                        <thead>
                            <tr>
                                <th>Sl</th>
                                <th>Group Name <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (FilteredGroups.Any())
                            {
                                @foreach (var item in FilteredGroups)
                                {
                                    <tr>
                                        <td data-label="Sl">@(FilteredGroups.IndexOf(item) + 1)</td>
                                        <td data-label="Group Name">@item.GroupName</td>
                                        <td data-label="Actions">
                                            <button class="btn-icon btn-icon-sm" title="Edit" @onclick="() => OpenEditModal(item)">
                                                <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="btn-icon btn-icon-sm" title="Delete" @onclick="() => ConfirmDelete(item.Id)">
                                                <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-8 text-muted">Data Not Available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <div class="flex items-center gap-3">
                        <span class="pagination-info">Rows per page:</span>
                        <select class="page-size-select">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                    </div>
                    <div class="pagination">
                        <button class="pagination-btn" disabled>‹</button>
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn" disabled>›</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add / Edit Modal -->
        @if (_showFormModal)
        {
            <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[2000] p-4 animate-fade-in">
                <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
                    <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                        <h3 class="font-bold text-sm text-zinc-950">@(_isEditMode ? "Edit Business Group" : "New Business Group")</h3>
                        <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseModal">&times;</button>
                    </div>
                    
                    <EditForm Model="@_editingGroup" OnValidSubmit="SaveGroup">
                        <DataAnnotationsValidator />
                        
                        <div class="p-5 flex flex-col gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Group Name</label>
                                <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingGroup.GroupName" placeholder="e.g. North America Group" />
                                <ValidationMessage For="@(() => _editingGroup.GroupName)" class="text-[11px] font-semibold text-red-500 mt-1" />
                            </div>
                        </div>

                        <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                            <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">Save Group</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<BusinessGroup> _groups = new();
    private string _searchQuery = "";
    private bool _showFormModal = false;
    private bool _isEditMode = false;
    private BusinessGroup _editingGroup = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadGroupsAsync();
    }

    private async Task LoadGroupsAsync()
    {
        _groups = await ErpService.GetBusinessGroupsAsync();
    }

    private List<BusinessGroup> FilteredGroups => _groups
        .Where(g => string.IsNullOrWhiteSpace(_searchQuery) || g.GroupName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private void OpenAddModal()
    {
        _editingGroup = new BusinessGroup();
        _isEditMode = false;
        _showFormModal = true;
    }

    private void OpenEditModal(BusinessGroup group)
    {
        _editingGroup = new BusinessGroup
        {
            Id = group.Id,
            GroupName = group.GroupName
        };
        _isEditMode = true;
        _showFormModal = true;
    }

    private void CloseModal()
    {
        _showFormModal = false;
    }

    private async Task SaveGroup()
    {
        if (_isEditMode)
        {
            await ErpService.UpdateBusinessGroupAsync(_editingGroup);
        }
        else
        {
            await ErpService.AddBusinessGroupAsync(_editingGroup);
        }
        await LoadGroupsAsync();
        _showFormModal = false;
    }

    private async Task ConfirmDelete(int id)
    {
        await ErpService.DeleteBusinessGroupAsync(id);
        await LoadGroupsAsync();
    }
}
