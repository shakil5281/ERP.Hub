@page "/group"

<PageTitle>ERPHub - Business Groups</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Business Groups</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Define corporate entities, divisions, and geographical groups.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_groups" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<BusinessGroup, object>(x=>x.GroupName)">Group Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BusinessGroup, object>(x=>x.DivisionType)">Division Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BusinessGroup, object>(x=>x.TotalLocations)">Total Locations</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BusinessGroup, object>(x=>x.TotalDepartments)">Total Departments</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BusinessGroup, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Group Name">@context.GroupName</MudTd>
                        <MudTd DataLabel="Division Type">@context.DivisionType</MudTd>
                        <MudTd DataLabel="Total Locations">@context.TotalLocations</MudTd>
                        <MudTd DataLabel="Total Departments">@context.TotalDepartments</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class BusinessGroup
    {
        public string GroupName { get; set; } = string.Empty;
        public string DivisionType { get; set; } = string.Empty;
        public int TotalLocations { get; set; }
        public int TotalDepartments { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private List<BusinessGroup> _groups = new()
    {
        new BusinessGroup { GroupName = "North America Group", DivisionType = "Domestic Division", TotalLocations = 4, TotalDepartments = 12, Status = "Active" },
        new BusinessGroup { GroupName = "EMEA Group", DivisionType = "International Division", TotalLocations = 2, TotalDepartments = 5, Status = "Active" }
    };
}
