@page "/floor"

<PageTitle>ERPHub - Floor & Workspace</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Floor & Workspace</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Map out department desks, cubicles, and building wings.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-responsive-wrapper">
                    <table class="w-full">
                        <thead>
                            <tr>
                                <th>Floor Level <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Assigned Wing <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Description <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Desks capacity <button class="sort-btn" @onclick="() => {}">↕</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_floors.Any())
                            {
                                @foreach (var item in _floors)
                                {
                                    <tr>
                                        <td data-label="Floor Level">@item.Level</td>
                                        <td data-label="Assigned Wing">@item.Wing</td>
                                        <td data-label="Description">@item.Description</td>
                                        <td data-label="Desks capacity">@item.Capacity</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-8 text-muted">Data Not Available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <div class="flex items-center gap-3">
                        <span class="pagination-info">Rows per page:</span>
                        <select class="page-size-select">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                    </div>
                    <div class="pagination">
                        <button class="pagination-btn" disabled>‹</button>
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn" disabled>›</button>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class FloorMap
    {
        public string Level { get; set; } = string.Empty;
        public string Wing { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Capacity { get; set; } = string.Empty;
    }

    private List<FloorMap> _floors = new()
    {
        new FloorMap { Level = "Level 1", Wing = "Executive Suites & Admin", Description = "Houses the management, HR departments, boardrooms, and front-desk reception.", Capacity = "15 / 20 Desks Filled" },
        new FloorMap { Level = "Level 2", Wing = "Engineering & Product", Description = "Assigned to engineering, QA testing rooms, research benches, and open collaborative zones.", Capacity = "45 / 50 Desks Filled" },
        new FloorMap { Level = "Level 3", Wing = "Sales, Support & Cafe", Description = "Dedicated to customer service desks, marketing cubicles, cafeteria, and wellness spaces.", Capacity = "22 / 40 Desks Filled" }
    };
}
