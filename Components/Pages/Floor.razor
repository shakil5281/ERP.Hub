@page "/floor"

<PageTitle>ERPHub - Floor & Workspace</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Floor & Workspace</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Map out department desks, cubicles, and building wings.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_floors" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<FloorMap, object>(x=>x.Level)">Floor Level</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<FloorMap, object>(x=>x.Wing)">Assigned Wing</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<FloorMap, object>(x=>x.Description)">Description</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<FloorMap, object>(x=>x.Capacity)">Desks capacity</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Floor Level">@context.Level</MudTd>
                        <MudTd DataLabel="Assigned Wing">@context.Wing</MudTd>
                        <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="Desks capacity">@context.Capacity</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class FloorMap
    {
        public string Level { get; set; } = string.Empty;
        public string Wing { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Capacity { get; set; } = string.Empty;
    }

    private List<FloorMap> _floors = new()
    {
        new FloorMap { Level = "Level 1", Wing = "Executive Suites & Admin", Description = "Houses the management, HR departments, boardrooms, and front-desk reception.", Capacity = "15 / 20 Desks Filled" },
        new FloorMap { Level = "Level 2", Wing = "Engineering & Product", Description = "Assigned to engineering, QA testing rooms, research benches, and open collaborative zones.", Capacity = "45 / 50 Desks Filled" },
        new FloorMap { Level = "Level 3", Wing = "Sales, Support & Cafe", Description = "Dedicated to customer service desks, marketing cubicles, cafeteria, and wellness spaces.", Capacity = "22 / 40 Desks Filled" }
    };
}
