@page "/hr/add-employee"

<PageTitle>ERPHub - Add Employee</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in max-w-7xl mx-auto">
            <!-- Header -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <NavLink href="/hr/employees" class="inline-flex items-center gap-1.5 text-xs font-semibold text-zinc-500 hover:text-zinc-800 transition-colors mb-2">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                        </svg>
                        Back to Employee Directory
                    </NavLink>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Add New Employee</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Register a new employee with personal, contact, and employment details.</p>
                </div>
            </div>

            <!-- Form Card -->
            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm overflow-hidden">
                <EditForm Model="@_employee" OnValidSubmit="SaveEmployee">
                    <DataAnnotationsValidator />

                    <div class="p-5 sm:p-6">
                        <div class="tabs add-employee-tabs">
                            <div class="tabs-header">
                            <button class="tab @(_activeTabIndex == 0 ? "active" : "")" @onclick="() => _activeTabIndex = 0">
                                <span class="material-icons" style="font-size:16px;">person</span> Personal Info
                            </button>
                            <button class="tab @(_activeTabIndex == 1 ? "active" : "")" @onclick="() => _activeTabIndex = 1">
                                <span class="material-icons" style="font-size:16px;">family_restroom</span> Family Info
                            </button>
                            <button class="tab @(_activeTabIndex == 2 ? "active" : "")" @onclick="() => _activeTabIndex = 2">
                                <span class="material-icons" style="font-size:16px;">work</span> Office Info
                            </button>
                            <button class="tab @(_activeTabIndex == 3 ? "active" : "")" @onclick="() => _activeTabIndex = 3">
                                <span class="material-icons" style="font-size:16px;">account_balance</span> Salary & Account
                            </button>
                            <button class="tab @(_activeTabIndex == 4 ? "active" : "")" @onclick="() => _activeTabIndex = 4">
                                <span class="material-icons" style="font-size:16px;">location_on</span> Address
                            </button>
                            <button class="tab @(_activeTabIndex == 5 ? "active" : "")" @onclick="() => _activeTabIndex = 5">
                                <span class="material-icons" style="font-size:16px;">image</span> Signature & Image
                            </button>
                            </div>
                            <div class="tabs-content">
                            <div class="tab-panel @(_activeTabIndex == 0 ? "active" : "")">
                                    <div class="pt-5">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.EmployeeId" @bind:event="oninput" class="form-control" placeholder="e.g. EMP-001" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" @bind="_employee.PunchNumber" class="form-control" placeholder="e.g. 1001" />
                                    </div>
                                    <div class="col-span-1">
                                    <input type="text" @bind="_employee.EmployeeName" @bind:event="oninput" class="form-control" placeholder="e.g. Jane Doe" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.NID" @bind:event="oninput" class="form-control" placeholder="e.g. 1234567890" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.MobileNo" @bind:event="oninput" class="form-control" placeholder="e.g. +880 1711-000000" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.Email" @bind:event="oninput" class="form-control" placeholder="e.g. jane.doe@company.com" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="date" @bind="_dob" class="form-control" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_gender" @onchange="@( (ChangeEventArgs e) => { OnGenderChanged(e.Value?.ToString() ?? string.Empty); } )">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                    </select>
                                    </div>
                                    </div>
                                    </div>
                            </div>
                            <div class="tab-panel @(_activeTabIndex == 1 ? "active" : "")">
                                    <div class="pt-5">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.FatherName" @bind:event="oninput" class="form-control" placeholder="e.g. John Doe" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.MotherName" @bind:event="oninput" class="form-control" placeholder="e.g. Mary Doe" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" value="@_spouseName" @onchange="@( (ChangeEventArgs e) => OnSpouseNameChanged(e.Value?.ToString() ?? "") )" class="form-control" placeholder="e.g. Sarah Doe" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_childrenCount" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnChildrenCountChanged(v); } )" class="form-control" min="0" />
                                    </div>
                                    </div>
                                    </div>
                            </div>
                            <div class="tab-panel @(_activeTabIndex == 2 ? "active" : "")">
                                    <div class="pt-5">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.CompanyId">
                                    <option value="0">Select Company</option>
                                    @foreach (var comp in _companies)
                                    {
                                    <option value="@comp.Id">@comp.CompanyNameEn</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_employee.DepartmentId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnDepartmentValueChanged(v); } )">
                                    <option value="0">Select Department</option>
                                    @foreach (var dept in _departments)
                                    {
                                    <option value="@dept.Id">@dept.NameEn</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_employee.SectionId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnSectionValueChanged(v); } )">
                                    <option value="0">Select Section</option>
                                    @foreach (var sec in _filteredSections)
                                    {
                                    <option value="@sec.Id">@sec.NameEn</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.DesignationId">
                                    <option value="0">Select Designation</option>
                                    @foreach (var desig in _filteredDesignations)
                                    {
                                    <option value="@desig.Id">@desig.NameEn</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.LineId">
                                    <option value="0">Select Line</option>
                                    @foreach (var line in _filteredLines)
                                    {
                                    <option value="@line.Id">@line.NameEn</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.ShiftId">
                                    <option value="0">Select Shift</option>
                                    @foreach (var shift in _shifts)
                                    {
                                    <option value="@shift.Id">@shift.ShiftName</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="date" @bind="_joiningDate" class="form-control" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.Status">
                                    <option value="Regular">Regular</option>
                                    <option value="Resign">Resign</option>
                                    <option value="Left">Left</option>
                                    <option value="Close">Close</option>
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <label class="switch mt-2">
                                    <input type="checkbox" @bind="_employee.OverTimeStatus" />
                                    <span class="switch-track"><span class="switch-thumb"></span></span>
                                    OverTime Status
                                    </label>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.EmployeeType">
                                    <option value="Permanent">Permanent</option>
                                    <option value="Contract">Contract</option>
                                    <option value="Probation">Probation</option>
                                    <option value="Intern">Intern</option>
                                    <option value="Part-Time">Part-Time</option>
                                    </select>
                                    </div>
                                    </div>
                                    </div>
                            </div>
                            <div class="tab-panel @(_activeTabIndex == 3 ? "active" : "")">
                                    <div class="pt-5 flex flex-col gap-6">

                                    @* --- Salary Section --- *@
                                    <div>
                                    <h4 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                                    <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                                    </svg>
                                    Salary Details
                                    </h4>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_grossSalary" @onchange="@( (ChangeEventArgs e) => { decimal.TryParse(e.Value?.ToString() ?? "0", out var v); OnGrossSalaryChanged(v); } )" class="form-control" placeholder="0.00" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_employee.BasicSalary" class="form-control" placeholder="0.00" disabled="true" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_houseRent" class="form-control" placeholder="0.00" disabled="true" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_foodAllowance" class="form-control" placeholder="0.00" disabled="true" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_medicalAllowance" class="form-control" placeholder="0.00" disabled="true" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="number" value="@_conveyanceAllowance" class="form-control" placeholder="0.00" disabled="true" />
                                    </div>
                                    <div class="col-span-1">
                                    <div class="flex items-center gap-2 mt-1">
                                    <span class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Total:</span>
                                    <span class="text-sm font-bold text-black">৳ @_totalSalary.ToString("N2")</span>
                                    </div>
                                    </div>
                                    </div>
                                    </div>

                                    <hr class="border-zinc-100" />

                                    @* --- Account Section --- *@
                                    <div>
                                    <h4 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                                    <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                                    </svg>
                                    Account Details
                                    </h4>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_accountType" @onchange="@( (ChangeEventArgs e) => { OnAccountTypeChanged(e.Value?.ToString() ?? string.Empty); } )">
                                    <option value="mCash">mCash</option>
                                    <option value="Card">Card</option>
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" value="@_accountNumber" @onchange="@( (ChangeEventArgs e) => OnAccountNumberChanged(e.Value?.ToString() ?? "") )" class="form-control" placeholder="@_accountPlaceholder" maxlength="@_accountMaxLength" aria-invalid="@_accountNumberError" />
                                    </div>
                                    </div>
                                    </div>

                                    </div>
                            </div>
                            <div class="tab-panel @(_activeTabIndex == 4 ? "active" : "")">
                                    <div class="pt-5 flex flex-col gap-6">

                                    @* --- Present Address --- *@
                                    <div>
                                    <h4 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                                    <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    Present Address
                                    </h4>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PresentVillage" @bind:event="oninput" class="form-control" placeholder="e.g. Vill: Genda" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PresentPostOffice" @bind:event="oninput" class="form-control" placeholder="e.g. GPO" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_presentDivisionId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnPresentDivisionChanged(v); } )">
                                    <option value="0">Select Division</option>
                                    @foreach (var div in _divisions)
                                    {
                                    <option value="@div.Id">@div.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_presentDistrictId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnPresentDistrictChanged(v); } )" disabled="@(_presentDivisionId == 0)">
                                    <option value="0">Select District</option>
                                    @foreach (var dist in _presentFilteredDistricts)
                                    {
                                    <option value="@dist.Id">@dist.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.PresentUpazilaId" disabled="@(_presentDistrictId == 0)">
                                    <option value="0">Select Upazila</option>
                                    @foreach (var upa in _presentFilteredUpazilas)
                                    {
                                    <option value="@upa.Id">@upa.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PresentPostalCode" @bind:event="oninput" class="form-control" placeholder="e.g. 1234" maxlength="4" />
                                    </div>
                                    </div>
                                    </div>

                                    <hr class="border-zinc-100" />

                                    @* --- Permanent Address --- *@
                                    <div>
                                    <div class="flex items-center justify-between mb-3">
                                    <h4 class="text-xs font-bold text-zinc-400 uppercase tracking-wider flex items-center gap-2">
                                    <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                    </svg>
                                    Permanent Address
                                    </h4>
                                    <label class="checkbox-container">
                                    <input type="checkbox" checked="@_sameAsPresent" @onchange="@( (ChangeEventArgs e) => OnSameAsPresentChanged(e.Value?.ToString() == "true") )" class="checkbox-input" />
                                    <span class="checkbox-checkmark"></span>
                                    <span class="checkbox-label">Same as Present</span>
                                    </label>
                                    </div>

                                    @if (!_sameAsPresent)
                                    {
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PermanentVillage" @bind:event="oninput" class="form-control" placeholder="e.g. Vill: Genda" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PermanentPostOffice" @bind:event="oninput" class="form-control" placeholder="e.g. GPO" />
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_permanentDivisionId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnPermanentDivisionChanged(v); } )">
                                    <option value="0">Select Division</option>
                                    @foreach (var div in _divisions)
                                    {
                                    <option value="@div.Id">@div.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" value="@_permanentDistrictId" @onchange="@( (ChangeEventArgs e) => { int.TryParse(e.Value?.ToString() ?? "0", out var v); OnPermanentDistrictChanged(v); } )" disabled="@(_permanentDivisionId == 0)">
                                    <option value="0">Select District</option>
                                    @foreach (var dist in _permanentFilteredDistricts)
                                    {
                                    <option value="@dist.Id">@dist.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <select class="form-control" @bind="_employee.PermanentUpazilaId" disabled="@(_permanentDistrictId == 0)">
                                    <option value="0">Select Upazila</option>
                                    @foreach (var upa in _permanentFilteredUpazilas)
                                    {
                                    <option value="@upa.Id">@upa.Name</option>
                                    }
                                    </select>
                                    </div>
                                    <div class="col-span-1 sm:col-span-2">
                                    <input type="text" @bind="_employee.PermanentPostalCode" @bind:event="oninput" class="form-control" placeholder="e.g. 1234" maxlength="4" />
                                    </div>
                                    </div>
                                    }
                                    </div>

                                    </div>
                            </div>
                            <div class="tab-panel @(_activeTabIndex == 5 ? "active" : "")">
                                    <div class="pt-5">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                    <div class="col-span-1 sm:col-span-2">
                                    <div class="border border-dashed border-zinc-300 rounded-xl p-6 text-center hover:border-zinc-400 transition-colors">
                                    <span class="material-icons mb-3" style="font-size:20px;">photo_camera</span>
                                    <p class="mb-2 font-semibold text-zinc-700">Employee Photo</p>
                                    <span class="text-zinc-400 mb-3">JPG, PNG up to 2MB</span>

                                    @if (!string.IsNullOrEmpty(_photoPreview))
                                    {
                                    <div class="mb-3 flex justify-center">
                                    <img src="@_photoPreview" alt="" class="rounded-lg border border-zinc-200" style="width:120px;height:120px;object-fit:cover" />
                                    </div>
                                    }

                                    <label class="inline-flex items-center gap-2 py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-sm">
                                    <span class="material-icons" style="font-size:20px;">upload</span>
                                    Choose Photo
                                    <InputFile OnChange="OnPhotoSelected" Accept=".jpg,.jpeg,.png" class="hidden" />
                                    </label>
                                    </div>
                                    </div>

                                    <div class="col-span-1 sm:col-span-2">
                                    <div class="border border-dashed border-zinc-300 rounded-xl p-6 text-center hover:border-zinc-400 transition-colors">
                                    <span class="material-icons mb-3" style="font-size:20px;">draw</span>
                                    <p class="mb-2 font-semibold text-zinc-700">Signature</p>
                                    <span class="text-zinc-400 mb-3">JPG, PNG up to 1MB</span>

                                    @if (!string.IsNullOrEmpty(_signaturePreview))
                                    {
                                    <div class="mb-3 flex justify-center">
                                    <img src="@_signaturePreview" alt="" class="rounded-lg border border-zinc-200" style="width:200px;height:80px;object-fit:contain" />
                                    </div>
                                    }

                                    <label class="inline-flex items-center gap-2 py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-sm">
                                    <span class="material-icons" style="font-size:20px;">upload</span>
                                    Choose Signature
                                    <InputFile OnChange="OnSignatureSelected" Accept=".jpg,.jpeg,.png" class="hidden" />
                                    </label>
                                    </div>
                                    </div>
                                    </div>
                                    </div>
                            </div>
                            </div>
                        </div>
</div>

                    <!-- Action Bar -->
                    <div class="p-4 sm:p-5 border-t border-zinc-100 bg-zinc-50 flex flex-col-reverse sm:flex-row justify-end gap-2.5">
                        <NavLink href="/hr/employees" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors text-center text-sm">Cancel</NavLink>
                        <button type="submit" class="py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-sm disabled:opacity-60 disabled:cursor-not-allowed" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save Employee</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        @if (_showToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✓</span>
                <span>@_toastMessage</span>
            </div>
        }
        @if (_showErrorToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✗</span>
                <span>@_errorMessage</span>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
