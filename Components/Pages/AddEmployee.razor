@page "/hr/add-employee"

<PageTitle>ERPHub - Add Employee</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in max-w-4xl mx-auto">
            <!-- Header -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <NavLink href="/hr/employees" class="inline-flex items-center gap-1.5 text-xs font-semibold text-zinc-500 hover:text-zinc-800 transition-colors mb-2">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                        </svg>
                        Back to Employee Directory
                    </NavLink>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Add New Employee</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Register a new employee with personal, contact, and employment details.</p>
                </div>
            </div>

            <!-- Form Card -->
            <div class="bg-white border border-zinc-200 rounded-xl shadow-sm overflow-hidden">
                <EditForm Model="@_employee" OnValidSubmit="SaveEmployee">
                    <DataAnnotationsValidator />

                    <div class="p-5 sm:p-6 flex flex-col gap-8">
                        <!-- Basic Information -->
                        <section>
                            <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                Basic Information
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Employee ID <span class="text-red-400">*</span></label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.EmployeeId" placeholder="e.g. EMP-001" />
                                    <ValidationMessage For="@(() => _employee.EmployeeId)" class="text-[11px] font-semibold text-red-500 mt-1" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Full Name <span class="text-red-400">*</span></label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.EmployeeName" placeholder="e.g. Jane Doe" />
                                    <ValidationMessage For="@(() => _employee.EmployeeName)" class="text-[11px] font-semibold text-red-500 mt-1" />
                                </div>
                            </div>
                        </section>

                        <hr class="border-zinc-100" />

                        <!-- Family Details -->
                        <section>
                            <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Family Details
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Father's Name</label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.FatherName" placeholder="e.g. John Doe" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Mother's Name</label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.MotherName" placeholder="e.g. Mary Doe" />
                                </div>
                                <div class="flex flex-col gap-1.5 sm:col-span-2">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">National ID (NID)</label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.NID" placeholder="e.g. 1234567890" />
                                </div>
                            </div>
                        </section>

                        <hr class="border-zinc-100" />

                        <!-- Contact & Address -->
                        <section>
                            <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                Contact & Address
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Mobile Number <span class="text-red-400">*</span></label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.MobileNo" placeholder="e.g. +880 1711-000000" />
                                    <ValidationMessage For="@(() => _employee.MobileNo)" class="text-[11px] font-semibold text-red-500 mt-1" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Email Address</label>
                                    <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.Email" placeholder="e.g. jane.doe@company.com" />
                                </div>
                                <div class="flex flex-col gap-1.5 sm:col-span-2">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Address</label>
                                    <InputTextArea class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors min-h-[72px] resize-y" @bind-Value="_employee.Address" placeholder="e.g. 123 Industrial Area, Dhaka" />
                                </div>
                            </div>
                        </section>

                        <hr class="border-zinc-100" />

                        <!-- Employment Details -->
                        <section>
                            <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                Employment Details
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                                <!-- Department -->
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Department <span class="text-red-400">*</span></label>
                                    <select class="block w-full appearance-none pl-3.5 pr-10 py-2.5 border border-zinc-200 focus:border-black rounded-lg bg-white text-[13.5px] transition-colors outline-none text-zinc-900 font-body cursor-pointer" @bind="_employee.DepartmentId" @bind:after="OnDepartmentChanged">
                                        <option value="0">Select Department</option>
                                        @foreach (var dept in _departments)
                                        {
                                            <option value="@dept.Id">@dept.NameEn</option>
                                        }
                                    </select>
                                </div>
                                <!-- Section -->
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Section <span class="text-red-400">*</span></label>
                                    <select class="block w-full appearance-none pl-3.5 pr-10 py-2.5 border border-zinc-200 focus:border-black rounded-lg bg-white text-[13.5px] transition-colors outline-none text-zinc-900 font-body cursor-pointer" @bind="_employee.SectionId" @bind:after="OnSectionChanged">
                                        <option value="0">Select Section</option>
                                        @foreach (var sec in _filteredSections)
                                        {
                                            <option value="@sec.Id">@sec.NameEn</option>
                                        }
                                    </select>
                                </div>
                                <!-- Designation -->
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Designation <span class="text-red-400">*</span></label>
                                    <select class="block w-full appearance-none pl-3.5 pr-10 py-2.5 border border-zinc-200 focus:border-black rounded-lg bg-white text-[13.5px] transition-colors outline-none text-zinc-900 font-body cursor-pointer" @bind="_employee.DesignationId">
                                        <option value="0">Select Designation</option>
                                        @foreach (var desig in _filteredDesignations)
                                        {
                                            <option value="@desig.Id">@desig.NameEn</option>
                                        }
                                    </select>
                                </div>
                                <!-- Line -->
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Line <span class="text-red-400">*</span></label>
                                    <select class="block w-full appearance-none pl-3.5 pr-10 py-2.5 border border-zinc-200 focus:border-black rounded-lg bg-white text-[13.5px] transition-colors outline-none text-zinc-900 font-body cursor-pointer" @bind="_employee.LineId">
                                        <option value="0">Select Line</option>
                                        @foreach (var line in _filteredLines)
                                        {
                                            <option value="@line.Id">@line.NameEn</option>
                                        }
                                    </select>
                                </div>
                                <!-- Shift -->
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Shift <span class="text-red-400">*</span></label>
                                    <select class="block w-full appearance-none pl-3.5 pr-10 py-2.5 border border-zinc-200 focus:border-black rounded-lg bg-white text-[13.5px] transition-colors outline-none text-zinc-900 font-body cursor-pointer" @bind="_employee.ShiftId">
                                        <option value="0">Select Shift</option>
                                        @foreach (var shift in _shifts)
                                        {
                                            <option value="@shift.Id">@shift.ShiftName</option>
                                        }
                                    </select>
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Joining Date</label>
                                    <DatePicker @bind-Value="_employee.JoiningDate" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Basic Salary</label>
                                    <InputNumber class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_employee.BasicSalary" placeholder="0.00" />
                                </div>
                                <div class="flex flex-col gap-1.5 justify-end">
                                    <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Status</label>
                                    <label class="inline-flex items-center gap-3 cursor-pointer py-2.5">
                                        <InputCheckbox class="w-4 h-4 rounded border-zinc-300 text-black focus:ring-black cursor-pointer" @bind-Value="_employee.IsActive" />
                                        <span class="text-[13.5px] font-medium text-zinc-700">Active Employee</span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Action Bar -->
                    <div class="p-4 sm:p-5 border-t border-zinc-100 bg-zinc-50 flex flex-col-reverse sm:flex-row justify-end gap-2.5">
                        <NavLink href="/hr/employees" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors text-center text-sm">Cancel</NavLink>
                        <button type="submit" class="py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-sm disabled:opacity-60 disabled:cursor-not-allowed" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save Employee</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        @if (_showToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✓</span>
                <span>@_toastMessage</span>
            </div>
        }
        @if (_showErrorToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✗</span>
                <span>@_errorMessage</span>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
