@page "/products"

<PageTitle>ERPHub - Projects Inventory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
    <!-- Header Block -->
    <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
        <div>
            <h2 class="text-[22px] font-extrabold text-black tracking-tight">Projects Inventory</h2>
            <p class="text-zinc-500 text-xs mt-0.5">Manage inventory data records with custom column selections and checkbox states.</p>
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
        <div class="flex-1 max-w-[320px] max-sm:max-w-none">
            <input type="text" class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors" placeholder="Search by name or SKU..." 
                   @bind="_searchQuery" @bind:event="oninput" />
        </div>
        
        <div class="flex gap-2 items-center max-sm:justify-between">
            <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Category:</span>
            <select class="border border-zinc-200 rounded-lg p-2 px-3 bg-white outline-none text-xs w-[180px] max-sm:w-[150px] cursor-pointer hover:bg-zinc-50 transition-colors" @bind="_categoryFilter">
                <option value="">All Categories</option>
                @foreach (var cat in _categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
    </div>

    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
        <div class="table-responsive-wrapper">
            <table class="w-full">
                <thead>
                    <tr>
                        <th>Header <button class="sort-btn" @onclick="() => {}">↕</button></th>
                        <th>SKU <button class="sort-btn" @onclick="() => {}">↕</button></th>
                        <th>Category <button class="sort-btn" @onclick="() => {}">↕</button></th>
                        <th>Unit Price <button class="sort-btn" @onclick="() => {}">↕</button></th>
                        <th>Status</th>
                        <th>Last Updated <button class="sort-btn" @onclick="() => {}">↕</button></th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredProducts.Any())
                    {
                        @foreach (var item in FilteredProducts)
                        {
                            <tr>
                                <td data-label="Header">
                                    <div>@item.Name</div>
                                    <div class="text-[11px] font-normal text-zinc-400 mt-0.5">@item.Description</div>
                                </td>
                                <td data-label="SKU"><code class="text-indigo-600 font-bold text-xs bg-indigo-50/50 px-2 py-1 rounded">@item.Sku</code></td>
                                <td data-label="Category">@item.Category</td>
                                <td data-label="Unit Price">@item.Price.ToString("C")</td>
                                <td data-label="Status">
                                    @if (item.Stock < 10)
                                    {
                                        <span class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full text-xs font-semibold border bg-white text-zinc-600 border-zinc-200">
                                            <span class="w-1.5 h-1.5 border-2 border-zinc-400 border-t-transparent rounded-full animate-spin"></span>
                                            In Process
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full text-xs font-semibold border bg-white text-green-700 border-green-200">
                                            <span class="text-green-600 font-bold text-[10px] mr-0.5">✓</span>
                                            Done
                                        </span>
                                    }
                                </td>
                                <td data-label="Last Updated">@item.LastUpdated.ToString("yyyy-MM-dd")</td>
                                <td data-label="Actions">
                                    <button class="btn-icon btn-icon-sm" title="Edit" @onclick="() => OpenEditModal(item)">
                                        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button class="btn-icon btn-icon-sm" title="Delete" @onclick="() => ConfirmDelete(item.Id)">
                                        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-8 text-muted">Data Not Available</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer">
            <div class="flex items-center gap-3">
                <span class="pagination-info">Rows per page:</span>
                <select class="page-size-select">
                    <option>10</option>
                    <option>25</option>
                    <option>50</option>
                </select>
            </div>
            <div class="pagination">
                <button class="pagination-btn" disabled>‹</button>
                <button class="pagination-btn active">1</button>
                <button class="pagination-btn" disabled>›</button>
            </div>
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
@if (_showFormModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4">
        <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[500px] overflow-hidden flex flex-col animate-fade-in">
            <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                <h3 class="font-bold text-sm text-zinc-950">@(_isEditMode ? "Modify Product Details" : "Create New Product Listing")</h3>
                <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseModal">&times;</button>
            </div>
            
            <EditForm Model="@_editingProduct" OnValidSubmit="SaveProduct">
                <DataAnnotationsValidator />
                
                <div class="p-5 overflow-y-auto max-h-[70vh] flex flex-col gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Product Name</label>
                        <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingProduct.Name" placeholder="e.g. MacBook Pro M3" />
                        <ValidationMessage For="@(() => _editingProduct.Name)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">SKU Identification</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingProduct.Sku" placeholder="e.g. MAC-M3-16" />
                            <ValidationMessage For="@(() => _editingProduct.Sku)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Category</label>
                            <select class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors cursor-pointer" @bind="_editingProduct.Category">
                                @foreach (var cat in _categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                            <ValidationMessage For="@(() => _editingProduct.Category)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Unit Price ($)</label>
                            <InputNumber class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingProduct.Price" />
                            <ValidationMessage For="@(() => _editingProduct.Price)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Stock Count</label>
                            <InputNumber class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingProduct.Stock" />
                            <ValidationMessage For="@(() => _editingProduct.Stock)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                    </div>

                    <!-- Date Picker -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Last Updated Date</label>
                        <input type="date" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind="_editingProduct.LastUpdated" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Item Description</label>
                        <InputTextArea class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingProduct.Description" rows="2" placeholder="Describe specifications..." />
                        <ValidationMessage For="@(() => _editingProduct.Description)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>
                </div>

                <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                    <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">Save Product</button>
                </div>
            </EditForm>
        </div>
    </div>
}
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
