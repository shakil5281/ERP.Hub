@page "/attendance/daily-summary"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ToastService Toast
@inject LookupDataService LookupData
@inject EmployeeFilterService EmployeeFilterSvc

<PageTitle>ERPHub - Daily Attendance Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <!-- Header with Export Buttons -->
        <div class="d-flex justify-content-between align-items-center mb-6" style="flex-wrap:wrap; gap:16px;">
            <div>
                <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Daily Attendance Summary</h2>
                <p class="text-zinc-500 text-xs mt-0.5 font-body">Overview of department attendance metrics, average working hours, and punctuality distributions.</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outlined btn-sm" disabled="@(_filteredSummaries.Count == 0 || _isExporting)" @onclick="ExportToExcel">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    Excel
                </button>
                <button class="btn btn-primary btn-sm" disabled="@(_filteredSummaries.Count == 0 || _isExporting)" @onclick="ExportToPdf">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/></svg>
                    PDF
                </button>
            </div>
        </div>

        <!-- Advanced Filter Section -->
        <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6 overflow-hidden">
            <!-- Filter Header with Toggle Button -->
            <div class="px-5 py-4 border-b border-zinc-100 flex justify-between items-center cursor-pointer select-none hover:bg-zinc-50 transition-colors" @onclick="ToggleFilterCollapse">
                <div class="flex items-center gap-2.5">
                    <svg class="w-4.5 h-4.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                    </svg>
                    <span class="text-sm font-semibold text-zinc-800 font-heading">Advanced Filters</span>
                    @if (HasActiveFilters)
                    {
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 animate-pulse-slow">
                            Active Filters
                        </span>
                    }
                </div>
                <svg class="w-4 h-4 text-zinc-400 transition-transform duration-200 @(_isFilterCollapsed ? "" : "transform rotate-180")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </div>

            <!-- Collapsible Filter Content -->
            <div class="collapse @(!_isFilterCollapsed ? "open" : "")">
                <div class="p-5 bg-zinc-50/50">
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                        <!-- Date Picker -->
                        <div>
                            <label class="form-label">Select Date</label>
                            <input type="date" class="form-control" @bind="_selectedDate" @bind:format="yyyy-MM-dd" />
                        </div>

                        <!-- Company Filter -->
                        <div>
                            <label class="form-label">Company</label>
                            <select class="form-control" @bind="_companyIdFilter">
                                <option value="0">All Companies</option>
                                @foreach (var c in _companies)
                                {
                                    <option value="@c.Id">@c.CompanyNameEn</option>
                                }
                            </select>
                        </div>

                        <!-- Department Filter -->
                        <div>
                            <label class="form-label">Department</label>
                            <select class="form-control" @bind="_departmentIdFilter">
                                <option value="0">All Departments</option>
                                @foreach (var d in _departmentsLookup)
                                {
                                    <option value="@d.Id">@d.NameEn</option>
                                }
                            </select>
                        </div>

                        <!-- Section Filter -->
                        <div>
                            <label class="form-label">Section</label>
                            <select class="form-control" @bind="_sectionIdFilter" disabled="@(_filteredSections.Count == 0)">
                                <option value="0">All Sections</option>
                                @foreach (var s in _filteredSections)
                                {
                                    <option value="@s.Id">@s.NameEn</option>
                                }
                            </select>
                        </div>

                        <!-- Line Filter -->
                        <div>
                            <label class="form-label">Line</label>
                            <select class="form-control" @bind="_lineIdFilter">
                                <option value="0">All Lines</option>
                                @foreach (var l in _lines)
                                {
                                    <option value="@l.Id">@l.NameEn</option>
                                }
                            </select>
                        </div>

                        <!-- Shift Filter -->
                        <div>
                            <label class="form-label">Shift</label>
                            <select class="form-control" @bind="_shiftIdFilter">
                                <option value="0">All Shifts</option>
                                @foreach (var sh in _shifts)
                                {
                                    <option value="@sh.Id">@sh.ShiftName</option>
                                }
                            </select>
                        </div>

                        <!-- Clear/Reset Buttons -->
                        <div class="flex justify-end gap-2.5 pt-2" style="align-self:end;">
                            <button class="btn btn-outlined btn-sm" @onclick="ResetFilters">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                                Reset
                            </button>
                            <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"/></svg>
                                Apply Filters
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="flex justify-center items-center py-16">
                <span class="spinner spinner-lg"></span>
            </div>
        }
        else if (_filteredSummaries.Count > 0)
        {
            @* Computed stats from filtered summaries *@
            var overallPresentRate = _filteredSummaries.Count > 0 ? _filteredSummaries.Average(d => d.PresentRate) : 0;
            var overallAvgHours = _filteredSummaries.Count > 0 ? _filteredSummaries.Average(d => d.AvgHours) : 0;
            var totalPunctual = _filteredSummaries.Sum(d => d.Present);
            var totalHeadcount = _filteredSummaries.Sum(d => d.Headcount);
            var totalLeaves = _filteredSummaries.Sum(d => d.Leave);
            var totalLateCount = _filteredSummaries.Sum(d => d.Late);
            var bestDept = _filteredSummaries.OrderByDescending(d => d.PresentRate).FirstOrDefault();
            var worstDept = _filteredSummaries.OrderBy(d => d.PresentRate).FirstOrDefault();

            @* Stats Highlight Cards *@
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                <div class="card stat-card hover:shadow-md transition-all duration-300" style="border-left: 4px solid var(--mud-palette-success);">
                    <div class="d-flex flex-column">
                        <span class="text-xs mud-secondary-text-color fw-bold text-uppercase font-heading" style="letter-spacing:0.05em;">Average Present Rate</span>
                        <h5 class="fw-extrabold mt-1 text-success font-heading" style="font-size:1.25rem;">@overallPresentRate.ToString("F1")%</h5>
                    </div>
                </div>
                <div class="card stat-card hover:shadow-md transition-all duration-300" style="border-left: 4px solid var(--mud-palette-info);">
                    <div class="d-flex flex-column">
                        <span class="text-xs mud-secondary-text-color fw-bold text-uppercase font-heading" style="letter-spacing:0.05em;">Average Working Hours</span>
                        <h5 class="fw-extrabold mt-1 text-info font-heading" style="font-size:1.25rem;">@overallAvgHours.ToString("F1") Hrs</h5>
                    </div>
                </div>
                <div class="card stat-card hover:shadow-md transition-all duration-300" style="border-left: 4px solid var(--mud-palette-primary);">
                    <div class="d-flex flex-column">
                        <span class="text-xs mud-secondary-text-color fw-bold text-uppercase font-heading" style="letter-spacing:0.05em;">Punctuality Index</span>
                        <h5 class="fw-extrabold mt-1 text-indigo-500 font-heading" style="font-size:1.25rem;">@totalPunctual / @totalHeadcount</h5>
                    </div>
                </div>
                <div class="card stat-card hover:shadow-md transition-all duration-300" style="border-left: 4px solid var(--mud-palette-secondary);">
                    <div class="d-flex flex-column">
                        <span class="text-xs mud-secondary-text-color fw-bold text-uppercase font-heading" style="letter-spacing:0.05em;">Leaves Registered</span>
                        <h5 class="fw-extrabold mt-1 text-zinc-600 font-heading" style="font-size:1.25rem;">@totalLeaves</h5>
                    </div>
                </div>
            </div>

            @* Dashboard Split Section *@
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
                <!-- Progress rates & Table column -->
                <div class="d-flex flex-column gap-6" style="grid-column:span 2;">
                    <!-- Progress Card -->
                    <div class="card p-6">
                        <span class="text-sm fw-bold mb-4 font-heading d-block">Department Attendance Breakdown</span>
                        <div class="d-flex flex-column" style="gap:16px;">
                            @foreach (var dept in _filteredSummaries.Take(5))
                            {
                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="text-sm fw-semibold text-zinc-700 font-body">@dept.Name (@dept.Headcount Staff)</span>
                                        <span class="text-sm fw-bold font-body">@dept.PresentRate%</span>
                                    </div>
                                    <div class="w-full bg-zinc-150 h-2 rounded-full overflow-hidden" style="border-radius:9999px;">
                                        <div class="h-full rounded-full @(dept.PresentRate >= 90 ? "bg-emerald-500" : dept.PresentRate >= 75 ? "bg-amber-500" : "bg-red-500")" style="width:@dept.PresentRate%;border-radius:9999px;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Enhanced Data Table -->
                    <div class="card" style="border-radius:12px; overflow:hidden;">
                        <div class="table-toolbar">
                            <span class="text-sm fw-bold font-heading">Department Summary Table</span>
                            <div class="flex-grow-1"></div>
                            <input type="text" class="form-control" @bind="_searchString" @bind:event="oninput" placeholder="Search department..." style="max-width:220px;" />
                        </div>
                        <div class="table-body">
                            <table class="w-full border-collapse" style="font-size:0.875rem;">
                                <thead>
                                    <tr>
                                        <th><button class="sort-btn" @onclick="() => {}">Department</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Headcount</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Present</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Absent</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Late</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Leave</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Present Rate</button></th>
                                        <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Avg Hours</button></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dept in _filteredSummaries.Where(FilterFunc))
                                    {
                                        <tr>
                                            <td data-label="Department"><span class="fw-semibold text-zinc-800 font-body">@dept.Name</span></td>
                                            <td style="text-align: center;" data-label="Headcount"><span class="font-mono">@dept.Headcount</span></td>
                                            <td style="text-align: center;" data-label="Present"><span class="font-mono fw-medium">@dept.Present</span></td>
                                            <td style="text-align: center;" data-label="Absent"><span class="font-mono">@dept.Absent</span></td>
                                            <td style="text-align: center;" data-label="Late"><span class="font-mono">@dept.Late</span></td>
                                            <td style="text-align: center;" data-label="Leave"><span class="font-mono">@dept.Leave</span></td>
                                            <td style="text-align: center;" data-label="Present Rate">
                                                <span class="fw-bold">@dept.PresentRate%</span>
                                            </td>
                                            <td style="text-align: center;" data-label="Avg Hours"><span class="font-mono">@dept.AvgHours Hrs</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (!_filteredSummaries.Where(FilterFunc).Any())
                        {
                            <div class="table-empty">
                                <span class="text-sm mud-secondary-text-color font-body">No matching departments found</span>
                            </div>
                        }
                        <div class="table-footer">
                            <div class="pagination">
                                <select class="page-size-select">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                </select>
                                <span class="pagination-info">1-@_filteredSummaries.Count of @_filteredSummaries.Count</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side Column (Charts & Quick Stats) -->
                <div class="d-flex flex-column gap-6">
                    <!-- Donut Chart Card -->
                    <div class="card p-6">
                        <span class="text-sm fw-bold mb-4 font-heading d-block">Attendance Distribution</span>
                        <div class="flex justify-center items-center py-2 flex-col">
                            <div class="d-flex flex-wrap justify-center gap-4 mb-3">
                                @for (int i = 0; i < _chartLabels.Length; i++)
                                {
                                    var colors = new[] { "bg-emerald-500", "bg-red-500", "bg-amber-500", "bg-indigo-500" };
                                    var idx = i < colors.Length ? i : 0;
                                    <div class="flex items-center gap-1.5">
                                        <span class="w-3 h-3 rounded-full @colors[idx] d-inline-block"></span>
                                        <span class="text-xs text-zinc-600">@_chartLabels[i]</span>
                                    </div>
                                }
                            </div>
                            <div class="flex gap-6">
                                @for (int i = 0; i < _chartLabels.Length; i++)
                                {
                                    var dataValues = _chartSeries.FirstOrDefault()?.Data ?? new double[] { 0, 0, 0, 0 };
                                    var val = i < dataValues.Length ? dataValues[i] : 0;
                                    <div class="d-flex flex-column items-center">
                                        <span class="fw-bold text-sm">@val</span>
                                        <span class="text-[10px] text-zinc-400">@_chartLabels[i]</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Quick Statistics Card -->
                    <div class="card p-6">
                        <span class="text-sm fw-bold mb-4 font-heading d-block">Quick Statistics</span>
                        <div class="d-flex flex-column" style="gap:12px;">
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <span class="text-sm mud-secondary-text-color font-body">Most Punctual Dept</span>
                                <span class="text-sm text-success fw-bold font-body">
                                    @(bestDept != null ? $"{bestDept.Name} ({bestDept.PresentRate}%)" : "N/A")
                                </span>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <span class="text-sm mud-secondary-text-color font-body">Lowest Present Rate</span>
                                <span class="text-sm text-error fw-bold font-body">
                                    @(worstDept != null ? $"{worstDept.Name} ({worstDept.PresentRate}%)" : "N/A")
                                </span>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <span class="text-sm mud-secondary-text-color font-body">Total Late Records</span>
                                <span class="text-sm text-warning fw-bold font-body">@totalLateCount Staff</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-sm mud-secondary-text-color font-body">Report Date</span>
                                <span class="text-sm fw-bold font-body">@_selectedDate.ToString("yyyy-MM-dd")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-xl p-8 text-center shadow-sm">
                <svg class="w-8 h-8 text-amber-500 mb-3 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                <span class="text-base fw-semibold text-zinc-700 font-heading d-block">No Attendance Records Found</span>
                <span class="text-sm text-zinc-400 mt-1 font-body d-block">Please select another date or change your active filters.</span>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _selectedDate = DateTime.Today;
    private bool _isLoading;
    private bool _isExporting;
    private bool _isFilterCollapsed = true;
    private string _searchString = "";

    // Filters
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _sectionIdFilter;
    private int _lineIdFilter;
    private int _shiftIdFilter;

    private bool HasActiveFilters => _companyIdFilter > 0 || _departmentIdFilter > 0 || _sectionIdFilter > 0 || _lineIdFilter > 0 || _shiftIdFilter > 0;

    // Lookups
    private List<Company> _companies = new();
    private List<Department> _departmentsLookup = new();
    private List<Section> _sections = new();
    private List<Section> _filteredSections = new();
    private List<Line> _lines = new();
    private List<ERPHub.Models.Shift> _shifts = new();
    private List<Employee> _employees = new();

    // Data Containers
    private List<AttendanceRecord> _allRecords = new();
    private List<DepartmentSummary> _filteredSummaries = new();

    // Donut Chart Data
    private List<ChartSeries<double>> _chartSeries = new()
    {
        new ChartSeries<double> { Name = "Attendance", Data = new double[] { 0, 0, 0, 0 } }
    };
    private string[] _chartLabels = { "Present", "Absent", "Late", "Leave" };

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadSummary();
    }

    private void ToggleFilterCollapse()
    {
        _isFilterCollapsed = !_isFilterCollapsed;
    }

    private async Task LoadLookupData()
    {
        try
        {
            var companiesTask = LookupData.GetCompaniesAsync();
            var departmentsTask = LookupData.GetDepartmentsAsync();
            var sectionsTask = LookupData.GetSectionsAsync();
            var linesTask = LookupData.GetLinesAsync();
            var shiftsTask = LookupData.GetShiftsAsync();
            var employeesTask = LookupData.GetEmployeesAsync();

            await Task.WhenAll(companiesTask, departmentsTask, sectionsTask, linesTask, shiftsTask, employeesTask);

            _companies = await companiesTask;
            _departmentsLookup = await departmentsTask;
            _sections = await sectionsTask;
            _lines = await linesTask;
            _shifts = await shiftsTask;
            _employees = await employeesTask;

            _filteredSections = _sections;
        }
        catch
        {
            // Fail silently - filters will remain empty
        }
    }

private async Task LoadSummary()
        {
            _isLoading = true;
            StateHasChanged();

            try
            {
                // Default to active employees only (exclude Resign, Left, Close)
                var url = $"{NavManager.BaseUri}api/attendance/records?fromDate={_selectedDate:yyyy-MM-dd}&toDate={_selectedDate:yyyy-MM-dd}&activeEmployees=true";
                _allRecords = await Http.GetFromJsonAsync<List<AttendanceRecord>>(url) ?? new();
                ApplyFilters();
            }
            catch
            {
                _allRecords = new();
                _filteredSummaries = new();
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }

    private void ApplyFilters()
    {
        // 1. Filter employees based on selected filters
        var criteria = new EmployeeFilterCriteria
        {
            CompanyIdFilter = _companyIdFilter,
            DepartmentIdFilter = _departmentIdFilter,
            SectionIdFilter = _sectionIdFilter,
            LineIdFilter = _lineIdFilter,
            ShiftIdFilter = _shiftIdFilter
        };

        var filteredEmployees = EmployeeFilterSvc.FilterEmployees(_employees, criteria);
        var employeeIds = filteredEmployees.Select(e => e.EmployeeId).ToHashSet(StringComparer.OrdinalIgnoreCase);

        // Group employees by Department
        var employeesByDept = filteredEmployees.GroupBy(e => e.DepartmentId).ToDictionary(g => g.Key, g => g.ToList());

        // 2. Filter attendance records to match the filtered employees
        var filteredRecords = _allRecords.Where(r => employeeIds.Contains(r.EmployeeId)).ToList();
        var recordsByEmployee = filteredRecords.ToDictionary(r => r.EmployeeId, r => r, StringComparer.OrdinalIgnoreCase);

        // 3. Generate summaries for each department that has active headcount
        var summaries = new List<DepartmentSummary>();
        foreach (var dept in _departmentsLookup)
        {
            if (!employeesByDept.TryGetValue(dept.Id, out var deptEmployees))
            {
                continue; // skip departments with 0 headcount under current filters
            }

            int headcount = deptEmployees.Count;
            int present = 0;
            int absent = 0;
            int late = 0;
            int leave = 0;
            double totalWorkedMinutes = 0;
            int workedCount = 0;

            foreach (var emp in deptEmployees)
            {
                if (recordsByEmployee.TryGetValue(emp.EmployeeId, out var rec))
                {
                    if (AttendanceAnalytics.IsPresent(rec.AttendanceStatus))
                    {
                        present++;
                    }
                    if (AttendanceAnalytics.IsAbsent(rec.AttendanceStatus))
                    {
                        absent++;
                    }
                    if (AttendanceAnalytics.IsLate(rec.AttendanceStatus))
                    {
                        late++;
                    }
                    if (AttendanceAnalytics.IsLeave(rec.AttendanceStatus))
                    {
                        leave++;
                    }

                    if (rec.WorkedMinutes > 0)
                    {
                        totalWorkedMinutes += rec.WorkedMinutes;
                        workedCount++;
                    }
                }
                else
                {
                    absent++; // No record for the day defaults to absent
                }
            }

            double presentRate = headcount > 0 ? Math.Round((double)present / headcount * 100, 1) : 0;
            double avgHours = workedCount > 0 ? Math.Round((totalWorkedMinutes / workedCount) / 60.0, 1) : 0;

            summaries.Add(new DepartmentSummary(
                dept.NameEn, headcount, present, absent, late, leave, presentRate, avgHours));
        }

        _filteredSummaries = summaries.OrderByDescending(d => d.PresentRate).ToList();

        // 4. Update Donut Chart
        var presentCount = _filteredSummaries.Sum(s => s.Present);
        var absentCount = _filteredSummaries.Sum(s => s.Absent);
        var lateCount = _filteredSummaries.Sum(s => s.Late);
        var leaveCount = _filteredSummaries.Sum(s => s.Leave);

        _chartSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "Attendance",
                Data = new double[] { presentCount, absentCount, lateCount, leaveCount }
            }
        };
    }

    private async Task ResetFilters()
    {
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _sectionIdFilter = 0;
        _lineIdFilter = 0;
        _shiftIdFilter = 0;
        _filteredSections = _sections;
        await LoadSummary();
    }

    private async Task OnDateChanged(DateTime? newDate)
    {
        if (newDate.HasValue)
        {
            _selectedDate = newDate.Value;
            await LoadSummary();
        }
    }

    private void OnCompanyFilterChanged(int companyId)
    {
        _companyIdFilter = companyId;
    }

    private void OnDepartmentFilterChanged(int deptId)
    {
        _departmentIdFilter = deptId;
        _sectionIdFilter = 0; // Reset section selection when department changes
        if (deptId == 0)
        {
            _filteredSections = _sections;
        }
        else
        {
            _filteredSections = _sections.Where(s => s.DepartmentId == deptId).ToList();
        }
    }

    private void OnSectionFilterChanged(int sectionId)
    {
        _sectionIdFilter = sectionId;
    }

    private void OnLineFilterChanged(int lineId)
    {
        _lineIdFilter = lineId;
    }

    private void OnShiftFilterChanged(int shiftId)
    {
        _shiftIdFilter = shiftId;
    }

    private bool FilterFunc(DepartmentSummary element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        return element.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task ExportToExcel()
    {
        if (_filteredSummaries.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var bytes = await ExportService.ExportToExcelAsync(_filteredSummaries, "Department Summary", $"Daily Attendance Summary - {_selectedDate:yyyy-MM-dd}", columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendanceSummary_{_selectedDate:yyyyMMdd}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            await Toast.ShowSuccessAsync("Excel exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_filteredSummaries.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var bytes = await ExportService.ExportToPdfAsync(_filteredSummaries, $"Daily Attendance Summary - {_selectedDate:yyyy-MM-dd}", columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendanceSummary_{_selectedDate:yyyyMMdd}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            await Toast.ShowSuccessAsync("PDF exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<DepartmentSummary, object>> GetExportColumns() => new()
    {
        ["Department"] = d => d.Name,
        ["Headcount"] = d => d.Headcount,
        ["Present"] = d => d.Present,
        ["Absent"] = d => d.Absent,
        ["Late"] = d => d.Late,
        ["Leave"] = d => d.Leave,
        ["Present Rate (%)"] = d => d.PresentRate,
        ["Avg Hours"] = d => d.AvgHours
    };

    public record DepartmentSummary(string Name, int Headcount, int Present, int Absent, int Late, int Leave, double PresentRate, double AvgHours);
}
