@page "/attendance/daily-summary"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>ERPHub - Daily Attendance Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-6" style="flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Daily Attendance Summary</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">Overview of department attendance metrics, average hours, and punctuality indexes.</MudText>
            </div>
            <div class="d-flex" style="gap:8px;">
                <MudDatePicker Label="Date"
                               Date="@_selectedDate"
                               DateChanged="@(d => { if (d.HasValue) _selectedDate = d.Value; })"
                               Editable="true"
                               Placeholder="Select Date"
                               DateFormat="yyyy-MM-dd"
                               dense="true"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Disabled="@_isLoading" @onclick="LoadSummary">Load</MudButton>
            </div>
        </div>

        @if (_isLoading)
        {
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Loading summary...</MudText>
        }
        else if (_departments.Count > 0)
        {
            @* Stats Highlight Cards *@
            var overallPresentRate = _departments.Average(d => d.PresentRate);
            var overallAvgHours = _departments.Average(d => d.AvgHours);
            var totalPunctual = _departments.Sum(d => d.Present);
            var totalHeadcount = _departments.Sum(d => d.Headcount);
            var totalLeaves = _departments.Sum(d => d.Leave);
            var bestDept = _departments.OrderByDescending(d => d.PresentRate).First();
            var worstDept = _departments.OrderBy(d => d.PresentRate).First();
            var totalLateMins = _departments.Sum(d => d.Late) * 15; // estimate

            <MudGrid Spacing="6" Class="mb-6">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-6" Style="border-radius:8px;">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase" Style="letter-spacing:0.05em;">Average Present Rate</MudText>
                            <MudText Typo="Typo.h6" Class="fw-semibold mt-1">@overallPresentRate.ToString("F1")%</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-6" Style="border-radius:8px;">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase" Style="letter-spacing:0.05em;">Average Working Hours</MudText>
                            <MudText Typo="Typo.h6" Class="fw-semibold mt-1">@overallAvgHours.ToString("F1") Hrs</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-6" Style="border-radius:8px;">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase" Style="letter-spacing:0.05em;">Total Punctual</MudText>
                            <MudText Typo="Typo.h6" Class="text-success fw-semibold mt-1">@totalPunctual / @totalHeadcount</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-6" Style="border-radius:8px;">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase" Style="letter-spacing:0.05em;">Leaves Registered</MudText>
                            <MudText Typo="Typo.h6" Class="text-info fw-semibold mt-1">@totalLeaves</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Department Breakdown *@
            <MudGrid Spacing="6" Class="mb-6">
                <MudItem xs="12" lg="8">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius:8px;">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold mb-4">Department Present Rates</MudText>
                        <div class="d-flex flex-column" style="gap:16px;">
                            @foreach (var dept in _departments)
                            {
                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <MudText Typo="Typo.body2" Class="fw-semibold">@dept.Name (@dept.Headcount Staff)</MudText>
                                        <MudText Typo="Typo.body2" Class="fw-semibold">@dept.PresentRate%</MudText>
                                    </div>
                                    <MudProgressLinear Value="@dept.PresentRate" Color="Color.Success" Size="Size.Small" Style="border-radius:9999px;" />
                                </div>
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                @* Quick Statistics *@
                <MudItem xs="12" lg="4">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius:8px;">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold mb-4">Quick Statistics</MudText>
                        <div class="d-flex flex-column" style="gap:12px;">
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color">Most Punctual Department</MudText>
                                <MudText Typo="Typo.body2" Class="text-success fw-bold">@bestDept.Name (@bestDept.PresentRate%)</MudText>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color">Lowest Present Rate</MudText>
                                <MudText Typo="Typo.body2" Class="text-error fw-bold">@worstDept.Name (@worstDept.PresentRate%)</MudText>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color">Total Late (est. mins)</MudText>
                                <MudText Typo="Typo.body2" Class="text-warning fw-bold">@totalLateMins Mins</MudText>
                            </div>
                            <div class="d-flex justify-content-between">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color">Date</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold">@_selectedDate.ToString("yyyy-MM-dd")</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Department Table *@
            <MudPaper Elevation="0" Outlined="true" Style="border-radius:8px; overflow:hidden;">
                <MudTable Items="@_departments" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Elevation="0" Outlined="false">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Name)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Headcount)">Total Headcount</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Present)">Present Count</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Absent)">Absent Count</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Late)">Late Count</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Leave)">Leave Count</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.PresentRate)">Present Rate (%)</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.AvgHours)">Avg Hours</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Department">@context.Name</MudTd>
                        <MudTd DataLabel="Total Headcount">@context.Headcount</MudTd>
                        <MudTd DataLabel="Present Count">@context.Present</MudTd>
                        <MudTd DataLabel="Absent Count">@context.Absent</MudTd>
                        <MudTd DataLabel="Late Count">@context.Late</MudTd>
                        <MudTd DataLabel="Leave Count">@context.Leave</MudTd>
                        <MudTd DataLabel="Present Rate (%)">@context.PresentRate%</MudTd>
                        <MudTd DataLabel="Avg Hours">@context.AvgHours Hrs</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _selectedDate = DateTime.Today;
    private bool _isLoading;
    private List<DepartmentSummary> _departments = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSummary();
    }

    private async Task LoadSummary()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var url = $"{NavManager.BaseUri}api/attendance/summary?date={_selectedDate:yyyy-MM-dd}";
            _departments = await Http.GetFromJsonAsync<List<DepartmentSummary>>(url) ?? new();
        }
        catch
        {
            _departments = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    public record DepartmentSummary(string Name, int Headcount, int Present, int Absent, int Late, int Leave, double PresentRate, double AvgHours);
}