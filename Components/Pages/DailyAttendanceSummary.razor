@page "/attendance/daily-summary"
@using ERPHub.Components.Common

<PageTitle>ERPHub - Daily Attendance Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight">Daily Attendance Summary</h2>
                    <p class="text-zinc-500 text-sm mt-0.5">Overview of department attendance metrics, average hours, and punctuality indexes.</p>
                </div>
                <div class="flex gap-2">
                    <button class="inline-flex items-center py-1.5 px-3 border border-zinc-200 rounded-md bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors cursor-pointer">
                        Filter Month
                    </button>
                    <button class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">
                        Export Report
                    </button>
                </div>
            </div>

            <!-- Stats Highlight Cards -->
            <div class="grid grid-cols-4 gap-6 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Average Present Rate</span>
                        <span class="text-sm font-semibold text-zinc-955">92.4%</span>
                    </div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Average Working Hours</span>
                        <span class="text-sm font-semibold text-zinc-955">8.2 Hrs</span>
                    </div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Total Punctual</span>
                        <span class="text-sm font-semibold text-emerald-600">94 / 102</span>
                    </div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[11.5px] text-zinc-500 font-bold uppercase tracking-wider mb-1">Leaves Registered</span>
                        <span class="text-sm font-semibold text-indigo-500">4 Approved</span>
                    </div>
                </div>
            </div>

            <!-- Department breakdown visual grid -->
            <div class="grid grid-cols-3 gap-6 mb-6 max-xl:grid-cols-1">
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm col-span-2 max-xl:col-span-1">
                    <h3 class="text-sm font-bold text-zinc-950 mb-5">Department Present Rates</h3>
                    <div class="flex flex-col gap-4">
                        @foreach (var dept in _departments)
                        {
                            <div>
                                <div class="flex justify-between text-xs font-semibold text-zinc-700 mb-1">
                                    <span>@dept.Name (@dept.Headcount Staff)</span>
                                    <span>@dept.PresentRate%</span>
                                </div>
                                <div class="w-full bg-zinc-150 h-2.5 rounded-full overflow-hidden">
                                    <div class="bg-emerald-500 h-full rounded-full transition-all duration-500" style="width: @(dept.PresentRate)%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                
                <!-- Summary statistics cards -->
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm col-span-1">
                    <h3 class="text-sm font-bold text-zinc-950 mb-4">Quick Statistics</h3>
                    <div class="flex flex-col gap-3 text-sm">
                        <div class="flex justify-between pb-2.5 border-b border-zinc-100">
                            <span class="text-zinc-500 font-medium">Most Punctual Department</span>
                            <span class="font-bold text-emerald-600">Finance (100%)</span>
                        </div>
                        <div class="flex justify-between pb-2.5 border-b border-zinc-100">
                            <span class="text-zinc-500 font-medium">Lowest Present Rate</span>
                            <span class="font-bold text-red-500">Production (82%)</span>
                        </div>
                        <div class="flex justify-between pb-2.5 border-b border-zinc-100">
                            <span class="text-zinc-500 font-medium">Total Late Minutes</span>
                            <span class="font-bold text-amber-500">180 Mins</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-zinc-500 font-medium">Auto-Mail Notifications</span>
                            <span class="font-bold text-zinc-700">8 Sent</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed table list -->
            <DataTable TItem="DepartmentSummary" Items="_departments">
                <TabsContent>
                    <button type="button" class="py-1.5 px-3 rounded-full text-xs font-semibold text-zinc-950 bg-white border border-zinc-200 shadow-sm cursor-pointer inline-flex items-center gap-1.5 transition-colors">Summary Directory</button>
                </TabsContent>
                <HeaderTemplate>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Department</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Total Headcount</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Present Count</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Absent Count</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Late Count</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Present Rate (%)</th>
                </HeaderTemplate>
                <RowTemplate Context="dept">
                    <td class="p-2.5 px-4 text-zinc-900 font-bold">@dept.Name</td>
                    <td class="p-2.5 px-4 text-zinc-800 font-semibold">@dept.Headcount</td>
                    <td class="p-2.5 px-4 text-emerald-600 font-bold">@dept.Present</td>
                    <td class="p-2.5 px-4 text-red-500 font-bold">@dept.Absent</td>
                    <td class="p-2.5 px-4 text-amber-500 font-bold">@dept.Late</td>
                    <td class="p-2.5 px-4 text-zinc-800 font-bold">@dept.PresentRate%</td>
                </RowTemplate>
            </DataTable>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<DepartmentSummary> _departments = new()
    {
        new("IT & Development", 25, 23, 1, 1, 92),
        new("Human Resources", 8, 7, 0, 1, 87.5),
        new("Finance & Accounts", 12, 12, 0, 0, 100),
        new("Production", 60, 49, 5, 6, 81.6),
        new("Marketing & Sales", 15, 11, 0, 0, 73.3)
    };

    public record DepartmentSummary(string Name, int Headcount, int Present, int Absent, int Late, double PresentRate);
}
