@page "/attendance/daily-summary"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>ERPHub - Daily Attendance Summary</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <!-- Header with Export Buttons -->
        <div class="d-flex justify-content-between align-items-center mb-6" style="flex-wrap:wrap; gap:16px;">
            <div>
                <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Daily Attendance Summary</h2>
                <p class="text-zinc-500 text-xs mt-0.5 font-body">Overview of department attendance metrics, average working hours, and punctuality distributions.</p>
            </div>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           Disabled="@(_filteredSummaries.Count == 0 || _isExporting)"
                           OnClick="ExportToExcel"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           Size="Size.Small">
                    Excel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(_filteredSummaries.Count == 0 || _isExporting)"
                           OnClick="ExportToPdf"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Size="Size.Small">
                    PDF
                </MudButton>
            </div>
        </div>

        <!-- Advanced Filter Section -->
        <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6 overflow-hidden">
            <!-- Filter Header with Toggle Button -->
            <div class="px-5 py-4 border-b border-zinc-100 flex justify-between items-center cursor-pointer select-none hover:bg-zinc-50 transition-colors" @onclick="ToggleFilterCollapse">
                <div class="flex items-center gap-2.5">
                    <svg class="w-4.5 h-4.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                    </svg>
                    <span class="text-sm font-semibold text-zinc-800 font-heading">Advanced Filters</span>
                    @if (HasActiveFilters)
                    {
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 animate-pulse-slow">
                            Active Filters
                        </span>
                    }
                </div>
                <svg class="w-4 h-4 text-zinc-400 transition-transform duration-200 @(_isFilterCollapsed ? "" : "transform rotate-180")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </div>

            <!-- Collapsible Filter Content -->
            <MudCollapse Expanded="!_isFilterCollapsed">
                <div class="p-5 bg-zinc-50/50">
                    <MudGrid Spacing="3">
                        <!-- Date Picker -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudDatePicker Label="Select Date"
                                           Date="@_selectedDate"
                                           DateChanged="OnDateChanged"
                                           Editable="true"
                                           Placeholder="Select Date"
                                           DateFormat="yyyy-MM-dd"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense" />
                        </MudItem>

                        <!-- Company Filter -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudSelect T="int" Value="_companyIdFilter" ValueChanged="OnCompanyFilterChanged" Label="Company" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                <MudSelectItem Value="0">All Companies</MudSelectItem>
                                @foreach (var c in _companies)
                                {
                                    <MudSelectItem Value="@c.Id">@c.CompanyNameEn</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Department Filter -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudSelect T="int" Value="_departmentIdFilter" ValueChanged="OnDepartmentFilterChanged" Label="Department" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                <MudSelectItem Value="0">All Departments</MudSelectItem>
                                @foreach (var d in _departmentsLookup)
                                {
                                    <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Section Filter -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudSelect T="int" Value="_sectionIdFilter" ValueChanged="OnSectionFilterChanged" Label="Section" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Disabled="@(_filteredSections.Count == 0)">
                                <MudSelectItem Value="0">All Sections</MudSelectItem>
                                @foreach (var s in _filteredSections)
                                {
                                    <MudSelectItem Value="@s.Id">@s.NameEn</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Line Filter -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudSelect T="int" Value="_lineIdFilter" ValueChanged="OnLineFilterChanged" Label="Line" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                <MudSelectItem Value="0">All Lines</MudSelectItem>
                                @foreach (var l in _lines)
                                {
                                    <MudSelectItem Value="@l.Id">@l.NameEn</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Shift Filter -->
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudSelect T="int" Value="_shiftIdFilter" ValueChanged="OnShiftFilterChanged" Label="Shift" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                <MudSelectItem Value="0">All Shifts</MudSelectItem>
                                @foreach (var sh in _shifts)
                                {
                                    <MudSelectItem Value="@sh.Id">@sh.ShiftName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <!-- Clear/Reset Buttons -->
                        <MudItem xs="12" Class="flex justify-end gap-2.5 pt-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh">Reset</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.FilterList">Apply Filters</MudButton>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudCollapse>
        </div>

        @if (_isLoading)
        {
            <div class="flex justify-center items-center py-16">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_filteredSummaries.Count > 0)
        {
            @* Computed stats from filtered summaries *@
            var overallPresentRate = _filteredSummaries.Count > 0 ? _filteredSummaries.Average(d => d.PresentRate) : 0;
            var overallAvgHours = _filteredSummaries.Count > 0 ? _filteredSummaries.Average(d => d.AvgHours) : 0;
            var totalPunctual = _filteredSummaries.Sum(d => d.Present);
            var totalHeadcount = _filteredSummaries.Sum(d => d.Headcount);
            var totalLeaves = _filteredSummaries.Sum(d => d.Leave);
            var totalLateCount = _filteredSummaries.Sum(d => d.Late);
            var bestDept = _filteredSummaries.OrderByDescending(d => d.PresentRate).FirstOrDefault();
            var worstDept = _filteredSummaries.OrderBy(d => d.PresentRate).FirstOrDefault();

            @* Stats Highlight Cards *@
            <MudGrid Spacing="6" Class="mb-6">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-5 hover:shadow-md transition-all duration-300" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines); border-left: 4px solid var(--mud-palette-success);">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase font-heading" Style="letter-spacing:0.05em;">Average Present Rate</MudText>
                            <MudText Typo="Typo.h5" Class="fw-extrabold mt-1 text-success font-heading">@overallPresentRate.ToString("F1")%</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-5 hover:shadow-md transition-all duration-300" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines); border-left: 4px solid var(--mud-palette-info);">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase font-heading" Style="letter-spacing:0.05em;">Average Working Hours</MudText>
                            <MudText Typo="Typo.h5" Class="fw-extrabold mt-1 text-info font-heading">@overallAvgHours.ToString("F1") Hrs</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-5 hover:shadow-md transition-all duration-300" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines); border-left: 4px solid var(--mud-palette-primary);">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase font-heading" Style="letter-spacing:0.05em;">Punctuality Index</MudText>
                            <MudText Typo="Typo.h5" Class="fw-extrabold mt-1 text-primary font-heading">@totalPunctual / @totalHeadcount</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Outlined="true" Class="d-flex align-items-center justify-content-between pa-5 hover:shadow-md transition-all duration-300" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines); border-left: 4px solid var(--mud-palette-secondary);">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase font-heading" Style="letter-spacing:0.05em;">Leaves Registered</MudText>
                            <MudText Typo="Typo.h5" Class="fw-extrabold mt-1 text-secondary font-heading">@totalLeaves</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Dashboard Split Section *@
            <MudGrid Spacing="6" Class="mb-6">
                <!-- Progress rates & Table column -->
                <MudItem xs="12" lg="8" Class="d-flex flex-column gap-6">
                    <!-- Progress Card -->
                    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines);">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold mb-4 font-heading">Department Attendance Breakdown</MudText>
                        <div class="d-flex flex-column" style="gap:16px;">
                            @foreach (var dept in _filteredSummaries.Take(5))
                            {
                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <MudText Typo="Typo.body2" Class="fw-semibold text-zinc-700 font-body">@dept.Name (@dept.Headcount Staff)</MudText>
                                        <MudText Typo="Typo.body2" Class="fw-bold font-body">@dept.PresentRate%</MudText>
                                    </div>
                                    <MudProgressLinear Value="@dept.PresentRate" Color="@(dept.PresentRate >= 90 ? Color.Success : dept.PresentRate >= 75 ? Color.Warning : Color.Error)" Size="Size.Small" Style="border-radius:9999px;" />
                                </div>
                            }
                        </div>
                    </MudPaper>

                    <!-- Enhanced Data Table -->
                    <MudPaper Elevation="0" Outlined="true" Style="border-radius:12px; overflow:hidden; border: 1px solid var(--mud-palette-lines);">
                        <MudTable Items="@_filteredSummaries" Bordered="true" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Elevation="0" Outlined="false" Filter="new Func<DepartmentSummary, bool>(FilterFunc)">
                            <ToolBarContent>
                                <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Department Summary Table</MudText>
                                <MudSpacer />
                                <MudTextField @bind-Value="_searchString"
                                              Placeholder="Search department..."
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Search"
                                              IconSize="Size.Small"
                                              Class="mt-0"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Clearable="true" />
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Name)">Department</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Headcount)">Headcount</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Present)">Present</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Absent)">Absent</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Late)">Late</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.Leave)">Leave</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.PresentRate)">Present Rate</MudTableSortLabel></MudTh>
                                <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<DepartmentSummary, object>(x => x.AvgHours)">Avg Hours</MudTableSortLabel></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Department"><span class="fw-semibold text-zinc-800 font-body">@context.Name</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Headcount"><span class="font-mono">@context.Headcount</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Present"><span class="font-mono fw-medium">@context.Present</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Absent"><span class="font-mono">@context.Absent</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Late"><span class="font-mono">@context.Late</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Leave"><span class="font-mono">@context.Leave</span></MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Present Rate">
                                    <span class="fw-bold">
                                        @context.PresentRate%
                                    </span>
                                </MudTd>
                                <MudTd Style="text-align: center;" DataLabel="Avg Hours"><span class="font-mono">@context.AvgHours Hrs</span></MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                            </PagerContent>
                            <NoRecordsContent>
                                <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8 font-body">No matching departments found</MudText>
                            </NoRecordsContent>
                        </MudTable>
                    </MudPaper>
                </MudItem>

                <!-- Right Side Column (Charts & Quick Stats) -->
                <MudItem xs="12" lg="4" Class="d-flex flex-column gap-6">
                    <!-- Donut Chart Card -->
                    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines);">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold mb-4 font-heading">Attendance Distribution</MudText>
                        <div class="flex justify-center items-center py-2">
                            <MudChart T="double" ChartType="ChartType.Donut" Width="100%" Height="180px" ChartSeries="@_chartSeries" ChartLabels="@_chartLabels" />
                        </div>
                    </MudPaper>

                    <!-- Quick Statistics Card -->
                    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius:12px; border: 1px solid var(--mud-palette-lines);">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold mb-4 font-heading">Quick Statistics</MudText>
                        <div class="d-flex flex-column" style="gap:12px;">
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color font-body">Most Punctual Dept</MudText>
                                <MudText Typo="Typo.body2" Class="text-success fw-bold font-body">
                                    @(bestDept != null ? $"{bestDept.Name} ({bestDept.PresentRate}%)" : "N/A")
                                </MudText>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color font-body">Lowest Present Rate</MudText>
                                <MudText Typo="Typo.body2" Class="text-error fw-bold font-body">
                                    @(worstDept != null ? $"{worstDept.Name} ({worstDept.PresentRate}%)" : "N/A")
                                </MudText>
                            </div>
                            <div class="d-flex justify-content-between pb-2" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color font-body">Total Late Records</MudText>
                                <MudText Typo="Typo.body2" Class="text-warning fw-bold font-body">@totalLateCount Staff</MudText>
                            </div>
                            <div class="d-flex justify-content-between">
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color font-body">Report Date</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold font-body">@_selectedDate.ToString("yyyy-MM-dd")</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-xl p-8 text-center shadow-sm">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
                <MudText Typo="Typo.body1" Class="fw-semibold text-zinc-700 font-heading">No Attendance Records Found</MudText>
                <MudText Typo="Typo.body2" Class="text-zinc-400 mt-1 font-body">Please select another date or change your active filters.</MudText>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _selectedDate = DateTime.Today;
    private bool _isLoading;
    private bool _isExporting;
    private bool _isFilterCollapsed = true;
    private string _searchString = "";

    // Filters
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _sectionIdFilter;
    private int _lineIdFilter;
    private int _shiftIdFilter;

    private bool HasActiveFilters => _companyIdFilter > 0 || _departmentIdFilter > 0 || _sectionIdFilter > 0 || _lineIdFilter > 0 || _shiftIdFilter > 0;

    // Lookups
    private List<Company> _companies = new();
    private List<Department> _departmentsLookup = new();
    private List<Section> _sections = new();
    private List<Section> _filteredSections = new();
    private List<Line> _lines = new();
    private List<ERPHub.Models.Shift> _shifts = new();
    private List<Employee> _employees = new();

    // Data Containers
    private List<AttendanceRecord> _allRecords = new();
    private List<DepartmentSummary> _filteredSummaries = new();

    // Donut Chart Data
    private List<ChartSeries<double>> _chartSeries = new()
    {
        new ChartSeries<double> { Name = "Attendance", Data = new double[] { 0, 0, 0, 0 } }
    };
    private string[] _chartLabels = { "Present", "Absent", "Late", "Leave" };

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadSummary();
    }

    private void ToggleFilterCollapse()
    {
        _isFilterCollapsed = !_isFilterCollapsed;
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var companiesTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var sectionsTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var linesTask = Http.GetFromJsonAsync<List<Line>>($"{baseUri}api/lines");
            var shiftsTask = Http.GetFromJsonAsync<List<ERPHub.Models.Shift>>($"{baseUri}api/shifts");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(companiesTask, departmentsTask, sectionsTask, linesTask, shiftsTask, employeesTask);

            _companies = await companiesTask ?? new();
            _departmentsLookup = await departmentsTask ?? new();
            _sections = await sectionsTask ?? new();
            _lines = await linesTask ?? new();
            _shifts = await shiftsTask ?? new();
            _employees = await employeesTask ?? new();

            _filteredSections = _sections;
        }
        catch
        {
            // Fail silently - filters will remain empty
        }
    }

    private async Task LoadSummary()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var url = $"{NavManager.BaseUri}api/attendance/records?fromDate={_selectedDate:yyyy-MM-dd}&toDate={_selectedDate:yyyy-MM-dd}";
            _allRecords = await Http.GetFromJsonAsync<List<AttendanceRecord>>(url) ?? new();
            ApplyFilters();
        }
        catch
        {
            _allRecords = new();
            _filteredSummaries = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        // 1. Filter employees based on selected filters
        var filteredEmployees = _employees.Where(e =>
            (_companyIdFilter == 0 || e.CompanyId == _companyIdFilter) &&
            (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
            (_sectionIdFilter == 0 || e.SectionId == _sectionIdFilter) &&
            (_shiftIdFilter == 0 || e.ShiftId == _shiftIdFilter) &&
            (_lineIdFilter == 0 || e.LineId == _lineIdFilter)
        ).ToList();

        var employeeIds = filteredEmployees.Select(e => e.EmployeeId).ToHashSet(StringComparer.OrdinalIgnoreCase);

        // Group employees by Department
        var employeesByDept = filteredEmployees.GroupBy(e => e.DepartmentId).ToDictionary(g => g.Key, g => g.ToList());

        // 2. Filter attendance records to match the filtered employees
        var filteredRecords = _allRecords.Where(r => employeeIds.Contains(r.EmployeeId)).ToList();
        var recordsByEmployee = filteredRecords.ToDictionary(r => r.EmployeeId, r => r, StringComparer.OrdinalIgnoreCase);

        // 3. Generate summaries for each department that has active headcount
        var summaries = new List<DepartmentSummary>();
        foreach (var dept in _departmentsLookup)
        {
            if (!employeesByDept.TryGetValue(dept.Id, out var deptEmployees))
            {
                continue; // skip departments with 0 headcount under current filters
            }

            int headcount = deptEmployees.Count;
            int present = 0;
            int absent = 0;
            int late = 0;
            int leave = 0;
            double totalWorkedMinutes = 0;
            int workedCount = 0;

            foreach (var emp in deptEmployees)
            {
                if (recordsByEmployee.TryGetValue(emp.EmployeeId, out var rec))
                {
                    if (rec.AttendanceStatus is "Present" or "Present + Overtime" or "Half Day" or "Holiday Worked" or "Weekly Off Worked" or "Missing In Punch" or "Missing Out Punch")
                    {
                        present++;
                    }
                    else if (rec.AttendanceStatus == "Absent")
                    {
                        absent++;
                    }
                    else if (rec.AttendanceStatus is "Late" or "Early Exit")
                    {
                        present++;
                        late++;
                    }
                    else if (rec.AttendanceStatus is "Leave" or "Holiday" or "Weekly Off")
                    {
                        leave++;
                    }

                    if (rec.WorkedMinutes > 0)
                    {
                        totalWorkedMinutes += rec.WorkedMinutes;
                        workedCount++;
                    }
                }
                else
                {
                    absent++; // No record for the day defaults to absent
                }
            }

            double presentRate = headcount > 0 ? Math.Round((double)present / headcount * 100, 1) : 0;
            double avgHours = workedCount > 0 ? Math.Round((totalWorkedMinutes / workedCount) / 60.0, 1) : 0;

            summaries.Add(new DepartmentSummary(
                dept.NameEn, headcount, present, absent, late, leave, presentRate, avgHours));
        }

        _filteredSummaries = summaries.OrderByDescending(d => d.PresentRate).ToList();

        // 4. Update Donut Chart
        var presentCount = _filteredSummaries.Sum(s => s.Present);
        var absentCount = _filteredSummaries.Sum(s => s.Absent);
        var lateCount = _filteredSummaries.Sum(s => s.Late);
        var leaveCount = _filteredSummaries.Sum(s => s.Leave);

        _chartSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "Attendance",
                Data = new double[] { presentCount, absentCount, lateCount, leaveCount }
            }
        };
    }

    private async Task ResetFilters()
    {
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _sectionIdFilter = 0;
        _lineIdFilter = 0;
        _shiftIdFilter = 0;
        _filteredSections = _sections;
        await LoadSummary();
    }

    private async Task OnDateChanged(DateTime? newDate)
    {
        if (newDate.HasValue)
        {
            _selectedDate = newDate.Value;
            await LoadSummary();
        }
    }

    private void OnCompanyFilterChanged(int companyId)
    {
        _companyIdFilter = companyId;
    }

    private void OnDepartmentFilterChanged(int deptId)
    {
        _departmentIdFilter = deptId;
        _sectionIdFilter = 0; // Reset section selection when department changes
        if (deptId == 0)
        {
            _filteredSections = _sections;
        }
        else
        {
            _filteredSections = _sections.Where(s => s.DepartmentId == deptId).ToList();
        }
    }

    private void OnSectionFilterChanged(int sectionId)
    {
        _sectionIdFilter = sectionId;
    }

    private void OnLineFilterChanged(int lineId)
    {
        _lineIdFilter = lineId;
    }

    private void OnShiftFilterChanged(int shiftId)
    {
        _shiftIdFilter = shiftId;
    }

    private bool FilterFunc(DepartmentSummary element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        return element.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task ExportToExcel()
    {
        if (_filteredSummaries.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var bytes = await ExportService.ExportToExcelAsync(_filteredSummaries, "Department Summary", $"Daily Attendance Summary - {_selectedDate:yyyy-MM-dd}", columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendanceSummary_{_selectedDate:yyyyMMdd}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            Snackbar.Add("Excel exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_filteredSummaries.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var bytes = await ExportService.ExportToPdfAsync(_filteredSummaries, $"Daily Attendance Summary - {_selectedDate:yyyy-MM-dd}", columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendanceSummary_{_selectedDate:yyyyMMdd}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            Snackbar.Add("PDF exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<DepartmentSummary, object>> GetExportColumns() => new()
    {
        ["Department"] = d => d.Name,
        ["Headcount"] = d => d.Headcount,
        ["Present"] = d => d.Present,
        ["Absent"] = d => d.Absent,
        ["Late"] = d => d.Late,
        ["Leave"] = d => d.Leave,
        ["Present Rate (%)"] = d => d.PresentRate,
        ["Avg Hours"] = d => d.AvgHours
    };

    public record DepartmentSummary(string Name, int Headcount, int Present, int Absent, int Late, int Leave, double PresentRate, double AvgHours);
}