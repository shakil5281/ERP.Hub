@page "/companies"

<PageTitle>ERPHub - Company Information</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
    <!-- Header Block -->
    <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
        <div>
            <h2 class="text-2xl font-semibold text-black tracking-tight font-heading">Company Information</h2>
        </div>
        <div>
    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddModal">+ Add Company</button>
        </div>
    </div>

    <!-- Dynamic DataTable component -->
    <DataTable TItem="Company" Items="FilteredCompanies">
        <HeaderTemplate>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left w-[60px]">Sl</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Company Name (EN)</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Company Name (BN)</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Address (EN)</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Address (BN)</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Email</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Phone Number</th>
            <th class="bg-zinc-50 text-zinc-500 font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Signature</th>
        </HeaderTemplate>
        <RowTemplate Context="comp">
            <td class="p-2.5 px-4 text-zinc-800 font-semibold font-body">
                @(FilteredCompanies.ToList().IndexOf(comp) + 1)
            </td>
            <td class="p-2.5 px-4 text-zinc-900 font-semibold font-body">@comp.CompanyNameEn</td>
            <td class="p-2.5 px-4 text-zinc-900 font-sutonnymj">@comp.CompanyNameBn</td>
            <td class="p-2.5 px-4 text-zinc-700 font-body">@comp.AddressEn</td>
            <td class="p-2.5 px-4 text-zinc-700 font-sutonnymj">@comp.AddressBn</td>
            <td class="p-2.5 px-4 text-zinc-700 font-body">
                <code class="text-indigo-600 bg-indigo-50/50 px-2 py-0.5 rounded">@comp.Email</code>
            </td>
            <td class="p-2.5 px-4 text-zinc-700 font-body">@comp.PhoneNumber</td>
            <td class="p-2.5 px-4 text-zinc-800 font-semibold font-body">
                <span class="font-serif italic border-b border-zinc-300 pb-0.5 text-zinc-600">@comp.Signature</span>
            </td>
        </RowTemplate>
        <RowActionsContent Context="comp">
            <button class="bg-transparent border-0 text-left py-1.5 px-3 cursor-pointer text-zinc-700 hover:bg-zinc-100 w-full" type="button" @onclick="() => OpenEditModal(comp)">Edit</button>
            <button class="bg-transparent border-0 text-left py-1.5 px-3 cursor-pointer text-red-600 hover:bg-zinc-100 w-full" type="button" @onclick="() => ConfirmDelete(comp.Id)">Delete</button>
        </RowActionsContent>
    </DataTable>
</div>

<!-- Add / Edit Modal -->
@if (_showFormModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
        <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[550px] overflow-hidden flex flex-col">
            <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                <h3 class="font-bold text-sm text-zinc-950">@(_isEditMode ? "Modify Company Details" : "Register New Company Listing")</h3>
                <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseModal">&times;</button>
            </div>
            
            <EditForm Model="@_editingCompany" OnValidSubmit="SaveCompany">
                <DataAnnotationsValidator />
                
                <div class="p-5 overflow-y-auto max-h-[70vh] flex flex-col gap-4">
                    <!-- Name Fields -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Company Name (EN)</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingCompany.CompanyNameEn" placeholder="e.g. Acme Corporation" />
                            <ValidationMessage For="@(() => _editingCompany.CompanyNameEn)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                        
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Company Name (BN)</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingCompany.CompanyNameBn" placeholder="একমি কর্পোরেশন" />
                            <ValidationMessage For="@(() => _editingCompany.CompanyNameBn)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                    </div>

                    <!-- Address Fields -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Address (EN)</label>
                        <InputTextArea class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors min-h-[60px] resize-y" @bind-Value="_editingCompany.AddressEn" placeholder="e.g. 123 Industrial Area, Dhaka" />
                        <ValidationMessage For="@(() => _editingCompany.AddressEn)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Address (BN)</label>
                        <InputTextArea class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-sutonnymj text-[13.5px] outline-none focus:border-black transition-colors min-h-[60px] resize-y" @bind-Value="_editingCompany.AddressBn" placeholder="যেমন: ১২৩ শিল্প এলাকা, ঢাকা" />
                        <ValidationMessage For="@(() => _editingCompany.AddressBn)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>

                    <!-- Contact Fields -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Contact Email</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingCompany.Email" placeholder="info@company.com" />
                            <ValidationMessage For="@(() => _editingCompany.Email)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Phone Number</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingCompany.PhoneNumber" placeholder="+880 1711-000000" />
                            <ValidationMessage For="@(() => _editingCompany.PhoneNumber)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                    </div>

                    <!-- Signature Field -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Authorized Signature Name</label>
                        <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors font-serif italic" @bind-Value="_editingCompany.Signature" placeholder="e.g. John Doe" />
                        <ValidationMessage For="@(() => _editingCompany.Signature)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>
                </div>

                <div class="p-4 px-5 border-t border-zinc-100 bg-zinc-50 flex justify-end gap-2.5">
                    <button type="button" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors cursor-pointer" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">Save Company</button>
                </div>
            </EditForm>
        </div>
    </div>
}

    <!-- Success & Error Toasts -->
    @if (_showToast)
    {
        <div class="fixed bottom-6 right-6 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
            <span>✓</span>
            <span>@_toastMessage</span>
        </div>
    }
    @if (_showErrorToast)
    {
        <div class="fixed bottom-6 right-6 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
            <span>✗</span>
            <span>@_errorMessage</span>
        </div>
    }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
