@page "/companies"

<PageTitle>ERPHub - Company Information</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
    <!-- Header Block -->
    <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
        <div>
            <h2 class="text-2xl font-semibold text-black tracking-tight font-heading">Company Information</h2>
        </div>
        <div>
    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddModal">+ Add Company</button>
        </div>
    </div>

    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
        <MudTable Items="@FilteredCompanies" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
            <HeaderContent>
                <MudTh>Sl</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.CompanyNameEn)">Company Name (EN)</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.CompanyNameBn)">Company Name (BN)</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.AddressEn)">Address (EN)</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.AddressBn)">Address (BN)</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.PhoneNumber)">Phone Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Company, object>(x=>x.Signature)">Signature</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Sl">@(FilteredCompanies.ToList().IndexOf(context) + 1)</MudTd>
                <MudTd DataLabel="Company Name (EN)">@context.CompanyNameEn</MudTd>
                <MudTd DataLabel="Company Name (BN)" Class="font-sutonnymj">@context.CompanyNameBn</MudTd>
                <MudTd DataLabel="Address (EN)">@context.AddressEn</MudTd>
                <MudTd DataLabel="Address (BN)" Class="font-sutonnymj">@context.AddressBn</MudTd>
                <MudTd DataLabel="Email"><code class="text-indigo-600 bg-indigo-50/50 px-2 py-0.5 rounded">@context.Email</code></MudTd>
                <MudTd DataLabel="Phone Number">@context.PhoneNumber</MudTd>
                <MudTd DataLabel="Signature"><span class="font-serif italic border-b border-zinc-300 pb-0.5 text-zinc-600">@context.Signature</span></MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="@Size.Small" Color="Color.Primary" OnClick="() => OpenEditModal(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="@Size.Small" Color="Color.Error" OnClick="() => ConfirmDelete(context.Id)" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
            </PagerContent>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
        </NoRecordsContent>
        </MudTable>
    </div>
</div>

<!-- Add / Edit Modal -->
@if (_showFormModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4 animate-fade-in">
        <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[550px] overflow-hidden flex flex-col">
            <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                <h3 class="font-bold text-sm text-zinc-950">@(_isEditMode ? "Modify Company Details" : "Register New Company Listing")</h3>
                <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseModal">&times;</button>
            </div>
            
            <EditForm Model="@_editingCompany" OnValidSubmit="SaveCompany">
                <DataAnnotationsValidator />
                
                <div class="p-5 overflow-y-auto max-h-[70vh] flex flex-col gap-4">
                    <!-- Name Fields -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Company Name (EN)</label>
                            <MudTextField @bind-Value="_editingCompany.CompanyNameEn" For="@(() => _editingCompany.CompanyNameEn)" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" placeholder="e.g. Acme Corporation" />
                        </div>
                        
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Company Name (BN)</label>
                            <MudTextField @bind-Value="_editingCompany.CompanyNameBn" For="@(() => _editingCompany.CompanyNameBn)" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" placeholder="একমি কর্পোরেশন" Class="font-sutonnymj" />
                        </div>
                    </div>

                    <!-- Address Fields -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Address (EN)</label>
                        <MudTextField @bind-Value="_editingCompany.AddressEn" For="@(() => _editingCompany.AddressEn)" Variant="Variant.Outlined" dense="true" Lines="3" Margin="Margin.Dense" placeholder="e.g. 123 Industrial Area, Dhaka" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Address (BN)</label>
                        <MudTextField @bind-Value="_editingCompany.AddressBn" For="@(() => _editingCompany.AddressBn)" Variant="Variant.Outlined" dense="true" Lines="3" Margin="Margin.Dense" placeholder="যেমন: ১২৩ শিল্প এলাকা, ঢাকা" Class="font-sutonnymj" />
                    </div>

                    <!-- Contact Fields -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Contact Email</label>
                            <MudTextField @bind-Value="_editingCompany.Email" For="@(() => _editingCompany.Email)" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" placeholder="info@company.com" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Phone Number</label>
                            <MudTextField @bind-Value="_editingCompany.PhoneNumber" For="@(() => _editingCompany.PhoneNumber)" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" placeholder="+880 1711-000000" />
                        </div>
                    </div>

                    <!-- Signature Field -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Authorized Signature Name</label>
                        <MudTextField @bind-Value="_editingCompany.Signature" For="@(() => _editingCompany.Signature)" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" placeholder="e.g. John Doe" />
                    </div>
                </div>

                <div class="p-4 px-5 border-t border-zinc-100 bg-zinc-50 flex justify-end gap-2.5">
                    <button type="button" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors cursor-pointer" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="py-2 px-4 rounded-lg bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">Save Company</button>
                </div>
            </EditForm>
        </div>
    </div>
}

    <!-- Success & Error Toasts -->
    @if (_showToast)
    {
        <div class="fixed bottom-6 right-6 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
            <span>✓</span>
            <span>@_toastMessage</span>
        </div>
    }
    @if (_showErrorToast)
    {
        <div class="fixed bottom-6 right-6 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
            <span>✗</span>
            <span>@_errorMessage</span>
        </div>
    }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
