@page "/leave/application"
@using ERPHub.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ErpDbContext> DbFactory

<PageTitle>ERPHub - Leave Applications</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Leave Applications</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Submit new time-off requests and track the approval status of current applications.</p>
                </div>
            </div>

            <!-- Main Layout: Form Left, History Right -->
            <div class="grid grid-cols-3 gap-6 mb-6 max-xl:grid-cols-1">
                <!-- Submission Form -->
                <div class="bg-white border border-zinc-200 rounded-lg p-6 shadow-sm col-span-1">
                    <h3 class="text-sm font-bold text-zinc-900 mb-5 border-b border-zinc-100 pb-2 font-heading">Submit Leave Request</h3>
                    
                    <form class="flex flex-col gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Leave Category</label>
                            <MudSelect T="string" @bind-Value="_leaveType" Class="mud-select-square" dense="true" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("annual")">Annual Leave</MudSelectItem>
                                <MudSelectItem Value="@("medical")">Medical Leave</MudSelectItem>
                                <MudSelectItem Value="@("casual")">Casual Leave</MudSelectItem>
                            </MudSelect>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Start Date</label>
                                <input type="date" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors cursor-pointer" @bind="_startDate" @bind:format="yyyy-MM-dd" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">End Date</label>
                                <input type="date" class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-xs outline-none focus:border-black transition-colors cursor-pointer" @bind="_endDate" @bind:format="yyyy-MM-dd" />
                            </div>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Reason / Remarks</label>
                            <MudTextField T="string" @bind-Value="_reason" Variant="Variant.Outlined" dense="true" Lines="3" Margin="Margin.Dense" placeholder="Briefly explain the reason for time-off..."></MudTextField>
                        </div>
                        <button type="button" class="w-full bg-black text-white text-xs font-semibold py-2.5 rounded-lg hover:bg-zinc-800 transition-colors cursor-pointer text-center" @onclick="SubmitLeave">
                            Submit Request
                        </button>
                    </form>

                    @if (!string.IsNullOrEmpty(_statusMessage))
                    {
                        <div class="mt-3 text-xs font-semibold @(_statusMessage.Contains("submitted", StringComparison.OrdinalIgnoreCase) ? "text-green-600" : "text-red-600")">@_statusMessage</div>
                    }
                </div>

                <!-- Application History -->
                <div class="col-span-2 max-xl:col-span-1">
                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                        <MudTable Items="@_applications" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.Type)">Type</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.StartDate)">Dates</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.TotalDays)">Days</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.Reason)">Reason</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.Approver)">Approver</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<LeaveRequest, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Type">@context.Type</MudTd>
                                <MudTd DataLabel="Dates">
                                    <div>@context.StartDate</div>
                                    <div class="text-[10px] text-zinc-400 mt-0.5">to @context.EndDate</div>
                                </MudTd>
                                <MudTd DataLabel="Days">@context.TotalDays</MudTd>
                                <MudTd DataLabel="Reason">@context.Reason</MudTd>
                                <MudTd DataLabel="Approver">@context.Approver</MudTd>
                                <MudTd DataLabel="Status">
                                    <span class="@($"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold {context.BadgeClass}")">@context.Status</span>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                            </PagerContent>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                        </NoRecordsContent>
                        </MudTable>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _leaveType = "annual";
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate = DateTime.Today.AddDays(1);
    private string _reason = string.Empty;
    private string _statusMessage = string.Empty;

    public class LeaveRequest
    {
        public string Type { get; set; } = string.Empty;
        public string StartDate { get; set; } = string.Empty;
        public string EndDate { get; set; } = string.Empty;
        public int TotalDays { get; set; }
        public string Reason { get; set; } = string.Empty;
        public string Approver { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<LeaveRequest> _applications = new()
    {
        new LeaveRequest { Type = "Annual Leave", StartDate = "2026-07-01", EndDate = "2026-07-05", TotalDays = 5, Reason = "Family vacation", Approver = "John Smith (HR)", Status = "Pending", BadgeClass = "bg-amber-50 text-amber-700 border border-amber-100" },
        new LeaveRequest { Type = "Medical Leave", StartDate = "2026-05-12", EndDate = "2026-05-13", TotalDays = 2, Reason = "Dental extraction checkup", Approver = "System Auto-Approval", Status = "Approved", BadgeClass = "bg-green-50 text-green-700 border border-green-100" }
    };

    private async Task SubmitLeave()
    {
        if (string.IsNullOrWhiteSpace(_leaveType) || string.IsNullOrWhiteSpace(_reason))
        {
            _statusMessage = "Please fill in all required fields.";
            return;
        }

        try
        {
            var startStr = _startDate.ToString("yyyy-MM-dd");
            var endStr = _endDate.ToString("yyyy-MM-dd");
            var totalDays = (_endDate - _startDate).Days + 1;

            await using var db = await DbFactory.CreateDbContextAsync();
            db.LeaveApplications.Add(new ERPHub.Models.LeaveApplication
            {
                EmployeeId = "1",
                EmployeeName = "Current User",
                LeaveDate = _startDate,
                LeaveType = _leaveType,
                Reason = _reason,
                Status = "Pending"
            });
            await db.SaveChangesAsync();

            _applications.Insert(0, new LeaveRequest
            {
                Type = _leaveType switch
                {
                    "annual" => "Annual Leave",
                    "medical" => "Medical Leave",
                    "casual" => "Casual Leave",
                    _ => _leaveType
                },
                StartDate = startStr,
                EndDate = endStr,
                TotalDays = totalDays,
                Reason = _reason,
                Approver = "Pending",
                Status = "Pending",
                BadgeClass = "bg-amber-50 text-amber-700 border border-amber-100"
            });

            _leaveType = "annual";
            _startDate = DateTime.Today;
            _endDate = DateTime.Today.AddDays(1);
            _reason = string.Empty;
            _statusMessage = "Leave request submitted successfully!";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error submitting request: {ex.Message}";
        }
    }

}
