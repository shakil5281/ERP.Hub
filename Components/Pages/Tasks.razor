@page "/tasks"

<PageTitle>ERPHub - Project Kanban Board</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
    <!-- Header Block -->
    <div class="flex justify-between items-center mb-7 max-sm:flex-col max-sm:items-start max-sm:gap-3">
        <div>
            <h2 class="text-2xl font-extrabold text-black tracking-tight">Kanban Board</h2>
            <p class="text-zinc-500 text-xs mt-0.5">Manage tasks, track progress, and transition status in real-time.</p>
        </div>
        <button class="inline-flex items-center gap-1.5 py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer" @onclick="OpenAddTaskModal">
            <svg viewBox="0 0 24 24" class="w-4.5 h-4.5 fill-current">
                <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"/>
            </svg>
            Create Task
        </button>
    </div>

    <!-- Kanban Grid -->
    <div class="grid grid-cols-4 gap-5 items-start max-xl:grid-cols-2 max-sm:grid-cols-1">
        @foreach (var status in Enum.GetValues<Models.TaskStatus>())
        {
            var currentStatus = status;
            var statusTasks = _tasks.Where(t => t.Status == currentStatus).ToList();
            
            <div class="bg-zinc-100 border border-zinc-200 rounded-lg p-4 min-h-[550px] flex flex-col gap-3 animate-fade-in">
                <div class="flex justify-between items-center pb-2 border-b-2 border-zinc-200 select-none">
                    <div class="flex items-center gap-2 font-bold text-sm text-zinc-800">
                        <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: @GetStatusColor(currentStatus);"></span>
                        <span>@GetStatusLabel(currentStatus)</span>
                    </div>
                    <span class="bg-zinc-200 text-zinc-500 rounded-full py-0.5 px-2 text-[11px] font-bold">@statusTasks.Count</span>
                </div>
                
                <div class="flex flex-col gap-3">
                    @if (statusTasks.Any())
                    {
                        @foreach (var task in statusTasks)
                        {
                            <div class="bg-white border border-zinc-200 rounded-md p-4 shadow-sm hover:border-zinc-400 hover:shadow-md transition-all">
                                <span class="inline-block text-[10px] font-bold uppercase py-0.5 px-2 rounded-md mb-2
                                             @(task.Priority == TaskPriority.High ? "bg-red-50 text-red-700" :
                                               task.Priority == TaskPriority.Medium ? "bg-amber-50 text-amber-700" :
                                               "bg-green-50 text-green-700")">
                                    @task.Priority
                                </span>
                                <div class="font-bold text-[13.5px] text-zinc-950 mb-1 leading-tight">@task.Title</div>
                                <div class="text-xs text-zinc-500 mb-3 leading-relaxed">@task.Description</div>
                                
                                <div class="flex justify-between items-center border-t border-zinc-100 pt-2.5 mb-2 select-none">
                                    <div class="flex items-center gap-1.5 text-xs text-zinc-800 font-medium">
                                        <div class="w-5 h-5 rounded-full bg-black text-white flex items-center justify-center text-[9px] font-bold select-none">@GetInitials(task.Assignee)</div>
                                        <span class="truncate max-w-[80px]">@task.Assignee</span>
                                    </div>
                                    <span class="text-[10.5px] text-zinc-400">Due: @task.DueDate.ToString("MM-dd")</span>
                                </div>
                                
                                <div class="flex gap-1 justify-end select-none">
                                    @if (currentStatus != Models.TaskStatus.Todo)
                                    {
                                        <button class="inline-flex items-center py-1 px-2 rounded bg-zinc-50 border border-zinc-200 text-zinc-500 text-[10px] font-semibold hover:bg-zinc-100 hover:text-black transition-colors cursor-pointer" title="Move Left" @onclick="() => MoveTask(task.Id, -1)">
                                            &larr;
                                        </button>
                                    }
                                    <button class="inline-flex items-center py-1 px-2 rounded bg-zinc-50 border border-zinc-200 text-blue-500 text-[10px] font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" title="Edit Task" @onclick="() => OpenEditTaskModal(task)">
                                        Edit
                                    </button>
                                    <button class="inline-flex items-center py-1 px-2 rounded bg-zinc-50 border border-zinc-200 text-red-500 text-[10px] font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" title="Delete Task" @onclick="() => DeleteTask(task.Id)">
                                        Delete
                                    </button>
                                    @if (currentStatus != Models.TaskStatus.Done)
                                    {
                                        <button class="inline-flex items-center py-1 px-2 rounded bg-zinc-50 border border-zinc-200 text-zinc-500 text-[10px] font-semibold hover:bg-zinc-100 hover:text-black transition-colors cursor-pointer" title="Move Right" @onclick="() => MoveTask(task.Id, 1)">
                                            &rarr;
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="flex-1 flex items-center justify-center border-2 border-dashed border-zinc-200 rounded-lg p-6 bg-zinc-50/20 select-none">
                            <span class="text-zinc-400 text-xs text-center">No Tasks</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Task Form Modal -->
@if (_showFormModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[1000] p-4">
        <div class="bg-white border border-zinc-200 rounded-xl shadow-2xl w-full max-w-[500px] overflow-hidden flex flex-col animate-fade-in">
            <div class="p-4 px-5 border-b border-zinc-100 flex justify-between items-center bg-white">
                <h3 class="font-bold text-sm text-zinc-950">@(_isEditMode ? "Modify Task Details" : "Create New Kanban Task")</h3>
                <button type="button" class="bg-transparent border-0 text-zinc-400 text-xl cursor-pointer hover:text-black transition-colors" @onclick="CloseModal">&times;</button>
            </div>
            
            <EditForm Model="@_editingTask" OnValidSubmit="SaveTask">
                <DataAnnotationsValidator />
                
                <div class="p-5 overflow-y-auto max-h-[70vh] flex flex-col gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Task Title</label>
                        <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingTask.Title" placeholder="What needs to be done?" />
                        <ValidationMessage For="@(() => _editingTask.Title)" class="text-[11px] font-semibold text-red-500 mt-1" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Description</label>
                        <InputTextArea class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingTask.Description" rows="3" placeholder="Provide background context or requirements..." />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Status Column</label>
                            <select class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors cursor-pointer" @bind="_editingTask.Status">
                                @foreach (var status in Enum.GetValues<Models.TaskStatus>())
                                {
                                    <option value="@status">@GetStatusLabel(status)</option>
                                }
                            </select>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Priority Rank</label>
                            <select class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors cursor-pointer" @bind="_editingTask.Priority">
                                @foreach (var priority in Enum.GetValues<TaskPriority>())
                                {
                                    <option value="@priority">@priority</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Assignee Name</label>
                            <InputText class="w-full bg-white border border-zinc-200 rounded-lg p-2.5 px-3.5 text-zinc-900 font-body text-[13.5px] outline-none focus:border-black transition-colors" @bind-Value="_editingTask.Assignee" placeholder="e.g. Tony Stark" />
                            <ValidationMessage For="@(() => _editingTask.Assignee)" class="text-[11px] font-semibold text-red-500 mt-1" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <MudDatePicker Date="@_editingTask.DueDate"
                                           DateChanged="@(d => { if (d.HasValue) _editingTask.DueDate = d.Value; })"
                                           Label="Due Date"
                                           Editable="true"
                                           Placeholder="Select Date"
                                           DateFormat="yyyy-MM-dd"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense" />
                        </div>
                    </div>
                </div>

                <div class="p-4 px-5 border-t border-zinc-100 flex justify-end gap-3 bg-zinc-50/75">
                    <button type="button" class="py-2 px-4 border border-zinc-200 rounded-md bg-white text-zinc-700 text-xs font-semibold hover:bg-zinc-100 transition-colors cursor-pointer" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="py-2 px-4 rounded-md bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">Save Task</button>
                </div>
            </EditForm>
        </div>
    </div>
}
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
