@page "/leave/details"

<PageTitle>ERPHub - Leave Ledger Details</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Leave Balance Ledger</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Detailed breakdown of individual employee leave balances, taken history, and accrual audits.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_ledgers" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeaveLedger, object>(x=>x.Category)">Leave Category</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeaveLedger, object>(x=>x.Allocated)">Allocated Days</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeaveLedger, object>(x=>x.Consumed)">Consumed Days</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeaveLedger, object>(x=>x.Balance)">Balance Remaining</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeaveLedger, object>(x=>x.AccrualRate)">Accrual Rate</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Leave Category">@context.Category</MudTd>
                        <MudTd DataLabel="Allocated Days">@context.Allocated</MudTd>
                        <MudTd DataLabel="Consumed Days">@context.Consumed</MudTd>
                        <MudTd DataLabel="Balance Remaining">@context.Balance</MudTd>
                        <MudTd DataLabel="Accrual Rate">@context.AccrualRate</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class LeaveLedger
    {
        public string Category { get; set; } = string.Empty;
        public int Allocated { get; set; }
        public int Consumed { get; set; }
        public int Balance { get; set; }
        public string AccrualRate { get; set; } = string.Empty;
    }

    private List<LeaveLedger> _ledgers = new()
    {
        new LeaveLedger { Category = "Annual Leave", Allocated = 15, Consumed = 3, Balance = 12, AccrualRate = "1.25 Days / Month" },
        new LeaveLedger { Category = "Medical Leave", Allocated = 10, Consumed = 2, Balance = 8, AccrualRate = "Yearly Lump-Sum" },
        new LeaveLedger { Category = "Casual Leave", Allocated = 5, Consumed = 0, Balance = 5, AccrualRate = "Yearly Lump-Sum" }
    };
}
