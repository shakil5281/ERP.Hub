@page "/hr/record-separation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject AttendanceService AttendanceService

<PageTitle>ERPHub - Record Employee Separation</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header *@
        <div class="d-flex align-center mb-6" style="flex-wrap:wrap; gap: 16px;width: 100%;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Record Employee Separation</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">Find absent employees and record their separation.</MudText>
            </div>
            <MudSpacer />
        </div>

        @* Filters *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4" Style="border-radius:8px;">
            <MudGrid Spacing="3" class="align-items-end">
                <MudItem xs="12" sm="4" md="2">
                    <MudDatePicker Label="From Date" Date="@_fromDate" DateChanged="@(d => { if (d.HasValue) _fromDate = d.Value; })" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudDatePicker Label="To Date" Date="@_toDate" DateChanged="@(d => { if (d.HasValue) _toDate = d.Value; })" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudNumericField Label="Min Cont. Absent" @bind-Value="_minContinuousAbsent" Min="0" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudTextField Label="Employee ID" @bind-Value="_employeeIdFilter" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudSelect Label="Department" @bind-Value="_departmentIdFilter" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem Value="0">All</MudSelectItem>
                        @foreach (var d in _departments) { <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudSelect Label="Designation" @bind-Value="_designationIdFilter" Variant="Variant.Outlined" dense="true" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem Value="0">All</MudSelectItem>
                        @foreach (var dg in _designations) { <MudSelectItem Value="@dg.Id">@dg.NameEn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="12" md="12" Class="d-flex align-center justify-end gap-2" Style="margin-top: 10px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" @onclick="LoadRecords" Class="px-8">
                        Apply Filters
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" @onclick="ClearFilters" Class="px-8">
                        Clear
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Data Table *@
        @if (_isLoading)
        {
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Loading records...</MudText>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden mb-6">
                <MudTable Items="@_records" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0" Filter="new Func<AbsentSummaryDto, bool>(FilterFunc)">
                    <ToolBarContent>
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Absent Employees</MudText>
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@_fromDate.ToString("yyyy-MM-dd") to @_toDate.ToString("yyyy-MM-dd")</MudText>
                        </div>
                        <MudSpacer />
                        <MudTextField @bind-Value="_searchString"
                                      Placeholder="Quick search name or ID..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Class="mt-0"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="width:44px; text-align:center;">
                            <MudCheckBox T="bool" Value="@_selectAll" ValueChanged="ToggleSelectAll" Color="Color.Primary" Size="Size.Small" />
                        </MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.EmployeeId)">Employee ID</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.Department)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.Designation)">Designation</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.TotalAbsentDays)">Total Absent</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AbsentSummaryDto, object>(x => x.ContinuousAbsentDays)">Continuous Absent</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align:center;">
                            @{
                                var isSelected = _selectedEmpIds.Contains(context.EmployeeId);
                            }
                            <MudCheckBox T="bool" Value="@isSelected" ValueChanged="@((bool v) => ToggleEmployee(context, v))" Color="Color.Primary" Size="Size.Small" />
                        </MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Employee ID"><MudText Typo="Typo.body2" Class="fw-bold font-mono">@context.EmployeeId</MudText></MudTd>
                        <MudTd DataLabel="Employee Name"><MudText Typo="Typo.body2" Class="fw-medium">@context.EmployeeName</MudText></MudTd>
                        <MudTd DataLabel="Department"><MudText Typo="Typo.body2">@context.Department</MudText></MudTd>
                        <MudTd DataLabel="Designation"><MudText Typo="Typo.body2">@context.Designation</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Total Absent">
                            <MudText Typo="Typo.body2" Class="fw-bold text-error">@context.TotalAbsentDays</MudText>
                        </MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Continuous Absent">
                            <MudText Typo="Typo.body2" Class="fw-bold text-warning">@context.ContinuousAbsentDays</MudText>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">No absent employees found</MudText>
                    </NoRecordsContent>
                </MudTable>
            </div>

            @if (_selectedEmpIds.Count > 0)
            {
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 mt-6" Style="border-radius:12px; border:2px solid var(--mud-palette-primary); background-color:var(--mud-palette-primary-hover);">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-2">Record Separation for @_selectedEmpIds.Count Selected Employee(s)</MudText>
                    <MudDivider Class="mb-4" />
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="string" Label="Separation Type" @bind-Value="_form.SeparationType" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem Value="@("Resign")">Resign</MudSelectItem>
                                <MudSelectItem Value="@("Terminate")">Terminate</MudSelectItem>
                                <MudSelectItem Value="@("Absconding")">Absconding</MudSelectItem>
                                <MudSelectItem Value="@("Layoff")">Layoff</MudSelectItem>
                                <MudSelectItem Value="@("Retirement")">Retirement</MudSelectItem>
                                <MudSelectItem Value="@("Death")">Death</MudSelectItem>
                                <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="string" Label="Status" @bind-Value="_form.Status" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem Value="@("Initiated")">Initiated</MudSelectItem>
                                <MudSelectItem Value="@("Pending Clearance")">Pending Clearance</MudSelectItem>
                                <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                                <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudDatePicker Label="Resign/Notice Date" @bind-Date="_form.ResignDate" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudDatePicker Label="Last Working Day" @bind-Date="_form.LastWorkingDay" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudNumericField Label="Clearance Progress (%)" @bind-Value="_form.ClearanceProgress" Min="0" Max="100" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Reason/Remarks" @bind-Value="_form.Reason" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>

                    <div class="d-flex justify-end mt-4 gap-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetAll">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSeparations" Disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Record Separations")
                        </MudButton>
                    </div>
                </MudPaper>
            }
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _toDate = DateTime.Today;
    
    private string? _employeeIdFilter;
    private int _departmentIdFilter;
    private int _designationIdFilter;
    private int _minContinuousAbsent = 0;
    
    private bool _isLoading;
    private bool _isSaving;
    private string _searchString = "";
    
    private List<AbsentSummaryDto> _records = new();
    private List<AbsentSummaryDto> _allRecords = new();

    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Employee> _employees = new();

    private HashSet<string> _selectedEmpIds = new(StringComparer.OrdinalIgnoreCase);
    private bool _selectAll;
    private SepForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        // Wait until user clicks Apply to load records
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(departmentsTask, designationsTask, employeesTask);

            _departments = await departmentsTask ?? new();
            _designations = await designationsTask ?? new();
            _employees = await employeesTask ?? new();
        }
        catch
        {
            // Lookup data failed
        }
    }

    private async Task LoadRecords()
    {
        _isLoading = true;
        _selectedEmpIds.Clear();
        _selectAll = false;
        StateHasChanged();

        try
        {
            await AttendanceService.CalculateAttendanceAsync(_fromDate, _toDate);
            
            _allRecords = await AttendanceService.GetAbsentSummaryAsync(_fromDate, _toDate, _employeeIdFilter, null);
            
            ApplyClientFilters();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading records: {ex.Message}", Severity.Error);
            _allRecords = new();
            _records = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyClientFilters()
    {
        var matchingEmployeeIds = _employees
            .Where(e =>
                (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
                (_designationIdFilter == 0 || e.DesignationId == _designationIdFilter))
            .Select(e => e.EmployeeId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        bool hasOrgFilter = _departmentIdFilter > 0 || _designationIdFilter > 0;

        _records = _allRecords
            .Where(r => (!hasOrgFilter || matchingEmployeeIds.Contains(r.EmployeeId)) &&
                        r.ContinuousAbsentDays >= _minContinuousAbsent)
            .ToList();
    }

    private async Task ClearFilters()
    {
        _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
        _toDate = DateTime.Today;
        _employeeIdFilter = null;
        _departmentIdFilter = 0;
        _designationIdFilter = 0;
        _minContinuousAbsent = 0;
        _searchString = "";
        
        // Clear records when filters are cleared
        _records.Clear();
        _allRecords.Clear();
        _selectedEmpIds.Clear();
        _selectAll = false;
        _form = new SepForm();
    }

    private bool FilterFunc(AbsentSummaryDto element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.EmployeeName != null && element.EmployeeName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
            
        if (element.Department != null && element.Department.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void ToggleSelectAll(bool isChecked)
    {
        _selectAll = isChecked;
        if (isChecked)
        {
            foreach (var r in _records.Where(FilterFunc))
            {
                _selectedEmpIds.Add(r.EmployeeId);
            }
        }
        else
        {
            _selectedEmpIds.Clear();
        }
    }

    private void ToggleEmployee(AbsentSummaryDto emp, bool isChecked)
    {
        if (isChecked) _selectedEmpIds.Add(emp.EmployeeId);
        else _selectedEmpIds.Remove(emp.EmployeeId);

        _selectAll = _selectedEmpIds.Count == _records.Count(FilterFunc);
    }

    private void ResetAll()
    {
        _selectedEmpIds.Clear();
        _selectAll = false;
        _form = new SepForm();
    }

    private async Task SaveSeparations()
    {
        if (_selectedEmpIds.Count == 0) return;
        _isSaving = true;

        try
        {
            var selected = _employees.Where(e => _selectedEmpIds.Contains(e.EmployeeId)).ToList();
            var payload  = selected.Select(emp => new Separation
            {
                EmployeeId      = emp.EmployeeId,
                EmployeeName    = emp.EmployeeName,
                DepartmentId    = emp.DepartmentId,
                SectionId       = emp.SectionId,
                DesignationId   = emp.DesignationId,
                SeparationType  = _form.SeparationType,
                Status          = _form.Status,
                ResignDate      = _form.ResignDate ?? DateTime.Today,
                LastWorkingDay  = _form.LastWorkingDay ?? DateTime.Today.AddDays(30),
                ClearanceProgress = _form.ClearanceProgress,
                Reason          = _form.Reason
            }).ToList();

            var response = await Http.PostAsJsonAsync($"{NavManager.BaseUri}api/separations/bulk", payload);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{payload.Count} separation(s) recorded successfully!", Severity.Success);
                NavManager.NavigateTo("/hr/seperation");
            }
            else
            {
                Snackbar.Add($"Save failed: {await response.Content.ReadAsStringAsync()}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class SepForm
    {
        public string   SeparationType  { get; set; } = "Absconding";
        public string   Status          { get; set; } = "Initiated";
        public DateTime? ResignDate      { get; set; } = DateTime.Today;
        public DateTime? LastWorkingDay  { get; set; } = DateTime.Today;
        public int      ClearanceProgress { get; set; } = 0;
        public string   Reason          { get; set; } = "";
    }
}
