@page "/hr/record-separation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject ERPHub.Services.AttendanceService AttendanceService

<PageTitle>ERPHub - Record Employee Separation</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>

        @* ── Header ─────────────────────────────────────────────────────── *@
        <div class="d-flex align-center mb-6 w-100" style="flex-wrap:wrap; gap:16px;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Record Employee Separation</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">
                    Filter employees, select one or more, then fill in separation details.
                </MudText>
            </div>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Size="Size.Small"
                       Href="/hr/seperation">
                Back to Separations
            </MudButton>
        </div>

        @* ── Advanced Filter ─────────────────────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4" Style="border-radius:8px;">
            <MudGrid Spacing="3" class="align-items-end">
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField Label="Employee ID / Name"
                                  @bind-Value="_empSearch"
                                  Variant="Variant.Outlined"
                                  Placeholder="Search..."
                                  dense="true"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect Label="Department"
                               @bind-Value="_empDeptFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect Label="Section"
                               @bind-Value="_empSectionFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Sections</MudSelectItem>
                        @foreach (var s in FilteredSections)
                        {
                            <MudSelectItem Value="@s.Id">@s.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect Label="Designation"
                               @bind-Value="_empDesigFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Designations</MudSelectItem>
                        @foreach (var dg in _designations)
                        {
                            <MudSelectItem Value="@dg.Id">@dg.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect Label="Line"
                               @bind-Value="_empLineFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Lines</MudSelectItem>
                        @foreach (var l in _lines)
                        {
                            <MudSelectItem Value="@l.Id">@l.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect Label="Employee Status"
                               @bind-Value="_empStatusFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                        <MudSelectItem Value="@("Regular")">Regular (Active)</MudSelectItem>
                        <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Absent From"
                                   Date="@_absentFrom"
                                   DateChanged="@(d => { if (d.HasValue) _absentFrom = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Absent To"
                                   Date="@_absentTo"
                                   DateChanged="@(d => { if (d.HasValue) _absentTo = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField Label="Min Continuous Absent"
                                     @bind-Value="_minContinuousAbsent"
                                     Min="0"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center gap-2" Style="padding-top:20px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FilterAlt"
                               OnClick="ApplyAbsentFilter"
                               Disabled="@_isAbsentLoading"
                               Size="Size.Small">
                        @(_isAbsentLoading ? "Loading..." : "Apply Absent Filter")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="ClearFilters" Size="Size.Small">
                        Clear All
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Step 1: Employee Selection Table ────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="mb-4" Style="border-radius:8px; overflow:hidden;">
            <div class="pa-4 pb-2">
                <MudText Typo="Typo.subtitle1" Class="fw-bold">Step 1 — Select Employees</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color">
                    Use the checkboxes to select one or more employees for separation.
                </MudText>
            </div>

            @* Select All bar *@
            <div class="px-4 py-2 d-flex align-center gap-2"
                 style="background:#f8fafc; border-top:1px solid #e2e8f0; border-bottom:1px solid #e2e8f0;">
                @{
                    var filteredList = FilteredEmployees.ToList();
                    var allSelected  = filteredList.Count > 0 && _selectedEmpIds.Count == filteredList.Count;
                    var capturedList = filteredList;
                }
                <MudCheckBox T="bool"
                             Value="@allSelected"
                             ValueChanged="@((bool v) => ToggleSelectAll(v, capturedList))"
                             Color="Color.Primary"
                             Size="Size.Small" />
                <MudText Typo="Typo.caption" Class="fw-bold">
                    @(_selectedEmpIds.Count > 0
                        ? $"{_selectedEmpIds.Count} employee{(_selectedEmpIds.Count > 1 ? "s" : "")} selected"
                        : $"{filteredList.Count} employees shown — select all")
                </MudText>
            </div>

            @* Table *@
            @if (_isEmpLoading)
            {
                <MudText Typo="Typo.body2" Class="text-center py-6 mud-secondary-text-color">Loading employees...</MudText>
            }
            else if (!filteredList.Any())
            {
                <MudText Typo="Typo.body2" Class="text-center py-6 mud-secondary-text-color">No employees match the current filter.</MudText>
            }
            else
            {
                <MudTable Items="@filteredList" Dense="true" Hover="true" Elevation="0" Outlined="false"
                          Style="max-height:400px; overflow-y:auto;">
                    <HeaderContent>
                        <MudTh Style="width:44px;"></MudTh>
                        <MudTh>Employee ID</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>Department</MudTh>
                        <MudTh>Section</MudTh>
                        <MudTh>Designation</MudTh>
                        <MudTh>Line</MudTh>
                        <MudTh Style="text-align:center;">Joining Date</MudTh>
                        <MudTh Style="text-align:center;" title="Last month total absent days">
                            <div style="line-height:1.2;">
                                <div>@(_lastMonthLabel)</div>
                                <div style="font-size:10px; font-weight:400; opacity:.75;">Absent Days</div>
                            </div>
                        </MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="width:44px;">
                            @{
                                var isSelected = _selectedEmpIds.Contains(context.EmployeeId);
                            }
                            <MudCheckBox T="bool"
                                         Value="@isSelected"
                                         ValueChanged="@((bool v) => ToggleEmployee(context, v))"
                                         Color="Color.Primary"
                                         Size="Size.Small" />
                        </MudTd>
                        <MudTd DataLabel="Employee ID">
                            <MudText Typo="Typo.body2" Class="font-mono fw-bold">@context.EmployeeId</MudText>
                        </MudTd>
                        <MudTd DataLabel="Name">
                            <MudText Typo="Typo.body2" Class="fw-medium">@context.EmployeeName</MudText>
                        </MudTd>
                        <MudTd DataLabel="Department">
                            <MudText Typo="Typo.body2">@(GetDeptName(context.DepartmentId))</MudText>
                        </MudTd>
                        <MudTd DataLabel="Section">
                            <MudText Typo="Typo.body2">@(GetSectionName(context.SectionId))</MudText>
                        </MudTd>
                        <MudTd DataLabel="Designation">
                            <MudText Typo="Typo.body2">@(GetDesigName(context.DesignationId))</MudText>
                        </MudTd>
                        <MudTd DataLabel="Line">
                            <MudText Typo="Typo.body2">@(GetLineName(context.LineId))</MudText>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Joining Date">
                            <MudText Typo="Typo.body2" Class="font-mono">@context.JoiningDate.ToString("yyyy-MM-dd")</MudText>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Last Month Absent">
                            @{
                                _absentSummaries.TryGetValue(context.EmployeeId, out var summary);
                            }
                            @if (summary != null && summary.TotalAbsentDays > 0)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small"
                                         Variant="Variant.Filled"
                                         Style="height:22px; font-size:11px; font-weight:700;">
                                    @(summary.TotalAbsentDays) Total / @(summary.ContinuousAbsentDays) Cont.
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mud-secondary-text-color">—</MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                    </PagerContent>
                </MudTable>
            }
        </MudPaper>

        @* ── Step 2: Separation Details ──────────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="border-radius:8px;">
            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-1">Step 2 — Separation Details</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text-color mb-3">
                @if (_selectedEmpIds.Count == 0)
                {
                    @("No employee selected. Select employees from the table above.")
                }
                else if (_selectedEmpIds.Count == 1)
                {
                    @($"1 employee selected — {_selectedEmpIds.First()}")
                }
                else
                {
                    @($"{_selectedEmpIds.Count} employees selected — a separation record will be created for each.")
                }
            </MudText>

            @if (_selectedEmpIds.Count > 0)
            {
                <div class="mb-4 pa-2 rounded" style="background:#fef3c7; border:1px solid #fde68a;">
                    <MudText Typo="Typo.caption" Class="fw-bold" Style="color:#92400e;">
                        Selected: @string.Join(", ", _selectedEmpIds.Take(6))
                        @(_selectedEmpIds.Count > 6 ? $" +{_selectedEmpIds.Count - 6} more" : "")
                    </MudText>
                </div>
            }

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect Label="Separation Type" @bind-Value="_form.SeparationType"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Resign")">Resign</MudSelectItem>
                        <MudSelectItem Value="@("Left")">Left</MudSelectItem>
                        <MudSelectItem Value="@("Close")">Close</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect Label="Status" @bind-Value="_form.Status"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Initiated")">Initiated</MudSelectItem>
                        <MudSelectItem Value="@("Notice Period")">Notice Period</MudSelectItem>
                        <MudSelectItem Value="@("Clearance")">Clearance</MudSelectItem>
                        <MudSelectItem Value="@("Terminated")">Terminated</MudSelectItem>
                        <MudSelectItem Value="@("Settled")">Settled</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Resign / Separation Date"
                                   Date="@_form.ResignDate"
                                   DateChanged="@(d => { if (d.HasValue) _form.ResignDate = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Last Working Day"
                                   Date="@_form.LastWorkingDay"
                                   DateChanged="@(d => { if (d.HasValue) _form.LastWorkingDay = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField Label="Clearance Progress % (0–100)"
                                     @bind-Value="_form.ClearanceProgress"
                                     Min="0" Max="100"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="9" md="9">
                    <MudTextField Label="Reason for Separation"
                                  @bind-Value="_form.Reason"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="Reason for leaving..."
                                  Lines="2" />
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-2 mt-5">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="@(_selectedEmpIds.Count == 0 || _isSaving)"
                           OnClick="SaveSeparations">
                    @if (_isSaving)
                    {
                        @("Saving...")
                    }
                    else
                    {
                        @($"Record {(_selectedEmpIds.Count > 1 ? $"{_selectedEmpIds.Count} Separations" : "Separation")}")
                    }
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetAll">
                    Reset All
                </MudButton>
            </div>
        </MudPaper>

    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    // Data
    private List<Employee>    _employees    = new();
    private List<Department>  _departments  = new();
    private List<Section>     _sections     = new();
    private List<Designation> _designations = new();
    private List<Line>        _lines        = new();

    // Last-month absent counts keyed by EmployeeId
    private Dictionary<string, AbsentSummaryDto> _absentSummaries = new(StringComparer.OrdinalIgnoreCase);
    private string _lastMonthLabel = string.Empty;
    private DateTime? _absentFrom;
    private DateTime? _absentTo;
    private bool _isAbsentLoading;

    private bool _isEmpLoading = true;
    private bool _isSaving;

    // Filters
    private string _empSearch       = "";
    private int    _empDeptFilter   = 0;
    private int    _empSectionFilter= 0;
    private int    _empDesigFilter  = 0;
    private int    _empLineFilter   = 0;
    private string _empStatusFilter = "All";
    private bool   _isAbsentFilterActive = false;
    private int    _minContinuousAbsent = 0;

    // Selection
    private HashSet<string> _selectedEmpIds = new(StringComparer.OrdinalIgnoreCase);

    // Form
    private SepForm _form = new();

    private class SepForm
    {
        public string   SeparationType  { get; set; } = "Resign";
        public string   Status          { get; set; } = "Initiated";
        public DateTime ResignDate      { get; set; } = DateTime.Today;
        public DateTime LastWorkingDay  { get; set; } = DateTime.Today.AddDays(30);
        public int      ClearanceProgress { get; set; } = 0;
        public string   Reason          { get; set; } = "";
    }

    // Computed: sections that belong to the selected department
    private IEnumerable<Section> FilteredSections =>
        _empDeptFilter > 0 ? _sections.Where(s => s.DepartmentId == _empDeptFilter) : _sections;

    private IEnumerable<Employee> FilteredEmployees => _employees.Where(e =>
        (_empDeptFilter    == 0 || e.DepartmentId  == _empDeptFilter)    &&
        (_empSectionFilter == 0 || e.SectionId     == _empSectionFilter) &&
        (_empDesigFilter   == 0 || e.DesignationId == _empDesigFilter)   &&
        (_empLineFilter    == 0 || e.LineId        == _empLineFilter)    &&
        (_empStatusFilter  == "All" || e.EmployeeStatus == _empStatusFilter) &&
        (!_isAbsentFilterActive || (_absentSummaries.TryGetValue(e.EmployeeId, out var sum) && sum.ContinuousAbsentDays >= _minContinuousAbsent)) &&
        (string.IsNullOrWhiteSpace(_empSearch) ||
         e.EmployeeId.Contains(_empSearch, StringComparison.OrdinalIgnoreCase) ||
         e.EmployeeName.Contains(_empSearch, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _isEmpLoading = true;

        // Determine last month
        var lastMonth = DateTime.Today.AddMonths(-1);
        _lastMonthLabel = lastMonth.ToString("MMM yyyy");

        try
        {
            var b = NavManager.BaseUri;
            var t1 = Http.GetFromJsonAsync<List<Employee>>   ($"{b}api/employees");
            var t2 = Http.GetFromJsonAsync<List<Department>> ($"{b}api/departments");
            var t3 = Http.GetFromJsonAsync<List<Section>>    ($"{b}api/sections");
            var t4 = Http.GetFromJsonAsync<List<Designation>>($"{b}api/designations");
            var t5 = Http.GetFromJsonAsync<List<Line>>       ($"{b}api/lines");
            
            _absentFrom = new DateTime(lastMonth.Year, lastMonth.Month, 1);
            _absentTo = new DateTime(lastMonth.Year, lastMonth.Month, DateTime.DaysInMonth(lastMonth.Year, lastMonth.Month));
            
            await Task.WhenAll(t1, t2, t3, t4, t5);
            _employees    = await t1 ?? new();
            _departments  = await t2 ?? new();
            _sections     = await t3 ?? new();
            _designations = await t4 ?? new();
            _lines        = await t5 ?? new();
            // Not loading _absentCounts on init anymore since we do it in ApplyAbsentFilter
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isEmpLoading = false;
        }
    }

    private void ToggleEmployee(Employee emp, bool selected)
    {
        if (selected) _selectedEmpIds.Add(emp.EmployeeId);
        else          _selectedEmpIds.Remove(emp.EmployeeId);
    }

    private void ToggleSelectAll(bool selectAll, List<Employee> list)
    {
        if (selectAll)
            foreach (var e in list) _selectedEmpIds.Add(e.EmployeeId);
        else
            _selectedEmpIds.Clear();
    }

    private void ClearFilters()
    {
        _empSearch        = "";
        _empDeptFilter    = 0;
        _empSectionFilter = 0;
        _empDesigFilter   = 0;
        _empLineFilter    = 0;
        _empStatusFilter  = "All";
        _isAbsentFilterActive = false;
        _minContinuousAbsent = 0;
        
        var lastMonth = DateTime.Today.AddMonths(-1);
        _absentFrom = new DateTime(lastMonth.Year, lastMonth.Month, 1);
        _absentTo = new DateTime(lastMonth.Year, lastMonth.Month, DateTime.DaysInMonth(lastMonth.Year, lastMonth.Month));
        
        _ = ApplyAbsentFilter();
    }

    private async Task ApplyAbsentFilter()
    {
        _isAbsentLoading = true;
        try
        {
            if (_absentFrom.HasValue && _absentTo.HasValue)
            {
                await AttendanceService.CalculateAttendanceAsync(_absentFrom, _absentTo);
                var summary = await AttendanceService.GetAbsentSummaryAsync(_absentFrom.Value, _absentTo.Value);
                _absentSummaries = summary.ToDictionary(s => s.EmployeeId, s => s, StringComparer.OrdinalIgnoreCase);
            }
            
            _isAbsentFilterActive = true;
            
            if (_absentFrom.HasValue && _absentTo.HasValue) {
                _lastMonthLabel = $"{_absentFrom.Value:MMM dd} - {_absentTo.Value:MMM dd}";
            } else {
                _lastMonthLabel = "Selected Period";
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load absent counts: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAbsentLoading = false;
            StateHasChanged();
        }
    }

    private void ResetAll()
    {
        ClearFilters();
        _selectedEmpIds.Clear();
        _form = new SepForm();
    }

    private async Task SaveSeparations()
    {
        if (_selectedEmpIds.Count == 0) return;
        _isSaving = true;

        try
        {
            var selected = _employees.Where(e => _selectedEmpIds.Contains(e.EmployeeId)).ToList();
            var payload  = selected.Select(emp => new Separation
            {
                EmployeeId      = emp.EmployeeId,
                EmployeeName    = emp.EmployeeName,
                DepartmentId    = emp.DepartmentId,
                SectionId       = emp.SectionId,
                DesignationId   = emp.DesignationId,
                SeparationType  = _form.SeparationType,
                Status          = _form.Status,
                ResignDate      = _form.ResignDate,
                LastWorkingDay  = _form.LastWorkingDay,
                ClearanceProgress = _form.ClearanceProgress,
                Reason          = _form.Reason
            }).ToList();

            var response = await Http.PostAsJsonAsync($"{NavManager.BaseUri}api/separations/bulk", payload);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{payload.Count} separation(s) recorded successfully!", Severity.Success);
                NavManager.NavigateTo("/hr/seperation");
            }
            else
            {
                Snackbar.Add($"Save failed: {await response.Content.ReadAsStringAsync()}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // Lookup helpers
    private string GetDeptName(int id)    => _departments .FirstOrDefault(d => d.Id == id)?.NameEn   ?? "-";
    private string GetSectionName(int id) => _sections    .FirstOrDefault(s => s.Id == id)?.NameEn   ?? "-";
    private string GetDesigName(int id)   => _designations.FirstOrDefault(d => d.Id == id)?.NameEn   ?? "-";
    private string GetLineName(int id)    => _lines       .FirstOrDefault(l => l.Id == id)?.NameEn ?? "-";
}
