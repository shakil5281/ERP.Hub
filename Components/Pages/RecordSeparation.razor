@page "/hr/record-separation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ToastService Toast
@inject AttendanceService AttendanceService

<PageTitle>ERPHub - Record Employee Separation</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header *@
        <div class="d-flex justify-between align-center mb-6" style="flex-wrap:wrap; gap: 16px;width: 100%;">
            <div>
                <h5 class="text-[22px] font-extrabold">Record Employee Separation</h5>
                <p class="text-xs text-zinc-500 mt-1">Find absent employees and record their separation.</p>
            </div>
        </div>

        @* Filters *@
        <div class="bg-white border border-zinc-200 rounded-lg p-4 mb-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3" style="align-items:end;">
                <div>
                    <label class="form-label">From Date</label>
                    <input type="date" class="form-control" value="@_fromDate.ToString("yyyy-MM-dd")" @onchange="@(e => { if (DateTime.TryParse((e as ChangeEventArgs)?.Value?.ToString(), out var d)) _fromDate = d; })" />
                </div>
                <div>
                    <label class="form-label">To Date</label>
                    <input type="date" class="form-control" value="@_toDate.ToString("yyyy-MM-dd")" @onchange="@(e => { if (DateTime.TryParse((e as ChangeEventArgs)?.Value?.ToString(), out var d)) _toDate = d; })" />
                </div>
                <div>
                    <label class="form-label">Min Cont. Absent</label>
                    <input type="number" class="form-control" @bind="_minContinuousAbsent" min="0" />
                </div>
                <div>
                    <label class="form-label">Employee ID</label>
                    <input type="text" class="form-control" @bind="_employeeIdFilter" />
                </div>
                <div>
                    <label class="form-label">Department</label>
                    <select class="form-control" @bind="_departmentIdFilter">
                        <option value="0">All</option>
                        @foreach (var d in _departments) { <option value="@d.Id">@d.NameEn</option> }
                    </select>
                </div>
                <div>
                    <label class="form-label">Designation</label>
                    <select class="form-control" @bind="_designationIdFilter">
                        <option value="0">All</option>
                        @foreach (var dg in _designations) { <option value="@dg.Id">@dg.NameEn</option> }
                    </select>
                </div>
                <div class="col-span-1 sm:col-span-2 md:col-span-3 flex justify-end gap-2" style="margin-top: 10px;">
                    <button class="btn btn-primary px-8" disabled="@_isLoading" @onclick="LoadRecords">Apply Filters</button>
                    <button class="btn btn-outlined px-8" @onclick="ClearFilters">Clear</button>
                </div>
            </div>
        </div>

        @* Data Table *@
        @if (_isLoading)
        {
            <div class="text-center py-8 text-zinc-500 text-sm">Loading records...</div>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden mb-6">
                <div class="table-toolbar">
                    <div>
                        <span class="text-sm font-bold font-heading">Absent Employees</span>
                        <span class="text-xs text-zinc-500 ml-2">@_fromDate.ToString("yyyy-MM-dd") to @_toDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="relative">
                        <input type="text" class="form-control pl-10" @bind="_searchString" placeholder="Quick search name or ID..." />
                        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                </div>
                <div class="table-body">
                    <table class="data-table-base">
                        <thead>
                            <tr>
                                <th style="width:44px; text-align:center;">
                                    <input type="checkbox" class="form-check-input" checked="@_selectAll" @onchange="ToggleSelectAll" />
                                </th>
                                <th style="text-align:center;"><button class="sort-btn">Employee ID</button></th>
                                <th><button class="sort-btn">Employee Name</button></th>
                                <th><button class="sort-btn">Department</button></th>
                                <th><button class="sort-btn">Designation</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Total Absent</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Continuous Absent</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var context in _records.Where(FilterFunc))
                            {
                                var isSelected = _selectedEmpIds.Contains(context.EmployeeId);
                                <tr>
                                    <td style="text-align:center;">
                                        <input type="checkbox" class="form-check-input" checked="@isSelected" @onchange="@((ChangeEventArgs e) => ToggleEmployee(context, (bool)(e.Value ?? false)))" />
                                    </td>
                                    <td style="text-align:center;">
                                        <span class="text-sm font-bold font-mono">@context.EmployeeId</span>
                                    </td>
                                    <td><span class="text-sm fw-medium">@context.EmployeeName</span></td>
                                    <td><span class="text-sm">@context.Department</span></td>
                                    <td><span class="text-sm">@context.Designation</span></td>
                                    <td style="text-align:center;">
                                        <span class="text-sm font-bold text-error">@context.TotalAbsentDays</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <span class="text-sm font-bold text-warning">@context.ContinuousAbsentDays</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!_records.Any(FilterFunc))
                {
                    <div class="table-empty">
                        <span class="text-sm text-zinc-500">No absent employees found</span>
                    </div>
                }
            </div>

            @if (_selectedEmpIds.Count > 0)
            {
                <div class="bg-white border-2 rounded-xl p-6 mt-6" style="border-color:var(--mud-palette-primary); background-color:var(--mud-palette-primary-hover);">
                    <h6 class="text-base font-bold mb-2">Record Separation for @_selectedEmpIds.Count Selected Employee(s)</h6>
                    <hr class="divider mb-4" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
                        <div>
                            <label class="form-label">Separation Type</label>
                            <select class="form-control" @bind="_form.SeparationType" required>
                                <option value="Resign">Resign</option>
                                <option value="Left">Left</option>
                                <option value="Close">Close</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Separation Date</label>
                            <input type="date" class="form-control" value="@_form.SeparationDate?.ToString("yyyy-MM-dd")" @onchange="@(e => { if (DateTime.TryParse((e as ChangeEventArgs)?.Value?.ToString(), out var d)) _form.SeparationDate = d; })" required />
                        </div>
                        <div>
                            <label class="form-label">Approved By</label>
                            <input type="text" class="form-control" @bind="_form.ApprovedBy" />
                        </div>
                        <div class="col-span-1 sm:col-span-2 md:col-span-3">
                            <label class="form-label">Reason</label>
                            <textarea class="form-control" @bind="_form.Reason" rows="2"></textarea>
                        </div>
                        <div class="col-span-1 sm:col-span-2 md:col-span-3">
                            <label class="form-label">Remarks</label>
                            <textarea class="form-control" @bind="_form.Remarks" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="flex justify-end mt-4 gap-2">
                        <button class="btn btn-outlined" @onclick="ResetAll">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveSeparations" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Record Separations")
                        </button>
                    </div>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _toDate = DateTime.Today;

    private string? _employeeIdFilter;
    private int _departmentIdFilter;
    private int _designationIdFilter;
    private int _minContinuousAbsent = 0;

    private bool _isLoading;
    private bool _isSaving;
    private string _searchString = "";

    private List<AbsentSummaryDto> _records = new();
    private List<AbsentSummaryDto> _allRecords = new();

    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Employee> _employees = new();

    private HashSet<string> _selectedEmpIds = new(StringComparer.OrdinalIgnoreCase);
    private bool _selectAll;
    private SepForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(departmentsTask, designationsTask, employeesTask);

            _departments = await departmentsTask ?? new();
            _designations = await designationsTask ?? new();
            _employees = await employeesTask ?? new();
        }
        catch
        {
        }
    }

    private async Task LoadRecords()
    {
        _isLoading = true;
        _selectedEmpIds.Clear();
        _selectAll = false;
        StateHasChanged();

        try
        {
            await AttendanceService.CalculateAttendanceAsync(_fromDate, _toDate);

            _allRecords = await AttendanceService.GetAbsentSummaryAsync(_fromDate, _toDate, _employeeIdFilter, null);

            ApplyClientFilters();
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Error loading records: {ex.Message}");
            _allRecords = new();
            _records = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyClientFilters()
    {
        var matchingEmployeeIds = _employees
            .Where(e =>
                (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
                (_designationIdFilter == 0 || e.DesignationId == _designationIdFilter))
            .Select(e => e.EmployeeId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        bool hasOrgFilter = _departmentIdFilter > 0 || _designationIdFilter > 0;

        _records = _allRecords
            .Where(r => (!hasOrgFilter || matchingEmployeeIds.Contains(r.EmployeeId)) &&
                        r.ContinuousAbsentDays >= _minContinuousAbsent)
            .ToList();
    }

    private async Task ClearFilters()
    {
        _fromDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
        _toDate = DateTime.Today;
        _employeeIdFilter = null;
        _departmentIdFilter = 0;
        _designationIdFilter = 0;
        _minContinuousAbsent = 0;
        _searchString = "";

        _records.Clear();
        _allRecords.Clear();
        _selectedEmpIds.Clear();
        _selectAll = false;
        _form = new SepForm();
    }

    private bool FilterFunc(AbsentSummaryDto element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.EmployeeName != null && element.EmployeeName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Department != null && element.Department.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        _selectAll = isChecked;
        if (isChecked)
        {
            foreach (var r in _records.Where(FilterFunc))
            {
                _selectedEmpIds.Add(r.EmployeeId);
            }
        }
        else
        {
            _selectedEmpIds.Clear();
        }
    }

    private void ToggleEmployee(AbsentSummaryDto emp, bool isChecked)
    {
        if (isChecked) _selectedEmpIds.Add(emp.EmployeeId);
        else _selectedEmpIds.Remove(emp.EmployeeId);

        _selectAll = _selectedEmpIds.Count == _records.Count(FilterFunc);
    }

    private void ResetAll()
    {
        _selectedEmpIds.Clear();
        _selectAll = false;
        _form = new SepForm();
    }

    private async Task SaveSeparations()
    {
        if (_selectedEmpIds.Count == 0) return;
        _isSaving = true;

        try
        {
            var selected = _employees.Where(e => _selectedEmpIds.Contains(e.EmployeeId)).ToList();
            var payload = selected.Select(emp => new RecordSeparationRequest
            {
                EmployeeId = emp.EmployeeId,
                SeparationType = _form.SeparationType,
                SeparationDate = _form.SeparationDate ?? DateTime.Today,
                Reason = _form.Reason,
                Remarks = _form.Remarks,
                ApprovedBy = _form.ApprovedBy,
                ApprovedDate = DateTime.Today,
                CreatedBy = "HR"
            }).ToList();

            var response = await Http.PostAsJsonAsync($"{NavManager.BaseUri}api/separations/bulk", payload);
            if (response.IsSuccessStatusCode)
            {
                await Toast.ShowSuccessAsync($"{payload.Count} separation(s) recorded successfully!");
                NavManager.NavigateTo("/hr/seperation");
            }
            else
            {
                await Toast.ShowErrorAsync($"Save failed: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Error: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class SepForm
    {
        public string SeparationType { get; set; } = SeparationTypes.Left;
        public DateTime? SeparationDate { get; set; } = DateTime.Today;
        public string ApprovedBy { get; set; } = "HR";
        public string Reason { get; set; } = "";
        public string Remarks { get; set; } = "";
    }
}
