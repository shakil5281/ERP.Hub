@page "/address"

<PageTitle>ERPHub - Address Directory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Address Directory</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage physical office locations, factories, and warehouses.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden mb-6">
                <MudTable Items="@_locations" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<BranchLocation, object>(x=>x.BranchName)">Branch Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BranchLocation, object>(x=>x.Type)">Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BranchLocation, object>(x=>x.StreetAddress)">Street Address</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<BranchLocation, object>(x=>x.Country)">Country</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Branch Name">@context.BranchName</MudTd>
                        <MudTd DataLabel="Type">@context.Type</MudTd>
                        <MudTd DataLabel="Street Address">@context.StreetAddress</MudTd>
                        <MudTd DataLabel="Country">@context.Country</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class BranchLocation
    {
        public string BranchName { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string StreetAddress { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
    }

    private List<BranchLocation> _locations = new()
    {
        new BranchLocation { BranchName = "Silicon Valley Office", Type = "Corporate HQ", StreetAddress = "100 Enterprise Way, Suite 400, Silicon Valley, CA 94025", Country = "United States" },
        new BranchLocation { BranchName = "Austin Factory", Type = "Manufacturing Unit", StreetAddress = "500 Innovation Boulevard, Austin, TX 78701", Country = "United States" },
        new BranchLocation { BranchName = "Rotterdam Hub", Type = "Distribution Center", StreetAddress = "Port of Rotterdam, Quay 12, Rotterdam, 3011 AA", Country = "Netherlands" }
    };
}
