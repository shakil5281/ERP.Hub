@page "/hr/employees"
@using ERPHub.Models
@using ERPHub.Services
@inject IErpService ErpService

<PageTitle>ERPHub - Employee Directory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Information</h2>
                </div>
                <div class="flex gap-2">
                    <NavLink href="/hr/import-employees" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md border border-zinc-300 text-zinc-700 bg-white font-semibold hover:bg-zinc-50 transition-colors cursor-pointer">
                        Import Excel
                    </NavLink>
                    <NavLink href="/hr/add-employee" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">+ Add Employee</NavLink>
                </div>
            </div>

            <!-- Premium Advanced Filter Section -->
            <div class="mb-8 relative animate-fade-in">
                <div class="bg-white border border-zinc-200 rounded-lg p-6">
                    <div class="flex items-center justify-between mb-5">
                        <h3 class="text-sm font-bold text-zinc-800 tracking-wide uppercase flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            Advanced Filtering
                        </h3>
                        @if (HasActiveFilters)
                        {
                            <button type="button" class="text-xs font-semibold text-pink-600 hover:text-pink-700 bg-pink-50 hover:bg-pink-100 px-3 py-1.5 rounded-full transition-colors cursor-pointer" @onclick="ClearFilters">
                                Clear All
                            </button>
                        }
                    </div>

                    <div class="flex flex-col gap-4">
                        <!-- Search Bar -->
                        <div class="relative w-full">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input type="text" class="block w-full pl-10 pr-3 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-900 placeholder-zinc-400" placeholder="Search employees by name, email or role..." @bind="_searchQuery" @bind:event="oninput" />
                        </div>
                        
                        <!-- Filters Container -->
                        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
                            <!-- Employee ID -->
                            <MudTextField T="string" @bind-Value="_employeeIdFilter" Label="Employee ID" Placeholder="e.g. 1001" Variant="Variant.Outlined" Margin="Margin.Dense" dense="true" />

                            <!-- Company -->
                            <MudSelect T="string" @bind-Value="_selectedCompany" Label="Company" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Companies</MudSelectItem>
                                @foreach (var c in _companies)
                                {
                                    <MudSelectItem Value="@c.CompanyNameEn">@c.CompanyNameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Department -->
                            <MudSelect T="string" @bind-Value="_selectedDept" Label="Department" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Departments</MudSelectItem>
                                @foreach (var dept in _departments)
                                {
                                    <MudSelectItem Value="@dept.NameEn">@dept.NameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Section -->
                            <MudSelect T="string" @bind-Value="_selectedSection" Label="Section" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Sections</MudSelectItem>
                                @foreach (var sec in _sections)
                                {
                                    <MudSelectItem Value="@sec.NameEn">@sec.NameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Designation -->
                            <MudSelect T="string" @bind-Value="_selectedDesignation" Label="Designation" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Designations</MudSelectItem>
                                @foreach (var desig in _designations)
                                {
                                    <MudSelectItem Value="@desig.NameEn">@desig.NameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Line -->
                            <MudSelect T="string" @bind-Value="_selectedLine" Label="Line" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Lines</MudSelectItem>
                                @foreach (var line in _lines)
                                {
                                    <MudSelectItem Value="@line.NameEn">@line.NameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Group -->
                            <MudSelect T="string" @bind-Value="_selectedGroup" Label="Group" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Groups</MudSelectItem>
                                @foreach (var group in _groups)
                                {
                                    <MudSelectItem Value="@group.GroupName">@group.GroupName</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Status -->
                            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Statuses</MudSelectItem>
                                <MudSelectItem Value="@("Regular")">Regular</MudSelectItem>
                                <MudSelectItem Value="@("Resign")">Resign</MudSelectItem>
                                <MudSelectItem Value="@("Left")">Left</MudSelectItem>
                                <MudSelectItem Value="@("Close")">Close</MudSelectItem>
                            </MudSelect>

                            <!-- Year -->
                            <MudSelect T="string" @bind-Value="_selectedYear" Label="Year" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("")">All Years</MudSelectItem>
                                <MudSelectItem Value="@("2020")">2020</MudSelectItem>
                                <MudSelectItem Value="@("2021")">2021</MudSelectItem>
                                <MudSelectItem Value="@("2022")">2022</MudSelectItem>
                                <MudSelectItem Value="@("2023")">2023</MudSelectItem>
                            </MudSelect>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Employee DataTable -->
            @if (_isLoading)
            {
                <div class="text-center py-8 text-zinc-500 text-sm">Loading employees...</div>
            }
            else
            {
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <MudTable Items="@FilteredEmployees" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                        <HeaderContent>
                            <MudTh>Avatar</MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.PunchNumber)">Punch No</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Department != null ? x.Department.NameEn : string.Empty)">Department</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Section != null ? x.Section.NameEn : string.Empty)">Section</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Designation != null ? x.Designation.NameEn : string.Empty)">Designation</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Line != null ? x.Line.NameEn : string.Empty)">Line</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.JoiningDate)">Join Date</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.EmployeeStatus)">Status</MudTableSortLabel></MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Avatar">
                                <div class="w-8 h-8 rounded-full bg-zinc-200 text-zinc-700 flex items-center justify-center text-xs font-bold">@GetInitials(context.EmployeeName)</div>
                            </MudTd>
                            <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                            <MudTd DataLabel="Punch No">@context.PunchNumber</MudTd>
                            <MudTd DataLabel="Email">@context.Email</MudTd>
                            <MudTd DataLabel="Department">@context.Department?.NameEn</MudTd>
                            <MudTd DataLabel="Section">@context.Section?.NameEn</MudTd>
                            <MudTd DataLabel="Designation">@context.Designation?.NameEn</MudTd>
                            <MudTd DataLabel="Line">@context.Line?.NameEn</MudTd>
                            <MudTd DataLabel="Join Date">@context.JoiningDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd DataLabel="Status">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @GetStatusBadge(context.EmployeeStatus)">@context.EmployeeStatus</span>
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                <div class="flex items-center gap-1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => NavManager.NavigateTo($"/hr/edit-employee/{context.Id}"))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => ConfirmDelete(context))" />
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                    </NoRecordsContent>
                    </MudTable>
                </div>
            }
        </div>

        @if (_showDeleteDialog)
        {
            <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[9999] animate-fade-in">
                <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
                    <h3 class="text-lg font-bold text-zinc-800 mb-2">Delete Employee</h3>
                    <p class="text-sm text-zinc-500 mb-5">Are you sure you want to delete <strong>@(_employeeToDelete?.EmployeeName)</strong>? This action cannot be undone.</p>
                    <div class="flex justify-end gap-2">
                        <button @onclick="CancelDelete" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors text-sm">Cancel</button>
                        <button @onclick="ExecuteDelete" class="py-2 px-4 rounded-lg bg-red-600 text-white font-semibold hover:bg-red-700 transition-colors text-sm">Delete</button>
                    </div>
                </div>
            </div>
        }
        @if (_showToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✓</span>
                <span>@_toastMessage</span>
            </div>
        }
        @if (_showErrorToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✗</span>
                <span>@_errorMessage</span>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private NavigationManager NavManager { get; set; } = default!;

    private string _searchQuery = "";
    private string _employeeIdFilter = "";
    private string _selectedCompany = "";
    private string _selectedDept = "";
    private string _selectedSection = "";
    private string _selectedDesignation = "";
    private string _selectedLine = "";
    private string _selectedGroup = "";
    private string _selectedStatus = "";
    private string _selectedYear = "";

    private bool _showAdvancedFilters = false;
    private bool _isLoading = true;
    private bool _showDeleteDialog = false;
    private Employee? _employeeToDelete;
    private List<Employee> _employees = new();
    
    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();
    private List<Line> _lines = new();
    private List<BusinessGroup> _groups = new();

    protected override async Task OnInitializedAsync()
    {
        var baseUri = NavManager.BaseUri;
        await Task.WhenAll(
            LoadEmployeesAsync(baseUri),
            LoadLookupDataAsync(baseUri)
        );
    }

    private async Task LoadEmployeesAsync(string baseUri)
    {
        try
        {
            _employees = await Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading employees: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadLookupDataAsync(string baseUri)
    {
        try
        {
            var deptTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var compTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var secTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var desigTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var lineTask = Http.GetFromJsonAsync<List<Line>>($"{baseUri}api/lines");

            await Task.WhenAll(deptTask, compTask, secTask, desigTask, lineTask);

            _departments = await deptTask ?? new();
            _companies = await compTask ?? new();
            _sections = await secTask ?? new();
            _designations = await desigTask ?? new();
            _lines = await lineTask ?? new();
            
            // Group has no API controller, load via ErpService
            _groups = await ErpService.GetBusinessGroupsAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading lookups: {ex.Message}");
        }
    }

    private void ToggleAdvancedFilters() => _showAdvancedFilters = !_showAdvancedFilters;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_employeeIdFilter) ||
                                     !string.IsNullOrEmpty(_selectedCompany) ||
                                     !string.IsNullOrEmpty(_selectedDept) || 
                                     !string.IsNullOrEmpty(_selectedSection) || 
                                     !string.IsNullOrEmpty(_selectedDesignation) || 
                                     !string.IsNullOrEmpty(_selectedLine) || 
                                     !string.IsNullOrEmpty(_selectedGroup) || 
                                     !string.IsNullOrEmpty(_selectedStatus) || 
                                     !string.IsNullOrEmpty(_selectedYear);

    private void ClearFilters()
    {
        _employeeIdFilter = "";
        _selectedCompany = "";
        _selectedDept = "";
        _selectedSection = "";
        _selectedDesignation = "";
        _selectedLine = "";
        _selectedGroup = "";
        _selectedStatus = "";
        _selectedYear = "";
    }

    private IEnumerable<Employee> FilteredEmployees => _employees
        .Where(e => string.IsNullOrEmpty(_searchQuery) || 
                    e.EmployeeName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    e.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    (e.EmployeeId != null && e.EmployeeId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)))
        .Where(e => string.IsNullOrEmpty(_employeeIdFilter) || (e.EmployeeId != null && e.EmployeeId.Equals(_employeeIdFilter, StringComparison.OrdinalIgnoreCase)))
        .Where(e => string.IsNullOrEmpty(_selectedCompany) || (e.Company?.CompanyNameEn == _selectedCompany))
        .Where(e => string.IsNullOrEmpty(_selectedDept) || (e.Department?.NameEn == _selectedDept))
        .Where(e => string.IsNullOrEmpty(_selectedSection) || (e.Section?.NameEn == _selectedSection))
        .Where(e => string.IsNullOrEmpty(_selectedDesignation) || (e.Designation?.NameEn == _selectedDesignation))
        .Where(e => string.IsNullOrEmpty(_selectedLine) || (e.Line?.NameEn == _selectedLine))
        // Note: Group is not currently a property on Employee, so we don't filter by it physically. If GroupId is added later, filter here.
        .Where(e => string.IsNullOrEmpty(_selectedStatus) || e.EmployeeStatus == _selectedStatus)
        .Where(e => string.IsNullOrEmpty(_selectedYear) || e.JoiningDate.Year.ToString() == _selectedYear);

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private static string GetStatusBadge(string status)
    {
        return status switch
        {
            "Regular" => "bg-green-50 text-green-700",
            "Resign" => "bg-amber-50 text-amber-700",
            "Left" => "bg-red-50 text-red-700",
            "Close" => "bg-zinc-100 text-zinc-600",
            _ => "bg-zinc-100 text-zinc-600"
        };
    }

    private void ConfirmDelete(Employee employee)
    {
        _employeeToDelete = employee;
        _showDeleteDialog = true;
    }

    private void CancelDelete()
    {
        _employeeToDelete = null;
        _showDeleteDialog = false;
    }

    private async Task ExecuteDelete()
    {
        if (_employeeToDelete == null) return;
        try
        {
            var baseUri = NavManager.BaseUri;
            var response = await Http.DeleteAsync($"{baseUri}api/employees/{_employeeToDelete.Id}");
            if (response.IsSuccessStatusCode)
            {
                _employees.Remove(_employeeToDelete);
                _showDeleteDialog = false;
                _employeeToDelete = null;
                ShowToast("Employee deleted successfully.");
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                ShowErrorToast($"Failed to delete employee. {errorBody}");
                _showDeleteDialog = false;
                _employeeToDelete = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting employee: {ex.Message}");
            ShowErrorToast($"Error: {ex.Message}");
            _showDeleteDialog = false;
            _employeeToDelete = null;
        }
    }

    private bool _showToast = false;
    private string _toastMessage = string.Empty;
    private bool _showErrorToast = false;
    private string _errorMessage = string.Empty;

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _showToast = true;
        _showErrorToast = false;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            _showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void ShowErrorToast(string message)
    {
        _errorMessage = message;
        _showErrorToast = true;
        _showToast = false;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            _showErrorToast = false;
            InvokeAsync(StateHasChanged);
        });
    }
}
