@page "/hr/employees"

<PageTitle>ERPHub - Employee Directory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Information</h2>
                </div>
                <div>
                    <NavLink href="/hr/add-employee" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">+ Add Employee</NavLink>
                </div>
            </div>

            <!-- Premium Advanced Filter Section -->
            <div class="mb-8 relative animate-fade-in">
                <div class="bg-white border border-zinc-200 rounded-lg p-6">
                    <div class="flex items-center justify-between mb-5">
                        <h3 class="text-sm font-bold text-zinc-800 tracking-wide uppercase flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            Advanced Filtering
                        </h3>
                        @if (HasActiveFilters)
                        {
                            <button type="button" class="text-xs font-semibold text-pink-600 hover:text-pink-700 bg-pink-50 hover:bg-pink-100 px-3 py-1.5 rounded-full transition-colors cursor-pointer" @onclick="ClearFilters">
                                Clear All
                            </button>
                        }
                    </div>

                    <div class="flex flex-col gap-4">
                        <!-- Search Bar -->
                        <div class="relative w-full">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input type="text" class="block w-full pl-10 pr-3 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-900 placeholder-zinc-400" placeholder="Search employees by name, email or role..." @bind="_searchQuery" @bind:event="oninput" />
                        </div>
                        
                        <!-- Filters Container: 3 Columns -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Department -->
                            <div class="relative">
                                <select class="block w-full appearance-none pl-4 pr-10 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-700 font-medium cursor-pointer" @bind="_selectedDept">
                                    <option value="">All Departments</option>
                                    @foreach (var dept in _departments)
                                    {
                                        <option value="@dept.NameEn">@dept.NameEn</option>
                                    }
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                            </div>

                            <!-- Status -->
                            <div class="relative">
                                <select class="block w-full appearance-none pl-4 pr-10 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-700 font-medium cursor-pointer" @bind="_selectedStatus">
                                    <option value="">All Statuses</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                            </div>

                            <!-- Year -->
                            <div class="relative">
                                <select class="block w-full appearance-none pl-4 pr-10 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-700 font-medium cursor-pointer" @bind="_selectedYear">
                                    <option value="">All Years</option>
                                    <option value="2020">2020</option>
                                    <option value="2021">2021</option>
                                    <option value="2022">2022</option>
                                    <option value="2023">2023</option>
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Employee DataTable -->
            @if (_isLoading)
            {
                <div class="text-center py-8 text-zinc-500 text-sm">Loading employees...</div>
            }
            else
            {
                <DataTable TItem="Employee" Items="FilteredEmployees">
                    <HeaderTemplate>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left w-12">Avatar</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left font-heading">Employee Name</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left font-body">Email</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Department</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Section</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Designation</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Line</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Join Date</th>
                        <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Status</th>
                    </HeaderTemplate>
                    <RowTemplate Context="emp">
                        <td class="p-2.5 px-4">
                            <div class="w-8 h-8 rounded-full bg-zinc-200 text-zinc-700 flex items-center justify-center text-xs font-bold font-heading">
                                @GetInitials(emp.EmployeeName)
                            </div>
                        </td>
                        <td class="p-2.5 px-4 text-zinc-900 font-bold font-heading">@emp.EmployeeName</td>
                        <td class="p-2.5 px-4 text-indigo-600 text-xs font-semibold font-body">@emp.Email</td>
                        <td class="p-2.5 px-4 text-zinc-700 text-xs">@emp.Department?.NameEn</td>
                        <td class="p-2.5 px-4 text-zinc-700 text-xs">@emp.Section?.NameEn</td>
                        <td class="p-2.5 px-4 text-zinc-650 text-xs">@emp.Designation?.NameEn</td>
                        <td class="p-2.5 px-4 text-zinc-650 text-xs">@emp.Line?.NameEn</td>
                        <td class="p-2.5 px-4 text-zinc-500 text-xs font-body">@emp.JoiningDate.ToString("yyyy-MM-dd")</td>
                        <td class="p-2.5 px-4">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @GetStatusBadge(emp.IsActive)">@(emp.IsActive ? "Active" : "Inactive")</span>
                        </td>
                    </RowTemplate>
                </DataTable>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private NavigationManager NavManager { get; set; } = default!;

    private string _searchQuery = "";
    private string _selectedDept = "";
    private string _selectedStatus = "";
    private string _selectedYear = "";
    private bool _showAdvancedFilters = false;
    private bool _isLoading = true;
    private List<Employee> _employees = new();
    private List<Department> _departments = new();

    protected override async Task OnInitializedAsync()
    {
        var baseUri = NavManager.BaseUri;
        await Task.WhenAll(
            LoadEmployeesAsync(baseUri),
            LoadDepartmentsAsync(baseUri)
        );
    }

    private async Task LoadEmployeesAsync(string baseUri)
    {
        try
        {
            _employees = await Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading employees: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDepartmentsAsync(string baseUri)
    {
        try
        {
            _departments = await Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading departments: {ex.Message}");
        }
    }

    private void ToggleAdvancedFilters() => _showAdvancedFilters = !_showAdvancedFilters;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_selectedDept) || 
                                     !string.IsNullOrEmpty(_selectedStatus) || 
                                     !string.IsNullOrEmpty(_selectedYear);

    private void ClearFilters()
    {
        _selectedDept = "";
        _selectedStatus = "";
        _selectedYear = "";
    }

    private IEnumerable<Employee> FilteredEmployees => _employees
        .Where(e => string.IsNullOrEmpty(_searchQuery) || 
                    e.EmployeeName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    e.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    (e.Designation?.NameEn?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(e => string.IsNullOrEmpty(_selectedDept) || (e.Department?.NameEn == _selectedDept))
        .Where(e => string.IsNullOrEmpty(_selectedStatus) || (e.IsActive && _selectedStatus == "Active") || (!e.IsActive && _selectedStatus == "Inactive"))
        .Where(e => string.IsNullOrEmpty(_selectedYear) || e.JoiningDate.Year.ToString() == _selectedYear);

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private static string GetStatusBadge(bool isActive)
    {
        return isActive ? "bg-green-50 text-green-700" : "bg-amber-50 text-amber-700";
    }
}
