@page "/hr/employees"
@using ERPHub.Models
@using ERPHub.Services
@inject IErpService ErpService

<PageTitle>ERPHub - Employee Directory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Information</h2>
                </div>
                <div class="flex gap-2">
                    <NavLink href="/hr/import-employees" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md border border-zinc-300 text-zinc-700 bg-white font-semibold hover:bg-zinc-50 transition-colors cursor-pointer">
                        Import Excel
                    </NavLink>
                    <NavLink href="/hr/add-employee" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">+ Add Employee</NavLink>
                </div>
            </div>

            <!-- Premium Advanced Filter Section -->
            <div class="mb-8 relative animate-fade-in">
                <div class="bg-white border border-zinc-200 rounded-lg p-6">
                    <div class="flex items-center justify-between mb-5">
                        <h3 class="text-sm font-bold text-zinc-800 tracking-wide uppercase flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            Advanced Filtering
                        </h3>
                        @if (HasActiveFilters)
                        {
                            <button type="button" class="text-xs font-semibold text-pink-600 hover:text-pink-700 bg-pink-50 hover:bg-pink-100 px-3 py-1.5 rounded-full transition-colors cursor-pointer" @onclick="ClearFilters">
                                Clear All
                            </button>
                        }
                    </div>

                    <div class="flex flex-col gap-4">
                        <!-- Search Bar -->
                        <div class="relative w-full">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input type="text" class="block w-full pl-10 pr-3 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-900 placeholder-zinc-400" placeholder="Search employees by name, email or role..." @bind="_searchQuery" @bind:event="oninput" />
                        </div>

                        <!-- Filters Container -->
                        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
                            <!-- Employee ID -->
                            <div>
                                <label class="form-label">Employee ID</label>
                                <input type="text" class="form-control" @bind="_employeeIdFilter" placeholder="e.g. 1001" />
                            </div>

                            <!-- Company -->
                            <div>
                                <label class="form-label">Company</label>
                                <select class="form-control" @bind="_selectedCompany">
                                    <option value="">All Companies</option>
                                    @foreach (var c in _companies)
                                    {
                                        <option value="@c.CompanyNameEn">@c.CompanyNameEn</option>
                                    }
                                </select>
                            </div>

                            <!-- Department -->
                            <div>
                                <label class="form-label">Department</label>
                                <select class="form-control" @bind="_selectedDept">
                                    <option value="">All Departments</option>
                                    @foreach (var dept in _departments)
                                    {
                                        <option value="@dept.NameEn">@dept.NameEn</option>
                                    }
                                </select>
                            </div>

                            <!-- Section -->
                            <div>
                                <label class="form-label">Section</label>
                                <select class="form-control" @bind="_selectedSection">
                                    <option value="">All Sections</option>
                                    @foreach (var sec in _sections)
                                    {
                                        <option value="@sec.NameEn">@sec.NameEn</option>
                                    }
                                </select>
                            </div>

                            <!-- Designation -->
                            <div>
                                <label class="form-label">Designation</label>
                                <select class="form-control" @bind="_selectedDesignation">
                                    <option value="">All Designations</option>
                                    @foreach (var desig in _designations)
                                    {
                                        <option value="@desig.NameEn">@desig.NameEn</option>
                                    }
                                </select>
                            </div>

                            <!-- Line -->
                            <div>
                                <label class="form-label">Line</label>
                                <select class="form-control" @bind="_selectedLine">
                                    <option value="">All Lines</option>
                                    @foreach (var line in _lines)
                                    {
                                        <option value="@line.NameEn">@line.NameEn</option>
                                    }
                                </select>
                            </div>

                            <!-- Group -->
                            <div>
                                <label class="form-label">Group</label>
                                <select class="form-control" @bind="_selectedGroup">
                                    <option value="">All Groups</option>
                                    @foreach (var group in _groups)
                                    {
                                        <option value="@group.GroupName">@group.GroupName</option>
                                    }
                                </select>
                            </div>

                            <!-- Status -->
                            <div>
                                <label class="form-label">Status</label>
                                <select class="form-control" @bind="_selectedStatus">
                                    <option value="">All Statuses</option>
                                    <option value="Active">Active</option>
                                    <option value="Separation">Separation</option>
                                </select>
                            </div>

                            <!-- Year -->
                            <div>
                                <label class="form-label">Year</label>
                                <select class="form-control" @bind="_selectedYear">
                                    <option value="">All Years</option>
                                    <option value="2020">2020</option>
                                    <option value="2021">2021</option>
                                    <option value="2022">2022</option>
                                    <option value="2023">2023</option>
                                </select>
                            </div>
                        </div>

                        <div class="flex justify-end mt-2">
                            <button type="button" class="py-2 px-6 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition-colors text-sm flex items-center gap-2" @onclick="ApplyFilters">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                                Apply Filters
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Employee DataTable -->
            @if (_isLoading)
            {
                <div class="text-center py-8 text-zinc-500 text-sm">Loading employees...</div>
            }
            else
            {
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <div class="table-body">
                        <table class="data-table-base">
                            <thead>
                                <tr>
                                    <th>Avatar</th>
                                    <th><button class="sort-btn">Employee Name</button></th>
                                    <th><button class="sort-btn">Punch No</button></th>
                                    <th><button class="sort-btn">Email</button></th>
                                    <th><button class="sort-btn">Department</button></th>
                                    <th><button class="sort-btn">Section</button></th>
                                    <th><button class="sort-btn">Designation</button></th>
                                    <th><button class="sort-btn">Line</button></th>
                                    <th><button class="sort-btn">Join Date</button></th>
                                    <th><button class="sort-btn">Status</button></th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var context in _employees)
                                {
                                    <tr>
                                        <td>
                                            <div class="w-8 h-8 rounded-full bg-zinc-200 text-zinc-700 flex items-center justify-center text-xs font-bold">@GetInitials(context.EmployeeName)</div>
                                        </td>
                                        <td>@context.EmployeeName</td>
                                        <td>@context.PunchNumber</td>
                                        <td>@context.Email</td>
                                        <td>@context.Department?.NameEn</td>
                                        <td>@context.Section?.NameEn</td>
                                        <td>@context.Designation?.NameEn</td>
                                        <td>@context.Line?.NameEn</td>
                                        <td>@context.JoiningDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @GetStatusBadge(context.Status)">@context.Status</span>
                                            @if (context.Status == "Separation" && !string.IsNullOrEmpty(context.SeparationType))
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 ml-1">@context.SeparationType</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="flex items-center gap-1">
                                                <button class="btn-icon btn-icon-sm text-indigo-500" @onclick='() => NavManager.NavigateTo("/hr/edit-employee/" + context.Id)'>
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                    </svg>
                                                </button>
                                                <button class="btn-icon btn-icon-sm text-red-500" @onclick="() => ConfirmDelete(context)">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (_employees.Count == 0)
                    {
                        <div class="table-empty">
                            <span class="text-sm text-zinc-500">Data Not Available</span>
                        </div>
                    }
                </div>
            }
        </div>

        @if (_showDeleteDialog)
        {
            <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[9999] animate-fade-in">
                <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
                    <h3 class="text-lg font-bold text-zinc-800 mb-2">Delete Employee</h3>
                    <p class="text-sm text-zinc-500 mb-5">Are you sure you want to delete <strong>@(_employeeToDelete?.EmployeeName)</strong>? This action cannot be undone.</p>
                    <div class="flex justify-end gap-2">
                        <button @onclick="CancelDelete" class="py-2 px-4 border border-zinc-200 rounded-lg bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors text-sm">Cancel</button>
                        <button @onclick="ExecuteDelete" class="py-2 px-4 rounded-lg bg-red-600 text-white font-semibold hover:bg-red-700 transition-colors text-sm">Delete</button>
                    </div>
                </div>
            </div>
        }
        @if (_showToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-emerald-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✓</span>
                <span>@_toastMessage</span>
            </div>
        }
        @if (_showErrorToast)
        {
            <div class="fixed bottom-6 right-6 max-sm:left-4 max-sm:right-4 bg-red-600 text-white text-xs font-semibold px-5 py-3 rounded-xl shadow-lg z-[9999] animate-fade-in flex items-center gap-2.5">
                <span>✗</span>
                <span>@_errorMessage</span>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private NavigationManager NavManager { get; set; } = default!;

    private string _searchQuery = "";
    private string _employeeIdFilter = "";
    private string _selectedCompany = "";
    private string _selectedDept = "";
    private string _selectedSection = "";
    private string _selectedDesignation = "";
    private string _selectedLine = "";
    private string _selectedGroup = "";
    private string _selectedStatus = "";
    private string _selectedYear = "";

    private string _activeSearchQuery = "";
    private string _activeEmployeeIdFilter = "";
    private string _activeCompany = "";
    private string _activeDept = "";
    private string _activeSection = "";
    private string _activeDesignation = "";
    private string _activeLine = "";
    private string _activeGroup = "";
    private string _activeStatus = "";
    private string _activeYear = "";

    private bool _showAdvancedFilters = false;
    private bool _isLoading = true;
    private bool _showDeleteDialog = false;
    private Employee? _employeeToDelete;
    private List<Employee> _employees = new();

    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();
    private List<Line> _lines = new();
    private List<BusinessGroup> _groups = new();

    protected override async Task OnInitializedAsync()
    {
        var baseUri = NavManager.BaseUri;
        await Task.WhenAll(
            LoadEmployeesAsync(baseUri),
            LoadLookupDataAsync(baseUri)
        );
    }

    private async Task LoadEmployeesAsync(string baseUri)
    {
        try
        {
            var url = $"{baseUri}api/employees";
            var separator = "?";
            void AddParam(string name, string? value)
            {
                if (!string.IsNullOrEmpty(value))
                {
                    url += $"{separator}{name}={Uri.EscapeDataString(value)}";
                    separator = "&";
                }
            }

            AddParam("searchQuery", _activeSearchQuery);
            AddParam("employeeId", _activeEmployeeIdFilter);
            AddParam("company", _activeCompany);
            AddParam("department", _activeDept);
            AddParam("section", _activeSection);
            AddParam("designation", _activeDesignation);
            AddParam("line", _activeLine);
            AddParam("status", _activeStatus);
            AddParam("year", _activeYear);

            _employees = await Http.GetFromJsonAsync<List<Employee>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading employees: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadLookupDataAsync(string baseUri)
    {
        try
        {
            var deptTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var compTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var secTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var desigTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var lineTask = Http.GetFromJsonAsync<List<Line>>($"{baseUri}api/lines");

            await Task.WhenAll(deptTask, compTask, secTask, desigTask, lineTask);

            _departments = await deptTask ?? new();
            _companies = await compTask ?? new();
            _sections = await secTask ?? new();
            _designations = await desigTask ?? new();
            _lines = await lineTask ?? new();

            _groups = await ErpService.GetBusinessGroupsAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading lookups: {ex.Message}");
        }
    }

    private void ToggleAdvancedFilters() => _showAdvancedFilters = !_showAdvancedFilters;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_activeEmployeeIdFilter) ||
                                     !string.IsNullOrEmpty(_activeCompany) ||
                                     !string.IsNullOrEmpty(_activeDept) ||
                                     !string.IsNullOrEmpty(_activeSection) ||
                                     !string.IsNullOrEmpty(_activeDesignation) ||
                                     !string.IsNullOrEmpty(_activeLine) ||
                                     !string.IsNullOrEmpty(_activeGroup) ||
                                     !string.IsNullOrEmpty(_activeStatus) ||
                                     !string.IsNullOrEmpty(_activeYear);

    private async Task ApplyFilters()
    {
        _activeSearchQuery = _searchQuery;
        _activeEmployeeIdFilter = _employeeIdFilter;
        _activeCompany = _selectedCompany;
        _activeDept = _selectedDept;
        _activeSection = _selectedSection;
        _activeDesignation = _selectedDesignation;
        _activeLine = _selectedLine;
        _activeGroup = _selectedGroup;
        _activeStatus = _selectedStatus;
        _activeYear = _selectedYear;
        await LoadEmployeesAsync(NavManager.BaseUri);
    }

    private async Task ClearFilters()
    {
        _searchQuery = "";
        _employeeIdFilter = "";
        _selectedCompany = "";
        _selectedDept = "";
        _selectedSection = "";
        _selectedDesignation = "";
        _selectedLine = "";
        _selectedGroup = "";
        _selectedStatus = "";
        _selectedYear = "";
        _activeSearchQuery = "";
        _activeEmployeeIdFilter = "";
        _activeCompany = "";
        _activeDept = "";
        _activeSection = "";
        _activeDesignation = "";
        _activeLine = "";
        _activeGroup = "";
        _activeStatus = "";
        _activeYear = "";
        await LoadEmployeesAsync(NavManager.BaseUri);
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private static string GetStatusBadge(string status)
    {
        return status switch
        {
            "Active" => "bg-green-50 text-green-700",
            "Separation" => "bg-red-50 text-red-700",
            _ => "bg-zinc-100 text-zinc-600"
        };
    }

    private void ConfirmDelete(Employee employee)
    {
        _employeeToDelete = employee;
        _showDeleteDialog = true;
    }

    private void CancelDelete()
    {
        _employeeToDelete = null;
        _showDeleteDialog = false;
    }

    private async Task ExecuteDelete()
    {
        if (_employeeToDelete == null) return;
        try
        {
            var baseUri = NavManager.BaseUri;
            var response = await Http.DeleteAsync($"{baseUri}api/employees/{_employeeToDelete.Id}");
            if (response.IsSuccessStatusCode)
            {
                _employees.Remove(_employeeToDelete);
                _showDeleteDialog = false;
                _employeeToDelete = null;
                ShowToast("Employee deleted successfully.");
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                ShowErrorToast($"Failed to delete employee. {errorBody}");
                _showDeleteDialog = false;
                _employeeToDelete = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting employee: {ex.Message}");
            ShowErrorToast($"Error: {ex.Message}");
            _showDeleteDialog = false;
            _employeeToDelete = null;
        }
    }

    private bool _showToast = false;
    private string _toastMessage = string.Empty;
    private bool _showErrorToast = false;
    private string _errorMessage = string.Empty;

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _showToast = true;
        _showErrorToast = false;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            _showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void ShowErrorToast(string message)
    {
        _errorMessage = message;
        _showErrorToast = true;
        _showToast = false;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            _showErrorToast = false;
            InvokeAsync(StateHasChanged);
        });
    }
}
