@page "/hr/employees"

<PageTitle>ERPHub - Employee Directory</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Information</h2>
                </div>
                <div>
                    <NavLink href="/hr/add-employee" type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">+ Add Employee</NavLink>
                </div>
            </div>

            <!-- Premium Advanced Filter Section -->
            <div class="mb-8 relative animate-fade-in">
                <div class="bg-white border border-zinc-200 rounded-lg p-6">
                    <div class="flex items-center justify-between mb-5">
                        <h3 class="text-sm font-bold text-zinc-800 tracking-wide uppercase flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            Advanced Filtering
                        </h3>
                        @if (HasActiveFilters)
                        {
                            <button type="button" class="text-xs font-semibold text-pink-600 hover:text-pink-700 bg-pink-50 hover:bg-pink-100 px-3 py-1.5 rounded-full transition-colors cursor-pointer" @onclick="ClearFilters">
                                Clear All
                            </button>
                        }
                    </div>

                    <div class="flex flex-col gap-4">
                        <!-- Search Bar -->
                        <div class="relative w-full">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input type="text" class="block w-full pl-10 pr-3 py-3 border border-zinc-200 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 rounded-xl bg-zinc-50 hover:bg-white text-sm transition-colors outline-none text-zinc-900 placeholder-zinc-400" placeholder="Search employees by name, email or role..." @bind="_searchQuery" @bind:event="oninput" />
                        </div>
                        
                        <!-- Filters Container: 3 Columns -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Department -->
                            <MudSelect T="string" @bind-Value="_selectedDept" Class="mud-select-square" dense="true" Variant="Variant.Outlined">
                                <MudSelectItem Value="@((string?)null)">All Departments</MudSelectItem>
                                @foreach (var dept in _departments)
                                {
                                    <MudSelectItem Value="@dept.NameEn">@dept.NameEn</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- Status -->
                            <MudSelect T="string" @bind-Value="_selectedStatus" Class="mud-select-square" dense="true" Variant="Variant.Outlined">
                                <MudSelectItem Value="@((string?)null)">All Statuses</MudSelectItem>
                                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                                <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
                            </MudSelect>

                            <!-- Year -->
                            <MudSelect T="string" @bind-Value="_selectedYear" Class="mud-select-square" dense="true" Variant="Variant.Outlined">
                                <MudSelectItem Value="@((string?)null)">All Years</MudSelectItem>
                                <MudSelectItem Value="@("2020")">2020</MudSelectItem>
                                <MudSelectItem Value="@("2021")">2021</MudSelectItem>
                                <MudSelectItem Value="@("2022")">2022</MudSelectItem>
                                <MudSelectItem Value="@("2023")">2023</MudSelectItem>
                            </MudSelect>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Employee DataTable -->
            @if (_isLoading)
            {
                <div class="text-center py-8 text-zinc-500 text-sm">Loading employees...</div>
            }
            else
            {
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <MudTable Items="@FilteredEmployees" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                        <HeaderContent>
                            <MudTh>Avatar</MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.PunchNumber)">Punch No</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Department != null ? x.Department.NameEn : string.Empty)">Department</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Section != null ? x.Section.NameEn : string.Empty)">Section</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Designation != null ? x.Designation.NameEn : string.Empty)">Designation</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.Line != null ? x.Line.NameEn : string.Empty)">Line</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.JoiningDate)">Join Date</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Employee, object>(x=>x.IsActive)">Status</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Avatar">
                                <div class="w-8 h-8 rounded-full bg-zinc-200 text-zinc-700 flex items-center justify-center text-xs font-bold">@GetInitials(context.EmployeeName)</div>
                            </MudTd>
                            <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                            <MudTd DataLabel="Punch No">@context.PunchNumber</MudTd>
                            <MudTd DataLabel="Email">@context.Email</MudTd>
                            <MudTd DataLabel="Department">@context.Department?.NameEn</MudTd>
                            <MudTd DataLabel="Section">@context.Section?.NameEn</MudTd>
                            <MudTd DataLabel="Designation">@context.Designation?.NameEn</MudTd>
                            <MudTd DataLabel="Line">@context.Line?.NameEn</MudTd>
                            <MudTd DataLabel="Join Date">@context.JoiningDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd DataLabel="Status">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @GetStatusBadge(context.IsActive)">@(context.IsActive ? "Active" : "Inactive")</span>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                    </NoRecordsContent>
                    </MudTable>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private NavigationManager NavManager { get; set; } = default!;

    private string _searchQuery = "";
    private string _selectedDept = "";
    private string _selectedStatus = "";
    private string _selectedYear = "";
    private bool _showAdvancedFilters = false;
    private bool _isLoading = true;
    private List<Employee> _employees = new();
    private List<Department> _departments = new();

    protected override async Task OnInitializedAsync()
    {
        var baseUri = NavManager.BaseUri;
        await Task.WhenAll(
            LoadEmployeesAsync(baseUri),
            LoadDepartmentsAsync(baseUri)
        );
    }

    private async Task LoadEmployeesAsync(string baseUri)
    {
        try
        {
            _employees = await Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading employees: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDepartmentsAsync(string baseUri)
    {
        try
        {
            _departments = await Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading departments: {ex.Message}");
        }
    }

    private void ToggleAdvancedFilters() => _showAdvancedFilters = !_showAdvancedFilters;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_selectedDept) || 
                                     !string.IsNullOrEmpty(_selectedStatus) || 
                                     !string.IsNullOrEmpty(_selectedYear);

    private void ClearFilters()
    {
        _selectedDept = "";
        _selectedStatus = "";
        _selectedYear = "";
    }

    private IEnumerable<Employee> FilteredEmployees => _employees
        .Where(e => string.IsNullOrEmpty(_searchQuery) || 
                    e.EmployeeName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    e.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    (e.Designation?.NameEn?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(e => string.IsNullOrEmpty(_selectedDept) || (e.Department?.NameEn == _selectedDept))
        .Where(e => string.IsNullOrEmpty(_selectedStatus) || (e.IsActive && _selectedStatus == "Active") || (!e.IsActive && _selectedStatus == "Inactive"))
        .Where(e => string.IsNullOrEmpty(_selectedYear) || e.JoiningDate.Year.ToString() == _selectedYear);

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private static string GetStatusBadge(bool isActive)
    {
        return isActive ? "bg-green-50 text-green-700" : "bg-amber-50 text-amber-700";
    }
}
