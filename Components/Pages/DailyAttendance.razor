@page "/attendance/daily"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ToastService Toast
@inject LookupDataService LookupData
@inject EmployeeFilterService EmployeeFilterSvc

<PageTitle>ERPHub - Daily Attendance</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header with Export Buttons *@
        <div class="d-flex align-center mb-6 w-100" style="flex-wrap:wrap; gap: 16px; width: 100%;">
            <div>
                <h5 class="fw-extrabold font-heading" style="font-size:1.25rem;">Daily Attendance Sheet</h5>
                <span class="text-xs mud-secondary-text-color mt-1">Track employee check-in/out, late registers, overtime, and daily status.</span>
            </div>
            <div class="flex-grow-1"></div>
            <div class="d-flex justify-end gap-2">
                <button class="btn btn-outlined btn-sm" disabled="@(_records.Count == 0 || _isExporting)" @onclick="ExportToExcel">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    Excel
                </button>
                <button class="btn btn-primary btn-sm" disabled="@(_records.Count == 0 || _isExporting)" @onclick="ExportToPdf">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/></svg>
                    PDF
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert alert-info mb-4">
                <span class="text-xs fw-semibold">@_message</span>
            </div>
        }

        @* Filters *@
        <div class="card mb-4" style="border-radius:8px;">
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-4 gap-3" style="align-items:end;">
                    <div>
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" @bind="_selectedDate" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div>
                        <label class="form-label">Employee ID</label>
                        <input type="text" class="form-control" @bind="_employeeIdFilter" placeholder="e.g. 1001" />
                    </div>
                    <div>
                        <label class="form-label">Employee Status</label>
                        <select class="form-control" @bind="_employeeStatus">
                            <option value="0">All</option>
                            <option value="1">Active</option>
                            <option value="2">Inactive</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Company</label>
                        <select class="form-control" @bind="_companyIdFilter">
                            <option value="0">All Companies</option>
                            @foreach (var c in _companies)
                            {
                                <option value="@c.Id">@c.CompanyNameEn</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Department</label>
                        <select class="form-control" @bind="_departmentIdFilter">
                            <option value="0">All Departments</option>
                            @foreach (var d in _departments)
                            {
                                <option value="@d.Id">@d.NameEn</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Section</label>
                        <select class="form-control" @bind="_sectionIdFilter">
                            <option value="0">All Sections</option>
                            @foreach (var s in _sections)
                            {
                                <option value="@s.Id">@s.NameEn</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Designation</label>
                        <select class="form-control" @bind="_designationIdFilter">
                            <option value="0">All Designations</option>
                            @foreach (var dg in _designations)
                            {
                                <option value="@dg.Id">@dg.NameEn</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Line</label>
                        <select class="form-control" @bind="_lineIdFilter">
                            <option value="0">All Lines</option>
                            @foreach (var l in _lines)
                            {
                                <option value="@l.Id">@l.NameEn</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Group</label>
                        <select class="form-control" @bind="_groupFilter">
                            <option value="All">All Groups</option>
                            <option value="A">Group A</option>
                            <option value="B">Group B</option>
                            <option value="C">Group C</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Shift</label>
                        <select class="form-control" @bind="_shiftIdFilter">
                            <option value="0">All Shifts</option>
                            @foreach (var sh in _shifts)
                            {
                                <option value="@sh.Id">@sh.ShiftName</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Attendance Status</label>
                        <select class="form-control" @bind="_attendanceStatusFilter">
                            <option value="All">All Statuses</option>
                            <option value="Present">Present</option>
                            <option value="Absent">Absent</option>
                            <option value="Late">Late</option>
                            <option value="Leave">Leave</option>
                            <option value="Holiday">Holiday / Off</option>
                        </select>
                    </div>
                    <div class="d-flex align-center gap-2" style="margin-top: 10px;">
                        <button class="btn btn-primary flex-grow-1" disabled="@_isLoading" @onclick="LoadRecords">
                            Apply
                        </button>
                        <button class="btn btn-outlined flex-grow-1" @onclick="ClearFilters">
                            Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Metrics *@
        @if (_records.Count > 0)
        {
            var present = _records.Count(r => AttendanceAnalytics.IsPresent(r.AttendanceStatus));
            var late = _records.Count(r => AttendanceAnalytics.IsLate(r.AttendanceStatus));
            var absent = _records.Count(r => AttendanceAnalytics.IsAbsent(r.AttendanceStatus));
            var leave = _records.Count(r => AttendanceAnalytics.IsLeave(r.AttendanceStatus));
            var total = _records.Count;

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 mb-4">
                <div class="card p-3" style="border-radius:8px;">
                    <span class="text-xs mud-secondary-text-color fw-bold text-uppercase" style="letter-spacing:0.05em;">Total</span>
                    <span class="text-base fw-bold mt-1 d-block">@total</span>
                </div>
                <div class="card p-3" style="border-radius:8px;">
                    <span class="text-xs text-success fw-bold text-uppercase" style="letter-spacing:0.05em;">Present</span>
                    <span class="text-base text-success fw-bold mt-1 d-block">@present</span>
                </div>
                <div class="card p-3" style="border-radius:8px;">
                    <span class="text-xs text-warning fw-bold text-uppercase" style="letter-spacing:0.05em;">Late/Early</span>
                    <span class="text-base text-warning fw-bold mt-1 d-block">@late</span>
                </div>
                <div class="card p-3" style="border-radius:8px;">
                    <span class="text-xs text-error fw-bold text-uppercase" style="letter-spacing:0.05em;">Absent</span>
                    <span class="text-base text-error fw-bold mt-1 d-block">@absent</span>
                </div>
                <div class="card p-3" style="border-radius:8px;">
                    <span class="text-xs text-info fw-bold text-uppercase" style="letter-spacing:0.05em;">Leave/Off</span>
                    <span class="text-base text-info fw-bold mt-1 d-block">@leave</span>
                </div>
            </div>
        }

        @* Attendance Records Table *@
        @if (_isLoading)
        {
            <div class="text-sm text-center mud-secondary-text-color py-8">Loading records...</div>
        }
        else
        {
            <div class="table-card">
                <div class="table-toolbar">
                    <div>
                        <span class="text-sm fw-bold font-heading">Attendance Records</span>
                        <span class="text-xs mud-secondary-text-color d-block">Date: @_selectedDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="flex-grow-1"></div>
                    <input type="text" class="form-control" @bind="_searchString" @bind:event="oninput" placeholder="Quick search name or ID..." style="max-width:220px;" />
                </div>
                <div class="table-body">
                    <table class="w-full border-collapse" style="font-size:0.875rem;">
                        <thead>
                            <tr>
                                <th style="text-align: center;">Sl</th>
                                <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Employee ID</button></th>
                                <th><button class="sort-btn" @onclick="() => {}">Employee Name</button></th>
                                <th style="text-align: center;"><span class="text-xs fw-bold mud-secondary-text-color">In Time</span></th>
                                <th style="text-align: center;"><span class="text-xs fw-bold mud-secondary-text-color">Out Time</span></th>
                                <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Late</button></th>
                                <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">OT</button></th>
                                <th style="text-align: center;"><button class="sort-btn" @onclick="() => {}">Status</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var context in _records.Where(FilterFunc))
                            {
                                <tr>
                                    <td style="text-align: center;" data-label="Sl">@(_records.IndexOf(context) + 1)</td>
                                    <td style="text-align: center;" data-label="Employee ID"><span class="text-sm fw-bold font-mono">@context.EmployeeId</span></td>
                                    <td data-label="Employee Name"><span class="text-sm fw-medium">@GetEmployeeName(context.EmployeeId)</span></td>
                                    <td style="text-align: center;" data-label="In Time"><span class="text-sm font-mono">@FormatTime(context.ActualInPunch)</span></td>
                                    <td style="text-align: center;" data-label="Out Time"><span class="text-sm font-mono">@FormatTime(context.ActualOutPunch)</span></td>
                                    <td style="text-align: center;" data-label="Late">
                                        <span class="text-sm @(context.LateMinutes > 0 ? "fw-bold" : "mud-secondary-text-color")">
                                            @(context.LateMinutes > 0 ? $"{context.LateMinutes}m" : "-")
                                        </span>
                                    </td>
                                    <td style="text-align: center;" data-label="OT">
                                        <span class="text-sm @(context.OvertimeMinutes > 0 ? "fw-bold" : "mud-secondary-text-color")">
                                            @(context.OvertimeMinutes > 0 ? $"{context.OvertimeMinutes}m" : "-")
                                        </span>
                                    </td>
                                    <td style="text-align: center;" data-label="Status">@StatusBadge(context.AttendanceStatus, context.Remarks)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (_records.Count == 0)
                {
                    <div class="table-empty">
                        <span class="text-sm mud-secondary-text-color">Data Not Available</span>
                    </div>
                }
                <div class="table-footer">
                    <div class="pagination">
                        <select class="page-size-select">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span class="pagination-info">1-@_records.Count of @_records.Count</span>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _selectedDate = DateTime.Today;
    private readonly DateTime _minDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private readonly DateTime _maxDate = new(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    private string? _employeeIdFilter;
    private int _employeeStatus; // 0=All, 1=Active, 2=Inactive
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _sectionIdFilter;
    private int _designationIdFilter;
    private int _lineIdFilter;
    private string _groupFilter = "All";
    private string _attendanceStatusFilter = "All";
    private int _shiftIdFilter;
    private bool _isLoading;
    private bool _isExporting;
    private string? _message;
    private string _searchString = "";
    private List<AttendanceRecord> _records = new();
    private List<AttendanceRecord> _allRecords = new();

    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();
    private List<Line> _lines = new();
    private List<ERPHub.Models.Shift> _shifts = new();
    private List<Employee> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadRecords();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var companiesTask  = LookupData.GetCompaniesAsync();
            var departmentsTask = LookupData.GetDepartmentsAsync();
            var sectionsTask   = LookupData.GetSectionsAsync();
            var designationsTask = LookupData.GetDesignationsAsync();
            var linesTask      = LookupData.GetLinesAsync();
            var shiftsTask     = LookupData.GetShiftsAsync();
            var employeesTask  = LookupData.GetEmployeesAsync();

            await Task.WhenAll(companiesTask, departmentsTask, sectionsTask, designationsTask, linesTask, shiftsTask, employeesTask);

            _companies    = await companiesTask;
            _departments  = await departmentsTask;
            _sections     = await sectionsTask;
            _designations = await designationsTask;
            _lines        = await linesTask;
            _shifts       = await shiftsTask;
            _employees    = await employeesTask;
        }
        catch
        {
            // Lookup data failed to load — filters will be empty
        }
    }

    private async Task LoadRecords()
        {
            _isLoading = true;
            _message = null;
            StateHasChanged();

            try
            {
                var url = $"{NavManager.BaseUri}api/attendance/records?fromDate={_selectedDate:yyyy-MM-dd}&toDate={_selectedDate:yyyy-MM-dd}";
                if (!string.IsNullOrWhiteSpace(_employeeIdFilter))
                    url += $"&employeeId={Uri.EscapeDataString(_employeeIdFilter.Trim())}";
                
                // Default to active employees (exclude Resign, Left, Close)
                // Only pass false if explicitly selected "Inactive" in the filter
                if (_employeeStatus == 2)
                    url += "&activeEmployees=false";

                _allRecords = await Http.GetFromJsonAsync<List<AttendanceRecord>>(url) ?? new();
                ApplyClientFilters();
            }
            catch
            {
                _allRecords = new();
                _records = new();
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }

    private void ApplyClientFilters()
    {
        var hasOrgFilter = _departmentIdFilter > 0 || _sectionIdFilter > 0 ||
                           _designationIdFilter > 0 || _lineIdFilter > 0 ||
                           _shiftIdFilter > 0 || _companyIdFilter > 0 ||
                           (_groupFilter != "All" && !string.IsNullOrEmpty(_groupFilter));

        var hasStatusFilter = _attendanceStatusFilter != "All" && !string.IsNullOrEmpty(_attendanceStatusFilter);

        if (!hasOrgFilter && !hasStatusFilter)
        {
            _records = _allRecords;
            return;
        }

        var criteria = new EmployeeFilterCriteria
        {
            CompanyIdFilter = _companyIdFilter,
            DepartmentIdFilter = _departmentIdFilter,
            SectionIdFilter = _sectionIdFilter,
            DesignationIdFilter = _designationIdFilter,
            LineIdFilter = _lineIdFilter,
            ShiftIdFilter = _shiftIdFilter
        };

        var matchingEmployeeIds = EmployeeFilterSvc.GetMatchingEmployeeIds(_employees, criteria);

        _records = _allRecords
            .Where(r => !hasOrgFilter || matchingEmployeeIds.Contains(r.EmployeeId))
            .Where(r => !hasStatusFilter || MatchStatus(r.AttendanceStatus, _attendanceStatusFilter))
            .ToList();
    }

    private bool MatchStatus(string? actualStatus, string filterStatus)
    {
        if (filterStatus == "Absent")  return AttendanceAnalytics.IsAbsent(actualStatus);
        if (filterStatus == "Present") return AttendanceAnalytics.IsPresent(actualStatus);
        if (filterStatus == "Late")    return AttendanceAnalytics.IsLate(actualStatus);
        if (filterStatus == "Leave")   return AttendanceAnalytics.IsLeave(actualStatus);
        if (filterStatus == "Holiday") return actualStatus is "Holiday" or "Weekly Off";
        if (string.IsNullOrEmpty(actualStatus)) return false;
        return actualStatus == filterStatus;
    }

    private async Task ClearFilters()
    {
        _selectedDate = DateTime.Today;
        _employeeIdFilter = null;
        _employeeStatus = 0;
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _sectionIdFilter = 0;
        _designationIdFilter = 0;
        _lineIdFilter = 0;
        _groupFilter = "All";
        _attendanceStatusFilter = "All";
        _shiftIdFilter = 0;
        _searchString = "";
        await LoadRecords();
    }

    private bool FilterFunc(AttendanceRecord element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        var name = GetEmployeeName(element.EmployeeId);
        if (name != null && name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.AttendanceStatus != null && element.AttendanceStatus.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private static string FormatTime(DateTime? dt)
    {
        return dt?.ToString("hh:mm:ss tt") ?? "--:--:--";
    }

    private static string FormatTimeSpan(TimeSpan? ts)
    {
        return ts.HasValue ? DateTime.Today.Add(ts.Value).ToString("hh:mm tt") : "--:--";
    }

    private string GetEmployeeName(string? employeeId)
    {
        if (string.IsNullOrEmpty(employeeId)) return "-";
        var emp = _employees.FirstOrDefault(e => e.EmployeeId == employeeId);
        return emp?.EmployeeName ?? "-";
    }

    private static string GetShortStatus(string status, string? remarks = null)
    {
        if (string.IsNullOrEmpty(status)) return "";
        var shortStatus = AttendanceAnalytics.GetShortStatus(status);
        if (shortStatus != "LV") return shortStatus;
        if (remarks != null && remarks.Contains("SL", StringComparison.OrdinalIgnoreCase)) return "SL";
        if (remarks != null && remarks.Contains("CL", StringComparison.OrdinalIgnoreCase)) return "CL";
        return "CL/SL";
    }

    private static RenderFragment StatusBadge(string status, string? remarks) => builder =>
    {
        var label = GetShortStatus(status, remarks);
        var colorClass = label == "A" ? "text-error fw-bold" : "fw-semibold text-zinc-800";
        
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", colorClass);
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    private async Task ExportToExcel()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                await Toast.ShowWarningAsync("No records match the current filter.");
                return;
            }

            var columns = GetExportColumns(exportRecords);
            var company = _companies.FirstOrDefault();
            var summary = new AttendanceSummary(
                TotalEmployees: exportRecords.Count,
                TotalPresent: exportRecords.Count(r => AttendanceAnalytics.IsPresent(r.AttendanceStatus)),
                TotalAbsent: exportRecords.Count(r => AttendanceAnalytics.IsAbsent(r.AttendanceStatus)),
                TotalLate: exportRecords.Count(r => AttendanceAnalytics.IsLate(r.AttendanceStatus)),
                TotalLeave: exportRecords.Count(r => AttendanceAnalytics.IsLeave(r.AttendanceStatus))
            );

            var bytes = await ExportService.ExportAttendanceToExcelAsync(
                exportRecords,
                "Daily Attendance Sheet",
                _selectedDate,
                company!,
                summary,
                columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendance_{_selectedDate:yyyyMMdd}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            await Toast.ShowSuccessAsync("Excel exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var exportRecords = _records.Where(FilterFunc).ToList();
            if (exportRecords.Count == 0)
            {
                await Toast.ShowWarningAsync("No records match the current filter.");
                return;
            }

            var columns = GetExportColumns(exportRecords);
            var company = _companies.FirstOrDefault();
            var summary = new AttendanceSummary(
                TotalEmployees: exportRecords.Count,
                TotalPresent: exportRecords.Count(r => AttendanceAnalytics.IsPresent(r.AttendanceStatus)),
                TotalAbsent: exportRecords.Count(r => AttendanceAnalytics.IsAbsent(r.AttendanceStatus)),
                TotalLate: exportRecords.Count(r => AttendanceAnalytics.IsLate(r.AttendanceStatus)),
                TotalLeave: exportRecords.Count(r => AttendanceAnalytics.IsLeave(r.AttendanceStatus))
            );

            var bytes = await ExportService.ExportAttendanceToPdfAsync(
                exportRecords,
                "Daily Attendance Sheet",
                _selectedDate,
                company!,
                summary,
                columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendance_{_selectedDate:yyyyMMdd}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            await Toast.ShowSuccessAsync("PDF exported successfully");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<AttendanceRecord, object>> GetExportColumns(List<AttendanceRecord> recordsSource) => new()
    {
        ["Sl"] = r => recordsSource.IndexOf(r) + 1,
        ["Employee ID"] = r => r.EmployeeId,
        ["Employee Name"] = r => GetEmployeeName(r.EmployeeId),
        ["In Time"] = r => r.ActualInPunch?.ToString("hh:mm:ss tt") ?? "--:--:--",
        ["Out Time"] = r => r.ActualOutPunch?.ToString("hh:mm:ss tt") ?? "--:--:--",
        ["Late (min)"] = r => r.LateMinutes > 0 ? r.LateMinutes : 0,
        ["OT (min)"] = r => r.OvertimeMinutes > 0 ? r.OvertimeMinutes : 0,
        ["Status"] = r => GetShortStatus(r.AttendanceStatus, r.Remarks)
    };
}
