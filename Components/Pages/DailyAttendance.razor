@page "/attendance/daily"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>ERPHub - Daily Attendance</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header with Export Buttons *@
        <div class="d-flex justify-content-between align-items-center mb-6" style="flex-wrap:wrap; gap: 16px;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Daily Attendance Sheet</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">Track employee check-in/out, late registers, overtime, and daily status.</MudText>
            </div>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           Disabled="@(_records.Count == 0 || _isExporting)"
                           OnClick="ExportToExcel"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           Size="Size.Small">
                    Excel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(_records.Count == 0 || _isExporting)"
                           OnClick="ExportToPdf"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Size="Size.Small">
                    PDF
                </MudButton>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <MudAlert Severity="Severity.Info" Class="mb-4" dense="true">
                <MudText Typo="Typo.caption" Class="fw-semibold">@_message</MudText>
            </MudAlert>
        }

        @* Filters *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4" Style="border-radius:8px;">
            <MudGrid Spacing="3" class="align-items-end">
                <MudItem xs="12" sm="4" md="3">
                    <MudDatePicker Label="Date"
                                   Date="@_selectedDate"
                                   DateChanged="@(d => { if (d.HasValue) _selectedDate = d.Value; })"
                                   MinDate="@_minDate"
                                   MaxDate="@_maxDate"
                                   Editable="true"
                                   Placeholder="Select Date"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Label="Employee ID"
                                  @bind-Value="_employeeIdFilter"
                                  Variant="Variant.Outlined"
                                  Placeholder="e.g. 1001"
                                  dense="true"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Employee Status"
                               @bind-Value="_employeeStatus"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="0">All</MudSelectItem>
                        <MudSelectItem Value="1">Active</MudSelectItem>
                        <MudSelectItem Value="2">Inactive</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Company"
                               @bind-Value="_companyIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="0">All Companies</MudSelectItem>
                        @foreach (var c in _companies)
                        {
                            <MudSelectItem Value="@c.Id">@c.CompanyNameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Department"
                               @bind-Value="_departmentIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Section"
                               @bind-Value="_sectionIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Sections</MudSelectItem>
                        @foreach (var s in _sections)
                        {
                            <MudSelectItem Value="@s.Id">@s.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Designation"
                               @bind-Value="_designationIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Designations</MudSelectItem>
                        @foreach (var dg in _designations)
                        {
                            <MudSelectItem Value="@dg.Id">@dg.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Line"
                               @bind-Value="_lineIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Lines</MudSelectItem>
                        @foreach (var l in _lines)
                        {
                            <MudSelectItem Value="@l.Id">@l.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Group"
                               @bind-Value="_groupFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="@("All")">All Groups</MudSelectItem>
                        <MudSelectItem Value="@("A")">Group A</MudSelectItem>
                        <MudSelectItem Value="@("B")">Group B</MudSelectItem>
                        <MudSelectItem Value="@("C")">Group C</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect Label="Shift"
                               @bind-Value="_shiftIdFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Shifts</MudSelectItem>
                        @foreach (var sh in _shifts)
                        {
                            <MudSelectItem Value="@sh.Id">@sh.ShiftName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="12" md="3" Class="d-flex align-center gap-2" Style="margin-top: 10px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="@_isLoading" @onclick="LoadRecords" Class="flex-grow-1">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               @onclick="ClearFilters" Class="flex-grow-1">
                        Clear
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Metrics *@
        @if (_records.Count > 0)
        {
            var present = _records.Count(r => r.AttendanceStatus is "Present" or "Present + Overtime" or "Late" or "Early Exit" or "Half Day" or "Holiday Worked" or "Weekly Off Worked" or "Missing In Punch" or "Missing Out Punch");
            var late = _records.Count(r => r.AttendanceStatus is "Late" or "Early Exit");
            var absent = _records.Count(r => r.AttendanceStatus == "Absent" || string.IsNullOrEmpty(r.AttendanceStatus));
            var leave = _records.Count(r => r.AttendanceStatus is "Leave" or "Holiday" or "Weekly Off");
            var total = _records.Count;

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px;">
                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color fw-bold text-uppercase" Style="letter-spacing:0.05em;">Total</MudText>
                        <MudText Typo="Typo.body1" Class="fw-bold mt-1">@total</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px;">
                        <MudText Typo="Typo.caption" Class="text-success fw-bold text-uppercase" Style="letter-spacing:0.05em;">Present</MudText>
                        <MudText Typo="Typo.body1" Class="text-success fw-bold mt-1">@present</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px;">
                        <MudText Typo="Typo.caption" Class="text-warning fw-bold text-uppercase" Style="letter-spacing:0.05em;">Late/Early</MudText>
                        <MudText Typo="Typo.body1" Class="text-warning fw-bold mt-1">@late</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px;">
                        <MudText Typo="Typo.caption" Class="text-error fw-bold text-uppercase" Style="letter-spacing:0.05em;">Absent</MudText>
                        <MudText Typo="Typo.body1" Class="text-error fw-bold mt-1">@absent</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px;">
                        <MudText Typo="Typo.caption" Class="text-info fw-bold text-uppercase" Style="letter-spacing:0.05em;">Leave/Off</MudText>
                        <MudText Typo="Typo.body1" Class="text-info fw-bold mt-1">@leave</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        @* Attendance Records Table *@
        @if (_isLoading)
        {
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Loading records...</MudText>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_records" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0" Filter="new Func<AttendanceRecord, bool>(FilterFunc)">
                    <ToolBarContent>
                        <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Attendance Records</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_searchString"
                                      Placeholder="Quick search name or ID..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Class="mt-0"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.AttendanceDate)">Date</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.EmployeeId)">Employee ID</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => GetEmployeeName(x.EmployeeId))">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudText Typo="Typo.caption" Class="fw-bold mud-secondary-text-color">In Time</MudText></MudTh>
                        <MudTh Style="text-align: center;"><MudText Typo="Typo.caption" Class="fw-bold mud-secondary-text-color">Out Time</MudText></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.LateMinutes)">Late</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.WorkedMinutes)">Worked</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.OvertimeMinutes)">OT</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<AttendanceRecord, object>(x => x.AttendanceStatus)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align: center;" DataLabel="Date"><MudText Typo="Typo.body2" Class="font-mono">@context.AttendanceDate.ToString("yyyy-MM-dd")</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Employee ID"><MudText Typo="Typo.body2" Class="fw-bold font-mono">@context.EmployeeId</MudText></MudTd>
                        <MudTd DataLabel="Employee Name"><MudText Typo="Typo.body2" Class="fw-medium">@GetEmployeeName(context.EmployeeId)</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="In Time"><MudText Typo="Typo.body2" Class="font-mono">@FormatTime(context.ActualInPunch)</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Out Time"><MudText Typo="Typo.body2" Class="font-mono">@FormatTime(context.ActualOutPunch)</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Late">
                            <MudText Typo="Typo.body2" Class="@(context.LateMinutes > 0 ? "fw-bold" : "mud-secondary-text-color")">
                                @(context.LateMinutes > 0 ? $"{context.LateMinutes}m" : "-")
                            </MudText>
                        </MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Worked"><MudText Typo="Typo.body2">@(context.WorkedMinutes > 0 ? $"{context.WorkedMinutes / 60}h {context.WorkedMinutes % 60}m" : "-")</MudText></MudTd>
                        <MudTd Style="text-align: center;" DataLabel="OT">
                            <MudText Typo="Typo.body2" Class="@(context.OvertimeMinutes > 0 ? "fw-bold" : "mud-secondary-text-color")">
                                @(context.OvertimeMinutes > 0 ? $"{context.OvertimeMinutes}m" : "-")
                            </MudText>
                        </MudTd>
                        <MudTd Style="text-align: center;" DataLabel="Status">@StatusBadge(context.AttendanceStatus)</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                    </NoRecordsContent>
                </MudTable>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private DateTime _selectedDate = DateTime.Today;
    private readonly DateTime _minDate = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private readonly DateTime _maxDate = new(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    private string? _employeeIdFilter;
    private int _employeeStatus; // 0=All, 1=Active, 2=Inactive
    private int _companyIdFilter;
    private int _departmentIdFilter;
    private int _sectionIdFilter;
    private int _designationIdFilter;
    private int _lineIdFilter;
    private string _groupFilter = "All";
    private int _shiftIdFilter;
    private bool _isLoading;
    private bool _isExporting;
    private string? _message;
    private string _searchString = "";
    private List<AttendanceRecord> _records = new();
    private List<AttendanceRecord> _allRecords = new();

    private List<Company> _companies = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();
    private List<Line> _lines = new();
    private List<ERPHub.Models.Shift> _shifts = new();
    private List<Employee> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadRecords();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var companiesTask = Http.GetFromJsonAsync<List<Company>>($"{baseUri}api/companies");
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var sectionsTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            var linesTask = Http.GetFromJsonAsync<List<Line>>($"{baseUri}api/lines");
            var shiftsTask = Http.GetFromJsonAsync<List<ERPHub.Models.Shift>>($"{baseUri}api/shifts");
            var employeesTask = Http.GetFromJsonAsync<List<Employee>>($"{baseUri}api/employees");

            await Task.WhenAll(companiesTask, departmentsTask, sectionsTask, designationsTask, linesTask, shiftsTask, employeesTask);

            _companies = await companiesTask ?? new();
            _departments = await departmentsTask ?? new();
            _sections = await sectionsTask ?? new();
            _designations = await designationsTask ?? new();
            _lines = await linesTask ?? new();
            _shifts = await shiftsTask ?? new();
            _employees = await employeesTask ?? new();
        }
        catch
        {
            // Lookup data failed to load — filters will be empty
        }
    }

    private async Task LoadRecords()
    {
        _isLoading = true;
        _message = null;
        StateHasChanged();

        try
        {
            var url = $"{NavManager.BaseUri}api/attendance/records?fromDate={_selectedDate:yyyy-MM-dd}&toDate={_selectedDate:yyyy-MM-dd}";
            if (!string.IsNullOrWhiteSpace(_employeeIdFilter))
                url += $"&employeeId={Uri.EscapeDataString(_employeeIdFilter.Trim())}";
            if (_employeeStatus == 1)
                url += "&activeEmployees=true";
            else if (_employeeStatus == 2)
                url += "&activeEmployees=false";

            _allRecords = await Http.GetFromJsonAsync<List<AttendanceRecord>>(url) ?? new();
            ApplyClientFilters();
        }
        catch
        {
            _allRecords = new();
            _records = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyClientFilters()
    {
        var hasOrgFilter = _departmentIdFilter > 0 || _sectionIdFilter > 0 ||
                           _designationIdFilter > 0 || _lineIdFilter > 0 ||
                           _shiftIdFilter > 0 || _companyIdFilter > 0 ||
                           (_groupFilter != "All" && !string.IsNullOrEmpty(_groupFilter));

        if (!hasOrgFilter)
        {
            _records = _allRecords;
            return;
        }

        var matchingEmployeeIds = _employees
            .Where(e =>
                (_departmentIdFilter == 0 || e.DepartmentId == _departmentIdFilter) &&
                (_sectionIdFilter == 0 || e.SectionId == _sectionIdFilter) &&
                (_designationIdFilter == 0 || e.DesignationId == _designationIdFilter) &&
                (_lineIdFilter == 0 || e.LineId == _lineIdFilter) &&
                (_shiftIdFilter == 0 || e.ShiftId == _shiftIdFilter))
            .Select(e => e.EmployeeId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _records = _allRecords
            .Where(r => matchingEmployeeIds.Contains(r.EmployeeId))
            .ToList();
    }

    private async Task ClearFilters()
    {
        _selectedDate = DateTime.Today;
        _employeeIdFilter = null;
        _employeeStatus = 0;
        _companyIdFilter = 0;
        _departmentIdFilter = 0;
        _sectionIdFilter = 0;
        _designationIdFilter = 0;
        _lineIdFilter = 0;
        _groupFilter = "All";
        _shiftIdFilter = 0;
        _searchString = "";
        await LoadRecords();
    }

    private bool FilterFunc(AttendanceRecord element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.EmployeeId != null && element.EmployeeId.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        var name = GetEmployeeName(element.EmployeeId);
        if (name != null && name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.AttendanceStatus != null && element.AttendanceStatus.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private static string FormatTime(DateTime? dt)
    {
        return dt?.ToString("hh:mm:ss tt") ?? "--:--:--";
    }

    private static string FormatTimeSpan(TimeSpan? ts)
    {
        return ts.HasValue ? DateTime.Today.Add(ts.Value).ToString("hh:mm tt") : "--:--";
    }

    private string GetEmployeeName(string? employeeId)
    {
        if (string.IsNullOrEmpty(employeeId)) return "-";
        var emp = _employees.FirstOrDefault(e => e.EmployeeId == employeeId);
        return emp?.EmployeeName ?? "-";
    }

    private static RenderFragment StatusBadge(string status) => builder =>
    {
        var label = status switch
        {
            "Present" => "Present",
            "Present + Overtime" => "Present + OT",
            "Late" => "Late",
            "Early Exit" => "Early Exit",
            "Absent" => "Absent",
            "Leave" => "Leave",
            "Half Day" => "Half Day",
            "Holiday" => "Holiday",
            "Holiday Worked" => "Holiday Worked",
            "Weekly Off" => "Weekly Off",
            "Weekly Off Worked" => "WO Worked",
            "Missing In Punch" => "Missing In",
            "Missing Out Punch" => "Missing Out",
            _ => status
        };

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "fw-semibold text-zinc-800");
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    private async Task ExportToExcel()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var company = _companies.FirstOrDefault();
            var summary = new AttendanceSummary(
                TotalEmployees: _records.Count,
                TotalPresent: _records.Count(r => r.AttendanceStatus is "Present" or "Present + Overtime" or "Late" or "Early Exit" or "Half Day" or "Holiday Worked" or "Weekly Off Worked" or "Missing In Punch" or "Missing Out Punch"),
                TotalAbsent: _records.Count(r => r.AttendanceStatus == "Absent" || string.IsNullOrEmpty(r.AttendanceStatus)),
                TotalLate: _records.Count(r => r.AttendanceStatus is "Late" or "Early Exit"),
                TotalLeave: _records.Count(r => r.AttendanceStatus is "Leave" or "Holiday" or "Weekly Off")
            );

            var bytes = await ExportService.ExportAttendanceToExcelAsync(
                _records,
                "Daily Attendance Sheet",
                _selectedDate,
                company!,
                summary,
                columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendance_{_selectedDate:yyyyMMdd}.xlsx";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            Snackbar.Add("Excel exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        if (_records.Count == 0 || _isExporting) return;

        _isExporting = true;
        StateHasChanged();

        try
        {
            var columns = GetExportColumns();
            var company = _companies.FirstOrDefault();
            var summary = new AttendanceSummary(
                TotalEmployees: _records.Count,
                TotalPresent: _records.Count(r => r.AttendanceStatus is "Present" or "Present + Overtime" or "Late" or "Early Exit" or "Half Day" or "Holiday Worked" or "Weekly Off Worked" or "Missing In Punch" or "Missing Out Punch"),
                TotalAbsent: _records.Count(r => r.AttendanceStatus == "Absent" || string.IsNullOrEmpty(r.AttendanceStatus)),
                TotalLate: _records.Count(r => r.AttendanceStatus is "Late" or "Early Exit"),
                TotalLeave: _records.Count(r => r.AttendanceStatus is "Leave" or "Holiday" or "Weekly Off")
            );

            var bytes = await ExportService.ExportAttendanceToPdfAsync(
                _records,
                "Daily Attendance Sheet",
                _selectedDate,
                company!,
                summary,
                columns);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"DailyAttendance_{_selectedDate:yyyyMMdd}.pdf";

            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            Snackbar.Add("PDF exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, Func<AttendanceRecord, object>> GetExportColumns() => new()
    {
        ["Date"] = r => r.AttendanceDate,
        ["Employee ID"] = r => r.EmployeeId,
        ["Employee Name"] = r => GetEmployeeName(r.EmployeeId),
        ["In Time"] = r => r.ActualInPunch?.ToString("hh:mm:ss tt") ?? "--:--:--",
        ["Out Time"] = r => r.ActualOutPunch?.ToString("hh:mm:ss tt") ?? "--:--:--",
        ["Late (min)"] = r => r.LateMinutes > 0 ? r.LateMinutes : 0,
        ["Worked (hrs)"] = r => r.WorkedMinutes > 0 ? Math.Round(r.WorkedMinutes / 60.0, 2) : 0,
        ["OT (min)"] = r => r.OvertimeMinutes > 0 ? r.OvertimeMinutes : 0,
        ["Status"] = r => r.AttendanceStatus
    };
}