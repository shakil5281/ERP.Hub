@page "/attendance/daily"
@using ERPHub.Models
@using ERPHub.Components.Common

<PageTitle>ERPHub - Daily Attendance</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight">Daily Attendance Sheet</h2>
                    <p class="text-zinc-500 text-sm mt-0.5">Track employee check-in times, late registers, and daily status logs.</p>
                </div>
                <div class="flex gap-2">
                    <button class="inline-flex items-center py-1.5 px-3 border border-zinc-200 rounded-md bg-white text-zinc-700 font-semibold hover:bg-zinc-50 transition-colors cursor-pointer">
                        Export CSV
                    </button>
                    <button class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer">
                        Download Report
                    </button>
                </div>
            </div>

            <!-- Metrics grid -->
            <div class="grid grid-cols-5 gap-4 mb-6 max-xl:grid-cols-3 max-sm:grid-cols-2">
                <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
                    <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider">Total Strength</div>
                    <div class="text-sm font-semibold text-zinc-950 mt-1">120 Employees</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
                    <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider text-emerald-600">Present</div>
                    <div class="text-sm font-semibold text-emerald-600 mt-1">102 (85%)</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
                    <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider text-amber-500">Late</div>
                    <div class="text-sm font-semibold text-amber-500 mt-1">8 (6.6%)</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
                    <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider text-red-500">Absent</div>
                    <div class="text-sm font-semibold text-red-500 mt-1">6 (5%)</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
                    <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider text-indigo-500">On Leave</div>
                    <div class="text-sm font-semibold text-indigo-500 mt-1">4 (3.3%)</div>
                </div>
            </div>

            <!-- Filters Bar -->
            <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm mb-6 flex justify-between items-center gap-4 max-sm:flex-col max-sm:items-stretch">
                <div class="flex gap-3 flex-1 max-w-[500px] max-sm:flex-col">
                    <input type="text" 
                           class="w-full bg-white border border-zinc-200 rounded-lg p-2 px-3 text-zinc-900 font-body text-sm outline-none focus:border-black transition-colors" 
                           placeholder="Search by Employee ID or Name..." 
                           @bind="_searchQuery" @bind:event="oninput" />
                    
                    <select class="border border-zinc-200 rounded-lg p-2 px-3 bg-white outline-none text-sm w-[180px] max-sm:w-full cursor-pointer hover:bg-zinc-50 transition-colors" @bind="_deptFilter">
                        <option value="">All Departments</option>
                        <option value="IT">IT & Dev</option>
                        <option value="HR">Human Resources</option>
                        <option value="Finance">Finance & Accounts</option>
                        <option value="Production">Production</option>
                        <option value="Marketing">Marketing</option>
                    </select>
                </div>
                <div class="flex gap-2 items-center">
                    <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Date:</span>
                    <input type="date" class="border border-zinc-200 rounded-lg p-1.5 px-3 bg-white outline-none text-sm cursor-pointer hover:bg-zinc-50 transition-colors" value="@_attendanceDate.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" />
                </div>
            </div>

            <!-- DataTable Listing -->
            <DataTable TItem="AttendanceRecord" Items="FilteredRecords">
                <TabsContent>
                    <button type="button" class="py-1.5 px-3 rounded-full text-xs font-semibold text-zinc-950 bg-white border border-zinc-200 shadow-sm cursor-pointer inline-flex items-center gap-1.5 transition-colors">Today's Logs</button>
                </TabsContent>
                <HeaderTemplate>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Emp ID</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Employee Name</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Department</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Shift</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">In Time</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Out Time</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Late Min</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Status</th>
                </HeaderTemplate>
                <RowTemplate Context="log">
                    <td class="p-2.5 px-4 text-zinc-650 font-mono text-xs">@log.EmpId</td>
                    <td class="p-2.5 px-4 text-zinc-900 font-bold">@log.Name</td>
                    <td class="p-2.5 px-4 text-zinc-700">@log.Department</td>
                    <td class="p-2.5 px-4 text-zinc-700">@log.Shift</td>
                    <td class="p-2.5 px-4 text-zinc-800 font-mono">@(log.InTime.HasValue ? DateTime.Today.Add(log.InTime.Value).ToString("hh:mm tt") : "--:--")</td>
                    <td class="p-2.5 px-4 text-zinc-800 font-mono">@(log.OutTime.HasValue ? DateTime.Today.Add(log.OutTime.Value).ToString("hh:mm tt") : "--:--")</td>
                    <td class="p-2.5 px-4 text-zinc-700">
                        @if (log.LateMinutes > 0)
                        {
                            <span class="text-red-500 font-bold">@log.LateMinutes m</span>
                        }
                        else
                        {
                            <span class="text-zinc-400">-</span>
                        }
                    </td>
                    <td class="p-2.5 px-4">
                        @if (log.Status == "Present")
                        {
                            <span class="inline-flex items-center gap-1.5 py-0.5 px-2.5 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">
                                Present
                            </span>
                        }
                        else if (log.Status == "Late")
                        {
                            <span class="inline-flex items-center gap-1.5 py-0.5 px-2.5 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200">
                                Late
                            </span>
                        }
                        else if (log.Status == "Absent")
                        {
                            <span class="inline-flex items-center gap-1.5 py-0.5 px-2.5 rounded-full text-xs font-bold bg-red-50 text-red-700 border border-red-200">
                                Absent
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1.5 py-0.5 px-2.5 rounded-full text-xs font-bold bg-indigo-50 text-indigo-700 border border-indigo-200">
                                Leave
                            </span>
                        }
                    </td>
                </RowTemplate>
            </DataTable>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _searchQuery = string.Empty;
    private string _deptFilter = string.Empty;
    private DateTime _attendanceDate = DateTime.Today;

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
        {
            _attendanceDate = parsedDate;
        }
    }

    private List<AttendanceRecord> _records = new()
    {
        new("EMP-001", "Bruce Wayne", "IT", "Day Shift", new TimeSpan(8, 45, 0), new TimeSpan(17, 30, 0), 0, "Present"),
        new("EMP-002", "Tony Stark", "IT", "Day Shift", new TimeSpan(9, 15, 0), new TimeSpan(18, 0, 0), 15, "Late"),
        new("EMP-003", "Clark Kent", "HR", "Day Shift", new TimeSpan(8, 55, 0), new TimeSpan(17, 0, 0), 0, "Present"),
        new("EMP-004", "Peter Parker", "Production", "Night Shift", new TimeSpan(20, 0, 0), new TimeSpan(5, 0, 0), 0, "Present"),
        new("EMP-005", "Selina Kyle", "Finance", "Day Shift", null, null, 0, "Absent"),
        new("EMP-006", "Steve Rogers", "Production", "Day Shift", new TimeSpan(8, 40, 0), new TimeSpan(17, 30, 0), 0, "Present"),
        new("EMP-007", "Natasha Romanoff", "HR", "Day Shift", new TimeSpan(9, 25, 0), new TimeSpan(17, 0, 0), 25, "Late"),
        new("EMP-008", "Bruce Banner", "IT", "Night Shift", null, null, 0, "Leave"),
        new("EMP-009", "Wanda Maximoff", "Finance", "Day Shift", new TimeSpan(8, 50, 0), new TimeSpan(17, 15, 0), 0, "Present"),
        new("EMP-010", "Barry Allen", "Marketing", "Day Shift", new TimeSpan(9, 0, 0), new TimeSpan(17, 0, 0), 0, "Present")
    };

    private IEnumerable<AttendanceRecord> FilteredRecords =>
        _records.Where(r => 
            (string.IsNullOrEmpty(_deptFilter) || r.Department == _deptFilter) &&
            (string.IsNullOrEmpty(_searchQuery) || 
             r.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
             r.EmpId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        );

    public record AttendanceRecord(string EmpId, string Name, string Department, string Shift, TimeSpan? InTime, TimeSpan? OutTime, int LateMinutes, string Status);
}
