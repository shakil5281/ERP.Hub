@page "/hr/manpower"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>ERPHub - Manpower Dashboard</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Manpower Dashboard</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Track department headcounts, section allocations, and target capacities dynamically.</p>
                </div>
                <div>
                    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-xs" @onclick="RecalculateManpower" disabled="@_isRecalculating">
                        @if (_isRecalculating)
                        {
                            <svg class="w-3.5 h-3.5 animate-spin mr-1.5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 40" /></svg>
                        }
                        else
                        {
                            <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                        }
                        Recalculate Stats
                    </button>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="flex justify-center items-center py-16">
                    <div class="spinner spinner-lg"></div>
                </div>
            }
            else
            {
                <!-- Dashboard Metrics Cards -->
                <div class="grid grid-cols-4 gap-4 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #6366f1;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Active Headcount</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@TotalHeadcount Employees</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #10b981;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Target Capacity</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@TotalCapacity Slots</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #ef4444;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Total Vacancies</div>
                        <div class="text-xl font-extrabold text-rose-600 mt-1 font-heading">@TotalVacancies Openings</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #f59e0b;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Average Utilization</div>
                        <div class="text-xl font-extrabold text-amber-600 mt-1 font-heading">@AverageUtilization.ToString("F1")%</div>
                    </div>
                </div>

                <!-- Advanced Filter Section -->
                <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6 overflow-hidden">
                    <div class="px-5 py-4 border-b border-zinc-100 flex justify-between items-center cursor-pointer select-none hover:bg-zinc-50 transition-colors" @onclick="ToggleFilterCollapse">
                        <div class="flex items-center gap-2.5">
                            <svg class="w-4.5 h-4.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            <span class="text-sm font-semibold text-zinc-800 font-heading">Advanced Filters</span>
                            @if (HasActiveFilters)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 animate-pulse-slow">
                                    Active Filters
                                </span>
                            }
                        </div>
                        <svg class="w-4 h-4 text-zinc-400 transition-transform duration-200 @(_isFilterCollapsed ? "" : "transform rotate-180")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>

                    <div class="collapse @(_isFilterCollapsed ? "" : "open")">
                        <div class="p-5 bg-zinc-50/50">
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                <!-- Department Dropdown -->
                                <div>
                                    <label class="form-label">Department</label>
                                    <select class="form-control" Value="@_departmentIdFilter" @onchange="OnDepartmentFilterChanged">
                                        <option value="0">All Departments</option>
                                        @foreach (var d in _departments)
                                        {
                                            <option value="@d.Id">@d.NameEn</option>
                                        }
                                    </select>
                                </div>

                                <!-- Section Dropdown -->
                                <div>
                                    <label class="form-label">Section</label>
                                    <select class="form-control" Value="@_sectionIdFilter" @onchange="OnSectionFilterChanged" disabled="@(_filteredSections.Count == 0)">
                                        <option value="0">All Sections</option>
                                        @foreach (var s in _filteredSections)
                                        {
                                            <option value="@s.Id">@s.NameEn</option>
                                        }
                                    </select>
                                </div>

                                <!-- Designation Dropdown -->
                                <div>
                                    <label class="form-label">Designation</label>
                                    <select class="form-control" Value="@_designationIdFilter" @onchange="OnDesignationFilterChanged" disabled="@(_filteredDesignations.Count == 0)">
                                        <option value="0">All Designations</option>
                                        @foreach (var ds in _filteredDesignations)
                                        {
                                            <option value="@ds.Id">@ds.NameEn</option>
                                        }
                                    </select>
                                </div>

                                <!-- Buttons -->
                                <div class="col-span-1 sm:col-span-3 flex justify-end gap-2.5 pt-2">
                                    <button class="btn btn-outlined btn-sm" @onclick="ResetFilters">
                                        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                        </svg>
                                        Reset
                                    </button>
                                    <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
                                        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                                        </svg>
                                        Apply Filters
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Manpowers Data Table -->
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <div class="table-toolbar">
                        <span class="text-sm font-bold font-heading">Department Capacities</span>
                        <div class="relative">
                            <input type="text" class="form-control pl-10" @bind="_searchString" placeholder="Search department, section, designation..." />
                            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                    </div>
                    <div class="table-body">
                        <table class="data-table-base">
                            <thead>
                                <tr>
                                    <th><button class="sort-btn">Department</button></th>
                                    <th><button class="sort-btn">Section</button></th>
                                    <th><button class="sort-btn">Designation</button></th>
                                    <th style="text-align:center;"><button class="sort-btn">Active Headcount</button></th>
                                    <th style="text-align:center;"><button class="sort-btn">Vacancies</button></th>
                                    <th style="text-align:center;"><button class="sort-btn">Target Capacity</button></th>
                                    <th style="text-align:center;"><button class="sort-btn">Utilization</button></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var context in _filteredManpowers.Where(FilterFunc))
                                {
                                    <tr>
                                        <td><span class="fw-semibold text-zinc-800">@(context.Department?.NameEn ?? "-")</span></td>
                                        <td>@(context.Section?.NameEn ?? "All Sections")</td>
                                        <td>@(context.Designation?.NameEn ?? "All Designations")</td>
                                        <td style="text-align:center;"><span class="font-mono">@context.CurrentHeadcount</span></td>
                                        <td style="text-align:center;">
                                            <span class="font-mono @(context.Vacancies > 0 ? "text-rose-600 fw-bold" : "text-zinc-400")">
                                                @context.Vacancies
                                            </span>
                                        </td>
                                        <td style="text-align:center;"><span class="font-mono">@context.TargetCapacity</span></td>
                                        <td style="text-align:center;">
                                            @{
                                                var util = context.TargetCapacity > 0 ? (context.CurrentHeadcount * 100.0 / context.TargetCapacity) : 0;
                                                var colorClass = util >= 90 ? "text-success fw-bold" : util >= 70 ? "text-warning fw-bold" : "text-error fw-bold";
                                            }
                                            <span class="font-mono @colorClass">@util.ToString("F1")%</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (!_filteredManpowers.Any(FilterFunc))
                    {
                        <div class="table-empty">
                            <span class="text-sm text-zinc-500 font-body">No matching records found</span>
                        </div>
                    }
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Manpower> _manpowers = new();
    private List<Manpower> _filteredManpowers = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Section> _filteredSections = new();
    private List<Designation> _designations = new();
    private List<Designation> _filteredDesignations = new();

    private bool _isLoading = true;
    private bool _isRecalculating = false;
    private bool _isFilterCollapsed = true;
    private string _searchString = "";

    // Filters
    private int _departmentIdFilter = 0;
    private int _sectionIdFilter = 0;
    private int _designationIdFilter = 0;

    private bool HasActiveFilters => _departmentIdFilter > 0 || _sectionIdFilter > 0 || _designationIdFilter > 0;

    // Metrics calculations
    private int TotalHeadcount => _filteredManpowers.Sum(m => m.CurrentHeadcount);
    private int TotalCapacity => _filteredManpowers.Sum(m => m.TargetCapacity);
    private int TotalVacancies => _filteredManpowers.Sum(m => m.Vacancies);
    private double AverageUtilization => TotalCapacity > 0 ? (TotalHeadcount * 100.0 / TotalCapacity) : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadData();
    }

    private void ToggleFilterCollapse()
    {
        _isFilterCollapsed = !_isFilterCollapsed;
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var sectionsTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");

            await Task.WhenAll(departmentsTask, sectionsTask, designationsTask);

            _departments = await departmentsTask ?? new();
            _sections = await sectionsTask ?? new();
            _designations = await designationsTask ?? new();

            _filteredSections = _sections;
            _filteredDesignations = _designations;
        }
        catch
        {
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var baseUri = NavManager.BaseUri;
            _manpowers = await Http.GetFromJsonAsync<List<Manpower>>($"{baseUri}api/manpower") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _manpowers = new();
            _filteredManpowers = new();
            await Toast.ShowErrorAsync($"Failed to load manpower statistics: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        _filteredManpowers = _manpowers.Where(m =>
            (_departmentIdFilter == 0 || m.DepartmentId == _departmentIdFilter) &&
            (_sectionIdFilter == 0 || m.SectionId == _sectionIdFilter) &&
            (_designationIdFilter == 0 || m.DesignationId == _designationIdFilter)
        ).ToList();
    }

    private void ResetFilters()
    {
        _departmentIdFilter = 0;
        _sectionIdFilter = 0;
        _designationIdFilter = 0;
        _filteredSections = _sections;
        _filteredDesignations = _designations;
        ApplyFilters();
    }

    private void OnDepartmentFilterChanged(ChangeEventArgs e)
    {
        var deptId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _departmentIdFilter = deptId;
        _sectionIdFilter = 0;
        _designationIdFilter = 0;

        if (deptId == 0)
        {
            _filteredSections = _sections;
            _filteredDesignations = _designations;
        }
        else
        {
            _filteredSections = _sections.Where(s => s.DepartmentId == deptId).ToList();
            var sectionIds = _filteredSections.Select(s => s.Id).ToHashSet();
            _filteredDesignations = _designations.Where(d => sectionIds.Contains(d.SectionId)).ToList();
        }
        ApplyFilters();
    }

    private void OnSectionFilterChanged(ChangeEventArgs e)
    {
        var sectionId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _sectionIdFilter = sectionId;
        _designationIdFilter = 0;

        if (sectionId == 0)
        {
            if (_departmentIdFilter == 0)
            {
                _filteredDesignations = _designations;
            }
            else
            {
                var sectionIds = _sections.Where(s => s.DepartmentId == _departmentIdFilter).Select(s => s.Id).ToHashSet();
                _filteredDesignations = _designations.Where(d => sectionIds.Contains(d.SectionId)).ToList();
            }
        }
        else
        {
            _filteredDesignations = _designations.Where(d => d.SectionId == sectionId).ToList();
        }
        ApplyFilters();
    }

    private void OnDesignationFilterChanged(ChangeEventArgs e)
    {
        _designationIdFilter = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        ApplyFilters();
    }

    private bool FilterFunc(Manpower element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.Department?.NameEn != null && element.Department.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Section?.NameEn != null && element.Section.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Designation?.NameEn != null && element.Designation.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Remarks != null && element.Remarks.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private async Task RecalculateManpower()
    {
        _isRecalculating = true;
        StateHasChanged();

        try
        {
            var baseUri = NavManager.BaseUri;
            var response = await Http.PostAsync($"{baseUri}api/manpower/recalculate", null);
            if (response.IsSuccessStatusCode)
            {
                await Toast.ShowSuccessAsync("Manpower recalculated and updated with active employees.");
                await LoadData();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                await Toast.ShowErrorAsync($"Recalculation failed: {msg}");
            }
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Recalculation failed: {ex.Message}");
        }
        finally
        {
            _isRecalculating = false;
            StateHasChanged();
        }
    }
}
