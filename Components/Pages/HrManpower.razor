@page "/hr/manpower"

<PageTitle>ERPHub - Manpower Dashboard</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Manpower Dashboard</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Track team size capacities, departmental headcounts, and organizational vacancies.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_manpowerStats" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ManpowerStat, object>(x=>x.Department)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ManpowerStat, object>(x=>x.ActiveHeadcount)">Active Headcount</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ManpowerStat, object>(x=>x.Vacancies)">Vacancies</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ManpowerStat, object>(x=>x.TargetCapacity)">Target Capacity</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ManpowerStat, object>(x=>x.Utilization)">Utilization</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Department">@context.Department</MudTd>
                        <MudTd DataLabel="Active Headcount">@context.ActiveHeadcount</MudTd>
                        <MudTd DataLabel="Vacancies">@context.Vacancies</MudTd>
                        <MudTd DataLabel="Target Capacity">@context.TargetCapacity</MudTd>
                        <MudTd DataLabel="Utilization">@context.Utilization</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class ManpowerStat
    {
        public string Department { get; set; } = string.Empty;
        public int ActiveHeadcount { get; set; }
        public int Vacancies { get; set; }
        public int TargetCapacity { get; set; }
        public string Utilization { get; set; } = string.Empty;
    }

    private List<ManpowerStat> _manpowerStats = new()
    {
        new ManpowerStat { Department = "Engineering & Development", ActiveHeadcount = 54, Vacancies = 4, TargetCapacity = 58, Utilization = "93.1%" },
        new ManpowerStat { Department = "Customer Success & Operations", ActiveHeadcount = 36, Vacancies = 2, TargetCapacity = 38, Utilization = "94.7%" },
        new ManpowerStat { Department = "Sales & Marketing", ActiveHeadcount = 28, Vacancies = 2, TargetCapacity = 30, Utilization = "93.3%" },
        new ManpowerStat { Department = "Finance & HR Admin", ActiveHeadcount = 24, Vacancies = 0, TargetCapacity = 24, Utilization = "100.0%" }
    };
}
