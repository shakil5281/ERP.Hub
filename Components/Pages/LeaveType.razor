@page "/leave/type"
@using ERPHub.Models
@using LeaveTypeModel = ERPHub.Models.LeaveType
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ToastService Toast

<PageTitle>ERPHub - Leave Types</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Leave Type Configuration</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Define leave categories, max allocations, accrual rules, and pay eligibility.</p>
                </div>
                <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-xs" @onclick="OpenAddModal">
                    <span class="material-icons text-sm mr-1">add</span>
                    Add Leave Type
                </button>
            </div>

            @if (_isLoading)
            {
                <div class="flex justify-center items-center py-20">
                    <div class="spinner spinner-lg"></div>
                </div>
            }
            else
            {
                <!-- KPI Cards -->
                <div class="grid grid-cols-4 gap-4 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left:4px solid #6366f1">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Total Types</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@_leaveTypes.Count Configured</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left:4px solid #10b981">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Active Types</div>
                        <div class="text-xl font-extrabold text-emerald-600 mt-1 font-heading">@_leaveTypes.Count(t => t.IsActive) Active</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left:4px solid #10b981">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Paid Types</div>
                        <div class="text-xl font-extrabold text-emerald-600 mt-1 font-heading">@_leaveTypes.Count(t => t.IsPaid) Paid</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left:4px solid #f59e0b">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Avg. Max Days</div>
                        <div class="text-xl font-extrabold text-amber-600 mt-1 font-heading">
                            @(_leaveTypes.Count > 0 ? (int)_leaveTypes.Average(t => t.MaxDaysPerYear) : 0) Days/Year
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <div class="flex items-center justify-between px-5 py-3.5 border-b border-zinc-100">
                        <span class="text-sm font-bold text-zinc-800 font-heading">Leave Policies</span>
                        <div class="flex-1"></div>
                        <div class="relative">
                            <span class="material-icons text-sm absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400">search</span>
                            <input type="text" class="w-64 border border-zinc-200 rounded-lg py-2 pl-10 pr-3 text-sm outline-none focus:border-black" @bind="_search" placeholder="Search types..." @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-xs">
                            <thead>
                                <tr class="bg-zinc-50 border-b border-zinc-100">
                                    <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Name</th>
                                    <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Code</th>
                                    <th class="text-center px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Max Days/Year</th>
                                    <th class="text-center px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Pay Status</th>
                                    <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Accrual</th>
                                    <th class="text-center px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Medical Cert.</th>
                                    <th class="text-center px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Status</th>
                                    <th class="text-center px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lt in _leaveTypes)
                                {
                                    <tr class="border-b border-zinc-50 hover:bg-zinc-50 transition-colors">
                                        <td data-label="Name" class="px-4 py-3">
                                            <div class="flex items-center gap-2">
                                                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: @lt.Color"></span>
                                                <span class="font-semibold text-zinc-900 text-sm">@lt.Name</span>
                                            </div>
                                        </td>
                                        <td data-label="Code" class="px-4 py-3">
                                            <span class="font-mono text-xs bg-zinc-100 text-zinc-600 px-1.5 py-0.5 rounded">@lt.Code</span>
                                        </td>
                                        <td class="text-center px-4 py-3" data-label="Max Days">
                                            <span class="text-sm font-bold text-zinc-700">@lt.MaxDaysPerYear</span>
                                        </td>
                                        <td class="text-center px-4 py-3" data-label="Pay Status">
                                            @if (lt.IsPaid)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">Paid</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-zinc-100 text-zinc-600">Unpaid</span>
                                            }
                                        </td>
                                        <td data-label="Accrual" class="px-4 py-3">
                                            <span class="text-xs text-zinc-600">@lt.AccrualType</span>
                                        </td>
                                        <td class="text-center px-4 py-3" data-label="Medical Cert.">
                                            @if (lt.RequiresMedicalCertificate)
                                            {
                                                <span class="material-icons text-sm text-emerald-500">check_circle</span>
                                            }
                                            else
                                            {
                                                <span class="material-icons text-sm text-zinc-300">remove_circle_outline</span>
                                            }
                                        </td>
                                        <td class="text-center px-4 py-3" data-label="Status">
                                            @if (lt.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">Active</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-zinc-100 text-zinc-400">Inactive</span>
                                            }
                                        </td>
                                        <td class="text-center px-4 py-3">
                                            <div class="flex items-center justify-center gap-1">
                                                <button type="button" class="p-1.5 rounded-md hover:bg-indigo-50 text-zinc-400 hover:text-indigo-600 transition-colors cursor-pointer"
                                                        title="Edit" @onclick="() => OpenEditModal(lt)">
                                                    <span class="material-icons text-sm">edit</span>
                                                </button>
                                                <button type="button" class="p-1.5 rounded-md hover:bg-red-50 text-zinc-400 hover:text-red-500 transition-colors cursor-pointer"
                                                        title="Delete" @onclick="() => DeleteLeaveType(lt)">
                                                    <span class="material-icons text-sm">delete</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="flex items-center justify-between px-4 py-3 border-t border-zinc-100">
                        <div class="text-xs text-zinc-400">@_leaveTypes.Count type(s)</div>
                        <div class="flex items-center gap-2 text-xs text-zinc-500">
                            <span>Rows per page:</span>
                            <select class="border border-zinc-200 rounded px-2 py-1 text-xs bg-white outline-none">
                                <option>10</option>
                                <option>25</option>
                            </select>
                        </div>
                    </div>
                    @if (!_leaveTypes.Any())
                    {
                        <div class="text-center py-8 text-zinc-400 text-xs">No leave types configured.</div>
                    }
                </div>
            }
        </div>

        <!-- Add / Edit Modal -->
        @if (_showModal)
        {
            <div class="fixed inset-0 bg-black/40 backdrop-blur-xs flex items-center justify-center z-[1000] animate-fade-in" @onclick="CloseModal">
                <div class="bg-white rounded-xl shadow-xl border border-zinc-200 max-w-lg w-full p-6 mx-4" @onclick:stopPropagation="true">
                    <h3 class="text-base font-bold text-zinc-950 font-heading mb-1">@(_isEdit ? "Edit Leave Type" : "Add Leave Type")</h3>
                    <p class="text-xs text-zinc-400 mb-5 font-body">Configure the leave category, day allocation, and accrual settings.</p>

                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Name</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm outline-none focus:border-black" @bind="_form.Name" placeholder="e.g. Annual Leave" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Code</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm outline-none focus:border-black font-mono" @bind="_form.Code" placeholder="e.g. AL" maxlength="10" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Max Days / Year</label>
                                <input type="number" min="1" max="365" class="w-full border border-zinc-200 rounded-lg p-2 text-sm outline-none focus:border-black" @bind="_form.MaxDaysPerYear" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Accrual Type</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm bg-white outline-none focus:border-black" @bind="_form.AccrualType">
                                    <option value="Monthly">Monthly</option>
                                    <option value="Yearly">Yearly</option>
                                    <option value="OnRequest">On Request</option>
                                </select>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Badge Color</label>
                                <div class="flex items-center gap-2">
                                    <input type="color" class="w-10 h-9 rounded border border-zinc-200 p-0.5 cursor-pointer" @bind="_form.Color" />
                                    <span class="text-xs font-mono text-zinc-500">@_form.Color</span>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2 justify-end pb-1">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="w-4 h-4 rounded" @bind="_form.IsPaid" />
                                    <span class="text-xs text-zinc-700 font-semibold">Paid Leave</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="w-4 h-4 rounded" @bind="_form.IsActive" />
                                    <span class="text-xs text-zinc-700 font-semibold">Active</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" class="w-4 h-4 rounded" @bind="_form.RequiresMedicalCertificate" />
                                    <span class="text-xs text-zinc-700 font-semibold">Requires Medical Certificate</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 mt-6">
                        <button type="button" class="px-4 py-2 border border-zinc-200 rounded-lg text-xs font-bold text-zinc-700 hover:bg-zinc-50 cursor-pointer" @onclick="CloseModal">Cancel</button>
                        <button type="button" class="px-4 py-2 bg-black text-white rounded-lg text-xs font-bold hover:bg-zinc-800 cursor-pointer" @onclick="SaveLeaveType" disabled="@_isSaving">
                            @(_isEdit ? "Update" : "Save")
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized><RedirectToLogin /></NotAuthorized>
</AuthorizeView>

@code {
    private List<LeaveTypeModel> _leaveTypes = new();
    private bool _isLoading = true;
    private string _search = "";
    private bool _showModal = false;
    private bool _isEdit = false;
    private bool _isSaving = false;
    private LeaveTypeModel _form = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            _leaveTypes = await Http.GetFromJsonAsync<List<LeaveTypeModel>>($"{NavManager.BaseUri}api/leavetypes") ?? new();
        }
        catch (Exception ex) { await Toast.ShowErrorAsync($"Error loading leave types: {ex.Message}"); }
        finally { _isLoading = false; }
    }

    private bool FilterFunc(LeaveTypeModel lt) =>
        string.IsNullOrWhiteSpace(_search) ||
        lt.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        lt.Code.Contains(_search, StringComparison.OrdinalIgnoreCase);

    private void OpenAddModal()
    {
        _isEdit = false;
        _form = new LeaveTypeModel { IsPaid = true, IsActive = true, MaxDaysPerYear = 10, AccrualType = "Yearly", Color = "#6366f1" };
        _showModal = true;
    }

    private void OpenEditModal(LeaveTypeModel lt)
    {
        _isEdit = true;
        _form = new LeaveTypeModel
        {
            Id = lt.Id, Name = lt.Name, Code = lt.Code, MaxDaysPerYear = lt.MaxDaysPerYear,
            IsPaid = lt.IsPaid, AccrualType = lt.AccrualType, IsActive = lt.IsActive,
            Color = lt.Color, RequiresMedicalCertificate = lt.RequiresMedicalCertificate
        };
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveLeaveType()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { await Toast.ShowWarningAsync("Name is required."); return; }
        _isSaving = true;
        try
        {
            HttpResponseMessage resp;
            if (_isEdit)
                resp = await Http.PutAsJsonAsync($"{NavManager.BaseUri}api/leavetypes/{_form.Id}", _form);
            else
                resp = await Http.PostAsJsonAsync($"{NavManager.BaseUri}api/leavetypes", _form);

            if (resp.IsSuccessStatusCode)
            {
                await Toast.ShowSuccessAsync(_isEdit ? "Leave type updated." : "Leave type added.");
                _showModal = false;
                await LoadData();
            }
            else await Toast.ShowErrorAsync($"Error: {await resp.Content.ReadAsStringAsync()}");
        }
        catch (Exception ex) { await Toast.ShowErrorAsync($"Error: {ex.Message}"); }
        finally { _isSaving = false; }
    }

    private async Task DeleteLeaveType(LeaveTypeModel lt)
    {
        var resp = await Http.DeleteAsync($"{NavManager.BaseUri}api/leavetypes/{lt.Id}");
        if (resp.IsSuccessStatusCode) { await Toast.ShowInfoAsync($"'{lt.Name}' deleted."); await LoadData(); }
        else await Toast.ShowErrorAsync("Delete failed.");
    }
}
