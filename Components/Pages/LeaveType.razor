@page "/leave/type"

<PageTitle>ERPHub - Leave Types</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Leave Policies</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Configure different leave categories, maximum day allocations, and accrual types.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_policies" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeavePolicy, object>(x=>x.Name)">Leave Policy Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeavePolicy, object>(x=>x.Category)">Category</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeavePolicy, object>(x=>x.Limit)">Day Limit</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeavePolicy, object>(x=>x.AccrualType)">Accrual Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<LeavePolicy, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Leave Policy Name">@context.Name</MudTd>
                        <MudTd DataLabel="Category">@context.Category</MudTd>
                        <MudTd DataLabel="Day Limit">@context.Limit</MudTd>
                        <MudTd DataLabel="Accrual Type">@context.AccrualType</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.BadgeClass">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class LeavePolicy
    {
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Limit { get; set; } = string.Empty;
        public string AccrualType { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<LeavePolicy> _policies = new()
    {
        new LeavePolicy { Name = "Annual Leave", Category = "Paid Leave", Limit = "15 Days", AccrualType = "Monthly Accrual (1.25 / Month)", Status = "Active", BadgeClass = "bg-green-50 text-green-700" },
        new LeavePolicy { Name = "Medical Leave", Category = "Paid Leave", Limit = "10 Days", AccrualType = "Yearly Lump-Sum", Status = "Active", BadgeClass = "bg-green-50 text-green-700" },
        new LeavePolicy { Name = "Casual Leave", Category = "Paid Leave", Limit = "5 Days", AccrualType = "Yearly Lump-Sum", Status = "Active", BadgeClass = "bg-green-50 text-green-700" },
        new LeavePolicy { Name = "Maternity Leave", Category = "Special Paid Leave", Limit = "90 Days", AccrualType = "On Requisition Event", Status = "Active", BadgeClass = "bg-green-50 text-green-700" }
    };
}
