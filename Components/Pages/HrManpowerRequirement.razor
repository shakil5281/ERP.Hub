@page "/hr/manpower-requirement"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>ERPHub - Manpower Requirements</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Manpower Requirements</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Review active job openings, staffing requisitions, and recruitment approvals.</p>
                </div>
                <div>
                    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-xs" @onclick="OpenAddModal">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-1" />
                        New Requisition
                    </button>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="flex justify-center items-center py-16">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                </div>
            }
            else
            {
                <!-- Dashboard Metrics Cards -->
                <div class="grid grid-cols-4 gap-4 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #6366f1;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Total Requisitions</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@TotalRequisitions Reqs</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #10b981;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Headcount Needed</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@TotalHeadcountNeeded Staff</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #3b82f6;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Active Recruiting</div>
                        <div class="text-xl font-extrabold text-blue-600 mt-1 font-heading">@ActiveRecruiting Recruiting</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #f59e0b;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Pending Approval</div>
                        <div class="text-xl font-extrabold text-amber-600 mt-1 font-heading">@PendingApprovals Pending</div>
                    </div>
                </div>

                <!-- Advanced Filter Section -->
                <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6 overflow-hidden">
                    <div class="px-5 py-4 border-b border-zinc-100 flex justify-between items-center cursor-pointer select-none hover:bg-zinc-50 transition-colors" @onclick="ToggleFilterCollapse">
                        <div class="flex items-center gap-2.5">
                            <svg class="w-4.5 h-4.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            <span class="text-sm font-semibold text-zinc-800 font-heading">Advanced Filters</span>
                            @if (HasActiveFilters)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 animate-pulse-slow">
                                    Active Filters
                                </span>
                            }
                        </div>
                        <svg class="w-4 h-4 text-zinc-400 transition-transform duration-200 @(_isFilterCollapsed ? "" : "transform rotate-180")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>

                    <MudCollapse Expanded="!_isFilterCollapsed">
                        <div class="p-5 bg-zinc-50/50">
                            <MudGrid Spacing="3">
                                <!-- Department Dropdown -->
                                <MudItem xs="12" sm="4">
                                    <MudSelect T="int" Value="_departmentIdFilter" ValueChanged="OnDepartmentFilterChanged" Label="Department" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                                        @foreach (var d in _departments)
                                        {
                                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <!-- Priority Dropdown -->
                                <MudItem xs="12" sm="4">
                                    <MudSelect T="string" Value="_priorityFilter" ValueChanged="OnPriorityFilterChanged" Label="Priority" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="@("All")">All Priorities</MudSelectItem>
                                        <MudSelectItem Value="@("High")">High</MudSelectItem>
                                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                                        <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- Status Dropdown -->
                                <MudItem xs="12" sm="4">
                                    <MudSelect T="string" Value="_statusFilter" ValueChanged="OnStatusFilterChanged" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="@("All")">All Statuses</MudSelectItem>
                                        <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                                        <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                                        <MudSelectItem Value="@("Recruiting")">Recruiting</MudSelectItem>
                                        <MudSelectItem Value="@("Filled")">Filled</MudSelectItem>
                                        <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- Buttons -->
                                <MudItem xs="12" Class="flex justify-end gap-2.5 pt-2">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh">Reset</MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.FilterList">Apply Filters</MudButton>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudCollapse>
                </div>

                <!-- Requisitions Data Table -->
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <MudTable Items="@_filteredRequisitions" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0" Filter="new Func<ManpowerRequirement, bool>(FilterFunc)">
                        <ToolBarContent>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Staff Requisitions</MudText>
                            <MudSpacer />
                            <MudTextField @bind-Value="_searchString"
                                          Placeholder="Search role title, description..."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          IconSize="Size.Small"
                                          Class="mt-0"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Clearable="true" />
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.RoleTitle)">Role Title</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.Department?.NameEn ?? string.Empty)">Department</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.Section?.NameEn ?? string.Empty)">Section</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.Designation?.NameEn ?? string.Empty)">Designation</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.HeadcountNeeded)">Headcount Needed</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.TargetDate)">Target Date</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.Priority)">Priority</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<ManpowerRequirement, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Role Title"><span class="fw-semibold text-zinc-800">@context.RoleTitle</span></MudTd>
                            <MudTd DataLabel="Department">@(context.Department?.NameEn ?? "-")</MudTd>
                            <MudTd DataLabel="Section">@(context.Section?.NameEn ?? "All Sections")</MudTd>
                            <MudTd DataLabel="Designation">@(context.Designation?.NameEn ?? "All Designations")</MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Headcount Needed"><span class="font-mono fw-bold">@context.HeadcountNeeded</span></MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Target Date"><span class="font-mono">@context.TargetDate.ToString("yyyy-MM-dd")</span></MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Priority">
                                @{
                                    var priorityClass = context.Priority switch
                                    {
                                        "High" => "bg-red-50 text-red-700 border border-red-200",
                                        "Medium" => "bg-amber-50 text-amber-700 border border-amber-200",
                                        "Low" => "bg-green-50 text-green-700 border border-green-200",
                                        _ => "bg-zinc-50 text-zinc-700"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @priorityClass">@context.Priority</span>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Status">
                                @{
                                    var statusClass = context.Status switch
                                    {
                                        "Approved" => "bg-indigo-50 text-indigo-700 border border-indigo-100",
                                        "Recruiting" => "bg-green-50 text-green-700 border border-green-100",
                                        "Pending" => "bg-zinc-50 text-zinc-600 border border-zinc-100",
                                        "Filled" => "bg-teal-50 text-teal-700 border border-teal-100",
                                        "Cancelled" => "bg-red-50 text-red-700 border border-red-100",
                                        _ => "bg-zinc-50 text-zinc-700"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @statusClass">@context.Status</span>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8 font-body">No staffing requirements match the filters.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            }
        </div>

        <!-- Add Requisition Form Dialog PopUp Modal -->
        @if (_showAddModal)
        {
            <div class="fixed inset-0 bg-black/40 backdrop-blur-xs flex items-center justify-center z-[1000] animate-fade-in">
                <div class="bg-white rounded-xl shadow-xl border border-zinc-200 max-w-lg w-full p-6 mx-4">
                    <h3 class="text-base font-bold text-zinc-950 font-heading mb-1 font-heading">New Staffing Requisition</h3>
                    <p class="text-xs text-zinc-500 mb-4 font-body">Create a new headcount requirement for department approvals.</p>
                    
                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="col-span-2">
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Role Title</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newReq.RoleTitle" placeholder="e.g. Lead Engineer" />
                            </div>
                        </div>
                        <div class="grid grid-cols-3 gap-4 font-body">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Department</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" Value="@_newReq.DepartmentId" @onchange="OnNewDeptChanged">
                                    <option value="0">Select...</option>
                                    @foreach (var d in _departments)
                                    {
                                        <option value="@d.Id">@d.NameEn</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Section</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newReq.SectionId" disabled="@(_newDeptSections.Count == 0)">
                                    <option value="0">Select...</option>
                                    @foreach (var s in _newDeptSections)
                                    {
                                        <option value="@s.Id">@s.NameEn</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Designation</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newReq.DesignationId" disabled="@(_newDeptDesignations.Count == 0)">
                                    <option value="0">Select...</option>
                                    @foreach (var ds in _newDeptDesignations)
                                    {
                                        <option value="@ds.Id">@ds.NameEn</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="grid grid-cols-3 gap-4 font-body">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Headcount</label>
                                <input type="number" min="1" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newReq.HeadcountNeeded" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Priority</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newReq.Priority">
                                    <option value="Low">Low</option>
                                    <option value="Medium">Medium</option>
                                    <option value="High">High</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Target Date</label>
                                <input type="date" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" Value="@_newReqTargetDateString" @onchange="OnNewReqTargetDateChanged" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Description</label>
                            <textarea rows="2" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newReq.Description" placeholder="Job description and duties..."></textarea>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Requirements</label>
                            <textarea rows="2" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newReq.Requirements" placeholder="Required experience, skills, certifications..."></textarea>
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 mt-6">
                        <button type="button" class="px-4 py-2 border border-zinc-200 rounded-lg text-xs font-bold text-zinc-700 hover:bg-zinc-50 transition-colors cursor-pointer font-heading" @onclick="CloseAddModal">Cancel</button>
                        <button type="button" class="px-4 py-2 bg-black text-white rounded-lg text-xs font-bold hover:bg-zinc-800 transition-colors cursor-pointer font-heading" @onclick="SaveRequisition" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <svg class="w-3.5 h-3.5 animate-spin mr-1.5 inline" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 40" /></svg>
                            }
                            Submit Request
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<ManpowerRequirement> _requisitions = new();
    private List<ManpowerRequirement> _filteredRequisitions = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();

    private bool _isLoading = true;
    private bool _isFilterCollapsed = true;
    private string _searchString = "";

    // Filters
    private int _departmentIdFilter = 0;
    private string _priorityFilter = "All";
    private string _statusFilter = "All";

    private bool HasActiveFilters => _departmentIdFilter > 0 || _priorityFilter != "All" || _statusFilter != "All";

    // Modal Form Requisition Fields
    private bool _showAddModal = false;
    private bool _isSaving = false;
    private ManpowerRequirement _newReq = new();
    private string _newReqTargetDateString = DateTime.Today.AddDays(30).ToString("yyyy-MM-dd");
    private List<Section> _newDeptSections = new();
    private List<Designation> _newDeptDesignations = new();

    // Summary calculations
    private int TotalRequisitions => _filteredRequisitions.Count;
    private int TotalHeadcountNeeded => _filteredRequisitions.Sum(r => r.HeadcountNeeded);
    private int ActiveRecruiting => _filteredRequisitions.Count(r => r.Status == "Recruiting");
    private int PendingApprovals => _filteredRequisitions.Count(r => r.Status == "Pending");

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadData();
    }

    private void ToggleFilterCollapse()
    {
        _isFilterCollapsed = !_isFilterCollapsed;
    }

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var departmentsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var sectionsTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var designationsTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");

            await Task.WhenAll(departmentsTask, sectionsTask, designationsTask);

            _departments = await departmentsTask ?? new();
            _sections = await sectionsTask ?? new();
            _designations = await designationsTask ?? new();
        }
        catch
        {
            // Fail silently
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var baseUri = NavManager.BaseUri;
            _requisitions = await Http.GetFromJsonAsync<List<ManpowerRequirement>>($"{baseUri}api/manpowerrequirements") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _requisitions = new();
            _filteredRequisitions = new();
            Snackbar.Add($"Failed to load requisitions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        _filteredRequisitions = _requisitions.Where(r =>
            (_departmentIdFilter == 0 || r.DepartmentId == _departmentIdFilter) &&
            (_priorityFilter == "All" || r.Priority == _priorityFilter) &&
            (_statusFilter == "All" || r.Status == _statusFilter)
        ).ToList();
    }

    private void ResetFilters()
    {
        _departmentIdFilter = 0;
        _priorityFilter = "All";
        _statusFilter = "All";
        ApplyFilters();
    }

    private void OnDepartmentFilterChanged(int deptId)
    {
        _departmentIdFilter = deptId;
        ApplyFilters();
    }

    private void OnPriorityFilterChanged(string priority)
    {
        _priorityFilter = priority ?? "All";
        ApplyFilters();
    }

    private void OnStatusFilterChanged(string status)
    {
        _statusFilter = status ?? "All";
        ApplyFilters();
    }

    private bool FilterFunc(ManpowerRequirement element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (element.RoleTitle != null && element.RoleTitle.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Department?.NameEn != null && element.Department.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Section?.NameEn != null && element.Section.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Designation?.NameEn != null && element.Designation.NameEn.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Description != null && element.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (element.Requirements != null && element.Requirements.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void OpenAddModal()
    {
        _newReq = new ManpowerRequirement
        {
            HeadcountNeeded = 1,
            Priority = "Medium",
            Status = "Pending",
            TargetDate = DateTime.Today.AddDays(30)
        };
        _newReqTargetDateString = _newReq.TargetDate.ToString("yyyy-MM-dd");
        _newDeptSections.Clear();
        _newDeptDesignations.Clear();
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
    }

    private void OnNewDeptChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var deptId))
        {
            _newReq.DepartmentId = deptId;
            _newReq.SectionId = null;
            _newReq.DesignationId = null;

            if (deptId == 0)
            {
                _newDeptSections.Clear();
                _newDeptDesignations.Clear();
            }
            else
            {
                _newDeptSections = _sections.Where(s => s.DepartmentId == deptId).ToList();
                var sectionIds = _newDeptSections.Select(s => s.Id).ToHashSet();
                _newDeptDesignations = _designations.Where(d => sectionIds.Contains(d.SectionId)).ToList();
            }
        }
    }

    private void OnNewReqTargetDateChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (DateTime.TryParse(val, out var parsedDate))
        {
            _newReq.TargetDate = parsedDate;
            _newReqTargetDateString = parsedDate.ToString("yyyy-MM-dd");
        }
    }

    private async Task SaveRequisition()
    {
        if (string.IsNullOrWhiteSpace(_newReq.RoleTitle))
        {
            Snackbar.Add("Please enter a role title.", Severity.Warning);
            return;
        }
        if (_newReq.DepartmentId <= 0)
        {
            Snackbar.Add("Please select a department.", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            var baseUri = NavManager.BaseUri;
            _newReq.CreatedAt = DateTime.Now;
            _newReq.CreatedBy = "HR Specialist";
            var response = await Http.PostAsJsonAsync($"{baseUri}api/manpowerrequirements", _newReq);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Staff requisition submitted successfully.", Severity.Success);
                _showAddModal = false;
                await LoadData();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to submit: {err}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Submission failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}
