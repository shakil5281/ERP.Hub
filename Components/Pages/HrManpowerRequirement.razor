@page "/hr/manpower-requirement"

<PageTitle>ERPHub - Manpower Requirements</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Manpower Requirements</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Review active job openings, staffing requisitions, and recruitment approvals.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_requisitions" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<Requisition, object>(x=>x.RoleTitle)">Role Title</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Requisition, object>(x=>x.Department)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Requisition, object>(x=>x.HeadcountNeeded)">Headcount Needed</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Requisition, object>(x=>x.TargetDate)">Target Date</MudTableSortLabel></MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Role Title">@context.RoleTitle</MudTd>
                        <MudTd DataLabel="Department">@context.Department</MudTd>
                        <MudTd DataLabel="Headcount Needed">@context.HeadcountNeeded</MudTd>
                        <MudTd DataLabel="Target Date">@context.TargetDate</MudTd>
                        <MudTd DataLabel="Priority">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.PriorityBadge">@context.Priority</span>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.StatusBadge">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class Requisition
    {
        public string RoleTitle { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public int HeadcountNeeded { get; set; }
        public string TargetDate { get; set; } = string.Empty;
        public string Priority { get; set; } = string.Empty;
        public string PriorityBadge { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string StatusBadge { get; set; } = string.Empty;
    }

    private List<Requisition> _requisitions = new()
    {
        new Requisition { RoleTitle = "Senior Full-Stack Engineer", Department = "Engineering", HeadcountNeeded = 2, TargetDate = "2026-07-15", Priority = "High", PriorityBadge = "bg-red-50 text-red-700", Status = "Approved", StatusBadge = "bg-indigo-50 text-indigo-700 border border-indigo-100" },
        new Requisition { RoleTitle = "Account Executive", Department = "Sales", HeadcountNeeded = 3, TargetDate = "2026-08-01", Priority = "Medium", PriorityBadge = "bg-amber-50 text-amber-700", Status = "Recruiting", StatusBadge = "bg-green-50 text-green-700 border border-green-100" },
        new Requisition { RoleTitle = "HR Generalist", Department = "HR Admin", HeadcountNeeded = 1, TargetDate = "2026-08-20", Priority = "Low", PriorityBadge = "bg-green-50 text-green-700", Status = "Pending", StatusBadge = "bg-zinc-50 text-zinc-600 border border-zinc-100" }
    };
}
