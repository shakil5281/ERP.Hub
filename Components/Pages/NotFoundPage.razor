@page "/notfound"

<PageTitle>Page Not Found - ERPHub</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="min-h-[70vh] flex flex-col items-center justify-center p-6 text-center animate-fade-in font-body">
            <div class="relative mb-6">
                <!-- Decorative Glow Background -->
                <div class="absolute inset-0 bg-zinc-900/5 blur-3xl rounded-full scale-150"></div>
                
                <!-- Icon/Illustration -->
                <div class="relative bg-zinc-900 text-white w-24 h-24 rounded-full flex items-center justify-center shadow-xl mx-auto border-4 border-white">
                    <svg class="w-12 h-12 stroke-current stroke-2 stroke-linecap-round stroke-linejoin-round fill-none" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
            </div>

            <!-- Error Codes & Message -->
            <span class="px-3 py-1 rounded-full text-xs font-extrabold text-zinc-500 bg-zinc-100 uppercase tracking-widest border border-zinc-200/50 mb-4 select-none">
                Error Code 404
            </span>
            
            <h1 class="text-3xl font-extrabold text-zinc-950 tracking-tight mb-3 font-heading max-w-md">
                Lost in space?
            </h1>
            
            <p class="text-zinc-500 text-sm max-w-sm leading-relaxed mb-8">
                The destination you are trying to reach does not exist or has been relocated to another address.
            </p>

            <!-- Navigation Options -->
            <div class="flex gap-3 max-sm:flex-col justify-center w-full max-w-[280px]">
                <a href="/" class="flex-1 inline-flex justify-center items-center gap-2 py-2.5 px-5 rounded-lg bg-black text-white text-xs font-semibold hover:bg-zinc-800 transition-colors shadow-md no-underline cursor-pointer">
                    <svg class="w-4 h-4 fill-none stroke-current stroke-2 stroke-linecap-round stroke-linejoin-round" viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    Go to Dashboard
                </a>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
