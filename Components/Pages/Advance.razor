@page "/payroll/advance"

<PageTitle>ERPHub - Salary Advances</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Salary Advances</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage employee loans, salary advances, and monthly amortization schedules.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_advances" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.LoanAmount)">Loan Amount</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.Installments)">Installments</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.MonthlyDeduction)">Monthly Deduction</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.TotalPaid)">Total Paid</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.Remaining)">Remaining</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryAdvance, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Loan Amount">@context.LoanAmount</MudTd>
                        <MudTd DataLabel="Installments">@context.Installments</MudTd>
                        <MudTd DataLabel="Monthly Deduction">@context.MonthlyDeduction</MudTd>
                        <MudTd DataLabel="Total Paid">@context.TotalPaid</MudTd>
                        <MudTd DataLabel="Remaining">@context.Remaining</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SalaryAdvance
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string LoanAmount { get; set; } = string.Empty;
        public string Installments { get; set; } = string.Empty;
        public string MonthlyDeduction { get; set; } = string.Empty;
        public string TotalPaid { get; set; } = string.Empty;
        public string Remaining { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<SalaryAdvance> _advances = new()
    {
        new SalaryAdvance { EmployeeName = "Michael Scott", LoanAmount = "$5,000.00", Installments = "10 Months", MonthlyDeduction = "$500.00", TotalPaid = "$2,000.00", Remaining = "$3,000.00", Status = "Repaying" }
    };
}
