@page "/payroll/advance"

<PageTitle>ERPHub - Salary Advances</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Salary Advances</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage employee loans, salary advances, and monthly amortization schedules.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-xs">
                        <thead>
                            <tr class="bg-zinc-50 border-b border-zinc-100">
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Employee Name</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Loan Amount</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Installments</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Monthly Deduction</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Total Paid</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Remaining</button>
                                </th>
                                <th class="text-left px-4 py-3 font-bold text-zinc-500 uppercase tracking-wider">
                                    <button type="button" class="bg-none border-none cursor-pointer inline-flex items-center gap-1 font-inherit text-inherit p-0 hover:text-zinc-900 font-bold text-zinc-500 uppercase tracking-wider text-xs">Status</button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _advances)
                            {
                                <tr class="border-b border-zinc-50 hover:bg-zinc-50 transition-colors">
                                    <td data-label="Employee Name" class="px-4 py-3">@item.EmployeeName</td>
                                    <td data-label="Loan Amount" class="px-4 py-3">@item.LoanAmount</td>
                                    <td data-label="Installments" class="px-4 py-3">@item.Installments</td>
                                    <td data-label="Monthly Deduction" class="px-4 py-3">@item.MonthlyDeduction</td>
                                    <td data-label="Total Paid" class="px-4 py-3">@item.TotalPaid</td>
                                    <td data-label="Remaining" class="px-4 py-3">@item.Remaining</td>
                                    <td data-label="Status" class="px-4 py-3">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@item.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between px-4 py-3 border-t border-zinc-100">
                    <div class="flex items-center gap-2 text-xs text-zinc-500">
                        <span>Rows per page:</span>
                        <select class="border border-zinc-200 rounded px-2 py-1 text-xs bg-white outline-none">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                    </div>
                    <div class="text-xs text-zinc-400">1-1 of 1</div>
                </div>
                <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-zinc-100">
                    <span class="text-xs text-zinc-400">No records to display</span>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SalaryAdvance
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string LoanAmount { get; set; } = string.Empty;
        public string Installments { get; set; } = string.Empty;
        public string MonthlyDeduction { get; set; } = string.Empty;
        public string TotalPaid { get; set; } = string.Empty;
        public string Remaining { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<SalaryAdvance> _advances = new()
    {
        new SalaryAdvance { EmployeeName = "Michael Scott", LoanAmount = "$5,000.00", Installments = "10 Months", MonthlyDeduction = "$500.00", TotalPaid = "$2,000.00", Remaining = "$3,000.00", Status = "Repaying" }
    };
}
