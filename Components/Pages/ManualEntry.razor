@page "/attendance/manual-entry"

<PageTitle>ERPHub - Manual Attendance Entry</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Manual Attendance Entry</h2>
                    <p class="text-zinc-500 text-sm mt-0.5 font-body">Create manual punch logs on behalf of employees who missed scans or traveled for duty.</p>
                </div>
            </div>

            <div class="grid grid-cols-12 gap-6">
                <!-- Manual Entry Form -->
                <div class="col-span-4 max-xl:col-span-5 max-lg:col-span-12">
                    <div class="bg-white border border-zinc-200 rounded-lg p-5 shadow-sm">
                        <h3 class="text-sm font-bold text-zinc-950 font-heading mb-4 uppercase tracking-wider">New Manual Log</h3>
                        
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Employee</label>
                                <MudSelect T="string" @bind-Value="_selectedEmpId" Placeholder="Choose Employee" Class="mud-select-square" dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                                    @foreach (var emp in _availableEmployees)
                                    {
                                        <MudSelectItem Value="@emp.EmployeeId">@emp.EmployeeName (@emp.EmployeeId)</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <MudDatePicker Date="@_entryDate"
                                                   DateChanged="@(d => { if (d.HasValue) _entryDate = d.Value; })"
                                                   Label="Date"
                                                   Editable="true"
                                                   Placeholder="Select Date"
                                                   DateFormat="yyyy-MM-dd"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense" />
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Time</label>
                                    <input type="time" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none" @bind="_entryTime" />
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Punch Type</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-1.5 text-xs text-zinc-900 outline-none bg-white focus:border-black" @bind="_selectedPunchType">
                                    <option value="Check In">Check In</option>
                                    <option value="Check Out">Check Out</option>
                                    <option value="OT Start">OT Start</option>
                                    <option value="OT End">OT End</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1">Reason / Notes</label>
                                <textarea class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black h-20 resize-none" @bind="_newReason" placeholder="Forgot ID Card, Machine breakdown, client visit, etc."></textarea>
                            </div>

                            <button class="w-full py-2 px-4 bg-black hover:bg-zinc-800 text-white font-bold rounded-lg text-xs transition-colors cursor-pointer" @onclick="SubmitManualPunch">
                                Submit Attendance Log
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Recent Logs List -->
                <div class="col-span-8 max-xl:col-span-7 max-lg:col-span-12">
                    <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden p-5">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-sm font-bold text-zinc-950 font-heading uppercase tracking-wider">Submitted Override Logs</h3>
                            <span class="text-xs text-zinc-400">Showing recent manual corrections</span>
                        </div>

                        <MudTable Items="@_logs" Hover="true" Dense="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Date</MudTh>
                                <MudTh>Emp ID</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Time</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Reason</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh Class="text-right">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Date">@context.LogDate.ToString("yyyy-MM-dd")</MudTd>
                                <MudTd DataLabel="Emp ID"><span class="font-mono text-xs font-semibold">@context.EmpId</span></MudTd>
                                <MudTd DataLabel="Name">@context.Name</MudTd>
                                <MudTd DataLabel="Time">@context.PunchTime</MudTd>
                                <MudTd DataLabel="Type">
                                    <span class="font-semibold text-zinc-700">@context.PunchType</span>
                                </MudTd>
                                <MudTd DataLabel="Reason"><span class="text-zinc-500 text-xs italic">@context.Reason</span></MudTd>
                                <MudTd DataLabel="Status">
                                    @if (context.Status == "Approved")
                                    {
                                        <span class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-200">Pending</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Actions" Class="text-right whitespace-nowrap">
                                    @if (context.Status == "Pending")
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="@Size.Small" Color="Color.Success" title="Approve Log" OnClick="() => ApproveLog(context)" />
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="@Size.Small" Color="Color.Error" title="Remove Log" OnClick="() => DeleteLog(context)" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private IErpService ErpService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private string _selectedEmpId = string.Empty;
    private string _selectedPunchType = "Check In";
    private string _newReason = string.Empty;
    private DateTime _entryDate = DateTime.Today;
    private TimeOnly? _entryTime = new TimeOnly(9, 0);

    private List<ManualPunchUiLog> _logs = new();
    private List<Employee> _availableEmployees = new();
    private Dictionary<string, string> _employeeNames = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var dbLogs = await ErpService.GetManualPunchLogsAsync();
        _availableEmployees = await ErpService.GetEmployeesAsync();
        _employeeNames = _availableEmployees
            .GroupBy(e => e.EmployeeId)
            .ToDictionary(g => g.Key, g => g.First().EmployeeName);

        _logs = dbLogs.Select(db => new ManualPunchUiLog
        {
            Id = db.Id,
            EmpId = db.EmployeeId,
            Name = _employeeNames.TryGetValue(db.EmployeeId, out var name) ? name : "Unknown Employee",
            LogDate = db.PunchDate,
            PunchTime = DateTime.Today.Add(db.PunchTime).ToString("hh:mm tt"),
            PunchType = db.PunchType,
            Reason = db.Reason,
            Status = db.Status
        }).ToList();
    }

    private async Task SubmitManualPunch()
    {
        if (string.IsNullOrWhiteSpace(_selectedEmpId))
        {
            Snackbar.Add("Please choose an employee.", Severity.Warning);
            return;
        }

        TimeSpan timeSpan = _entryTime?.ToTimeSpan() ?? new TimeSpan(9, 0, 0);

        var log = new ManualPunchLog
        {
            EmployeeId = _selectedEmpId,
            PunchDate = _entryDate,
            PunchTime = timeSpan,
            PunchType = _selectedPunchType,
            Reason = _newReason,
            Status = "Pending"
        };

        await ErpService.AddManualPunchLogAsync(log);
        await LoadData();
        Snackbar.Add($"Manual punch recorded. Pending approval.", Severity.Success);

        // Reset fields
        _selectedEmpId = string.Empty;
        _newReason = string.Empty;
        _entryTime = new TimeOnly(9, 0);
        _entryDate = DateTime.Today;
    }

    private async Task ApproveLog(ManualPunchUiLog log)
    {
        await ErpService.ApproveManualPunchLogAsync(log.Id);
        await LoadData();
        Snackbar.Add($"Manual punch log approved.", Severity.Success);
    }

    private async Task DeleteLog(ManualPunchUiLog log)
    {
        await ErpService.DeleteManualPunchLogAsync(log.Id);
        await LoadData();
        Snackbar.Add("Manual punch log removed.", Severity.Info);
    }

    public class ManualPunchUiLog
    {
        public int Id { get; set; }
        public string EmpId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public DateTime LogDate { get; set; }
        public string PunchTime { get; set; } = string.Empty;
        public string PunchType { get; set; } = string.Empty;
        public string Reason { get; set; } = string.Empty;
        public string Status { get; set; } = "Pending";
    }
}
