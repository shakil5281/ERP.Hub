@page "/hr/seperation"

<PageTitle>ERPHub - Employee Separations</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Separations</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage resignations, termination requests, notice periods, and clearance checklists.</p>
                </div>
            </div>

            <!-- Separations Listing DataTable -->
            <DataTable TItem="SeparationRecord" Items="_records">
                <HeaderTemplate>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left font-heading">Employee</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Type</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Resign Date</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Last Working Day</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Clearance</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Status</th>
                </HeaderTemplate>
                <RowTemplate Context="rec">
                    <td class="p-2.5 px-4 font-bold text-zinc-900 font-heading">@rec.Employee</td>
                    <td class="p-2.5 px-4 text-zinc-700 text-xs">@rec.Type</td>
                    <td class="p-2.5 px-4 text-zinc-600 text-xs font-body">@rec.ResignDate</td>
                    <td class="p-2.5 px-4 text-zinc-600 text-xs font-body">@rec.LastWorkingDay</td>
                    <td class="p-2.5 px-4">
                        <span class="text-xs font-semibold text-zinc-800">@rec.ClearanceProgress</span>
                    </td>
                    <td class="p-2.5 px-4">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @rec.BadgeClass">@rec.Status</span>
                    </td>
                </RowTemplate>
            </DataTable>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SeparationRecord
    {
        public string Employee { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string ResignDate { get; set; } = string.Empty;
        public string LastWorkingDay { get; set; } = string.Empty;
        public string ClearanceProgress { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<SeparationRecord> _records = new()
    {
        new SeparationRecord { Employee = "Peter Parker", Type = "Resignation", ResignDate = "2026-06-01", LastWorkingDay = "2026-06-30", ClearanceProgress = "75% (3/4 Done)", Status = "Notice Period", BadgeClass = "bg-amber-50 text-amber-700" },
        new SeparationRecord { Employee = "Bruce Wayne", Type = "Retirement", ResignDate = "2026-05-15", LastWorkingDay = "2026-06-15", ClearanceProgress = "100% (Completed)", Status = "Settled", BadgeClass = "bg-green-50 text-green-700 border border-green-100" }
    };
}
