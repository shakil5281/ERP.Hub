@page "/hr/seperation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>ERPHub - Employee Separations</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Separations</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage resignations, terminations, retirements, notice periods, and clearance checklists.</p>
                </div>
                <div>
                    <button type="button" class="inline-flex items-center py-1.5 px-3 rounded-md bg-black text-white font-semibold hover:bg-zinc-800 transition-colors cursor-pointer text-xs" @onclick="OpenAddModal">
                        <MudIcon Icon="@Icons.Material.Filled.PersonRemove" Size="Size.Small" Class="mr-1" />
                        Record Separation
                    </button>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="flex justify-center items-center py-16">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                </div>
            }
            else
            {
                <!-- Dashboard Metrics Cards -->
                <div class="grid grid-cols-4 gap-4 mb-6 max-xl:grid-cols-2 max-sm:grid-cols-1">
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #6366f1;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Total Separations</div>
                        <div class="text-xl font-extrabold text-zinc-950 mt-1 font-heading">@TotalSeparations Cases</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #f59e0b;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">In Notice Period</div>
                        <div class="text-xl font-extrabold text-amber-600 mt-1 font-heading">@InNoticePeriod Active</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #10b981;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Settled / Cleared</div>
                        <div class="text-xl font-extrabold text-emerald-600 mt-1 font-heading">@TotalSettled Cleared</div>
                    </div>
                    <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm" style="border-left: 4px solid #ef4444;">
                        <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider font-heading">Avg. Clearance</div>
                        <div class="text-xl font-extrabold text-rose-600 mt-1 font-heading">@AvgClearance%</div>
                    </div>
                </div>

                <!-- Advanced Filter Section -->
                <div class="bg-white border border-zinc-200 rounded-xl shadow-sm mb-6 overflow-hidden">
                    <div class="px-5 py-4 border-b border-zinc-100 flex justify-between items-center cursor-pointer select-none hover:bg-zinc-50 transition-colors" @onclick="ToggleFilterCollapse">
                        <div class="flex items-center gap-2.5">
                            <svg class="w-4.5 h-4.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            <span class="text-sm font-semibold text-zinc-800 font-heading">Advanced Filters</span>
                            @if (HasActiveFilters)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 animate-pulse-slow">
                                    Active Filters
                                </span>
                            }
                        </div>
                        <svg class="w-4 h-4 text-zinc-400 transition-transform duration-200 @(_isFilterCollapsed ? "" : "transform rotate-180")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>

                    <MudCollapse Expanded="!_isFilterCollapsed">
                        <div class="p-5 bg-zinc-50/50">
                            <MudGrid Spacing="3">
                                <!-- Department -->
                                <MudItem xs="12" sm="3">
                                    <MudSelect T="int" Value="_deptFilter" ValueChanged="OnDeptFilterChanged" Label="Department" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                                        @foreach (var d in _departments)
                                        {
                                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <!-- Separation Type -->
                                <MudItem xs="12" sm="3">
                                    <MudSelect T="string" Value="_typeFilter" ValueChanged="OnTypeFilterChanged" Label="Separation Type" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="@("All")">All Types</MudSelectItem>
                                        <MudSelectItem Value="@("Resignation")">Resignation</MudSelectItem>
                                        <MudSelectItem Value="@("Termination")">Termination</MudSelectItem>
                                        <MudSelectItem Value="@("Retirement")">Retirement</MudSelectItem>
                                        <MudSelectItem Value="@("Voluntary Exit")">Voluntary Exit</MudSelectItem>
                                        <MudSelectItem Value="@("Abandonment")">Abandonment</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- Status -->
                                <MudItem xs="12" sm="3">
                                    <MudSelect T="string" Value="_statusFilter" ValueChanged="OnStatusFilterChanged" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        <MudSelectItem Value="@("All")">All Statuses</MudSelectItem>
                                        <MudSelectItem Value="@("Initiated")">Initiated</MudSelectItem>
                                        <MudSelectItem Value="@("Notice Period")">Notice Period</MudSelectItem>
                                        <MudSelectItem Value="@("Clearance")">Clearance</MudSelectItem>
                                        <MudSelectItem Value="@("Terminated")">Terminated</MudSelectItem>
                                        <MudSelectItem Value="@("Settled")">Settled</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- Buttons -->
                                <MudItem xs="12" sm="3" Class="flex items-end gap-2.5">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh">Reset</MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" Size="Size.Small" StartIcon="@Icons.Material.Filled.FilterList">Apply</MudButton>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudCollapse>
                </div>

                <!-- Separations Data Table -->
                <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                    <MudTable Items="@_filteredSeparations" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0" Filter="new Func<Separation, bool>(FilterFunc)">
                        <ToolBarContent>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold font-heading">Separation Records</MudText>
                            <MudSpacer />
                            <MudTextField @bind-Value="_searchString"
                                          Placeholder="Search by name, ID, type..."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          IconSize="Size.Small"
                                          Class="mt-0"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Clearable="true" />
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.EmployeeName)">Employee</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.Department?.NameEn ?? string.Empty)">Department</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.SeparationType)">Type</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.ResignDate)">Resign Date</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.LastWorkingDay)">Last Day</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.ClearanceProgress)">Clearance</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: center;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Employee">
                                <div class="flex flex-col">
                                    <span class="fw-semibold text-zinc-900 text-sm">@context.EmployeeName</span>
                                    <span class="text-zinc-400 text-[10px] font-mono">@context.EmployeeId</span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Department">
                                <div class="flex flex-col">
                                    <span class="text-zinc-700 text-xs">@(context.Department?.NameEn ?? "-")</span>
                                    @if (context.Designation != null)
                                    {
                                        <span class="text-zinc-400 text-[10px]">@context.Designation.NameEn</span>
                                    }
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Type">
                                @{
                                    var typeClass = context.SeparationType switch
                                    {
                                        "Resignation" => "bg-blue-50 text-blue-700 border border-blue-100",
                                        "Termination" => "bg-red-50 text-red-700 border border-red-100",
                                        "Retirement" => "bg-emerald-50 text-emerald-700 border border-emerald-100",
                                        "Voluntary Exit" => "bg-violet-50 text-violet-700 border border-violet-100",
                                        "Abandonment" => "bg-rose-50 text-rose-800 border border-rose-100",
                                        _ => "bg-zinc-50 text-zinc-600"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @typeClass">@context.SeparationType</span>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Resign Date">
                                <span class="font-mono text-xs text-zinc-600">@context.ResignDate.ToString("yyyy-MM-dd")</span>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Last Day">
                                <span class="font-mono text-xs text-zinc-600">@context.LastWorkingDay.ToString("yyyy-MM-dd")</span>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Clearance">
                                <div class="flex flex-col items-center gap-1">
                                    <span class="text-xs font-bold @(context.ClearanceProgress == 100 ? "text-emerald-600" : context.ClearanceProgress >= 50 ? "text-amber-600" : "text-zinc-500")">
                                        @context.ClearanceProgress%
                                    </span>
                                    <div class="w-20 h-1.5 bg-zinc-100 rounded-full overflow-hidden">
                                        <div class="h-full rounded-full transition-all @(context.ClearanceProgress == 100 ? "bg-emerald-500" : context.ClearanceProgress >= 50 ? "bg-amber-400" : "bg-indigo-400")"
                                             style="width: @(context.ClearanceProgress)%"></div>
                                    </div>
                                </div>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Status">
                                @{
                                    var statusClass = context.Status switch
                                    {
                                        "Initiated" => "bg-zinc-50 text-zinc-600 border border-zinc-200",
                                        "Notice Period" => "bg-amber-50 text-amber-700 border border-amber-200",
                                        "Clearance" => "bg-blue-50 text-blue-700 border border-blue-100",
                                        "Terminated" => "bg-red-50 text-red-700 border border-red-100",
                                        "Settled" => "bg-emerald-50 text-emerald-700 border border-emerald-100",
                                        _ => "bg-zinc-50 text-zinc-600"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @statusClass">@context.Status</span>
                            </MudTd>
                            <MudTd Style="text-align: center;" DataLabel="Actions">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 rounded-md hover:bg-indigo-50 text-zinc-400 hover:text-indigo-600 transition-colors cursor-pointer"
                                            title="Update Status"
                                            @onclick="() => OpenUpdateModal(context)">
                                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                    </button>
                                    <button type="button"
                                            class="p-1.5 rounded-md hover:bg-red-50 text-zinc-400 hover:text-red-500 transition-colors cursor-pointer"
                                            title="Delete Record"
                                            @onclick="() => DeleteSeparation(context)">
                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                    </button>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8 font-body">No separation records match the current filters.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            }
        </div>

        <!-- Record New Separation Modal -->
        @if (_showAddModal)
        {
            <div class="fixed inset-0 bg-black/40 backdrop-blur-xs flex items-center justify-center z-[1000] animate-fade-in" @onclick="CloseAddModal">
                <div class="bg-white rounded-xl shadow-xl border border-zinc-200 max-w-2xl w-full p-6 mx-4 max-h-[90vh] overflow-y-auto" @onclick:stopPropagation="true">
                    <h3 class="text-base font-bold text-zinc-950 font-heading mb-1">@(_isEditMode ? "Update Separation Record" : "Record Employee Separation")</h3>
                    <p class="text-xs text-zinc-500 mb-5 font-body">@(_isEditMode ? "Update the clearance progress and status for this separation." : "Register a new employee separation with type, dates, and clearance details.")</p>

                    <div class="space-y-4">
                        <!-- Row 1: Employee ID + Name -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Employee ID</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.EmployeeId" placeholder="e.g. EMP-0042" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Employee Name</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.EmployeeName" placeholder="Full name" />
                            </div>
                        </div>

                        <!-- Row 2: Department + Section + Designation cascading -->
                        <div class="grid grid-cols-3 gap-4 font-body">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Department</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @onchange="OnModalDeptChanged">
                                    <option value="0">Select...</option>
                                    @foreach (var d in _departments)
                                    {
                                        <option value="@d.Id" selected="@(_newSep.DepartmentId == d.Id)">@d.NameEn</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Section</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newSep.SectionId" disabled="@(_modalSections.Count == 0)">
                                    <option value="">Select...</option>
                                    @foreach (var s in _modalSections)
                                    {
                                        <option value="@s.Id">@s.NameEn</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Designation</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newSep.DesignationId" disabled="@(_modalDesignations.Count == 0)">
                                    <option value="">Select...</option>
                                    @foreach (var ds in _modalDesignations)
                                    {
                                        <option value="@ds.Id">@ds.NameEn</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- Row 3: Type + Status + Clearance -->
                        <div class="grid grid-cols-3 gap-4 font-body">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Separation Type</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newSep.SeparationType">
                                    <option value="Resignation">Resignation</option>
                                    <option value="Termination">Termination</option>
                                    <option value="Retirement">Retirement</option>
                                    <option value="Voluntary Exit">Voluntary Exit</option>
                                    <option value="Abandonment">Abandonment</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Status</label>
                                <select class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 bg-white outline-none focus:border-black font-body" @bind="_newSep.Status">
                                    <option value="Initiated">Initiated</option>
                                    <option value="Notice Period">Notice Period</option>
                                    <option value="Clearance">Clearance</option>
                                    <option value="Terminated">Terminated</option>
                                    <option value="Settled">Settled</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Clearance % (0–100)</label>
                                <input type="number" min="0" max="100" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.ClearanceProgress" />
                            </div>
                        </div>

                        <!-- Row 4: Resign Date + Last Working Day + Exit Interview -->
                        <div class="grid grid-cols-3 gap-4 font-body">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Resign Date</label>
                                <input type="date" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body"
                                       value="@_newSep.ResignDate.ToString("yyyy-MM-dd")"
                                       @onchange="OnResignDateChanged" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Last Working Day</label>
                                <input type="date" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body"
                                       value="@_newSep.LastWorkingDay.ToString("yyyy-MM-dd")"
                                       @onchange="OnLastDayChanged" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Exit Interview Date</label>
                                <input type="date" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body"
                                       value="@(_newSep.ExitInterviewDate?.ToString("yyyy-MM-dd") ?? "")"
                                       @onchange="OnExitDateChanged" />
                            </div>
                        </div>

                        <!-- Row 5: Reason -->
                        <div>
                            <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Reason for Leaving</label>
                            <textarea rows="2" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.Reason" placeholder="State the reason for separation..."></textarea>
                        </div>

                        <!-- Row 6: Handover Notes + Approved By -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Handover Notes</label>
                                <textarea rows="2" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.HandoverNotes" placeholder="Tasks, assets, knowledge transfer..."></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-1 font-heading">Approved By</label>
                                <input type="text" class="w-full border border-zinc-200 rounded-lg p-2 text-sm text-zinc-900 outline-none focus:border-black font-body" @bind="_newSep.ApprovedBy" placeholder="e.g. HR Manager" />
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 mt-6">
                        <button type="button" class="px-4 py-2 border border-zinc-200 rounded-lg text-xs font-bold text-zinc-700 hover:bg-zinc-50 transition-colors cursor-pointer font-heading" @onclick="CloseAddModal">Cancel</button>
                        <button type="button" class="px-4 py-2 bg-black text-white rounded-lg text-xs font-bold hover:bg-zinc-800 transition-colors cursor-pointer font-heading" @onclick="SaveSeparation" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <svg class="w-3.5 h-3.5 animate-spin mr-1.5 inline" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 40" /></svg>
                            }
                            @(_isEditMode ? "Update Record" : "Save Separation")
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Separation> _separations = new();
    private List<Separation> _filteredSeparations = new();
    private List<Department> _departments = new();
    private List<Section> _sections = new();
    private List<Designation> _designations = new();

    private bool _isLoading = true;
    private bool _isFilterCollapsed = true;
    private string _searchString = "";

    // Filters
    private int _deptFilter = 0;
    private string _typeFilter = "All";
    private string _statusFilter = "All";

    private bool HasActiveFilters => _deptFilter > 0 || _typeFilter != "All" || _statusFilter != "All";

    // Modal
    private bool _showAddModal = false;
    private bool _isSaving = false;
    private bool _isEditMode = false;
    private Separation _newSep = new();
    private List<Section> _modalSections = new();
    private List<Designation> _modalDesignations = new();

    // Metrics
    private int TotalSeparations => _filteredSeparations.Count;
    private int InNoticePeriod => _filteredSeparations.Count(s => s.Status == "Notice Period");
    private int TotalSettled => _filteredSeparations.Count(s => s.Status == "Settled");
    private int AvgClearance => _filteredSeparations.Count > 0
        ? (int)Math.Round(_filteredSeparations.Average(s => s.ClearanceProgress))
        : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadData();
    }

    private void ToggleFilterCollapse() => _isFilterCollapsed = !_isFilterCollapsed;

    private async Task LoadLookupData()
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var deptsTask = Http.GetFromJsonAsync<List<Department>>($"{baseUri}api/departments");
            var secsTask = Http.GetFromJsonAsync<List<Section>>($"{baseUri}api/sections");
            var desigTask = Http.GetFromJsonAsync<List<Designation>>($"{baseUri}api/designations");
            await Task.WhenAll(deptsTask, secsTask, desigTask);
            _departments = await deptsTask ?? new();
            _sections = await secsTask ?? new();
            _designations = await desigTask ?? new();
        }
        catch { /* fail silently */ }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var baseUri = NavManager.BaseUri;
            _separations = await Http.GetFromJsonAsync<List<Separation>>($"{baseUri}api/separations") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _separations = new();
            _filteredSeparations = new();
            Snackbar.Add($"Failed to load separations: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        _filteredSeparations = _separations.Where(s =>
            (_deptFilter == 0 || s.DepartmentId == _deptFilter) &&
            (_typeFilter == "All" || s.SeparationType == _typeFilter) &&
            (_statusFilter == "All" || s.Status == _statusFilter)
        ).ToList();
    }

    private void ResetFilters()
    {
        _deptFilter = 0;
        _typeFilter = "All";
        _statusFilter = "All";
        ApplyFilters();
    }

    private void OnDeptFilterChanged(int id) { _deptFilter = id; ApplyFilters(); }
    private void OnTypeFilterChanged(string t) { _typeFilter = t ?? "All"; ApplyFilters(); }
    private void OnStatusFilterChanged(string s) { _statusFilter = s ?? "All"; ApplyFilters(); }

    private bool FilterFunc(Separation s)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        var q = _searchString;
        return (s.EmployeeName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.EmployeeId?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.SeparationType?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Department?.NameEn?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Status?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Reason?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void OpenAddModal()
    {
        _isEditMode = false;
        _newSep = new Separation
        {
            SeparationType = "Resignation",
            Status = "Initiated",
            ResignDate = DateTime.Today,
            LastWorkingDay = DateTime.Today.AddDays(30),
            ClearanceProgress = 0
        };
        _modalSections.Clear();
        _modalDesignations.Clear();
        _showAddModal = true;
    }

    private void OpenUpdateModal(Separation sep)
    {
        _isEditMode = true;
        // Deep copy to avoid mutating list directly
        _newSep = new Separation
        {
            Id = sep.Id,
            EmployeeId = sep.EmployeeId,
            EmployeeName = sep.EmployeeName,
            DepartmentId = sep.DepartmentId,
            SectionId = sep.SectionId,
            DesignationId = sep.DesignationId,
            SeparationType = sep.SeparationType,
            ResignDate = sep.ResignDate,
            LastWorkingDay = sep.LastWorkingDay,
            ExitInterviewDate = sep.ExitInterviewDate,
            Reason = sep.Reason,
            HandoverNotes = sep.HandoverNotes,
            Status = sep.Status,
            ClearanceProgress = sep.ClearanceProgress,
            ApprovedBy = sep.ApprovedBy,
            ApprovedDate = sep.ApprovedDate
        };
        // Preload cascading dropdowns
        _modalSections = _sections.Where(s => s.DepartmentId == _newSep.DepartmentId).ToList();
        var secIds = _modalSections.Select(s => s.Id).ToHashSet();
        _modalDesignations = _designations.Where(d => secIds.Contains(d.SectionId)).ToList();
        _showAddModal = true;
    }

    private void CloseAddModal() => _showAddModal = false;

    private void OnModalDeptChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _newSep.DepartmentId = id;
            _newSep.SectionId = null;
            _newSep.DesignationId = null;
            _modalSections = id > 0 ? _sections.Where(s => s.DepartmentId == id).ToList() : new();
            var secIds = _modalSections.Select(s => s.Id).ToHashSet();
            _modalDesignations = _designations.Where(d => secIds.Contains(d.SectionId)).ToList();
        }
    }

    private void OnDateChanged(ChangeEventArgs e, string field)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            if (field == "resign") _newSep.ResignDate = dt;
            else if (field == "last") _newSep.LastWorkingDay = dt;
            else if (field == "exit") _newSep.ExitInterviewDate = dt;
        }
        else if (field == "exit")
        {
            _newSep.ExitInterviewDate = null;
        }
    }

    private void OnResignDateChanged(ChangeEventArgs e) => OnDateChanged(e, "resign");
    private void OnLastDayChanged(ChangeEventArgs e) => OnDateChanged(e, "last");
    private void OnExitDateChanged(ChangeEventArgs e) => OnDateChanged(e, "exit");

    private async Task SaveSeparation()
    {
        if (string.IsNullOrWhiteSpace(_newSep.EmployeeId))
        {
            Snackbar.Add("Please enter an Employee ID.", Severity.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(_newSep.EmployeeName))
        {
            Snackbar.Add("Please enter the Employee Name.", Severity.Warning);
            return;
        }
        if (_newSep.DepartmentId <= 0)
        {
            Snackbar.Add("Please select a Department.", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            var baseUri = NavManager.BaseUri;
            HttpResponseMessage response;

            if (_isEditMode)
            {
                _newSep.ApprovedDate = string.IsNullOrWhiteSpace(_newSep.ApprovedBy) ? null : DateTime.Now;
                response = await Http.PutAsJsonAsync($"{baseUri}api/separations/{_newSep.Id}", _newSep);
                if (response.IsSuccessStatusCode)
                    Snackbar.Add("Separation record updated successfully.", Severity.Success);
                else
                    Snackbar.Add($"Update failed: {await response.Content.ReadAsStringAsync()}", Severity.Error);
            }
            else
            {
                response = await Http.PostAsJsonAsync($"{baseUri}api/separations", _newSep);
                if (response.IsSuccessStatusCode)
                    Snackbar.Add("Separation recorded successfully.", Severity.Success);
                else
                    Snackbar.Add($"Save failed: {await response.Content.ReadAsStringAsync()}", Severity.Error);
            }

            if (response.IsSuccessStatusCode)
            {
                _showAddModal = false;
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteSeparation(Separation sep)
    {
        try
        {
            var baseUri = NavManager.BaseUri;
            var response = await Http.DeleteAsync($"{baseUri}api/separations/{sep.Id}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Separation record for {sep.EmployeeName} deleted.", Severity.Info);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Failed to delete record.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete error: {ex.Message}", Severity.Error);
        }
    }
}
