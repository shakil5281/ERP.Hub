@page "/hr/seperation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>ERPHub - Employee Separations</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header *@
        <div class="d-flex justify-between align-center mb-6" style="flex-wrap:wrap; gap: 16px;width: 100%;">
            <div>
                <h5 class="text-[22px] font-extrabold">Employee Separations</h5>
                <p class="text-xs text-zinc-500 mt-1">View separation history — resignations, retirements, terminations and more.</p>
            </div>
            <a href="/hr/record-separation" class="btn btn-primary btn-sm mr-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2m7-10a4 4 0 100-8 4 4 0 000 8zm8-3v6m3-3h-6" />
                </svg>
                Record Separation
            </a>
        </div>

        @* Metrics *@
        @if (_separations.Count > 0)
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 max-xl:grid-cols-3 gap-3 mb-4">
                <div class="bg-white border border-zinc-200 rounded-lg p-3" style="border-radius:8px; border-left:4px solid #6366f1;">
                    <div class="text-xs font-bold text-uppercase" style="color:#6366f1; letter-spacing:.05em;">Total</div>
                    <div class="text-sm font-extrabold mt-1">@_separations.Count</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-3" style="border-radius:8px; border-left:4px solid #f59e0b;">
                    <div class="text-xs font-bold text-uppercase" style="color:#f59e0b; letter-spacing:.05em;">Resign</div>
                    <div class="text-sm font-extrabold mt-1">@_separations.Count(s => s.SeparationType == "Resign")</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-3" style="border-radius:8px; border-left:4px solid #10b981;">
                    <div class="text-xs font-bold text-uppercase" style="color:#10b981; letter-spacing:.05em;">Settled</div>
                    <div class="text-sm font-extrabold mt-1">@_separations.Count(s => s.IsSettled)</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-3" style="border-radius:8px; border-left:4px solid #ef4444;">
                    <div class="text-xs font-bold text-uppercase" style="color:#ef4444; letter-spacing:.05em;">Left</div>
                    <div class="text-sm font-extrabold mt-1">@_separations.Count(s => s.SeparationType == "Left")</div>
                </div>
                <div class="bg-white border border-zinc-200 rounded-lg p-3" style="border-radius:8px; border-left:4px solid #8b5cf6;">
                    <div class="text-xs font-bold text-uppercase" style="color:#8b5cf6; letter-spacing:.05em;">Close</div>
                    <div class="text-sm font-extrabold mt-1">@_separations.Count(s => s.SeparationType == "Close")</div>
                </div>
            </div>
        }

        @* Advanced Filters *@
        <div class="bg-white border border-zinc-200 rounded-lg p-4 mb-4">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <div>
                    <label class="form-label">From Date</label>
                    <input type="date" class="form-control" value="@_fromDate.ToString("yyyy-MM-dd")" @onchange="@(e => { if (DateTime.TryParse((e as ChangeEventArgs)?.Value?.ToString(), out var d)) _fromDate = d; })" />
                </div>
                <div>
                    <label class="form-label">To Date</label>
                    <input type="date" class="form-control" value="@_toDate.ToString("yyyy-MM-dd")" @onchange="@(e => { if (DateTime.TryParse((e as ChangeEventArgs)?.Value?.ToString(), out var d)) _toDate = d; })" />
                </div>
                <div>
                    <label class="form-label">Department</label>
                    <select class="form-control" @bind="_deptFilter">
                        <option value="0">All Departments</option>
                        @foreach (var d in _departments)
                        {
                            <option value="@d.Id">@d.NameEn</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Separation Type</label>
                    <select class="form-control" @bind="_typeFilter">
                        <option value="All">All Types</option>
                        <option value="Resign">Resign</option>
                        <option value="Left">Left</option>
                        <option value="Close">Close</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Status</label>
                    <select class="form-control" @bind="_statusFilter">
                        <option value="All">All Statuses</option>
                        <option value="Recorded">Recorded</option>
                        <option value="Settled">Settled</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="flex items-end">
                    <div class="flex gap-2 w-100 pt-3">
                        <button class="btn btn-primary flex-grow-1" disabled="@_isLoading" @onclick="LoadData">Apply</button>
                        <button class="btn btn-outlined flex-grow-1" @onclick="ResetFilters">Clear</button>
                    </div>
                </div>
            </div>
        </div>

        @* Data Table *@
        @if (_isLoading)
        {
            <div class="text-center py-8 text-zinc-500 text-sm">Loading...</div>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-toolbar">
                    <span class="text-sm font-bold fw-bold">Separation Records</span>
                    <div class="relative">
                        <input type="text" class="form-control pl-10" @bind="_searchString" placeholder="Search by name, ID, type..." />
                        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                </div>
                <div class="table-body">
                    <table class="data-table-base">
                        <thead>
                            <tr>
                                <th style="text-align:center;">Sl</th>
                                <th><button class="sort-btn">Employee</button></th>
                                <th><button class="sort-btn">Department</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Type</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Separation Date</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Clearance</button></th>
                                <th style="text-align:center;"><button class="sort-btn">Status</button></th>
                                <th style="text-align:center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var context in _separations.Where(FilterFunc))
                            {
                                <tr>
                                    <td style="text-align:center;">@(_separations.IndexOf(context) + 1)</td>
                                    <td>
                                        <span class="text-sm font-semibold">@context.EmployeeName</span>
                                        <span class="text-xs text-zinc-500 font-mono">@context.EmployeeId</span>
                                    </td>
                                    <td>
                                        <span class="text-sm">@(context.Department?.NameEn ?? "-")</span>
                                        @if (context.Designation != null)
                                        {
                                            <span class="text-xs text-zinc-500">@context.Designation.NameEn</span>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        @{
                                            var typeClass = context.SeparationType switch
                                            {
                                                "Resign" => "bg-blue-50 text-blue-700 border border-blue-100",
                                                "Left"   => "bg-violet-50 text-violet-700 border border-violet-100",
                                                "Close"  => "bg-red-50 text-red-700 border border-red-100",
                                                _        => "bg-zinc-50 text-zinc-600"
                                            };
                                        }
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @typeClass">@context.SeparationType</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <span class="text-sm font-mono">@context.SeparationDate.ToString("yyyy-MM-dd")</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <div class="flex flex-col items-center gap-1">
                                            <span class="text-xs font-bold @(context.ClearanceProgress == 100 ? "text-emerald-600" : context.ClearanceProgress >= 50 ? "text-amber-600" : "text-zinc-500")">
                                                @context.ClearanceProgress%
                                            </span>
                                            <div class="w-16 h-1.5 bg-zinc-100 rounded-full overflow-hidden">
                                                <div class="h-full rounded-full transition-all @(context.ClearanceProgress == 100 ? "bg-emerald-500" : context.ClearanceProgress >= 50 ? "bg-amber-400" : "bg-indigo-400")"
                                                     style="width: @(context.ClearanceProgress)%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align:center;">
                                        @{
                                            var statusClass = context.Status switch
                                            {
                                                "Initiated"     => "bg-zinc-50 text-zinc-600 border border-zinc-200",
                                                "Notice Period" => "bg-amber-50 text-amber-700 border border-amber-200",
                                                "Clearance"     => "bg-blue-50 text-blue-700 border border-blue-100",
                                                "Terminated"    => "bg-red-50 text-red-700 border border-red-100",
                                                "Settled"       => "bg-emerald-50 text-emerald-700 border border-emerald-100",
                                                _               => "bg-zinc-50 text-zinc-600"
                                            };
                                        }
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @statusClass">@context.Status</span>
                                    </td>
                                    <td style="text-align:center;">
                                        <div class="flex items-center justify-center gap-1">
                                            <button class="btn-icon btn-icon-sm text-indigo-500" title="Update Status" @onclick="() => OpenUpdateModal(context)">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                            </button>
                                            <button class="btn-icon btn-icon-sm text-red-500" title="Delete" @onclick="() => DeleteSeparation(context)">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!_separations.Any(FilterFunc))
                {
                    <div class="table-empty">
                        <span class="text-sm text-zinc-500">No records found.</span>
                    </div>
                }
            </div>
        }

        @* Edit Modal *@
        @if (_showUpdateModal && _editSep != null)
        {
            <div class="overlay"></div>
            <div class="fixed inset-0 flex items-center justify-center z-[9999] animate-fade-in">
                <div class="bg-white rounded-xl shadow-xl p-6" style="min-width:380px; max-width:500px; width:100%; margin:0 16px;">
                    <h6 class="text-base font-bold mb-4">Update Separation Status</h6>
                    <p class="text-sm font-semibold mb-4">@_editSep.EmployeeName (@_editSep.EmployeeId)</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                            <label class="form-label">Status</label>
                            <select class="form-control" @bind="_editSep.Status">
                                <option value="Recorded">Recorded</option>
                                <option value="Settled">Settled</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Clearance % (0-100)</label>
                            <input type="number" class="form-control" @bind="_editSep.ClearanceProgress" min="0" max="100" />
                        </div>
                        <div class="col-span-1 sm:col-span-2">
                            <label class="form-label">Approved By</label>
                            <input type="text" class="form-control" @bind="_editSep.ApprovedBy" />
                        </div>
                        <div class="col-span-1 sm:col-span-2">
                            <label class="form-label">Reason / Notes</label>
                            <textarea class="form-control" @bind="_editSep.Reason" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="flex justify-end gap-2 mt-4">
                        <button class="btn btn-outlined" @onclick="CloseUpdateModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveUpdate" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save")
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Separation> _separations = new();
    private List<Department> _departments = new();

    private bool _isLoading = true;
    private bool _isSaving;
    private string _searchString = "";

    // Filters
    private DateTime _fromDate = new(DateTime.Today.Year, 1, 1);
    private DateTime _toDate = DateTime.Today;
    private int _deptFilter = 0;
    private string _typeFilter = "All";
    private string _statusFilter = "All";

    // Edit
    private bool _showUpdateModal;
    private Separation? _editSep;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        try
        {
            _departments = await Http.GetFromJsonAsync<List<Department>>($"{NavManager.BaseUri}api/departments") ?? new();
        }
        catch { }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var url = $"{NavManager.BaseUri}api/separations?fromDate={_fromDate:yyyy-MM-dd}&toDate={_toDate:yyyy-MM-dd}";
            if (_deptFilter > 0) url += $"&deptId={_deptFilter}";
            if (_typeFilter != "All") url += $"&type={Uri.EscapeDataString(_typeFilter)}";
            if (_statusFilter != "All") url += $"&status={Uri.EscapeDataString(_statusFilter)}";

            _separations = await Http.GetFromJsonAsync<List<Separation>>(url) ?? new();
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Failed to load: {ex.Message}");
            _separations = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ResetFilters()
    {
        _fromDate = new(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _deptFilter = 0;
        _typeFilter = "All";
        _statusFilter = "All";
        _searchString = "";
        await LoadData();
    }

    private bool FilterFunc(Separation s)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        var q = _searchString;
        return (s.EmployeeName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.EmployeeId?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.SeparationType?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Department?.NameEn?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void OpenUpdateModal(Separation sep)
    {
        _editSep = new Separation
        {
            Id = sep.Id,
            EmployeeRefId = sep.EmployeeRefId,
            EmployeeId = sep.EmployeeId,
            EmployeeName = sep.EmployeeName,
            DepartmentId = sep.DepartmentId,
            SectionId = sep.SectionId,
            DesignationId = sep.DesignationId,
            CompanyId = sep.CompanyId,
            SeparationType = sep.SeparationType,
            SeparationDate = sep.SeparationDate,
            ExitInterviewDate = sep.ExitInterviewDate,
            Reason = sep.Reason,
            Remarks = sep.Remarks,
            Status = sep.Status,
            ClearanceProgress = sep.ClearanceProgress,
            ApprovedBy = sep.ApprovedBy,
            IsSettled = sep.IsSettled,
            IsCancelled = sep.IsCancelled
        };
        _showUpdateModal = true;
    }

    private void CloseUpdateModal() { _showUpdateModal = false; _editSep = null; }

    private async Task SaveUpdate()
    {
        if (_editSep == null) return;
        _isSaving = true;
        try
        {
            _editSep.ApprovedDate = string.IsNullOrWhiteSpace(_editSep.ApprovedBy) ? null : DateTime.Now;
            var response = await Http.PutAsJsonAsync($"{NavManager.BaseUri}api/separations/{_editSep.Id}", _editSep);
            if (response.IsSuccessStatusCode)
            {
                await Toast.ShowSuccessAsync("Separation updated successfully.");
                CloseUpdateModal();
                await LoadData();
            }
            else
                await Toast.ShowErrorAsync("Update failed.");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Error: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSeparation(Separation sep)
    {
        try
        {
            var response = await Http.DeleteAsync($"{NavManager.BaseUri}api/separations/{sep.Id}");
            if (response.IsSuccessStatusCode)
            {
                await Toast.ShowInfoAsync($"{sep.EmployeeName} separation record deleted.");
                await LoadData();
            }
            else
                await Toast.ShowErrorAsync("Delete failed.");
        }
        catch (Exception ex)
        {
            await Toast.ShowErrorAsync($"Error: {ex.Message}");
        }
    }
}
