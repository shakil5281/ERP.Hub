@page "/hr/seperation"
@using ERPHub.Models
@using ERPHub.Services
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>ERPHub - Employee Separations</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @* Header *@
        <div class="d-flex align-center mb-6 w-100" style="flex-wrap:wrap; gap: 16px;">
            <div>
                <MudText Typo="Typo.h5" Class="fw-extrabold">Employee Separations</MudText>
                <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">View separation history — resignations, retirements, terminations and more.</MudText>
            </div>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PersonRemove"
                       Size="Size.Small"
                       Href="/hr/record-separation">
                Record Separation
            </MudButton>
        </div>

        @* Metrics *@
        @if (_separations.Count > 0)
        {
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px; border-left:4px solid #6366f1;">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase" Style="color:#6366f1; letter-spacing:.05em;">Total</MudText>
                        <MudText Typo="Typo.body1" Class="fw-extrabold mt-1">@_separations.Count</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px; border-left:4px solid #f59e0b;">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase" Style="color:#f59e0b; letter-spacing:.05em;">Notice Period</MudText>
                        <MudText Typo="Typo.body1" Class="fw-extrabold mt-1">@_separations.Count(s => s.Status == "Notice Period")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px; border-left:4px solid #10b981;">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase" Style="color:#10b981; letter-spacing:.05em;">Settled</MudText>
                        <MudText Typo="Typo.body1" Class="fw-extrabold mt-1">@_separations.Count(s => s.Status == "Settled")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px; border-left:4px solid #ef4444;">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase" Style="color:#ef4444; letter-spacing:.05em;">Resigned</MudText>
                        <MudText Typo="Typo.body1" Class="fw-extrabold mt-1">@_separations.Count(s => s.SeparationType == "Resignation")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3" md="2">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="border-radius:8px; border-left:4px solid #8b5cf6;">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase" Style="color:#8b5cf6; letter-spacing:.05em;">Retired</MudText>
                        <MudText Typo="Typo.body1" Class="fw-extrabold mt-1">@_separations.Count(s => s.SeparationType == "Retirement")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        @* Advanced Filters *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4" Style="border-radius:8px;">
            <MudGrid Spacing="3" class="align-items-end">
                <MudItem xs="12" sm="4" md="2">
                    <MudDatePicker Label="From Date"
                                   Date="@_fromDate"
                                   DateChanged="@(d => { if(d.HasValue) _fromDate = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudDatePicker Label="To Date"
                                   Date="@_toDate"
                                   DateChanged="@(d => { if(d.HasValue) _toDate = d.Value; })"
                                   Editable="true"
                                   DateFormat="yyyy-MM-dd"
                                   dense="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudSelect Label="Department"
                               @bind-Value="_deptFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem Value="0">All Departments</MudSelectItem>
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem Value="@d.Id">@d.NameEn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudSelect Label="Separation Type"
                               @bind-Value="_typeFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("All")">All Types</MudSelectItem>
                        <MudSelectItem Value="@("Resign")">Resign</MudSelectItem>
                        <MudSelectItem Value="@("Left")">Left</MudSelectItem>
                        <MudSelectItem Value="@("Close")">Close</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudSelect Label="Status"
                               @bind-Value="_statusFilter"
                               Variant="Variant.Outlined"
                               dense="true"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("All")">All Statuses</MudSelectItem>
                        <MudSelectItem Value="@("Initiated")">Initiated (New Joining Notice)</MudSelectItem>
                        <MudSelectItem Value="@("Notice Period")">Notice Period</MudSelectItem>
                        <MudSelectItem Value="@("Clearance")">Clearance</MudSelectItem>
                        <MudSelectItem Value="@("Terminated")">Terminated (Resigned / Closed)</MudSelectItem>
                        <MudSelectItem Value="@("Settled")">Settled (Left / Cleared)</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" md="2" Class="d-flex align-center gap-2" Style="margin-top:10px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="@_isLoading" @onclick="LoadData" Class="flex-grow-1">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               @onclick="ResetFilters" Class="flex-grow-1">
                        Clear
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Data Table *@
        @if (_isLoading)
        {
            <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Loading...</MudText>
        }
        else
        {
            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_separations" Hover="true" SortLabel="Sort By" Dense="true" Elevation="0"
                          Filter="new Func<Separation, bool>(FilterFunc)">
                    <ToolBarContent>
                        <MudText Typo="Typo.subtitle2" Class="fw-bold">Separation Records</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_searchString"
                                      Placeholder="Search by name, ID, type..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Class="mt-0"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="text-align:center;">Sl</MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.EmployeeName)">Employee</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.Department?.NameEn ?? string.Empty)">Department</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.SeparationType)">Type</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.ResignDate)">Resign Date</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.LastWorkingDay)">Last Day</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.ClearanceProgress)">Clearance</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<Separation, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:center;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align:center;" DataLabel="Sl">@(_separations.IndexOf(context) + 1)</MudTd>
                        <MudTd DataLabel="Employee">
                            <MudText Typo="Typo.body2" Class="fw-semibold">@context.EmployeeName</MudText>
                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color font-mono">@context.EmployeeId</MudText>
                        </MudTd>
                        <MudTd DataLabel="Department">
                            <MudText Typo="Typo.body2">@(context.Department?.NameEn ?? "-")</MudText>
                            @if (context.Designation != null)
                            {
                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@context.Designation.NameEn</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Type">
                            @{
                                var typeClass = context.SeparationType switch
                                {
                                    "Resign" => "bg-blue-50 text-blue-700 border border-blue-100",
                                    "Left"   => "bg-violet-50 text-violet-700 border border-violet-100",
                                    "Close"  => "bg-red-50 text-red-700 border border-red-100",
                                    _        => "bg-zinc-50 text-zinc-600"
                                };
                            }
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @typeClass">@context.SeparationType</span>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Resign Date">
                            <MudText Typo="Typo.body2" Class="font-mono">@context.ResignDate.ToString("yyyy-MM-dd")</MudText>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Last Day">
                            <MudText Typo="Typo.body2" Class="font-mono">@context.LastWorkingDay.ToString("yyyy-MM-dd")</MudText>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Clearance">
                            <div class="flex flex-col items-center gap-1">
                                <span class="text-xs font-bold @(context.ClearanceProgress == 100 ? "text-emerald-600" : context.ClearanceProgress >= 50 ? "text-amber-600" : "text-zinc-500")">
                                    @context.ClearanceProgress%
                                </span>
                                <div class="w-16 h-1.5 bg-zinc-100 rounded-full overflow-hidden">
                                    <div class="h-full rounded-full transition-all @(context.ClearanceProgress == 100 ? "bg-emerald-500" : context.ClearanceProgress >= 50 ? "bg-amber-400" : "bg-indigo-400")"
                                         style="width: @(context.ClearanceProgress)%"></div>
                                </div>
                            </div>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Status">
                            @{
                                var statusClass = context.Status switch
                                {
                                    "Initiated"     => "bg-zinc-50 text-zinc-600 border border-zinc-200",
                                    "Notice Period" => "bg-amber-50 text-amber-700 border border-amber-200",
                                    "Clearance"     => "bg-blue-50 text-blue-700 border border-blue-100",
                                    "Terminated"    => "bg-red-50 text-red-700 border border-red-100",
                                    "Settled"       => "bg-emerald-50 text-emerald-700 border border-emerald-100",
                                    _               => "bg-zinc-50 text-zinc-600"
                                };
                            }
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @statusClass">@context.Status</span>
                        </MudTd>
                        <MudTd Style="text-align:center;" DataLabel="Actions">
                            <div class="flex items-center justify-center gap-1">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                               title="Update Status" OnClick="() => OpenUpdateModal(context)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               title="Delete" OnClick="() => DeleteSeparation(context)" />
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">No records found.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </div>
        }

        @* Edit Modal *@
        @if (_showUpdateModal && _editSep != null)
        {
            <MudOverlay Visible="true" DarkBackground="true" ZIndex="1000" />
            <div style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1001;">
                <MudPaper Elevation="4" Class="pa-6" Style="border-radius:10px; min-width:380px; max-width:500px; width:100%;">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-4">Update Separation Status</MudText>
                    <MudText Typo="Typo.body2" Class="fw-semibold mb-4">@_editSep.EmployeeName (@_editSep.EmployeeId)</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect Label="Status" @bind-Value="_editSep.Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("Initiated")">Initiated</MudSelectItem>
                                <MudSelectItem Value="@("Notice Period")">Notice Period</MudSelectItem>
                                <MudSelectItem Value="@("Clearance")">Clearance</MudSelectItem>
                                <MudSelectItem Value="@("Terminated")">Terminated</MudSelectItem>
                                <MudSelectItem Value="@("Settled")">Settled</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField Label="Clearance % (0-100)" @bind-Value="_editSep.ClearanceProgress"
                                             Min="0" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Approved By" @bind-Value="_editSep.ApprovedBy"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Reason / Notes" @bind-Value="_editSep.Reason"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                        </MudItem>
                    </MudGrid>
                    <div class="d-flex justify-end gap-2 mt-4">
                        <MudButton OnClick="CloseUpdateModal" Color="Color.Default" Variant="Variant.Outlined">Cancel</MudButton>
                        <MudButton OnClick="SaveUpdate" Color="Color.Primary" Variant="Variant.Filled" Disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save")
                        </MudButton>
                    </div>
                </MudPaper>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Separation> _separations = new();
    private List<Department> _departments = new();

    private bool _isLoading = true;
    private bool _isSaving;
    private string _searchString = "";

    // Filters
    private DateTime _fromDate = new(DateTime.Today.Year, 1, 1);
    private DateTime _toDate = DateTime.Today;
    private int _deptFilter = 0;
    private string _typeFilter = "All";
    private string _statusFilter = "All";

    // Edit
    private bool _showUpdateModal;
    private Separation? _editSep;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        try
        {
            _departments = await Http.GetFromJsonAsync<List<Department>>($"{NavManager.BaseUri}api/departments") ?? new();
        }
        catch { }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var url = $"{NavManager.BaseUri}api/separations?fromDate={_fromDate:yyyy-MM-dd}&toDate={_toDate:yyyy-MM-dd}";
            if (_deptFilter > 0) url += $"&deptId={_deptFilter}";
            if (_typeFilter != "All") url += $"&type={Uri.EscapeDataString(_typeFilter)}";
            if (_statusFilter != "All") url += $"&status={Uri.EscapeDataString(_statusFilter)}";

            _separations = await Http.GetFromJsonAsync<List<Separation>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load: {ex.Message}", Severity.Error);
            _separations = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ResetFilters()
    {
        _fromDate = new(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _deptFilter = 0;
        _typeFilter = "All";
        _statusFilter = "All";
        _searchString = "";
        await LoadData();
    }

    private bool FilterFunc(Separation s)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        var q = _searchString;
        return (s.EmployeeName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.EmployeeId?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.SeparationType?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Department?.NameEn?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void OpenUpdateModal(Separation sep)
    {
        _editSep = new Separation
        {
            Id = sep.Id,
            EmployeeId = sep.EmployeeId,
            EmployeeName = sep.EmployeeName,
            DepartmentId = sep.DepartmentId,
            SectionId = sep.SectionId,
            DesignationId = sep.DesignationId,
            SeparationType = sep.SeparationType,
            ResignDate = sep.ResignDate,
            LastWorkingDay = sep.LastWorkingDay,
            ExitInterviewDate = sep.ExitInterviewDate,
            Reason = sep.Reason,
            HandoverNotes = sep.HandoverNotes,
            Status = sep.Status,
            ClearanceProgress = sep.ClearanceProgress,
            ApprovedBy = sep.ApprovedBy
        };
        _showUpdateModal = true;
    }

    private void CloseUpdateModal() { _showUpdateModal = false; _editSep = null; }

    private async Task SaveUpdate()
    {
        if (_editSep == null) return;
        _isSaving = true;
        try
        {
            _editSep.ApprovedDate = string.IsNullOrWhiteSpace(_editSep.ApprovedBy) ? null : DateTime.Now;
            var response = await Http.PutAsJsonAsync($"{NavManager.BaseUri}api/separations/{_editSep.Id}", _editSep);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Separation updated successfully.", Severity.Success);
                CloseUpdateModal();
                await LoadData();
            }
            else
                Snackbar.Add("Update failed.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSeparation(Separation sep)
    {
        try
        {
            var response = await Http.DeleteAsync($"{NavManager.BaseUri}api/separations/{sep.Id}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{sep.EmployeeName} separation record deleted.", Severity.Info);
                await LoadData();
            }
            else
                Snackbar.Add("Delete failed.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
