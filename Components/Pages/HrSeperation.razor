@page "/hr/seperation"

<PageTitle>ERPHub - Employee Separations</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Employee Separations</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage resignations, termination requests, notice periods, and clearance checklists.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_records" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.Employee)">Employee</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.Type)">Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.ResignDate)">Resign Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.LastWorkingDay)">Last Working Day</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.ClearanceProgress)">Clearance</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SeparationRecord, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee">@context.Employee</MudTd>
                        <MudTd DataLabel="Type">@context.Type</MudTd>
                        <MudTd DataLabel="Resign Date">@context.ResignDate</MudTd>
                        <MudTd DataLabel="Last Working Day">@context.LastWorkingDay</MudTd>
                        <MudTd DataLabel="Clearance">@context.ClearanceProgress</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @context.BadgeClass">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SeparationRecord
    {
        public string Employee { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string ResignDate { get; set; } = string.Empty;
        public string LastWorkingDay { get; set; } = string.Empty;
        public string ClearanceProgress { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
    }

    private List<SeparationRecord> _records = new()
    {
        new SeparationRecord { Employee = "Peter Parker", Type = "Resignation", ResignDate = "2026-06-01", LastWorkingDay = "2026-06-30", ClearanceProgress = "75% (3/4 Done)", Status = "Notice Period", BadgeClass = "bg-amber-50 text-amber-700" },
        new SeparationRecord { Employee = "Bruce Wayne", Type = "Retirement", ResignDate = "2026-05-15", LastWorkingDay = "2026-06-15", ClearanceProgress = "100% (Completed)", Status = "Settled", BadgeClass = "bg-green-50 text-green-700 border border-green-100" }
    };
}
