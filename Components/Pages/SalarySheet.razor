@page "/payroll/salary-sheet"

<PageTitle>ERPHub - Salary Sheets</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Salary Register Sheets</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Browse, search, and export monthly salary ledgers and registers.</p>
                </div>
            </div>

            <!-- Salary Register DataTable -->
            <DataTable TItem="SalaryRegister" Items="_sheets">
                <HeaderTemplate>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left font-heading">Pay Period</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Staff Count</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Gross Payroll</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Deductions</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Net Paid</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Payment Date</th>
                    <th class="bg-zinc-50 text-zinc-500 text-xs font-semibold p-2.5 px-4 border-b border-zinc-200 text-left">Status</th>
                </HeaderTemplate>
                <RowTemplate Context="sheet">
                    <td class="p-2.5 px-4 font-bold text-zinc-900 font-heading">@sheet.PayPeriod</td>
                    <td class="p-2.5 px-4 text-zinc-800 text-center font-semibold">@sheet.StaffCount</td>
                    <td class="p-2.5 px-4 text-zinc-900 font-bold font-body">@sheet.GrossPayroll</td>
                    <td class="p-2.5 px-4 text-red-600 font-medium font-body">@sheet.Deductions</td>
                    <td class="p-2.5 px-4 text-zinc-900 font-bold font-body">@sheet.NetPaid</td>
                    <td class="p-2.5 px-4 text-zinc-600 text-xs font-body">@sheet.PaymentDate</td>
                    <td class="p-2.5 px-4">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@sheet.Status</span>
                    </td>
                </RowTemplate>
            </DataTable>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SalaryRegister
    {
        public string PayPeriod { get; set; } = string.Empty;
        public int StaffCount { get; set; }
        public string GrossPayroll { get; set; } = string.Empty;
        public string Deductions { get; set; } = string.Empty;
        public string NetPaid { get; set; } = string.Empty;
        public string PaymentDate { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<SalaryRegister> _sheets = new()
    {
        new SalaryRegister { PayPeriod = "June 2026", StaffCount = 142, GrossPayroll = "$420,500.00", Deductions = "-$12,450.00", NetPaid = "$408,050.00", PaymentDate = "2026-06-01", Status = "Paid" },
        new SalaryRegister { PayPeriod = "May 2026", StaffCount = 139, GrossPayroll = "$410,200.00", Deductions = "-$9,800.00", NetPaid = "$400,400.00", PaymentDate = "2026-05-01", Status = "Paid" },
        new SalaryRegister { PayPeriod = "April 2026", StaffCount = 138, GrossPayroll = "$405,000.00", Deductions = "-$10,150.00", NetPaid = "$394,850.00", PaymentDate = "2026-04-01", Status = "Paid" }
    };
}
