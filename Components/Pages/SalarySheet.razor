@page "/payroll/salary-sheet"

<PageTitle>ERPHub - Salary Sheets</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Salary Register Sheets</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Browse, search, and export monthly salary ledgers and registers.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_sheets" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.PayPeriod)">Pay Period</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.StaffCount)">Staff Count</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.GrossPayroll)">Gross Payroll</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.Deductions)">Deductions</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.NetPaid)">Net Paid</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.PaymentDate)">Payment Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<SalaryRegister, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Pay Period">@context.PayPeriod</MudTd>
                        <MudTd DataLabel="Staff Count">@context.StaffCount</MudTd>
                        <MudTd DataLabel="Gross Payroll">@context.GrossPayroll</MudTd>
                        <MudTd DataLabel="Deductions">@context.Deductions</MudTd>
                        <MudTd DataLabel="Net Paid">@context.NetPaid</MudTd>
                        <MudTd DataLabel="Payment Date">@context.PaymentDate</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class SalaryRegister
    {
        public string PayPeriod { get; set; } = string.Empty;
        public int StaffCount { get; set; }
        public string GrossPayroll { get; set; } = string.Empty;
        public string Deductions { get; set; } = string.Empty;
        public string NetPaid { get; set; } = string.Empty;
        public string PaymentDate { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<SalaryRegister> _sheets = new()
    {
        new SalaryRegister { PayPeriod = "June 2026", StaffCount = 142, GrossPayroll = "$420,500.00", Deductions = "-$12,450.00", NetPaid = "$408,050.00", PaymentDate = "2026-06-01", Status = "Paid" },
        new SalaryRegister { PayPeriod = "May 2026", StaffCount = 139, GrossPayroll = "$410,200.00", Deductions = "-$9,800.00", NetPaid = "$400,400.00", PaymentDate = "2026-05-01", Status = "Paid" },
        new SalaryRegister { PayPeriod = "April 2026", StaffCount = 138, GrossPayroll = "$405,000.00", Deductions = "-$10,150.00", NetPaid = "$394,850.00", PaymentDate = "2026-04-01", Status = "Paid" }
    };
}
