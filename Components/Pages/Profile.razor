@page "/profile"

<PageTitle>ERPHub - My Profile</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (_profileUser != null)
        {
            @* Header *@
            <div class="d-flex justify-content-between align-items-center mb-6" style="flex-wrap:wrap;">
                <div>
                    <MudText Typo="Typo.h4" Class="fw-extrabold">My Profile</MudText>
                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color mt-1">Manage your personal information, credentials, and account preferences.</MudText>
                </div>
            </div>

            @* Profile Hero Card *@
            <MudPaper Elevation="1" Outlined="true" Class="mb-6 overflow-hidden" Style="border-radius:12px;">
                <div style="height:100px; border-bottom:1px solid var(--mud-palette-table-lines); background:linear-gradient(to right, rgba(99,102,241,0.1), rgba(16,185,129,0.1), rgba(99,102,241,0.1));"></div>
                <div class="px-6 pb-6" style="margin-top:-48px;">
                    <div class="d-flex align-items-end" style="gap:20px;">
                        <MudPaper Elevation="2" Class="d-flex align-items-center justify-content-center flex-shrink-0" Style="width:80px;height:80px;border-radius:12px;overflow:hidden;border:2px solid white;background-color:var(--mud-palette-table-hover);">
                            <MudText Typo="Typo.h4" Class="mud-secondary-text-color fw-bold">@GetInitials(_profileUser.FullName)</MudText>
                        </MudPaper>
                        <div class="flex-grow-1 pt-3">
                            <MudText Typo="Typo.h5" Class="fw-extrabold">@_profileUser.FullName</MudText>
                            <div class="d-flex align-items-center" style="gap:8px; margin-top:2px;">
                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@@@_profileUser.Username</MudText>
                                <span style="width:4px;height:4px;border-radius:50%;background-color:var(--mud-palette-table-lines);"></span>
                                <MudChip Size="Size.Small" Color="@(_profileUser.Role == "Admin" ? Color.Info : Color.Success)" Class="fw-bold" Style="font-size:10px;" T="string">
                                    @_profileUser.Role
                                </MudChip>
                            </div>
                        </div>
                        <div class="d-flex text-center" style="gap:16px;">
                            <MudPaper Elevation="0" Outlined="true" Class="px-4 py-2" Style="border-radius:8px;">
                                <MudText Typo="Typo.body2" Class="fw-extrabold">@_totalCompanies</MudText>
                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold mt-1" Style="letter-spacing:0.05em;">Companies</MudText>
                            </MudPaper>
                            <MudPaper Elevation="0" Outlined="true" Class="px-4 py-2" Style="border-radius:8px;">
                                <MudText Typo="Typo.body2" Class="fw-extrabold">@_totalProducts</MudText>
                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold mt-1" Style="letter-spacing:0.05em;">Products</MudText>
                            </MudPaper>
                            <MudPaper Elevation="0" Outlined="true" Class="px-4 py-2" Style="border-radius:8px;">
                                <MudText Typo="Typo.body2" Class="fw-extrabold">@_totalInvoices</MudText>
                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color text-uppercase fw-bold mt-1" Style="letter-spacing:0.05em;">Invoices</MudText>
                            </MudPaper>
                        </div>
                    </div>
                </div>
            </MudPaper>

            <MudGrid Spacing="6">
                @* Personal Information *@
                <MudItem xs="12" lg="8">
                    <MudPaper Elevation="1" Outlined="true" Style="border-radius:12px; overflow:hidden;">
                        <div class="pa-5 px-6" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold">Personal Information</MudText>
                        </div>
                        <div class="pa-5 px-6">
                            <MudGrid Spacing="5">
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Full Name"
                                                  @bind-Value="_editFullName"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="Enter full name"
                                                  FullWidth="true"
                                                  dense="true" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Username"
                                                  Value="@_profileUser.Username"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  dense="true"
                                                  ReadOnly="true"
                                                  Disabled="true"
                                                  HelperText="Username cannot be changed." />
                                </MudItem>
                            </MudGrid>
                            <MudGrid Spacing="5" Class="mt-3">
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Email Address"
                                                  @bind-Value="_editEmail"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="user@example.com"
                                                  FullWidth="true"
                                                  dense="true" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Role"
                                                  Value="@_profileUser.Role"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  dense="true"
                                                  ReadOnly="true"
                                                  Disabled="true" />
                                </MudItem>
                            </MudGrid>
                            <div class="d-flex justify-content-end" style="gap:12px; margin-top:24px; padding-top:20px; border-top:1px solid var(--mud-palette-table-lines);">
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" @onclick="ResetForm">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="@(!_hasChanges)" @onclick="SaveProfile">Save Changes</MudButton>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>

                @* Right Column *@
                <MudItem xs="12" lg="4" Class="d-flex flex-column" Style="gap:24px;">
                    @* Change Password *@
                    <MudPaper Elevation="1" Outlined="true" Style="border-radius:12px; overflow:hidden;">
                        <div class="pa-5 px-6" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold">Change Password</MudText>
                        </div>
                        <div class="pa-5 px-6 d-flex flex-column" style="gap:16px;">
                            <MudTextField Label="Current Password"
                                          @bind-Value="_currentPassword"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Password"
                                          Placeholder="Enter current password"
                                          FullWidth="true"
                                          dense="true" />
                            <MudTextField Label="New Password"
                                          @bind-Value="_newPassword"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Password"
                                          Placeholder="Enter new password"
                                          FullWidth="true"
                                          dense="true" />
                            <MudTextField Label="Confirm New Password"
                                          @bind-Value="_confirmPassword"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Password"
                                          Placeholder="Confirm new password"
                                          FullWidth="true"
                                          dense="true" />

                            @if (!string.IsNullOrEmpty(_passwordMessage))
                            {
                                <MudAlert Severity="@(_passwordSuccess ? Severity.Success : Severity.Error)" Class="pa-2" dense="true">
                                    <MudText Typo="Typo.caption" Class="fw-semibold">@_passwordMessage</MudText>
                                </MudAlert>
                            }

                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Small" @onclick="ChangePassword">Update Password</MudButton>
                        </div>
                    </MudPaper>

                    @* Recent Activity *@
                    <MudPaper Elevation="1" Outlined="true" Style="border-radius:12px; overflow:hidden;">
                        <div class="pa-5 px-6" style="border-bottom:1px solid var(--mud-palette-table-lines);">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold">Recent Activity</MudText>
                        </div>
                        <div class="pa-5 px-6 d-flex flex-column" style="gap:14px;">
                            @foreach (var activity in _activities)
                            {
                                <div class="d-flex" style="gap:12px; padding-bottom:14px; border-bottom:1px solid var(--mud-palette-table-lines);">
                                    <div style="width:8px; height:8px; border-radius:50%; margin-top:6px; flex-shrink:0; background-color:@activity.Color;"></div>
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.body2" Class="fw-semibold">@activity.Title</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@activity.TimeDescription</MudText>
                                    </div>
                                </div>
                            }
                            @if (!_activities.Any())
                            {
                                <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-6">No recent activity.</MudText>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* Success Toast *@
            @if (_showToast)
            {
                <div class="d-flex align-items-center" style="position:fixed; bottom:24px; right:24px; background-color:var(--mud-palette-success); color:white; font-size:12px; font-weight:600; padding:12px 20px; border-radius:12px; box-shadow:var(--mud-elevation-8); z-index:9999; gap:10px;">
                    <span>✓</span>
                    <span>@_toastMessage</span>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
