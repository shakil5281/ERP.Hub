@page "/payroll/holiday-bill"

<PageTitle>ERPHub - Holiday Work Bills</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Holiday Duty Billing</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage and calculate employee overtime compensations for public holiday shifts.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <MudTable Items="@_claims" Hover="true" SortLabel="Sort By" Dense="true" Striped="false" Outlined="false" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.EmployeeName)">Employee Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.HolidayDate)">Holiday Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.HolidayName)">Holiday Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.HoursLogged)">Hours Logged</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.PayoutRate)">Payout Rate</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.TotalBill)">Total Bill</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<HolidayWorkClaim, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee Name">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Holiday Date">@context.HolidayDate</MudTd>
                        <MudTd DataLabel="Holiday Name">@context.HolidayName</MudTd>
                        <MudTd DataLabel="Hours Logged">@context.HoursLogged</MudTd>
                        <MudTd DataLabel="Payout Rate">@context.PayoutRate</MudTd>
                        <MudTd DataLabel="Total Bill">@context.TotalBill</MudTd>
                        <MudTd DataLabel="Status">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@context.Status</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="text-center mud-secondary-text-color py-8">Data Not Available</MudText>
                </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class HolidayWorkClaim
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string HolidayDate { get; set; } = string.Empty;
        public string HolidayName { get; set; } = string.Empty;
        public string HoursLogged { get; set; } = string.Empty;
        public string PayoutRate { get; set; } = string.Empty;
        public string TotalBill { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<HolidayWorkClaim> _claims = new()
    {
        new HolidayWorkClaim { EmployeeName = "Steve Rogers", HolidayDate = "2026-05-25", HolidayName = "Memorial Day", HoursLogged = "8 hrs", PayoutRate = "$50.00 / hr", TotalBill = "$400.00", Status = "Approved" }
    };
}
