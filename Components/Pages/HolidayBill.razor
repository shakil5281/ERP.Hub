@page "/payroll/holiday-bill"

<PageTitle>ERPHub - Holiday Work Bills</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="animate-fade-in">
            <!-- Header Block -->
            <div class="flex justify-between items-center mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
                <div>
                    <h2 class="text-[22px] font-extrabold text-black tracking-tight font-heading">Holiday Duty Billing</h2>
                    <p class="text-zinc-500 text-xs mt-0.5 font-body">Manage and calculate employee overtime compensations for public holiday shifts.</p>
                </div>
            </div>

            <div class="bg-white border border-zinc-200 rounded-lg shadow-sm overflow-hidden">
                <div class="table-responsive-wrapper">
                    <table class="w-full">
                        <thead>
                            <tr>
                                <th>Employee Name <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Holiday Date <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Holiday Name <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Hours Logged <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Payout Rate <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Total Bill <button class="sort-btn" @onclick="() => {}">↕</button></th>
                                <th>Status <button class="sort-btn" @onclick="() => {}">↕</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_claims.Any())
                            {
                                @foreach (var item in _claims)
                                {
                                    <tr>
                                        <td data-label="Employee Name">@item.EmployeeName</td>
                                        <td data-label="Holiday Date">@item.HolidayDate</td>
                                        <td data-label="Holiday Name">@item.HolidayName</td>
                                        <td data-label="Hours Logged">@item.HoursLogged</td>
                                        <td data-label="Payout Rate">@item.PayoutRate</td>
                                        <td data-label="Total Bill">@item.TotalBill</td>
                                        <td data-label="Status">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-8 text-muted">Data Not Available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <div class="flex items-center gap-3">
                        <span class="pagination-info">Rows per page:</span>
                        <select class="page-size-select">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                    </div>
                    <div class="pagination">
                        <button class="pagination-btn" disabled>‹</button>
                        <button class="pagination-btn active">1</button>
                        <button class="pagination-btn" disabled>›</button>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    public class HolidayWorkClaim
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string HolidayDate { get; set; } = string.Empty;
        public string HolidayName { get; set; } = string.Empty;
        public string HoursLogged { get; set; } = string.Empty;
        public string PayoutRate { get; set; } = string.Empty;
        public string TotalBill { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }

    private List<HolidayWorkClaim> _claims = new()
    {
        new HolidayWorkClaim { EmployeeName = "Steve Rogers", HolidayDate = "2026-05-25", HolidayName = "Memorial Day", HoursLogged = "8 hrs", PayoutRate = "$50.00 / hr", TotalBill = "$400.00", Status = "Approved" }
    };
}
