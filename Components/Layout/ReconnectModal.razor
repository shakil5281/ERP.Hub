<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<div id="components-reconnect-modal" class="components-reconnect-hide" data-nosnippet>
    <div class="components-reconnect-container">
        <!-- New Simple Loading Animation Reconnection -->
        <div class="components-reconnect-spinner-container">
            <div class="components-reconnect-spinner"></div>
            <div class="components-reconnect-pulse-circle"></div>
        </div>

        <!-- Reconnection States -->
        <div class="components-reconnect-states">
            <!-- First attempt -->
            <div class="components-reconnect-first-attempt-visible">
                <h2 class="components-reconnect-title">Reconnecting</h2>
                <p class="components-reconnect-desc">Attempting to restore session...</p>
            </div>

            <!-- Repeated attempts -->
            <div class="components-reconnect-repeated-attempt-visible">
                <h2 class="components-reconnect-title">Retrying Connection</h2>
                <p class="components-reconnect-desc">Reconnecting in <strong id="components-seconds-to-next-attempt"></strong>s</p>
            </div>

            <!-- Paused by server -->
            <div class="components-pause-visible">
                <h2 class="components-reconnect-title">Connection Paused</h2>
                <p class="components-reconnect-desc">Your session has been paused</p>
                <button id="components-resume-button" class="components-reconnect-button">Resume Session</button>
            </div>

            <!-- Resume failed -->
            <div class="components-resume-failed-visible">
                <h2 class="components-reconnect-title">Connection Failed</h2>
                <p class="components-reconnect-desc">Could not resume your session</p>
                <button id="components-retry-resume-button" class="components-reconnect-button">Retry Connection</button>
            </div>

            <!-- Reconnect failed -->
            <div class="components-reconnect-failed-visible">
                <h2 class="components-reconnect-title">Connection Lost</h2>
                <p class="components-reconnect-desc">Unable to connect to the server</p>
                <button id="components-reconnect-button" class="components-reconnect-button">Reload Page</button>
            </div>
        </div>
    </div>
</div>

