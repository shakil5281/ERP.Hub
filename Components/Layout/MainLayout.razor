@inherits LayoutComponentBase

<div class="flex min-h-screen bg-zinc-50 font-body">
    <NavMenu />

    <main class="pl-0 md:pl-[250px] flex-1 min-h-screen flex flex-col transition-all duration-300">
        <header class="h-[60px] px-8 max-sm:px-4 border-b border-zinc-200 bg-white flex items-center justify-between sticky top-0 z-40 animate-fade-in">
            <div class="flex items-center flex-1 gap-3">
                <!-- Hamburger Button (only visible on mobile, < 768px / md breakpoint) -->
                <button class="md:hidden flex items-center justify-center p-2 rounded-lg text-zinc-500 hover:text-black hover:bg-zinc-100 border-0 bg-transparent cursor-pointer transition-colors" @onclick="ToggleSidebar" aria-label="Toggle Navigation Sidebar">
                    <svg class="w-6 h-6 stroke-current stroke-2 stroke-linecap-round stroke-linejoin-round fill-none" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>

                <!-- Navbar Search Box -->
                <div class="flex items-center bg-zinc-100 border border-zinc-200 rounded-lg px-3 py-1.5 w-full max-w-[320px]">
                    <svg class="w-4 h-4 text-zinc-400 mr-2 flex-shrink-0 fill-current" viewBox="0 0 24 24">
                        <path d="M10 18a7.952 7.952 0 0 0 4.897-1.688l4.396 4.396 1.414-1.414-4.396-4.396A7.952 7.952 0 0 0 18 10c0-4.411-3.589-8-8-8s-8 3.589-8 8 3.589 8 8 8zm0-14c3.309 0 6 2.691 6 6s-2.691 6-6 6-6-2.691-6-6 2.691-6 6-6z"/>
                    </svg>
                    <input type="text" placeholder="Search dashboard, logs, sales..." class="border-0 bg-transparent outline-none text-zinc-950 font-body text-xs w-full placeholder-zinc-400" @bind="_globalSearchQuery" />
                </div>
            </div>
            
            <div class="flex items-center gap-5">
                <!-- Notifications Bell -->
                <div class="relative">
                    <button class="relative p-1.5 rounded-full text-zinc-500 hover:text-black hover:bg-zinc-50 transition-colors border-0 bg-transparent cursor-pointer flex items-center justify-center" @onclick="ToggleNotificationsPopover" title="Notifications">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                            <path d="M19 13.586V10c0-3.217-2.185-5.927-5.145-6.742C13.562 2.52 12.846 2 12 2s-1.562.52-1.855 1.258C7.185 4.074 5 6.783 5 10v3.586l-1.707 1.707A.996.996 0 0 0 3 16v2a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-2a.996.996 0 0 0-.293-.707L19 13.586zM19 17H5v-.586l1.707-1.707A.996.996 0 0 0 7 14v-4c0-2.757 2.243-5 5-5s5 2.243 5 5v4c0 .266.105.52.293.707L19 16.414V17zm-7 5a2.98 2.98 0 0 0 2.818-2H9.182A2.98 2.98 0 0 0 12 22z"/>
                        </svg>
                        @if (UnreadCount > 0)
                        {
                            <span class="absolute top-0 right-0 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[8.5px] font-extrabold text-white shadow-sm animate-pulse" style="width: 14px; height: 14px;">
                                @UnreadCount
                            </span>
                        }
                    </button>

                    @if (_showNotificationsPopover)
                    {
                        <!-- Backdrop to close popover when clicking outside -->
                        <div class="fixed inset-0 z-[9998] bg-transparent cursor-default" @onclick="ToggleNotificationsPopover"></div>

                        <div class="absolute right-0 mt-2 w-72 rounded-xl border border-zinc-200 bg-white shadow-lg p-3 z-[9999] origin-top-right transition-all duration-200 text-left">
                            <div class="flex justify-between items-center pb-2 border-b border-zinc-100">
                                <div>
                                    <h4 class="text-xs font-bold text-zinc-950">Inbox Messages</h4>
                                    <p class="text-[10px] text-zinc-400 mt-0.5">You have @UnreadCount unread alerts.</p>
                                </div>
                                @if (UnreadCount > 0)
                                {
                                    <button type="button" class="text-[10px] text-indigo-600 hover:text-indigo-800 font-bold border-0 bg-transparent cursor-pointer" @onclick="MarkAllAsRead">
                                        Clear
                                    </button>
                                }
                            </div>
                            
                            <div class="popover-items-list overflow-y-auto max-h-[300px] mt-2 flex flex-col gap-1">
                                @if (_notifications.Any())
                                {
                                    @foreach (var note in _notifications)
                                    {
                                        <div class="popover-note-item @(note.IsRead ? "opacity-60" : "bg-indigo-50/10")" @onclick="() => NavigateToLink(note)">
                                            <div class="flex gap-2">
                                                <span class="text-sm self-start mt-0.5">@note.Icon</span>
                                                <div class="flex-1 text-left">
                                                    <div class="flex justify-between items-start">
                                                        <h5 class="text-xs font-bold text-zinc-900 leading-snug">@note.Title</h5>
                                                        @if (!note.IsRead)
                                                        {
                                                            <span class="w-1.5 h-1.5 bg-indigo-600 rounded-full mt-1 flex-shrink-0"></span>
                                                        }
                                                    </div>
                                                    <p class="text-[10.5px] text-zinc-500 mt-0.5 leading-normal">@note.Message</p>
                                                    <span class="text-[9px] text-zinc-400 mt-1 block">@FormatTimeAgo(note.Timestamp)</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-8 text-xs text-zinc-400">
                                        No new messages.
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Profile Dropdown Container -->
                <div class="relative">
                    <AuthorizeView>
                        <Authorized>
                            <!-- Avatar Trigger Button -->
                            <button class="flex items-center gap-2 p-1.5 rounded-full hover:bg-zinc-50 transition-colors border-0 bg-transparent cursor-pointer" @onclick="ToggleProfileDropdown" aria-label="User menu">
                                <div class="w-8 h-8 rounded-full bg-zinc-200 flex items-center justify-center text-zinc-600 font-semibold text-sm overflow-hidden select-none">
                                    <svg class="w-5 h-5 fill-current text-zinc-500" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                                    </svg>
                                </div>
                                <span class="hidden md:inline-block text-xs font-semibold text-zinc-700 pr-1">@context.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
                                <svg class="w-4 h-4 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                </svg>
                            </button>

                            <!-- Dropdown Menu List -->
                            @if (_showProfileDropdown)
                            {
                                <!-- Backdrop to close dropdown when clicking outside -->
                                <div class="fixed inset-0 z-[9998] bg-transparent cursor-default" @onclick="ToggleProfileDropdown"></div>
                                
                                <div class="absolute right-0 mt-2 w-56 rounded-xl border border-zinc-200 bg-white shadow-lg py-1.5 z-[9999] origin-top-right transition-all duration-200">
                                    <!-- User Info Header -->
                                    <div class="px-4 py-2 border-b border-zinc-100">
                                        <p class="text-xs font-bold text-zinc-800 m-0">@context.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</p>
                                        <p class="text-[11px] text-zinc-400 truncate mt-0.5 mb-0">Role: @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                                    </div>
                                    
                                    <!-- Links -->
                                    <div class="py-1">
                                        <a href="/profile" class="flex items-center gap-2.5 px-4 py-2 text-xs font-medium text-zinc-700 hover:bg-zinc-50 hover:text-black transition-colors no-underline" @onclick="CloseProfileDropdown">
                                            <svg class="w-4 h-4 text-zinc-400 stroke-current stroke-2 fill-none" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                            </svg>
                                            My Profile
                                        </a>
                                        <a href="#settings" class="flex items-center gap-2.5 px-4 py-2 text-xs font-medium text-zinc-700 hover:bg-zinc-50 hover:text-black transition-colors no-underline" @onclick="CloseProfileDropdown">
                                            <svg class="w-4 h-4 text-zinc-400 stroke-current stroke-2 fill-none" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            Settings
                                        </a>
                                    </div>
                                    
                                    <div class="border-t border-zinc-100 my-1"></div>
                                    
                                    <!-- Log Out -->
                                    <div class="py-1">
                                        <button type="button" class="w-full text-left flex items-center gap-2.5 px-4 py-2 text-xs font-semibold text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors border-0 bg-transparent cursor-pointer" @onclick="HandleLogout">
                                            <svg class="w-4 h-4 text-red-500 stroke-current stroke-2 fill-none" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                            </svg>
                                            Log Out
                                        </button>
                                    </div>
                                </div>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <a href="/login" class="text-xs font-semibold text-zinc-700 hover:text-black transition-colors no-underline">Sign In</a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </header>

        <article class="p-8 flex-1 max-sm:p-4 animate-fade-in">
            @Body
        </article>
    </main>
</div>
