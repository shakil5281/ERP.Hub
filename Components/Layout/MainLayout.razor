@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Class="app-drawer">
        <div class="drawer-content">
            <div class="drawer-brand">
                <div class="brand-logo-mark"></div>
                <span class="brand-text">ERPHub</span>
            </div>
            <div class="drawer-nav-scroll">
                <NavMenu />
            </div>
            <div class="drawer-footer">
                <div class="drawer-footer-divider"></div>
                <div class="drawer-footer-info">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mud-secondary-text-color" />
                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color">v1.0.0</MudText>
                </div>
            </div>
        </div>
    </MudDrawer>

    <MudAppBar Fixed="true" Class="app-topbar" Elevation="0">
        <div class="topbar-inner">
            <div class="topbar-left">
                <MudIconButton Icon="@(_drawerOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                               OnClick="ToggleDrawer"
                               Size="Size.Small"
                               Class="topbar-menu-btn"
                               aria-label="Toggle sidebar" />
                <div class="topbar-brand-mobile">
                    <div class="brand-logo-mark brand-logo-sm"></div>
                    <MudText Typo="Typo.subtitle2" Class="fw-bold">ERPHub</MudText>
                </div>
            </div>

            <div class="topbar-center">
                <div class="topbar-search-trigger" @onclick="OpenSearchDialog">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="mud-secondary-text-color" />
                    <span class="topbar-search-placeholder">Search...</span>
                    <div class="topbar-search-kbd">
                        <kbd>Ctrl</kbd>
                        <kbd>K</kbd>
                    </div>
                </div>
            </div>

            <div class="topbar-right">
                <MudIconButton Icon="@Icons.Material.Filled.Search"
                               OnClick="OpenSearchDialog"
                               Size="Size.Small"
                               Class="topbar-icon-btn d-lg-none"
                               aria-label="Search" />

                <div class="topbar-notif-wrapper">
                    <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone"
                                   OnClick="ToggleNotifications"
                                   Size="Size.Small"
                                   Class="topbar-icon-btn"
                                   aria-label="Notifications" />
                    @if (_unreadCount > 0)
                    {
                        <span class="notif-badge">@_unreadCount</span>
                    }

                    @if (_showNotifications)
                    {
                        <div class="topbar-overlay" @onclick="CloseNotifications"></div>
                        <div class="notif-panel">
                            <div class="notif-header">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="fw-bold">Notifications</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color">@_unreadCount unread</MudText>
                                </div>
                                @if (_unreadCount > 0)
                                {
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="MarkAllRead">
                                        Mark all read
                                    </MudButton>
                                }
                            </div>
                            <div class="notif-list">
                                @if (_notifications.Any())
                                {
                                    @foreach (var n in _notifications)
                                    {
                                        <div class="notif-item @(!n.IsRead ? "unread" : "")"
                                             @onclick="() => HandleNotificationClick(n)">
                                            <span class="notif-icon">@n.Icon</span>
                                            <div class="notif-body">
                                                <div class="notif-title-row">
                                                    <MudText Typo="Typo.body2" Class="fw-semibold notif-title">@n.Title</MudText>
                                                    @if (!n.IsRead)
                                                    {
                                                        <span class="notif-dot"></span>
                                                    }
                                                </div>
                                                <MudText Typo="Typo.caption" Class="mud-secondary-text-color notif-msg">@n.Message</MudText>
                                                <MudText Typo="Typo.caption" Class="notif-time">@FormatTimeAgo(n.Timestamp)</MudText>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="notif-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" Size="Size.Large" Class="mud-secondary-text-color" />
                                        <MudText Typo="Typo.body2" Class="mud-secondary-text-color">No notifications</MudText>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <AuthorizeView Context="authCtx">
                    <Authorized>
                        <div class="topbar-profile-wrapper">
                            <div class="profile-trigger" @onclick="ToggleProfileMenu">
                                <MudAvatar Size="Size.Small" Color="Color.Primary" Class="profile-avatar">
                                    <MudText Typo="Typo.caption" Class="fw-bold">@GetInitials(authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value)</MudText>
                                </MudAvatar>
                                <div class="profile-info d-none d-sm-flex">
                                    <MudText Typo="Typo.caption" Class="fw-semibold profile-name-text">@authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-secondary-text-color profile-role-text">@GetUserRole(authCtx.User)</MudText>
                                </div>
                                <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" Class="mud-secondary-text-color d-none d-sm-flex" />
                            </div>

                            @if (_showProfileMenu)
                            {
                                <div class="topbar-overlay" @onclick="CloseProfileMenu"></div>
                                <div class="profile-panel">
                                    <div class="profile-panel-header">
                                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                                            <MudText Typo="Typo.caption" Class="fw-bold">@GetInitials(authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value)</MudText>
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.subtitle2" Class="fw-bold" Style="font-size:13px;">@authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-secondary-text-color" Style="font-size:11px;">@GetUserRole(authCtx.User)</MudText>
                                        </div>
                                    </div>
                                    <div class="profile-panel-divider"></div>
                                    <div class="profile-panel-item" @onclick='() => { CloseProfileMenu(); Nav.NavigateTo("/profile"); }'>
                                        <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" />
                                        <span>My Profile</span>
                                    </div>
                                    <div class="profile-panel-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                                        <span>Settings</span>
                                    </div>
                                    <div class="profile-panel-divider"></div>
                                    <div class="profile-panel-item profile-logout" @onclick="HandleLogout">
                                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                                        <span>Log Out</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Href="/login"
                                   Size="Size.Small">
                            Sign In
                        </MudButton>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </MudAppBar>

    <MudMainContent Class="app-main-content">
        @Body
    </MudMainContent>
</MudLayout>
