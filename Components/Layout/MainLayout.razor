@inherits LayoutComponentBase

<div class="app-layout">
    <aside class="sidebar @(_drawerOpen ? "open" : "")" id="app-sidebar">
        <div class="sidebar-content">
            <div class="drawer-brand">
                <div class="brand-logo-mark brand-logo-sm"></div>
                <span class="brand-text">ERPHub</span>
            </div>
            <div class="sidebar-nav-scroll">
                <NavMenu />
            </div>
            <div class="sidebar-footer">
                <div class="sidebar-footer-divider"></div>
                <div class="sidebar-footer-info">
                    <span class="material-icons" style="font-size:14px;">info</span>
                    <span>v1.0.0</span>
                </div>
            </div>
        </div>
    </aside>

    <div class="sidebar-backdrop @(_drawerOpen ? "show" : "")" id="sidebar-backdrop"
         @onclick="ToggleDrawer"></div>

    <header class="topbar">
        <div class="topbar-inner">
            <div class="topbar-left">
                <button class="topbar-menu-btn" @onclick="ToggleDrawer" aria-label="Toggle sidebar">
                    <span class="material-icons">@(_drawerOpen ? "menu_open" : "menu")</span>
                </button>
                <div class="topbar-brand">
                    <div class="brand-logo-mark brand-logo-sm"></div>
                    <span class="brand-text d-none d-sm-flex">ERPHub</span>
                </div>
            </div>

            <div class="topbar-center">
                <div class="topbar-search-trigger" @onclick="OpenSearchDialog">
                    <span class="material-icons" style="font-size:18px;color:#9ca3af;">search</span>
                    <span class="topbar-search-placeholder">Search...</span>
                    <div class="topbar-search-kbd">
                        <kbd>Ctrl</kbd>
                        <kbd>K</kbd>
                    </div>
                </div>
            </div>

            <div class="topbar-right">
                <button class="topbar-icon-btn d-lg-none" @onclick="OpenSearchDialog" aria-label="Search">
                    <span class="material-icons">search</span>
                </button>

                <div class="topbar-notif-wrapper">
                    <button class="topbar-icon-btn" @onclick="ToggleNotifications" aria-label="Notifications">
                        <span class="material-icons">notifications_none</span>
                    </button>
                    @if (_unreadCount > 0)
                    {
                        <span class="notif-badge">@_unreadCount</span>
                    }

                    @if (_showNotifications)
                    {
                        <div class="topbar-overlay" @onclick="CloseNotifications"></div>
                        <div class="notif-panel" style="color: black;">
                            <div class="notif-header">
                                <div>
                                    <p class="fw-semibold text-sm" style="margin:0;">Notifications</p>
                                    <p class="text-xs text-muted" style="margin:0;">@_unreadCount unread</p>
                                </div>
                                @if (_unreadCount > 0)
                                {
                                    <button class="btn btn-text btn-sm" @onclick="MarkAllRead">Mark all read</button>
                                }
                            </div>
                            <div class="notif-list">
                                @if (_notifications.Any())
                                {
                                    @foreach (var n in _notifications)
                                    {
                                        <div class="notif-item @(!n.IsRead ? "unread" : "")"
                                             @onclick="() => HandleNotificationClick(n)">
                                            <span class="notif-icon">@n.Icon</span>
                                            <div class="notif-body">
                                                <div class="notif-title-row">
                                                    <span class="notif-title">@n.Title</span>
                                                    @if (!n.IsRead)
                                                    {
                                                        <span class="notif-dot"></span>
                                                    }
                                                </div>
                                                <span class="notif-msg">@n.Message</span>
                                                <span class="notif-time">@FormatTimeAgo(n.Timestamp)</span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="notif-empty">
                                        <span class="material-icons" style="font-size:32px;color:#9ca3af;">notifications_off</span>
                                        <p class="text-sm text-muted">No notifications</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <AuthorizeView Context="authCtx">
                    <Authorized>
                        <div class="topbar-profile-wrapper">
                            <div class="profile-trigger" @onclick="ToggleProfileMenu">
                                <div class="profile-avatar">
                                    <span>@GetInitials(authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value)</span>
                                </div>
                                <div class="profile-info d-none d-sm-flex">
                                    <span class="profile-name-text" style="color: black;">@authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
                                    <span class="profile-role-text" style="color: black;">@GetUserRole(authCtx.User)</span>
                                </div>
                                <span class="material-icons d-none d-sm-flex" style="font-size:18px;color:#52525b;">expand_more</span>
                            </div>

                            @if (_showProfileMenu)
                            {
                                <div class="topbar-overlay" @onclick="CloseProfileMenu"></div>
                                <div class="profile-panel">
                                    <div class="profile-panel-header">
                                        <div class="profile-avatar">
                                            <span>@GetInitials(authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value)</span>
                                        </div>
                                        <div>
                                            <p class="fw-semibold" style="font-size:13px;margin:0;color:black;">@authCtx.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</p>
                                            <p class="text-xs" style="font-size:11px;margin:0;color:black;">@GetUserRole(authCtx.User)</p>
                                        </div>
                                    </div>
                                    <div class="profile-panel-divider"></div>
                                    <button class="profile-panel-item" style="color:black;" @onclick='() => { CloseProfileMenu(); Nav.NavigateTo("/profile"); }'>
                                        <span class="material-icons" style="font-size:18px;">person_outline</span>
                                        <span>My Profile</span>
                                    </button>
                                    <button class="profile-panel-item" style="color:black;">
                                        <span class="material-icons" style="font-size:18px;">settings</span>
                                        <span>Settings</span>
                                    </button>
                                    <div class="profile-panel-divider"></div>
                                    <button class="profile-panel-item profile-logout" @onclick="HandleLogout">
                                        <span class="material-icons" style="font-size:18px;">logout</span>
                                        <span>Log Out</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-text btn-sm">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

@if (_showSearchDialog)
{
    <GlobalSearchDialog OnClose="CloseSearchDialog" />
}
