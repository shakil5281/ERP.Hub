{
  "name": "erphub",
  "version": "1.0.0",
  "description": "ERPHub Enterprise Portal - Tailwind CSS compilation configuration",
  "main": "index.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./wwwroot/css/input.css -o ./wwwroot/css/app.min.css --minify",
    "watch:css": "npx tailwindcss -i ./wwwroot/css/input.css -o ./wwwroot/css/app.min.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1"
  }
}
